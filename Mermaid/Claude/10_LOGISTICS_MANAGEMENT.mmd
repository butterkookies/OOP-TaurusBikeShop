%% =====================================================
%% BIKE SHOP - PART 10: LOGISTICS MANAGEMENT
%% =====================================================
%% This diagram covers: Delivery tracking and management
%% Connected from: Part 7 (Admin Dashboard)
%% =====================================================

flowchart TD

%% =====================================================
%% DATABASES & EXTERNAL SERVICES
%% =====================================================

DB3[("Order Database")]
EXT1["Payment Gateway"]
EXT2["Lalamove API"]
EXT4["Email/SMS Service"]

%% =====================================================
%% ENTRY POINT FROM PART 7
%% =====================================================

L_START(["FROM Part 7:<br/>Manage Logistics"])

%% =====================================================
%% LOGISTICS MANAGEMENT
%% =====================================================

L_START --> L1[/"View All Deliveries"/]

L1 --> DB3
DB3 --> L1B[/"Filter by Status<br/>Pending / Out / Delivered"/]

L1B --> L1C{{"What Would You Like?"}}

%% VIEW TRACKING
L1C -->|View Tracking| L1D[/"Show Real-Time Status<br/>Location, ETA, Driver"/]
L1D --> DB3
DB3 --> L1C

%% DELIVERY DELAYED
L1C -->|Delivery Delayed| L1E[/"Mark as Delayed<br/>Update ETA"/]
L1E --> DB3
DB3 --> L1F["Send Delay Notification"]
L1F --> EXT4
EXT4 --> L1C

%% CANCEL DELIVERY
L1C -->|Cancel Delivery| L1G[/"Confirm Cancellation<br/>Will refund customer"/]
L1G --> EXT2
EXT2 --> L1H["Refund Customer"]
L1H --> EXT1
EXT1 --> DB3
DB3 --> END1(["BACK TO<br/>Part 7: Admin Dashboard"])

