%% =====================================================
%% BIKE SHOP - PART 12: INVENTORY MANAGEMENT
%% =====================================================
%% This diagram covers: Stock level updates and monitoring
%% Connected from: Part 7 (Admin Dashboard)
%% =====================================================

flowchart TD

%% =====================================================
%% DATABASES & EXTERNAL SERVICES
%% =====================================================

DB2[("Product Database")]
DB4[("Inventory Database")]
DB6[("Notification Queue")]
EXT4["Email/SMS Service"]

%% =====================================================
%% ENTRY POINT FROM PART 7
%% =====================================================

INV_START(["FROM Part 7:<br/>Inventory Management"])

%% =====================================================
%% INVENTORY MANAGEMENT
%% =====================================================

INV_START --> INV1[/"View All Products"/]

INV1 --> DB2
DB2 --> INV2[/"Select Product"/]

INV2 --> INV3[/"Display Stock Levels<br/>Available / Reserved / Locked"/]
INV3 --> INV4{{"Action?"}}

%% UPDATE STOCK
INV4 -->|Update Stock| INV5[/"Enter Quantity<br/>Add or remove"/]
INV5 --> DB4

INV5 --> INV6["Update DB4<br/>Sync online + POS"]
INV6 --> INV7{"Low Stock Alert?"}

%% LOW STOCK TRIGGERED
INV7 -->|Yes| INV8["Trigger Reorder Notification"]
INV8 --> DB6

INV8 --> INV9A["Auto-Notify Wishlist Customers<br/>Item back in stock soon!"]
INV9A --> EXT4
EXT4 --> END1(["BACK TO<br/>Part 7: Admin Dashboard"])

%% NO ALERT NEEDED
INV7 -->|No| INV9["Stock Updated<br/>No alert needed"]
INV9 --> END1

%% VIEW HISTORY
INV4 -->|View History| INV11[/"Show Stock Movement Log<br/>All adds/removes with dates"/]
INV11 --> END1

