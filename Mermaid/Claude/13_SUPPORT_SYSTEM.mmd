%% =====================================================
%% BIKE SHOP - PART 13: SUPPORT TICKET SYSTEM
%% =====================================================
%% This diagram covers: Customer support and ticket management
%% Connected from: Part 7 (Admin Dashboard)
%% =====================================================

flowchart TD

%% =====================================================
%% DATABASES & EXTERNAL SERVICES
%% =====================================================

DB6[("Notification Queue")]
EXT4["Email/SMS Service"]

%% =====================================================
%% ENTRY POINT FROM PART 7
%% =====================================================

SUP_START(["FROM Part 7:<br/>Support Tickets"])

%% =====================================================
%% SUPPORT TICKET MANAGEMENT
%% =====================================================

SUP_START --> SUP3[/"View Support Tickets"/]

SUP3 --> DB6
DB6 --> SUP4[/"Filter by Status<br/>Open / In Progress / Resolved"/]

SUP4 --> SUP5[/"Select Ticket"/]
SUP5 --> SUP6[/"Display Ticket Details<br/>Category, Description, Attachments"/]

SUP6 --> SUP7{{"Action?"}}

%% REPLY TO CUSTOMER
SUP7 -->|Reply| SUP8[/"Type Response Message"/]
SUP8 --> EXT4
EXT4 --> SUP9["Send Reply Email"]

%% CREATE FOLLOW-UP TASK
SUP7 -->|Create Task| SUP10[/"Create Follow-up Task<br/>e.g., Ship replacement"/]
SUP10 --> DB6

%% RESOLVE TICKET
SUP7 -->|Resolve| SUP11["Mark as Resolved"]
SUP11 --> DB6

%% UPDATE STATUS
SUP9 --> SUP12["Update Ticket Status<br/>Change to 'Awaiting Response'"]
SUP12 --> DB6
DB6 --> END1(["BACK TO<br/>Part 7: Admin Dashboard"])

SUP11 --> END1

