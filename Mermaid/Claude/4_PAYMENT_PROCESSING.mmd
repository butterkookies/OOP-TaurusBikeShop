%% =====================================================
%% BIKE SHOP - PART 4: PAYMENT PROCESSING
%% =====================================================
%% This diagram covers: 3 payment methods with error handling
%% Connected from: Part 3 (Checkout)
%% Connected to: Part 5 (Order Confirmation & Tracking)
%% =====================================================

flowchart TD

%% =====================================================
%% DATABASES & EXTERNAL SERVICES
%% =====================================================

DB3[("Order Database")]
EXT1["GCash Payment Gateway"]
EXT4["Email/SMS Service"]
EXT5["Bank Verification"]

%% =====================================================
%% ENTRY POINT FROM PART 3
%% =====================================================

P_START(["FROM Part 3:<br/>Confirm Payment Method"])

%% =====================================================
%% PAYMENT METHOD SELECTION
%% =====================================================

P_START --> P10{{"Select Payment Method:"}}

%% =====================================================
%% PAYMENT OPTION 1: GCASH
%% =====================================================

P10 -->|GCash| P11[/"Display GCash QR Code"/]

P11 --> P11A[/"Enter GCash Reference"/]
P11A --> EXT1
EXT1 --> P12{"Payment Verified?"}

P12 -->|Success| P14["Create Order Record"]

P12 -->|Failed| P12D[/"Show Error Message"/]
P12D --> P12B{"Retry Payment?"}

P12B -->|Yes| P10
P12B -->|No - Save Draft| P12C["Save Cart & Exit"]
P12C --> BACK_DASH(["BACK TO<br/>Dashboard"])

P12 -->|Pending| P12A[/"Show 'Processing...'"/]
P12A --> P12E{"Still Pending?"}
P12E -->|Eventually Success| P14
P12E -->|Timeout| P12B

%% =====================================================
%% PAYMENT OPTION 2: BANK TRANSFER
%% =====================================================

P10 -->|Bank Transfer| P29[/"Display Bank Details"/]

P29 --> P29A[/"Upload Payment Proof"/]
P29A --> P29B["Set Status: Pending Verification"]
P29B --> DB3

DB3 --> P30["Add to Admin Verification Queue"]
P30 --> EXT4
EXT4 --> P30A["Send: Payment received, verifying..."]

P30A --> P30B{"ADMIN VERIFIES<br/>Payment?"}

P30B -->|Approved| P14

P30B -->|Rejected| P29C[/"Show Error<br/>Reason: Proof unclear"/]
P29C --> P29D{"Resubmit Proof?"}

P29D -->|Yes| P29A
P29D -->|Support| SUP_REFER(["CONTACT SUPPORT<br/>From Part 7"])
SUP_REFER --> BACK_DASH

P30B -->|Timeout 24hrs| P30C["Auto-Hold Order"]
P30C --> EXT4
EXT4 --> P30D{"Customer Action?"}
P30D -->|Resubmit| P29A
P30D -->|Want Refund| P30E["Process Refund"]
P30E --> DB3

%% =====================================================
%% PAYMENT OPTION 3: CASH ON DELIVERY
%% =====================================================

P10 -->|Cash on Delivery| P31["Set Payment: COD"]
P31 --> P14

%% =====================================================
%% ORDER RECORD CREATION
%% =====================================================

P14 --> P14A["Create Order Record in DB3"]
P14A --> DB3

P14A --> P14B["Lock Inventory Stock"]
P14B --> ORDER_CONFIRM(["CONTINUE TO<br/>Part 5: Confirmation"])

%% =====================================================
%% STYLING
%% =====================================================

classDef startend fill:#7ED957,stroke:#2E7D32,stroke-width:3px,color:#000,font-weight:bold
classDef process fill:#90CAF9,stroke:#1565C0,stroke-width:2px,color:#000
classDef decision fill:#FFF59D,stroke:#F9A825,stroke-width:2px,color:#000
classDef io fill:#FFCC80,stroke:#EF6C00,stroke-width:2px,color:#000
classDef database fill:#CE93D8,stroke:#6A1B9A,stroke-width:2px,color:#000
classDef external fill:#80DEEA,stroke:#00838F,stroke-width:2px,color:#000
classDef connector fill:#FFB6C1,stroke:#FF1493,stroke-width:3px,color:#000,font-weight:bold

class P_START,BACK_DASH,ORDER_CONFIRM,SUP_REFER startend
class P14,P14A,P14B process
class P10,P12,P12B,P12E,P29D,P30B,P30D decision
class P11,P11A,P29,P29A,P29C,P31 io
class DB3 database
class EXT1,EXT4,EXT5 external
