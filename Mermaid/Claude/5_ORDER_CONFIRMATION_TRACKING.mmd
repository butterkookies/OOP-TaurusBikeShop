%% =====================================================
%% BIKE SHOP - PART 5: ORDER CONFIRMATION & TRACKING
%% =====================================================
%% This diagram covers: Order confirmation and delivery tracking
%% Connected from: Part 4 (Payment)
%% Connected to: Part 6 (Delivery Completion & Review)
%% =====================================================

flowchart TD

%% =====================================================
%% DATABASES & EXTERNAL SERVICES
%% =====================================================

DB3[("Order Database")]
DB4[("Inventory Database")]
DB6[("Notification Queue")]
EXT2["Lalamove Delivery API"]
EXT3["LBC Delivery API"]
EXT4["Email/SMS Service"]

%% =====================================================
%% ENTRY POINT FROM PART 4
%% =====================================================

O_START(["FROM Part 4:<br/>Order Confirmed"])

%% =====================================================
%% ORDER CONFIRMATION
%% =====================================================

O_START --> O15["Set Order Status: PENDING"]
O15 --> DB3

O15 --> O15A["Add to Notification Queue"]
O15A --> DB6

O15A --> O16[/"Generate Order Confirmation"/]

O16 --> O16A["Send Confirmation Email & SMS"]
O16A --> EXT4
EXT4 --> O17[/"Show Confirmation Page<br/>Order #, Next Steps"/]

%% =====================================================
%% LOGISTICS DECISION
%% =====================================================

O17 --> O17A{"AUTO or MANUAL<br/>Logistics?"}

%% AUTO BOOKING PATH
O17A -->|Auto-Book| O18["System Auto-Books Courier"]
O18 --> EXT2
EXT2 --> O18A{"Booking Success?"}

O18A -->|Yes| O19["Generate Tracking Link"]
O19 --> DB3

O19 --> O19A["Update Status: PROCESSING"]
O19A --> DB3

O19A --> O19B["Add Tracking to Queue"]
O19B --> DB6

O19B --> O19C["Send Tracking Email & SMS"]
O19C --> EXT4
EXT4 --> TRACKING

O18A -->|No| O18B[/"Alert Admin<br/>Manual Booking Required"/]
O18B --> DB6
DB6 --> TRACKING

%% MANUAL BOOKING PATH
O17A -->|Manual| MANUAL[["Admin Books Manually<br/>In Part 8"]]
MANUAL --> TRACKING

%% =====================================================
%% ORDER TRACKING
%% =====================================================

TRACKING["Customer Tracking Page"]
TRACKING --> TRACK_LOOP{{"Customer Check<br/>Status?"}}

TRACK_LOOP -->|View Status| TRACK_VIEW[/"Show Real-Time Status<br/>Current location, ETA"/]
TRACK_VIEW --> DB3
DB3 --> TRACK_WHAT{"What Now?"}

TRACK_WHAT -->|Still Delivering| TRACK_LOOP

TRACK_WHAT -->|Issue with Delivery| ISSUE[/"Report Issue<br/>Options: Support"/]
ISSUE --> DB6
DB6 --> TRACK_LOOP

TRACK_WHAT -->|Delivery Failed| FAILED[/"Show Delivery Failed<br/>Options: Reschedule/Refund"/]
FAILED --> FAILED_OPT{"What Would<br/>You Like?"}

FAILED_OPT -->|Reschedule| TRACK_LOOP
FAILED_OPT -->|Request Refund| REFUND["Process Refund Request"]
REFUND --> DB6
DB6 --> TRACK_LOOP
FAILED_OPT -->|Get Support| ISSUE

TRACK_WHAT -->|Received| DELIVERY_COMPLETE(["CONTINUE TO<br/>Part 6: Delivery & Review"])

%% =====================================================
%% STYLING
%% =====================================================

classDef startend fill:#7ED957,stroke:#2E7D32,stroke-width:3px,color:#000,font-weight:bold
classDef process fill:#90CAF9,stroke:#1565C0,stroke-width:2px,color:#000
classDef decision fill:#FFF59D,stroke:#F9A825,stroke-width:2px,color:#000
classDef io fill:#FFCC80,stroke:#EF6C00,stroke-width:2px,color:#000
classDef database fill:#CE93D8,stroke:#6A1B9A,stroke-width:2px,color:#000
classDef external fill:#80DEEA,stroke:#00838F,stroke-width:2px,color:#000
classDef connector fill:#FFB6C1,stroke:#FF1493,stroke-width:3px,color:#000,font-weight:bold

class O_START,DELIVERY_COMPLETE,MANUAL startend
class O15,O16A,O19,O19A,O19B,O19C,REFUND process
class O17A,O18A,TRACK_LOOP,TRACK_WHAT,FAILED_OPT decision
class O16,O17,ISSUE,FAILED,TRACK_VIEW io
class DB3,DB4,DB6 database
class EXT2,EXT3,EXT4 external
