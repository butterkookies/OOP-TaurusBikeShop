%% =====================================================
%% BIKE SHOP - PART 14: BACKGROUND JOBS & AUTOMATION
%% =====================================================
%% Schema tables: ProductVariant (ReorderThreshold, StockQuantity),
%%   Order, BankTransferPayment (VerificationDeadline),
%%   PickupOrder (PickupExpiresAt), Delivery, Notification, SystemLog
%% All 5 jobs run 24/7 without manual intervention
%% =====================================================

flowchart TD

DB3[("Order Database")]
DB4[("Inventory Database")]
DB6[("Notification Queue")]
EXT2["Lalamove API"]
EXT3["LBC Delivery API"]

%% JOB 1: REAL-TIME INVENTORY SYNC
J1["JOB 1: Inventory Sync — Every 10 Seconds"]
J1 --> J1A[""Detect and Log Stock Discrepancies in InventoryLog""]
J1A --> DB4
DB4 --> J1B["Write Unified InventoryLog — Single View"]

%% JOB 2: PENDING ORDERS MONITOR
J2["JOB 2: Pending Orders Monitor — Every 5 Minutes"]
J2 --> J2A["Check Orders Unprocessed > 24 Hours"]
J2A --> DB3
DB3 --> J2B["Queue PendingOrderAlert to Admin"]

%% JOB 3: PAYMENT TIMEOUT MONITOR
J3["JOB 3: Payment Timeout Monitor — Every 5 Minutes"]
J3 --> J3A["Check BankTransferPayment.VerificationDeadline Exceeded"]
J3A --> DB3
DB3 --> J3B["Set Order Status: OnHold — Queue Alert"]

%% JOB 4: STOCK LEVEL MONITOR
J4["JOB 4: Stock Level Monitor — Every 15 Minutes"]
J4 --> J4A["Check StockQuantity < ReorderThreshold per ProductVariant"]
J4A --> DB4
DB4 --> J4B["Queue LowStockAlert to Admin — Notify Wishlist Customers"]

%% JOB 5: DELIVERY STATUS UPDATE
J5["JOB 5: Delivery Status Update — Every 5 Minutes"]
J5 --> J5A["Poll Courier APIs"]
J5A --> EXT2
J5A --> EXT3
EXT2 --> J5B["Sync Tracking Data to Delivery Table"]
EXT3 --> J5B
J5B --> DB3
DB3 --> J5C["Queue Status Update Notification to Customer"]

SUMMARY["All 5 Jobs Running 24/7 — No Manual Intervention Required"]

J1B --> SUMMARY
J2B --> SUMMARY
J3B --> SUMMARY
J4B --> SUMMARY
J5C --> SUMMARY

classDef job fill:#FFD700,stroke:#FFA500,stroke-width:3px,color:#000,font-weight:bold
classDef process fill:#90CAF9,stroke:#1565C0,stroke-width:2px,color:#000
classDef database fill:#CE93D8,stroke:#6A1B9A,stroke-width:2px,color:#000
classDef external fill:#80DEEA,stroke:#00838F,stroke-width:2px,color:#000
classDef summary fill:#7ED957,stroke:#2E7D32,stroke-width:3px,color:#000,font-weight:bold

class J1,J2,J3,J4,J5 job
class J1A,J1B,J2A,J2B,J3A,J3B,J4A,J4B,J5A,J5B,J5C process
class DB3,DB4,DB6 database
class EXT2,EXT3 external
class SUMMARY summary
