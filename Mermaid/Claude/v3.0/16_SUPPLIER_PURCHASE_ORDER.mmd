classDef decision fill:#FFF59D,stroke:#F9A825,stroke-width:2px,color:#000
classDef io fill:#FFCC80,stroke:#EF6C00,stroke-width:2px,color:#000
classDef database fill:#CE93D8,stroke:#6A1B9A,stroke-width:2px,color:#000
classDef external fill:#80DEEA,stroke:#00838F,stroke-width:2px,color:#000
classDef connector fill:#FFB6C1,stroke:#FF1493,stroke-width:3px,color:#000,font-weight:bold

class PO_START,END1 startend
class PO7,PO12,PO16,PO17,PO25,PO26,PO27,PO29,PO31,PO42,PO43 process
class PO3,PO5,PO13,PO15,PO22,PO23,PO28,PO41 decision
class PO1,PO2,PO4,PO5A,PO6,PO8,PO9,PO10,PO11,PO14,PO18,PO20,PO21,PO24,PO30,PO40 io
class DB2,DB4,DB6 database
class EXT4,EXT6 external