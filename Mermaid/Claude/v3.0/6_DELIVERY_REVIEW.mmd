%% =====================================================
%% BIKE SHOP - PART 6: DELIVERY & REVIEW
%% =====================================================
%% Schema tables: Order, Review, SupportTicket, InventoryLog,
%%   Notification
%% Connected from: Part 5
%% Loops back to: Part 2 (Dashboard)
%% =====================================================

flowchart TD

DB3[("Order Database")]
DB4[("Inventory Database")]
DB6[("Notification Queue")]
EXT4["Email/SMS Service"]

D_START(["FROM Part 5: Order Arrived"])

D_START --> D26[/"Confirm Order Received"/]
D26 --> D26A{"Bike Condition?"}

D26A -->|Damaged or Defective| D26B[/"Report Issue: Upload Photos, Describe Problem"/]
D26B --> DB6
DB6 --> D26C["Support Ticket Created"]
D26C --> D_CASE(["SUPPORT CASE CREATED — See Part 13"])
D_CASE --> BACK_DASH(["BACK TO Part 2: Dashboard"])

D26A -->|Perfect Condition| D26D[/"Add Review & Rating: 1–5 Stars"/]
D26D --> DB3
D26D --> D27["Queue Review Confirmation Notification"]
D27 --> EXT4
EXT4 --> D_COMPLETE([Transaction Complete])

D_COMPLETE --> D28A["Update Order Status: Delivered"]
D28A --> DB3
D28A --> D28B["Unlock Pending Stock in InventoryLog"]
D28B --> DB4
D28B --> BACK_DASH

classDef startend fill:#7ED957,stroke:#2E7D32,stroke-width:3px,color:#000,font-weight:bold
