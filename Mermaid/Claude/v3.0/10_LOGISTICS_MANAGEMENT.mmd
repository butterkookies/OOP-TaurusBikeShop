flowchart TD

DB3[("Order Database")]
EXT1["Payment Gateway"]
EXT2["Lalamove API"]
EXT4["Email/SMS Service"]

L_START(["FROM Part 7: Manage Logistics"])

L_START --> L1[/"View All Deliveries"/]
L1 --> DB3
DB3 --> L1B[/"Filter by Status: Pending / Shipped / Delivered"/]
L1B --> L1C{{"What Would You Like?"}}

L1C -->|View Tracking| L1D[/"Show Real-Time Status: Location, ETA, Driver"/]
L1D --> DB3
DB3 --> L1C

L1C -->|Delivery Delayed| L1E[/"Mark IsDelayed = true — Update DelayedUntil ETA"/]
L1E --> DB3
DB3 --> L1F["Queue Delay Notification to Customer"]
L1F --> EXT4
EXT4 --> L1C

L1C -->|Cancel Delivery| L1G[/"Confirm Cancellation — Refund Customer"/]
L1G --> EXT2
EXT2 --> L1H["Process Refund via Payment Gateway"]
L1H --> EXT1
EXT1 --> DB3
DB3 --> END1(["BACK TO Part 7: Admin Dashboard"])

