%% =====================================================
%% BIKE SHOP - PART 12: INVENTORY MANAGEMENT
%% =====================================================
%% Schema tables: ProductVariant (StockQuantity, ReorderThreshold),
%%   InventoryLog, Wishlist, Notification
%% ReorderThreshold column used for low-stock detection
%% Connected from: Part 7
%% =====================================================

flowchart TD

DB2[("Product Database")]
DB4[("Inventory Database")]
DB6[("Notification Queue")]
EXT4["Email/SMS Service"]

INV_START(["FROM Part 7: Inventory Management"])

INV_START --> INV1[/"View All Products"/]
INV1 --> DB2
DB2 --> INV2[/"Select Product"/]
INV2 --> INV3[/"Display Stock Levels: Available / Reserved / Locked"/]
INV3 --> INV4{{"Action?"}}

INV4 -->|Update Stock| INV5[/"Enter Quantity to Add or Remove"/]
INV5 --> DB4
INV5 --> INV6["Write InventoryLog — Sync Online & POS"]
INV6 --> INV7{"StockQuantity < ReorderThreshold?"}

INV7 -->|Yes| INV8["Trigger Low Stock Alert"]
INV8 --> DB6
INV8 --> INV9A["Notify Wishlist Customers: Item Back in Stock"]
INV9A --> EXT4
EXT4 --> END1(["BACK TO Part 7: Admin Dashboard"])

INV7 -->|No| INV9["Stock Updated — No Alert Needed"]
INV9 --> END1

INV4 -->|View History| INV11[/"Show InventoryLog: All Stock Movements with Dates"/]
INV11 --> END1

