%% =====================================================
%% BIKE SHOP - PART 2: CUSTOMER DASHBOARD & SHOPPING
%% =====================================================
%% Schema tables: Product, ProductVariant, Cart, CartItem,
%%   Wishlist, Order, Delivery, SupportTicket, Notification
%% Connected from: Part 1
%% Connected to: Part 3 (Cart & Checkout)
%% =====================================================

flowchart TD

DB2[("Product Database")]
DB3[("Order Database")]
DB4[("Inventory Database")]
DB5[("Cart Database")]
DB6[("Notification Queue")]

A_START(["FROM Part 1: Shop as Guest / Logged In"])

A_START --> CD1[/"Customer Dashboard"/]
CD1 --> CD2{"What Would You Like To Do?"}

CD2 -->|Shop Products| B1[/"Browse Product Catalog"/]
CD2 -->|View Cart| CART_LINK(["CONTINUE TO Part 3: Cart & Checkout"])
CD2 -->|Order History| CH1[/"View Past Orders"/]
CD2 -->|Track Orders| CH2[/"View Active Deliveries"/]
CD2 -->|Wishlist| CH3[/"View Saved Items"/]
CD2 -->|Support| SUP1[/"Contact Support Form"/]
CD2 -->|Logout| L1([Logout - End])

CH1 --> DB3
DB3 --> CH1A[/"Display Order List"/]
CH1A --> CD1

CH2 --> DB3
DB3 --> CH2A[/"Show Real-Time Tracking"/]
CH2A --> CD1

CH3 --> DB5
DB5 --> CH3A[/"Display Wishlist"/]
CH3A --> CH3B{"Action?"}
CH3B -->|Add to Cart| SHOP_FLOW["Go to Shopping"]
CH3B -->|Remove| DB5
DB5 --> CD1

SUP1 --> DB6
DB6 --> SUP1A["Support Ticket Created"]
SUP1A --> CD1

B1 --> SHOP_FLOW
SHOP_FLOW --> DB2
DB2 --> B2[/"Select Product"/]
B2 --> B2A[/"View Product Details"/]
B2A --> BINV{"Item In Stock?"}
BINV --> DB4

BINV -->|Out of Stock| B2B[/"Out of Stock"/]
B2B --> B2C{"What Would You Like?"}
B2C -->|Add to Wishlist| B2D["Save to Wishlist"]
B2D --> DB5
DB5 --> B2E["Will Notify When Back in Stock"]
B2E --> B1
B2C -->|View Similar Bikes| B1

BINV -->|Yes| B3{"Action?"}
B3 -->|Add to Cart| B4["Add Item to Cart"]
B4 --> DB5
B4 --> B5{"Continue Shopping?"}
B5 -->|Yes| B1
B5 -->|No| CART_LINK
B3 -->|Buy Now| CART_LINK

