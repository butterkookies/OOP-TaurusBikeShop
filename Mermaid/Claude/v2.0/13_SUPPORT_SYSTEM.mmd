%% =====================================================
%% BIKE SHOP - PART 13: SUPPORT TICKET SYSTEM
%% =====================================================
%% Schema tables: SupportTicket, SupportTicketReply,
%%   SupportTask, Notification
%% SupportTask used for "Create Follow-up Task" branch
%% Connected from: Part 7
%% =====================================================

flowchart TD

DB6[("Notification Queue")]
EXT4["Email/SMS Service"]

SUP_START(["FROM Part 7: Support Tickets"])

SUP_START --> SUP3[/"View Support Tickets"/]
SUP3 --> DB6
DB6 --> SUP4[/"Filter by Status: Open / InProgress / Resolved"/]
SUP4 --> SUP5[/"Select Ticket"/]
SUP5 --> SUP6[/"Display Ticket: Category, Description, Attachments"/]
SUP6 --> SUP7{{"Action?"}}

SUP7 -->|Reply| SUP8[/"Type Response Message"/]
SUP8 --> EXT4
EXT4 --> SUP9["Send Reply Email to Customer"]
SUP9 --> SUP12["Update Ticket Status: AwaitingResponse"]
SUP12 --> DB6
DB6 --> END1(["BACK TO Part 7: Admin Dashboard"])

SUP7 -->|Create Follow-up Task| SUP10[/"Define Task: Type, Assignee, Due Date"/]
SUP10 --> SUP10A["Save SupportTask Record"]
SUP10A --> DB6
DB6 --> END1

SUP7 -->|Resolve| SUP11["Mark Ticket Status: Resolved — Set ResolvedAt"]
SUP11 --> DB6
SUP11 --> END1

