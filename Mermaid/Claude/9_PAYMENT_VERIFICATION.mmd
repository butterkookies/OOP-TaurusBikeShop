%% =====================================================
%% BIKE SHOP - PART 9: PAYMENT VERIFICATION
%% =====================================================
%% This diagram covers: Admin bank transfer verification
%% Connected from: Part 7 (Admin Dashboard)
%% =====================================================

flowchart TD

%% =====================================================
%% DATABASES & EXTERNAL SERVICES
%% =====================================================

DB3[("Order Database")]
EXT4["Email/SMS Service"]

%% =====================================================
%% ENTRY POINT FROM PART 7
%% =====================================================

PV_START(["FROM Part 7:<br/>Payment Verification"])

%% =====================================================
%% PAYMENT VERIFICATION FLOW
%% =====================================================

PV_START --> PV1[/"View Pending Payments"/]

PV1 --> DB3
DB3 --> PV2[/"Filter by Payment Method"/]

PV2 --> PV3[/"Display Unverified Bank Transfers<br/>Oldest first"/]

PV3 --> PV4[/"Select Payment to Verify"/]

PV4 --> PV5[/"Review Uploaded Proof<br/>Screenshot + Order Details"/]

PV5 --> PV6{"Proof Valid?"}

%% =====================================================
%% APPROVAL PATH
%% =====================================================

PV6 -->|Yes - Approve| PV7["Mark as VERIFIED"]
PV7 --> DB3

PV7 --> PV8["Update Status: PROCESSING<br/>Auto-book courier"]
PV8 --> DB3

PV8 --> PV9["Send Confirmation Email"]
PV9 --> EXT4
EXT4 --> END1(["BACK TO<br/>Part 7: Admin Dashboard"])

%% =====================================================
%% REJECTION PATH
%% =====================================================

PV6 -->|No - Reject| PV10[/"Request New Proof<br/>Show reason"/]
PV10 --> DB3

PV10 --> PV11["Send Email to Customer"]
PV11 --> EXT4
EXT4 --> END1

%% =====================================================
%% TIMEOUT PATH
%% =====================================================

PV6 -->|Hold - Timeout| PV12["Auto-Hold Order<br/>24-hour deadline set"]
PV12 --> DB3

PV12 --> PV13["Send URGENT email to admin<br/>SMS to customer"]
PV13 --> EXT4
EXT4 --> END1

