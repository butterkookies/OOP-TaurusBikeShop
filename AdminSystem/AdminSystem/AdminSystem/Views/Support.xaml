<UserControl x:Class="AdminSystem.Views.SupportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT: Ticket List ════════════════════════════════════════ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,14">
                <TextBlock Text="Support Tickets" Foreground="#F0F0F0"
                           FontSize="22" FontWeight="Bold"
                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                <Button x:Name="BtnRefreshTickets"
                        Content="↻ Refresh" Height="34" Padding="14,0"
                        Background="#3A3A3A" Foreground="#A0A0A0"
                        BorderThickness="0" Cursor="Hand"
                        FontFamily="Segoe UI" FontSize="12"
                        HorizontalAlignment="Right"
                        Click="BtnRefreshTickets_Click"/>
            </Grid>

            <!-- Status filter buttons -->
            <WrapPanel Grid.Row="1" Margin="0,0,0,12">
                <Button x:Name="BtnFilterAll"    Content="All"    Tag=""
                        Click="FilterBtn_Click"
                        Background="#CC0000" Foreground="White"
                        BorderThickness="0" Padding="12,6"
                        FontSize="12" FontFamily="Segoe UI"
                        Cursor="Hand" Margin="0,0,6,0"/>
                <Button x:Name="BtnFilterOpen"   Content="Open"   Tag="Open"
                        Click="FilterBtn_Click"
                        Background="#2E2E2E" Foreground="#F0F0F0"
                        BorderThickness="0" Padding="12,6"
                        FontSize="12" FontFamily="Segoe UI"
                        Cursor="Hand" Margin="0,0,6,0"/>
                <Button x:Name="BtnFilterInProgress" Content="In Progress" Tag="InProgress"
                        Click="FilterBtn_Click"
                        Background="#2E2E2E" Foreground="#F0F0F0"
                        BorderThickness="0" Padding="12,6"
                        FontSize="12" FontFamily="Segoe UI"
                        Cursor="Hand" Margin="0,0,6,0"/>
                <Button x:Name="BtnFilterAwaiting" Content="Awaiting" Tag="AwaitingResponse"
                        Click="FilterBtn_Click"
                        Background="#2E2E2E" Foreground="#F0F0F0"
                        BorderThickness="0" Padding="12,6"
                        FontSize="12" FontFamily="Segoe UI"
                        Cursor="Hand" Margin="0,0,6,0"/>
                <Button x:Name="BtnFilterResolved" Content="Resolved" Tag="Resolved"
                        Click="FilterBtn_Click"
                        Background="#2E2E2E" Foreground="#F0F0F0"
                        BorderThickness="0" Padding="12,6"
                        FontSize="12" FontFamily="Segoe UI"
                        Cursor="Hand"/>
            </WrapPanel>

            <!-- Error bar -->
            <Border x:Name="TicketErrorBar" Grid.Row="2"
                    Background="#3B1212" Padding="14,8" Margin="0,0,0,8"
                    Visibility="Collapsed">
                <TextBlock x:Name="TbTicketError"
                           Foreground="#CC0000" FontSize="12"
                           FontFamily="Segoe UI" TextWrapping="Wrap"/>
            </Border>

            <!-- DataGrid -->
            <Border Grid.Row="3" Background="#242424" CornerRadius="10"
                    BorderThickness="1" BorderBrush="#3A3A3A">
                <DataGrid x:Name="DgTickets"
                          AutoGenerateColumns="False"
                          Background="#242424" Foreground="#F0F0F0"
                          BorderThickness="0" RowHeight="40"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#3A3A3A"
                          CanUserAddRows="False" IsReadOnly="True"
                          SelectionMode="Single" SelectionUnit="FullRow"
                          SelectionChanged="DgTickets_SelectionChanged">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"      Value="#1A1A1A"/>
                            <Setter Property="Foreground"      Value="#606060"/>
                            <Setter Property="FontSize"        Value="11"/>
                            <Setter Property="FontWeight"      Value="SemiBold"/>
                            <Setter Property="Padding"         Value="12,10"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#242424"/>
                            <Setter Property="Foreground" Value="#F0F0F0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2C2C2C"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#3A1A1A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding"         Value="12,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontFamily"      Value="Segoe UI"/>
                            <Setter Property="FontSize"        Value="12"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background"  Value="Transparent"/>
                                    <Setter Property="Foreground"  Value="#F0F0F0"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"
                            Binding="{Binding TicketId}" Width="50"/>
                        <DataGridTextColumn Header="Customer"
                            Binding="{Binding CustomerName}" Width="130"/>
                        <DataGridTextColumn Header="Subject"
                            Binding="{Binding Subject}" Width="*"/>
                        <DataGridTextColumn Header="Category"
                            Binding="{Binding TicketCategory}" Width="120"/>
                        <DataGridTextColumn Header="Status"
                            Binding="{Binding TicketStatus}" Width="120"/>
                        <DataGridTextColumn Header="Created"
                            Binding="{Binding CreatedAt, StringFormat='{}{0:MMM d, yyyy}'}"
                            Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- ═══ RIGHT: Detail / Action Panel ════════════════════════════════ -->
        <Border Grid.Column="2" Background="#242424" CornerRadius="10"
                Padding="16" BorderThickness="1" BorderBrush="#3A3A3A">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Ticket summary -->
                    <TextBlock Text="Ticket Detail" Foreground="#F0F0F0"
                               FontSize="14" FontWeight="SemiBold"
                               FontFamily="Segoe UI" Margin="0,0,0,10"/>
                    <TextBlock x:Name="TbTicketSubject"
                               Foreground="#CCCCCC" FontFamily="Segoe UI"
                               FontSize="13" TextWrapping="Wrap"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="TbTicketMeta"
                               Foreground="#606060" FontFamily="Segoe UI"
                               FontSize="11" TextWrapping="Wrap"
                               Margin="0,0,0,16"/>

                    <!-- Resolve button -->
                    <Button x:Name="BtnResolve"
                            Content="✔ Mark Resolved" Height="36"
                            Background="#4CAF50" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            FontFamily="Segoe UI" FontSize="12"
                            Margin="0,0,0,14"
                            Click="BtnResolve_Click"/>

                    <Separator Background="#3A3A3A" Margin="0,0,0,14"/>

                    <!-- Recent replies -->
                    <TextBlock Text="REPLIES" Foreground="#606060" FontSize="10"
                               FontWeight="SemiBold" FontFamily="Segoe UI"
                               Margin="0,0,0,8"/>
                    <ListBox x:Name="LbReplies"
                             Background="Transparent" BorderThickness="0"
                             MaxHeight="160" ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,12">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background"   Value="Transparent"/>
                                <Setter Property="BorderBrush"  Value="Transparent"/>
                                <Setter Property="Padding"      Value="0,4"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2A2A2A" CornerRadius="6"
                                        Padding="10,8" Margin="0,0,0,4">
                                    <StackPanel>
                                        <TextBlock Text="{Binding AuthorName}"
                                                   Foreground="#A0A0A0" FontSize="10"
                                                   FontFamily="Segoe UI" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding Message}"
                                                   Foreground="#F0F0F0" FontSize="11"
                                                   FontFamily="Segoe UI" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Reply box -->
                    <TextBlock Text="ADD REPLY" Foreground="#606060" FontSize="10"
                               FontWeight="SemiBold" FontFamily="Segoe UI"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="TbReplyText"
                             Background="#2E2E2E" Foreground="#F0F0F0"
                             BorderBrush="#3A3A3A" BorderThickness="1"
                             FontFamily="Segoe UI" FontSize="12"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             Height="72" Padding="10,8"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,8"/>
                    <Button x:Name="BtnSendReply"
                            Content="Send Reply" Height="36"
                            Background="#2196F3" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            FontFamily="Segoe UI" FontSize="12"
                            Margin="0,0,0,16"
                            Click="BtnSendReply_Click"/>

                    <Separator Background="#3A3A3A" Margin="0,0,0,14"/>

                    <!-- Tasks -->
                    <TextBlock Text="TASKS" Foreground="#606060" FontSize="10"
                               FontWeight="SemiBold" FontFamily="Segoe UI"
                               Margin="0,0,0,8"/>
                    <ListBox x:Name="LbTasks"
                             Background="Transparent" BorderThickness="0"
                             MaxHeight="120" ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,8">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background"   Value="Transparent"/>
                                <Setter Property="BorderBrush"  Value="Transparent"/>
                                <Setter Property="Padding"      Value="0,2"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▸ " Foreground="#606060"
                                               FontFamily="Segoe UI" FontSize="11"/>
                                    <TextBlock Text="{Binding TaskType}"
                                               Foreground="#D0D0D0" FontFamily="Segoe UI"
                                               FontSize="11" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding TaskStatus}"
                                               Foreground="#888888" FontFamily="Segoe UI"
                                               FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Add task -->
                    <TextBlock Text="ADD TASK" Foreground="#606060" FontSize="10"
                               FontWeight="SemiBold" FontFamily="Segoe UI"
                               Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbTaskType" Height="34"
                              Background="#2E2E2E" Foreground="#F0F0F0"
                              BorderBrush="#3A3A3A" BorderThickness="1"
                              FontFamily="Segoe UI" FontSize="12"
                              Margin="0,0,0,8">
                        <ComboBoxItem Content="Ship Replacement"  Tag="ShipReplacement"/>
                        <ComboBoxItem Content="Arrange Return"    Tag="ArrangeReturn"/>
                        <ComboBoxItem Content="Contact Supplier"  Tag="ContactSupplier"/>
                        <ComboBoxItem Content="Other"             Tag="Other"/>
                    </ComboBox>
                    <Button x:Name="BtnAddTask"
                            Content="Add Task" Height="34"
                            Background="#3A3A3A" Foreground="#D0D0D0"
                            BorderThickness="0" Cursor="Hand"
                            FontFamily="Segoe UI" FontSize="12"
                            Margin="0,0,0,14"
                            Click="BtnAddTask_Click"/>

                    <!-- Feedback -->
                    <TextBlock x:Name="TbSupportSuccess"
                               Foreground="#4CAF50" FontFamily="Segoe UI"
                               FontSize="12" TextWrapping="Wrap"
                               Visibility="Collapsed"/>
                    <TextBlock x:Name="TbSupportError"
                               Foreground="#CC0000" FontFamily="Segoe UI"
                               FontSize="12" TextWrapping="Wrap"
                               Visibility="Collapsed"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</UserControl>
