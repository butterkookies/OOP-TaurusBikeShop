<UserControl x:Class="AdminSystem.Views.VouchersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT: Voucher List ═══════════════════════════════════════ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,14">
                <TextBlock Text="Vouchers" Foreground="#F0F0F0"
                           FontSize="22" FontWeight="Bold"
                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnNewVoucher"
                            Content="+ New Voucher" Height="34" Padding="14,0"
                            Background="#CC0000" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            FontFamily="Segoe UI" FontSize="12"
                            Margin="0,0,8,0"
                            Click="BtnNewVoucher_Click"/>
                    <Button x:Name="BtnRefreshVouchers"
                            Content="↻ Refresh" Height="34" Padding="14,0"
                            Background="#3A3A3A" Foreground="#A0A0A0"
                            BorderThickness="0" Cursor="Hand"
                            FontFamily="Segoe UI" FontSize="12"
                            Click="BtnRefreshVouchers_Click"/>
                </StackPanel>
            </Grid>

            <!-- Error bar -->
            <Border x:Name="VoucherErrorBar" Grid.Row="1"
                    Background="#3B1212" Padding="14,8" Margin="0,0,0,8"
                    Visibility="Collapsed">
                <TextBlock x:Name="TbVoucherError"
                           Foreground="#CC0000" FontSize="12"
                           FontFamily="Segoe UI" TextWrapping="Wrap"/>
            </Border>

            <!-- DataGrid -->
            <Border Grid.Row="2" Background="#242424" CornerRadius="10"
                    BorderThickness="1" BorderBrush="#3A3A3A">
                <DataGrid x:Name="DgVouchers"
                          AutoGenerateColumns="False"
                          Background="#242424" Foreground="#F0F0F0"
                          BorderThickness="0" RowHeight="40"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#3A3A3A"
                          CanUserAddRows="False" IsReadOnly="True"
                          SelectionMode="Single" SelectionUnit="FullRow"
                          SelectionChanged="DgVouchers_SelectionChanged">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"      Value="#1A1A1A"/>
                            <Setter Property="Foreground"      Value="#606060"/>
                            <Setter Property="FontSize"        Value="11"/>
                            <Setter Property="FontWeight"      Value="SemiBold"/>
                            <Setter Property="Padding"         Value="12,10"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#242424"/>
                            <Setter Property="Foreground" Value="#F0F0F0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2C2C2C"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#3A1A1A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding"         Value="12,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontFamily"      Value="Segoe UI"/>
                            <Setter Property="FontSize"        Value="12"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background"  Value="Transparent"/>
                                    <Setter Property="Foreground"  Value="#F0F0F0"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Code"
                            Binding="{Binding Code}" Width="130"/>
                        <DataGridTextColumn Header="Type"
                            Binding="{Binding DiscountType}" Width="100"/>
                        <DataGridTextColumn Header="Value"
                            Binding="{Binding DiscountValue, StringFormat='{}{0:N2}'}"
                            Width="80"/>
                        <DataGridTextColumn Header="Min Order"
                            Binding="{Binding MinimumOrderAmount, StringFormat='{}{0:N2}'}"
                            Width="90"/>
                        <DataGridTextColumn Header="Max Uses"
                            Binding="{Binding MaxUsageCount}"
                            Width="80"/>
                        <DataGridTextColumn Header="Expires"
                            Binding="{Binding ExpiresAt, StringFormat='{}{0:MMM d, yyyy}'}"
                            Width="120"/>
                        <DataGridCheckBoxColumn Header="Active"
                            Binding="{Binding IsActive}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- ═══ RIGHT: Edit/Create Panel ════════════════════════════════════ -->
        <Border Grid.Column="2" Background="#242424" CornerRadius="10"
                Padding="20" BorderThickness="1" BorderBrush="#3A3A3A"
                VerticalAlignment="Top">
            <StackPanel>
                <TextBlock x:Name="TbPanelTitle" Text="New Voucher"
                           Foreground="#F0F0F0" FontSize="15"
                           FontWeight="SemiBold" FontFamily="Segoe UI"
                           Margin="0,0,0,18"/>

                <!-- Code -->
                <TextBlock Text="CODE" Foreground="#606060" FontSize="10"
                           FontWeight="SemiBold" FontFamily="Segoe UI"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="TbCode" Height="36" Padding="10,0"
                         Background="#2E2E2E" Foreground="#F0F0F0"
                         BorderBrush="#3A3A3A" BorderThickness="1"
                         FontFamily="Segoe UI" FontSize="12"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,14"/>

                <!-- Discount Type -->
                <TextBlock Text="DISCOUNT TYPE" Foreground="#606060" FontSize="10"
                           FontWeight="SemiBold" FontFamily="Segoe UI"
                           Margin="0,0,0,5"/>
                <ComboBox x:Name="CbDiscountType" Height="36"
                          Background="#2E2E2E" Foreground="#F0F0F0"
                          BorderBrush="#3A3A3A" BorderThickness="1"
                          FontFamily="Segoe UI" FontSize="12"
                          SelectedValuePath="Tag"
                          Margin="0,0,0,14">
                    <ComboBoxItem Content="Percentage" Tag="Percentage" IsSelected="True"/>
                    <ComboBoxItem Content="Fixed Amount" Tag="Fixed"/>
                </ComboBox>

                <!-- Discount Value -->
                <TextBlock Text="DISCOUNT VALUE" Foreground="#606060" FontSize="10"
                           FontWeight="SemiBold" FontFamily="Segoe UI"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="TbDiscountValue" Height="36" Padding="10,0"
                         Background="#2E2E2E" Foreground="#F0F0F0"
                         BorderBrush="#3A3A3A" BorderThickness="1"
                         FontFamily="Segoe UI" FontSize="12"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,14"/>

                <!-- Min Order Amount -->
                <TextBlock Text="MIN ORDER AMOUNT (optional)" Foreground="#606060"
                           FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="TbMinOrder" Height="36" Padding="10,0"
                         Background="#2E2E2E" Foreground="#F0F0F0"
                         BorderBrush="#3A3A3A" BorderThickness="1"
                         FontFamily="Segoe UI" FontSize="12"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,14"/>

                <!-- Max Uses / Max Per User row -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="MAX USES" Foreground="#606060"
                                   FontSize="10" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Margin="0,0,0,5"/>
                        <TextBox x:Name="TbMaxUsage" Height="36" Padding="10,0"
                                 Background="#2E2E2E" Foreground="#F0F0F0"
                                 BorderBrush="#3A3A3A" BorderThickness="1"
                                 FontFamily="Segoe UI" FontSize="12"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="MAX / USER" Foreground="#606060"
                                   FontSize="10" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Margin="0,0,0,5"/>
                        <TextBox x:Name="TbMaxPerUser" Height="36" Padding="10,0"
                                 Background="#2E2E2E" Foreground="#F0F0F0"
                                 BorderBrush="#3A3A3A" BorderThickness="1"
                                 FontFamily="Segoe UI" FontSize="12"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Expires At -->
                <TextBlock Text="EXPIRES AT (optional)" Foreground="#606060"
                           FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"
                           Margin="0,0,0,5"/>
                <DatePicker x:Name="DpExpiresAt" Height="36"
                            Background="#2E2E2E" Foreground="#F0F0F0"
                            BorderBrush="#3A3A3A" BorderThickness="1"
                            FontFamily="Segoe UI" FontSize="12"
                            Margin="0,0,0,20"/>

                <!-- Save -->
                <Button x:Name="BtnSaveVoucher"
                        Content="Save Voucher" Height="38"
                        Background="#CC0000" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                        Margin="0,0,0,8"
                        Click="BtnSaveVoucher_Click"/>

                <!-- Toggle active (only shown when editing) -->
                <Button x:Name="BtnToggleActive"
                        Content="Deactivate" Height="36"
                        Background="#3A3A3A" Foreground="#A0A0A0"
                        BorderThickness="0" Cursor="Hand"
                        FontFamily="Segoe UI" FontSize="12"
                        Visibility="Collapsed"
                        Click="BtnToggleActive_Click"/>

                <!-- Feedback -->
                <TextBlock x:Name="TbVoucherSuccess"
                           Foreground="#4CAF50" FontFamily="Segoe UI"
                           FontSize="12" TextWrapping="Wrap"
                           Margin="0,10,0,0" Visibility="Collapsed"/>
                <TextBlock x:Name="TbVoucherFormError"
                           Foreground="#CC0000" FontFamily="Segoe UI"
                           FontSize="12" TextWrapping="Wrap"
                           Margin="0,10,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
