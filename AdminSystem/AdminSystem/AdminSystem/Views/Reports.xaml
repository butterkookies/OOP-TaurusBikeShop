<UserControl x:Class="AdminSystem.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- ── Header ──────────────────────────────────────────────── -->
            <Grid Margin="0,0,0,20">
                <TextBlock Text="Reports" Foreground="#F0F0F0"
                           FontSize="22" FontWeight="Bold"
                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                <Button x:Name="BtnRefreshReports"
                        Content="↻ Refresh" Height="34" Padding="14,0"
                        Background="#3A3A3A" Foreground="#A0A0A0"
                        BorderThickness="0" Cursor="Hand"
                        FontFamily="Segoe UI" FontSize="12"
                        HorizontalAlignment="Right"
                        Click="BtnRefreshReports_Click"/>
            </Grid>

            <!-- ── Date Range Filter ───────────────────────────────────── -->
            <Border Background="#242424" CornerRadius="10"
                    Padding="16,14" BorderThickness="1" BorderBrush="#3A3A3A"
                    Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="From" Foreground="#A0A0A0" FontSize="12"
                               FontFamily="Segoe UI" VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <DatePicker x:Name="DpFrom" Height="34" Width="150"
                                Background="#2E2E2E" Foreground="#F0F0F0"
                                BorderBrush="#3A3A3A" BorderThickness="1"
                                FontFamily="Segoe UI" FontSize="12"/>
                    <TextBlock Text="To" Foreground="#A0A0A0" FontSize="12"
                               FontFamily="Segoe UI" VerticalAlignment="Center"
                               Margin="12,0"/>
                    <DatePicker x:Name="DpTo" Height="34" Width="150"
                                Background="#2E2E2E" Foreground="#F0F0F0"
                                BorderBrush="#3A3A3A" BorderThickness="1"
                                FontFamily="Segoe UI" FontSize="12"/>
                    <Button x:Name="BtnApplyFilter"
                            Content="Apply" Height="34" Padding="16,0"
                            Background="#CC0000" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                            Margin="14,0,0,0"
                            Click="BtnApplyFilter_Click"/>
                </StackPanel>
            </Border>

            <!-- ── Error bar ───────────────────────────────────────────── -->
            <Border x:Name="ReportsErrorBar"
                    Background="#3B1212" Padding="14,8" Margin="0,0,0,12"
                    Visibility="Collapsed">
                <TextBlock x:Name="TbReportsError"
                           Foreground="#CC0000" FontSize="12"
                           FontFamily="Segoe UI" TextWrapping="Wrap"/>
            </Border>

            <!-- ── Stat Cards ──────────────────────────────────────────── -->
            <UniformGrid Columns="4" Margin="0,0,0,20">

                <!-- Today's Sales -->
                <Border Background="#242424" CornerRadius="10"
                        Padding="16,14" BorderThickness="1" BorderBrush="#3A3A3A"
                        Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="TODAY'S SALES" Foreground="#606060"
                                   FontSize="10" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Margin="0,0,0,6"/>
                        <TextBlock x:Name="TbTodaySales" Text="₱ 0.00"
                                   Foreground="#F0F0F0" FontSize="20"
                                   FontWeight="Bold" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>

                <!-- Period Sales -->
                <Border Background="#242424" CornerRadius="10"
                        Padding="16,14" BorderThickness="1" BorderBrush="#3A3A3A"
                        Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="PERIOD SALES" Foreground="#606060"
                                   FontSize="10" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Margin="0,0,0,6"/>
                        <TextBlock x:Name="TbPeriodSales" Text="₱ 0.00"
                                   Foreground="#CC0000" FontSize="20"
                                   FontWeight="Bold" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>

                <!-- Delivered -->
                <Border Background="#242424" CornerRadius="10"
                        Padding="16,14" BorderThickness="1" BorderBrush="#3A3A3A"
                        Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="DELIVERED ORDERS" Foreground="#606060"
                                   FontSize="10" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Margin="0,0,0,6"/>
                        <TextBlock x:Name="TbDeliveredCount" Text="0"
                                   Foreground="#4CAF50" FontSize="20"
                                   FontWeight="Bold" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>

                <!-- Cancelled -->
                <Border Background="#242424" CornerRadius="10"
                        Padding="16,14" BorderThickness="1" BorderBrush="#3A3A3A">
                    <StackPanel>
                        <TextBlock Text="CANCELLED ORDERS" Foreground="#606060"
                                   FontSize="10" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Margin="0,0,0,6"/>
                        <TextBlock x:Name="TbCancelledCount" Text="0"
                                   Foreground="#D97706" FontSize="20"
                                   FontWeight="Bold" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ── Three DataGrids row ─────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Top Orders by Value -->
                <Border Grid.Column="0" Background="#242424" CornerRadius="10"
                        BorderThickness="1" BorderBrush="#3A3A3A" Padding="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Top Orders by Value" Foreground="#F0F0F0"
                                   FontSize="13" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Margin="16,14,16,10"/>
                        <DataGrid x:Name="DgTopOrders"
                                  AutoGenerateColumns="False"
                                  Background="#242424" Foreground="#F0F0F0"
                                  BorderThickness="0" RowHeight="36"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#3A3A3A"
                                  MaxHeight="300"
                                  CanUserAddRows="False" IsReadOnly="True"
                                  SelectionMode="Single" SelectionUnit="FullRow">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"      Value="#1A1A1A"/>
                                    <Setter Property="Foreground"      Value="#606060"/>
                                    <Setter Property="FontSize"        Value="10"/>
                                    <Setter Property="FontWeight"      Value="SemiBold"/>
                                    <Setter Property="Padding"         Value="10,8"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding"         Value="10,0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FontFamily"      Value="Segoe UI"/>
                                    <Setter Property="FontSize"        Value="11"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background"  Value="#3A1A1A"/>
                                            <Setter Property="Foreground"  Value="#F0F0F0"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="#242424"/>
                                    <Setter Property="Foreground" Value="#F0F0F0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2C2C2C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Order #"
                                    Binding="{Binding OrderNumber}" Width="110"/>
                                <DataGridTextColumn Header="Customer"
                                    Binding="{Binding CustomerName}" Width="*"/>
                                <DataGridTextColumn Header="Date"
                                    Binding="{Binding OrderDate, StringFormat='{}{0:MMM d}'}"
                                    Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Low Stock Products -->
                <Border Grid.Column="2" Background="#242424" CornerRadius="10"
                        BorderThickness="1" BorderBrush="#3A3A3A">
                    <StackPanel>
                        <TextBlock Text="Low Stock Products" Foreground="#F0F0F0"
                                   FontSize="13" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Margin="16,14,16,10"/>
                        <DataGrid x:Name="DgLowStock"
                                  AutoGenerateColumns="False"
                                  Background="#242424" Foreground="#F0F0F0"
                                  BorderThickness="0" RowHeight="36"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#3A3A3A"
                                  MaxHeight="300"
                                  CanUserAddRows="False" IsReadOnly="True"
                                  SelectionMode="Single" SelectionUnit="FullRow">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"      Value="#1A1A1A"/>
                                    <Setter Property="Foreground"      Value="#606060"/>
                                    <Setter Property="FontSize"        Value="10"/>
                                    <Setter Property="FontWeight"      Value="SemiBold"/>
                                    <Setter Property="Padding"         Value="10,8"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding"         Value="10,0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FontFamily"      Value="Segoe UI"/>
                                    <Setter Property="FontSize"        Value="11"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background"  Value="#3A1A1A"/>
                                            <Setter Property="Foreground"  Value="#F0F0F0"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="#242424"/>
                                    <Setter Property="Foreground" Value="#F0F0F0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2C2C2C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product"
                                    Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Brand"
                                    Binding="{Binding BrandName}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Inventory Movements -->
                <Border Grid.Column="4" Background="#242424" CornerRadius="10"
                        BorderThickness="1" BorderBrush="#3A3A3A">
                    <StackPanel>
                        <TextBlock Text="Inventory Movements" Foreground="#F0F0F0"
                                   FontSize="13" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" Margin="16,14,16,10"/>
                        <DataGrid x:Name="DgMovements"
                                  AutoGenerateColumns="False"
                                  Background="#242424" Foreground="#F0F0F0"
                                  BorderThickness="0" RowHeight="36"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#3A3A3A"
                                  MaxHeight="300"
                                  CanUserAddRows="False" IsReadOnly="True"
                                  SelectionMode="Single" SelectionUnit="FullRow">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"      Value="#1A1A1A"/>
                                    <Setter Property="Foreground"      Value="#606060"/>
                                    <Setter Property="FontSize"        Value="10"/>
                                    <Setter Property="FontWeight"      Value="SemiBold"/>
                                    <Setter Property="Padding"         Value="10,8"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding"         Value="10,0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FontFamily"      Value="Segoe UI"/>
                                    <Setter Property="FontSize"        Value="11"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background"  Value="#3A1A1A"/>
                                            <Setter Property="Foreground"  Value="#F0F0F0"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="#242424"/>
                                    <Setter Property="Foreground" Value="#F0F0F0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2C2C2C"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product"
                                    Binding="{Binding ProductName}" Width="*"/>
                                <DataGridTextColumn Header="Type"
                                    Binding="{Binding ChangeType}" Width="90"/>
                                <DataGridTextColumn Header="Qty"
                                    Binding="{Binding ChangeQuantity}" Width="50"/>
                                <DataGridTextColumn Header="Date"
                                    Binding="{Binding CreatedAt, StringFormat='{}{0:MMM d}'}"
                                    Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
