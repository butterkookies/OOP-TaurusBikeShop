<UserControl x:Class="AdminSystem.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24">

            <!-- ── Stat Cards ──────────────────────────────────────────── -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Active Orders -->
                <Border Grid.Column="0" Background="#242424" CornerRadius="8"
                        Padding="20,16" BorderThickness="1" BorderBrush="#2E2E2E">
                    <StackPanel>
                        <TextBlock Text="ACTIVE ORDERS"
                                   Foreground="#888888" FontSize="10"
                                   FontWeight="SemiBold" FontFamily="Segoe UI"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="TbActiveOrders" Text="—"
                                   Foreground="#F0F0F0" FontSize="32"
                                   FontWeight="Bold" FontFamily="Segoe UI"/>
                        <TextBlock Text="Processing + Shipped"
                                   Foreground="#666666" FontSize="10"
                                   FontFamily="Segoe UI" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Pending Payments -->
                <Border Grid.Column="2" Background="#242424" CornerRadius="8"
                        Padding="20,16" BorderThickness="1" BorderBrush="#2E2E2E">
                    <StackPanel>
                        <TextBlock Text="PENDING PAYMENTS"
                                   Foreground="#888888" FontSize="10"
                                   FontWeight="SemiBold" FontFamily="Segoe UI"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="TbPendingPayments" Text="—"
                                   Foreground="#FFC107" FontSize="32"
                                   FontWeight="Bold" FontFamily="Segoe UI"/>
                        <TextBlock Text="Awaiting verification"
                                   Foreground="#666666" FontSize="10"
                                   FontFamily="Segoe UI" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Low Stock -->
                <Border Grid.Column="4" Background="#242424" CornerRadius="8"
                        Padding="20,16" BorderThickness="1" BorderBrush="#2E2E2E">
                    <StackPanel>
                        <TextBlock Text="LOW STOCK ITEMS"
                                   Foreground="#888888" FontSize="10"
                                   FontWeight="SemiBold" FontFamily="Segoe UI"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="TbLowStock" Text="—"
                                   Foreground="#CC0000" FontSize="32"
                                   FontWeight="Bold" FontFamily="Segoe UI"/>
                        <TextBlock Text="Below reorder threshold"
                                   Foreground="#666666" FontSize="10"
                                   FontFamily="Segoe UI" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Today's Sales -->
                <Border Grid.Column="6" Background="#242424" CornerRadius="8"
                        Padding="20,16" BorderThickness="1" BorderBrush="#2E2E2E">
                    <StackPanel>
                        <TextBlock Text="TODAY'S SALES"
                                   Foreground="#888888" FontSize="10"
                                   FontWeight="SemiBold" FontFamily="Segoe UI"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="TbTodaySales" Text="—"
                                   Foreground="#4CAF50" FontSize="24"
                                   FontWeight="Bold" FontFamily="Segoe UI"/>
                        <TextBlock Text="Delivered orders today"
                                   Foreground="#666666" FontSize="10"
                                   FontFamily="Segoe UI" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Recent Orders Table ────────────────────────────────── -->
            <Border Background="#242424" CornerRadius="8"
                    BorderThickness="1" BorderBrush="#2E2E2E">
                <DockPanel>

                    <!-- Header -->
                    <Border DockPanel.Dock="Top" Padding="20,14"
                            BorderThickness="0,0,0,1" BorderBrush="#2E2E2E">
                        <Grid>
                            <TextBlock Text="Recent Orders"
                                       Foreground="#F0F0F0" FontSize="14"
                                       FontWeight="SemiBold" FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="BtnDashRefresh"
                                    HorizontalAlignment="Right"
                                    Background="Transparent" Foreground="#888888"
                                    BorderBrush="#3A3A3A" BorderThickness="1"
                                    Padding="10,4" FontSize="11"
                                    FontFamily="Segoe UI" Cursor="Hand"
                                    Content="↻ Refresh"
                                    Click="BtnDashRefresh_Click"/>
                        </Grid>
                    </Border>

                    <!-- DataGrid -->
                    <DataGrid x:Name="DgRecentOrders"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="#242424"
                              Foreground="#F0F0F0"
                              BorderThickness="0"
                              RowBackground="#242424"
                              AlternatingRowBackground="#1E1E1E"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#2E2E2E"
                              ColumnHeaderHeight="36"
                              RowHeight="36"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              CanUserResizeRows="False"
                              CanUserAddRows="False"
                              MaxHeight="340">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"      Value="#1E1E1E"/>
                                <Setter Property="Foreground"      Value="#888888"/>
                                <Setter Property="FontSize"        Value="11"/>
                                <Setter Property="FontFamily"      Value="Segoe UI"/>
                                <Setter Property="FontWeight"      Value="SemiBold"/>
                                <Setter Property="Padding"         Value="12,0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Foreground"      Value="#F0F0F0"/>
                                <Setter Property="FontSize"        Value="12"/>
                                <Setter Property="FontFamily"      Value="Segoe UI"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding"         Value="12,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#CC0000"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Order #"
                                Binding="{Binding OrderNumber}"
                                Width="150"/>
                            <DataGridTextColumn Header="Customer"
                                Binding="{Binding CustomerName}"
                                Width="*"/>
                            <DataGridTextColumn Header="Date"
                                Binding="{Binding OrderDate, StringFormat='{}{0:MMM dd, yyyy}'}"
                                Width="120"/>
                            <DataGridTextColumn Header="Status"
                                Binding="{Binding OrderStatus}"
                                Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Error message -->
            <TextBlock x:Name="TbDashError"
                       Foreground="#CC0000" FontSize="12"
                       FontFamily="Segoe UI" Margin="0,12,0,0"
                       TextWrapping="Wrap" Visibility="Collapsed"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
