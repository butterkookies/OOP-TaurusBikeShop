<UserControl x:Class="AdminSystem.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootPanel"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.25"/>
                    <DoubleAnimation Storyboard.TargetName="PanelTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="16" To="0" Duration="0:0:0.3"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid x:Name="RootPanel"
                Margin="24"
                Opacity="0">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="PanelTranslate" Y="16"/>
            </Grid.RenderTransform>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Dashboard"
                            Style="{StaticResource TextTitle}"/>
                    <TextBlock x:Name="TbSubtitle"
                            Style="{StaticResource TextSubtitle}"/>
                </StackPanel>

                <Button x:Name="BtnDashRefresh"
                        Grid.Column="1"
                        Click="BtnDashRefresh_Click"
                        Style="{StaticResource SecondaryButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;"
                                FontFamily="Segoe MDL2 Assets"
                                Margin="0,0,6,0"/>
                        <TextBlock Text="Refresh"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Stat Cards -->
            <UniformGrid Grid.Row="2" Columns="4" Margin="0">

                <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="ACTIVE ORDERS"
                                Style="{StaticResource TextCaption}"/>
                        <TextBlock x:Name="TbActiveOrders"
                                FontSize="28" FontWeight="Bold"
                                Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Processing + Shipped"
                                Style="{StaticResource TextCaption}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="PENDING PAYMENTS"
                                Style="{StaticResource TextCaption}"/>
                        <TextBlock x:Name="TbPendingPayments"
                                FontSize="28" FontWeight="Bold"
                                Foreground="{StaticResource WarningBrush}"/>
                        <TextBlock Text="Awaiting verification"
                                Style="{StaticResource TextCaption}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="LOW STOCK ITEMS"
                                Style="{StaticResource TextCaption}"/>
                        <TextBlock x:Name="TbLowStock"
                                FontSize="28" FontWeight="Bold"
                                Foreground="{StaticResource ErrorBrush}"/>
                        <TextBlock Text="Below reorder threshold"
                                Style="{StaticResource TextCaption}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="TODAY'S SALES"
                                Style="{StaticResource TextCaption}"/>
                        <TextBlock x:Name="TbTodaySales"
                                FontSize="24" FontWeight="Bold"
                                Foreground="{StaticResource SuccessBrush}"/>
                        <TextBlock Text="Delivered orders today"
                                Style="{StaticResource TextCaption}"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- Quick Actions -->
            <Border Grid.Row="4" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Quick Actions"
                               Style="{StaticResource TextSubtitle}"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BtnOpenPOS"
                                Click="BtnOpenPOS_Click"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7BF;"
                                        FontFamily="Segoe MDL2 Assets"
                                        Margin="0,0,6,0"
                                        Foreground="White"/>
                                <TextBlock Text="Walk-in Order"
                                        Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnGoInventory"
                                Click="BtnGoInventory_Click"
                                Style="{StaticResource SecondaryButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xEA37;"
                                        FontFamily="Segoe MDL2 Assets"
                                        Margin="0,0,6,0"/>
                                <TextBlock Text="View Inventory"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Bottom Section: Recent Orders | Pending Payments | Low Stock -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Orders -->
                <Border Style="{StaticResource Card}">
                    <DockPanel>
                        <TextBlock Text="Recent Orders"
                                   DockPanel.Dock="Top"
                                   Style="{StaticResource TextSubtitle}"
                                   Margin="0,0,0,8"/>
                        <DataGrid x:Name="DgRecentOrders"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  RowHeight="36"
                                  ColumnHeaderHeight="32"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{StaticResource BorderBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Order #"
                                                    Binding="{Binding OrderNumber}"
                                                    Width="140"/>
                                <DataGridTextColumn Header="Customer"
                                                    Binding="{Binding CustomerName}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="Date"
                                                    Binding="{Binding OrderDate, StringFormat='{}{0:MMM dd}'}"
                                                    Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- Pending Payments -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <DockPanel>
                        <TextBlock Text="Pending Payments"
                                   DockPanel.Dock="Top"
                                   Style="{StaticResource TextSubtitle}"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="TbNoPendingPayments"
                                   DockPanel.Dock="Top"
                                   Text="No payments awaiting verification"
                                   Style="{StaticResource TextCaption}"
                                   Visibility="Collapsed"
                                   Margin="0,0,0,4"/>
                        <DataGrid x:Name="DgPendingPayments"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  RowHeight="36"
                                  ColumnHeaderHeight="32"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{StaticResource BorderBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Order #"
                                                    Binding="{Binding OrderId}"
                                                    Width="65"/>
                                <DataGridTextColumn Header="Method"
                                                    Binding="{Binding PaymentMethod}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="Amount"
                                                    Binding="{Binding Amount, StringFormat='&#x20B1; {0:N2}'}"
                                                    Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- Low Stock -->
                <Border Grid.Column="4" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Low Stock Alert"
                                   Style="{StaticResource TextSubtitle}"
                                   Margin="0,0,0,8"/>
                        <ScrollViewer MaxHeight="380">
                            <StackPanel x:Name="SpLowStock">
                                <TextBlock x:Name="TbNoLowStock"
                                           Text="All variants are adequately stocked"
                                           Style="{StaticResource TextCaption}"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Error -->
            <Border x:Name="BdrError"
                    Grid.Row="7"
                    Background="#2A0E0E"
                    BorderBrush="#5A1A1A"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE814;"
                            FontFamily="Segoe MDL2 Assets"
                            Margin="0,0,8,0"
                            Foreground="{StaticResource ErrorBrush}"/>
                    <TextBlock x:Name="TbDashError"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </Grid>

    </ScrollViewer>

</UserControl>
