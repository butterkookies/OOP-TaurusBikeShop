<UserControl x:Class="AdminSystem.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">

    <!-- ── Entrance animation ─────────────────────────────────────────────── -->
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootPanel"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.32">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="PanelTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="18" To="0" Duration="0:0:0.38">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel x:Name="RootPanel" Margin="28,22,28,28" Opacity="0">
            <StackPanel.RenderTransform>
                <TranslateTransform x:Name="PanelTranslate" Y="18"/>
            </StackPanel.RenderTransform>

            <!-- ── Page Header ──────────────────────────────────────────────── -->
            <Grid Margin="0,0,0,22">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Dashboard"
                               Foreground="#F0F0F0" FontSize="22"
                               FontWeight="Bold" FontFamily="Segoe UI"/>
                    <TextBlock x:Name="TbSubtitle"
                               Foreground="#505050" FontSize="11"
                               FontFamily="Segoe UI" Margin="0,3,0,0"/>
                </StackPanel>
                <Button x:Name="BtnDashRefresh" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Cursor="Hand"
                        Click="BtnDashRefresh_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="RefreshBorder"
                                    Background="#252525" BorderBrush="#353535"
                                    BorderThickness="1" CornerRadius="7"
                                    Padding="11,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="RefreshIcon" Text="&#xE72C;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="11" Foreground="#777777"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <TextBlock Text="Refresh"
                                               FontSize="11" FontFamily="Segoe UI"
                                               Foreground="#777777"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="RefreshBorder" Property="Background" Value="#2E2E2E"/>
                                    <Setter TargetName="RefreshBorder" Property="BorderBrush" Value="#444444"/>
                                    <Setter TargetName="RefreshIcon" Property="Foreground" Value="#AAAAAA"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="RefreshBorder" Property="Opacity" Value="0.75"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- ── Stat Cards ──────────────────────────────────────────────── -->
            <UniformGrid Rows="1" Margin="0,0,0,16">

                <!-- Active Orders — blue accent -->
                <Border Margin="0,0,10,0" Background="#242424" CornerRadius="10"
                        BorderThickness="1" BorderBrush="#2E2E2E">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.35"
                                          BlurRadius="14" ShadowDepth="5" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Border Width="3" HorizontalAlignment="Left"
                                CornerRadius="10,0,0,10" Background="#2563EB"/>
                        <StackPanel Margin="20,16,16,16">
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="ACTIVE ORDERS"
                                           Foreground="#505050" FontSize="9"
                                           FontWeight="Bold" FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                                <Border HorizontalAlignment="Right"
                                        Width="30" Height="30" CornerRadius="7"
                                        Background="#0D1A38">
                                    <TextBlock Text="&#xE7BF;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="13" Foreground="#4B8EF1"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock x:Name="TbActiveOrders" Text="—"
                                       Foreground="#F0F0F0" FontSize="34"
                                       FontWeight="Bold" FontFamily="Segoe UI"/>
                            <TextBlock Text="Processing + Shipped"
                                       Foreground="#454545" FontSize="10"
                                       FontFamily="Segoe UI" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Pending Payments — amber accent -->
                <Border Margin="5,0,5,0" Background="#242424" CornerRadius="10"
                        BorderThickness="1" BorderBrush="#2E2E2E">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.35"
                                          BlurRadius="14" ShadowDepth="5" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Border Width="3" HorizontalAlignment="Left"
                                CornerRadius="10,0,0,10" Background="#D97706"/>
                        <StackPanel Margin="20,16,16,16">
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="PENDING PAYMENTS"
                                           Foreground="#505050" FontSize="9"
                                           FontWeight="Bold" FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                                <Border HorizontalAlignment="Right"
                                        Width="30" Height="30" CornerRadius="7"
                                        Background="#2A1C06">
                                    <TextBlock Text="&#xE8C7;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="13" Foreground="#F59E0B"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock x:Name="TbPendingPayments" Text="—"
                                       Foreground="#FFC107" FontSize="34"
                                       FontWeight="Bold" FontFamily="Segoe UI"/>
                            <TextBlock Text="Awaiting verification"
                                       Foreground="#454545" FontSize="10"
                                       FontFamily="Segoe UI" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Low Stock — red accent -->
                <Border Margin="5,0,5,0" Background="#242424" CornerRadius="10"
                        BorderThickness="1" BorderBrush="#2E2E2E">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.35"
                                          BlurRadius="14" ShadowDepth="5" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Border Width="3" HorizontalAlignment="Left"
                                CornerRadius="10,0,0,10" Background="#DC2626"/>
                        <StackPanel Margin="20,16,16,16">
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="LOW STOCK ITEMS"
                                           Foreground="#505050" FontSize="9"
                                           FontWeight="Bold" FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                                <Border HorizontalAlignment="Right"
                                        Width="30" Height="30" CornerRadius="7"
                                        Background="#2A0A0A">
                                    <TextBlock Text="&#xE71A;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="13" Foreground="#EF4444"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock x:Name="TbLowStock" Text="—"
                                       Foreground="#FF6B6B" FontSize="34"
                                       FontWeight="Bold" FontFamily="Segoe UI"/>
                            <TextBlock Text="Below reorder threshold"
                                       Foreground="#454545" FontSize="10"
                                       FontFamily="Segoe UI" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Today's Sales — green accent -->
                <Border Margin="10,0,0,0" Background="#242424" CornerRadius="10"
                        BorderThickness="1" BorderBrush="#2E2E2E">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.35"
                                          BlurRadius="14" ShadowDepth="5" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Border Width="3" HorizontalAlignment="Left"
                                CornerRadius="10,0,0,10" Background="#16A34A"/>
                        <StackPanel Margin="20,16,16,16">
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="TODAY'S SALES"
                                           Foreground="#505050" FontSize="9"
                                           FontWeight="Bold" FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                                <Border HorizontalAlignment="Right"
                                        Width="30" Height="30" CornerRadius="7"
                                        Background="#061A0E">
                                    <TextBlock Text="&#xE8D6;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="13" Foreground="#22C55E"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock x:Name="TbTodaySales" Text="—"
                                       Foreground="#4ADE80" FontSize="26"
                                       FontWeight="Bold" FontFamily="Segoe UI"/>
                            <TextBlock Text="Delivered orders today"
                                       Foreground="#454545" FontSize="10"
                                       FontFamily="Segoe UI" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- ── Quick Actions Bar ────────────────────────────────────────── -->
            <Border Background="#1E1E1E" CornerRadius="9"
                    BorderThickness="1" BorderBrush="#282828"
                    Padding="16,11" Margin="0,0,0,16">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE712;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="10" Foreground="#444444"
                                   VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Text="QUICK ACTIONS"
                                   Foreground="#444444" FontSize="9"
                                   FontWeight="Bold" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">

                        <!-- Walk-in Order (POS) — primary red -->
                        <Button x:Name="BtnOpenPOS" Margin="0,0,8,0"
                                Cursor="Hand" Click="BtnOpenPOS_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="POSBorder" Background="#CC0000"
                                            CornerRadius="7" Padding="12,6">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE7BF;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="11" Foreground="White"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0"/>
                                            <TextBlock Text="Walk-in Order"
                                                       FontSize="11" FontFamily="Segoe UI"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="POSBorder" Property="Background" Value="#E50000"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="POSBorder" Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- View Inventory — muted outline -->
                        <Button x:Name="BtnGoInventory"
                                Cursor="Hand" Click="BtnGoInventory_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="InvBorder" Background="Transparent"
                                            BorderBrush="#333333" BorderThickness="1"
                                            CornerRadius="7" Padding="12,6">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xEA37;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="11" Foreground="#777777"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0"/>
                                            <TextBlock Text="View Inventory"
                                                       FontSize="11" FontFamily="Segoe UI"
                                                       FontWeight="SemiBold"
                                                       Foreground="#777777"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="InvBorder" Property="Background" Value="#2A2A2A"/>
                                            <Setter TargetName="InvBorder" Property="BorderBrush" Value="#444444"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Bottom: Orders + Low Stock ──────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="380"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="300" MinWidth="260"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Orders card ──────────────────────────────────────── -->
                <Border Grid.Column="0" Background="#242424" CornerRadius="10"
                        BorderThickness="1" BorderBrush="#2E2E2E">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.28"
                                          BlurRadius="12" ShadowDepth="4" Direction="270"/>
                    </Border.Effect>
                    <DockPanel>

                        <!-- Card header -->
                        <Border DockPanel.Dock="Top" Padding="18,13"
                                BorderThickness="0,0,0,1" BorderBrush="#2A2A2A">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8A1;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="12" Foreground="#CC0000"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="Recent Orders"
                                               Foreground="#E8E8E8" FontSize="13"
                                               FontWeight="SemiBold" FontFamily="Segoe UI"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Last 10 active"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Foreground="#444444" FontSize="10"
                                           FontFamily="Segoe UI"/>
                            </Grid>
                        </Border>

                        <!-- DataGrid with status badge column -->
                        <DataGrid x:Name="DgRecentOrders"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Background="#242424"
                                  Foreground="#D0D0D0"
                                  BorderThickness="0"
                                  RowBackground="#242424"
                                  AlternatingRowBackground="#202020"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#272727"
                                  ColumnHeaderHeight="32"
                                  RowHeight="40"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  CanUserResizeRows="False"
                                  CanUserAddRows="False"
                                  EnableRowVirtualization="False"
                                  MaxHeight="380">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"      Value="#1C1C1C"/>
                                    <Setter Property="Foreground"      Value="#4A4A4A"/>
                                    <Setter Property="FontSize"        Value="9"/>
                                    <Setter Property="FontFamily"      Value="Segoe UI"/>
                                    <Setter Property="FontWeight"      Value="Bold"/>
                                    <Setter Property="Padding"         Value="14,0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="BorderBrush"     Value="Transparent"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2C2C2C"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#2A1515"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Foreground"        Value="#C8C8C8"/>
                                    <Setter Property="FontSize"          Value="12"/>
                                    <Setter Property="FontFamily"        Value="Segoe UI"/>
                                    <Setter Property="BorderThickness"   Value="0"/>
                                    <Setter Property="Padding"           Value="14,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background"  Value="Transparent"/>
                                            <Setter Property="Foreground"  Value="#F0F0F0"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ORDER #"
                                    Binding="{Binding OrderNumber}"
                                    Width="150"/>
                                <DataGridTextColumn Header="CUSTOMER"
                                    Binding="{Binding CustomerName}"
                                    Width="*"/>
                                <DataGridTextColumn Header="DATE"
                                    Binding="{Binding OrderDate, StringFormat='{}{0:MMM dd}'}"
                                    Width="70"/>
                                <!-- Status badge column
                                     IMPORTANT: BadgeText has NO Text binding.
                                     Every DataTrigger sets Text explicitly to
                                     avoid the Binding/Setter conflict that breaks
                                     badge styling when rows are recycled. -->
                                <DataGridTemplateColumn Header="STATUS" Width="155">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border x:Name="BadgeBorder"
                                                    CornerRadius="4" Padding="8,4"
                                                    HorizontalAlignment="Left"
                                                    Margin="10,0" Background="#2A2A2A">
                                                <TextBlock x:Name="BadgeText"
                                                           Text="—"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           FontFamily="Segoe UI"
                                                           Foreground="#666666"/>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding OrderStatus}" Value="Pending">
                                                    <Setter TargetName="BadgeBorder" Property="Background" Value="#161E2E"/>
                                                    <Setter TargetName="BadgeText"   Property="Foreground" Value="#5B8FCA"/>
                                                    <Setter TargetName="BadgeText"   Property="Text"       Value="Pending"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding OrderStatus}" Value="PendingVerification">
                                                    <Setter TargetName="BadgeBorder" Property="Background" Value="#261C08"/>
                                                    <Setter TargetName="BadgeText"   Property="Foreground" Value="#F59E0B"/>
                                                    <Setter TargetName="BadgeText"   Property="Text"       Value="Pending Verification"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding OrderStatus}" Value="OnHold">
                                                    <Setter TargetName="BadgeBorder" Property="Background" Value="#1E1828"/>
                                                    <Setter TargetName="BadgeText"   Property="Foreground" Value="#A78BFA"/>
                                                    <Setter TargetName="BadgeText"   Property="Text"       Value="On Hold"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding OrderStatus}" Value="Processing">
                                                    <Setter TargetName="BadgeBorder" Property="Background" Value="#0F2018"/>
                                                    <Setter TargetName="BadgeText"   Property="Foreground" Value="#34D399"/>
                                                    <Setter TargetName="BadgeText"   Property="Text"       Value="Processing"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding OrderStatus}" Value="ReadyForPickup">
                                                    <Setter TargetName="BadgeBorder" Property="Background" Value="#0A1A26"/>
                                                    <Setter TargetName="BadgeText"   Property="Foreground" Value="#38BDF8"/>
                                                    <Setter TargetName="BadgeText"   Property="Text"       Value="Ready for Pickup"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding OrderStatus}" Value="PickedUp">
                                                    <Setter TargetName="BadgeBorder" Property="Background" Value="#0A2010"/>
                                                    <Setter TargetName="BadgeText"   Property="Foreground" Value="#4ADE80"/>
                                                    <Setter TargetName="BadgeText"   Property="Text"       Value="Picked Up"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding OrderStatus}" Value="Shipped">
                                                    <Setter TargetName="BadgeBorder" Property="Background" Value="#161630"/>
                                                    <Setter TargetName="BadgeText"   Property="Foreground" Value="#818CF8"/>
                                                    <Setter TargetName="BadgeText"   Property="Text"       Value="Shipped"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding OrderStatus}" Value="Delivered">
                                                    <Setter TargetName="BadgeBorder" Property="Background" Value="#0A1E0E"/>
                                                    <Setter TargetName="BadgeText"   Property="Foreground" Value="#22C55E"/>
                                                    <Setter TargetName="BadgeText"   Property="Text"       Value="Delivered"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding OrderStatus}" Value="Cancelled">
                                                    <Setter TargetName="BadgeBorder" Property="Background" Value="#2A0A0A"/>
                                                    <Setter TargetName="BadgeText"   Property="Foreground" Value="#EF4444"/>
                                                    <Setter TargetName="BadgeText"   Property="Text"       Value="Cancelled"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- Low Stock Alert panel ───────────────────────────────────── -->
                <Border Grid.Column="2" Background="#242424" CornerRadius="10"
                        BorderThickness="1" BorderBrush="#2E2E2E"
                        VerticalAlignment="Top">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.28"
                                          BlurRadius="12" ShadowDepth="4" Direction="270"/>
                    </Border.Effect>
                    <DockPanel>

                        <!-- Card header -->
                        <Border DockPanel.Dock="Top" Padding="16,13"
                                BorderThickness="0,0,0,1" BorderBrush="#2A2A2A">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE71A;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="12" Foreground="#DC2626"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="Low Stock Alert"
                                               Foreground="#E8E8E8" FontSize="13"
                                               FontWeight="SemiBold" FontFamily="Segoe UI"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Background="#2A0A0A" CornerRadius="10"
                                        Padding="8,3">
                                    <TextBlock x:Name="TbLowStockBadge" Text="0"
                                               Foreground="#EF4444" FontSize="10"
                                               FontWeight="Bold" FontFamily="Segoe UI"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Low stock items — built from code-behind -->
                        <ScrollViewer DockPanel.Dock="Bottom"
                                      VerticalScrollBarVisibility="Auto"
                                      MaxHeight="380">
                            <StackPanel x:Name="SpLowStock">
                                <TextBlock x:Name="TbNoLowStock"
                                           Text="All variants are adequately stocked"
                                           Foreground="#454545" FontSize="11"
                                           FontFamily="Segoe UI" FontStyle="Italic"
                                           Margin="16,14" Visibility="Collapsed"/>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- ── Error Banner ─────────────────────────────────────────────── -->
            <Border x:Name="BdrError" Background="#230D0D" CornerRadius="8"
                    BorderThickness="1" BorderBrush="#4A1515"
                    Padding="14,10" Margin="0,14,0,0"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE814;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13" Foreground="#EF4444"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="TbDashError"
                               Foreground="#FCA5A5" FontSize="12"
                               FontFamily="Segoe UI" TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
