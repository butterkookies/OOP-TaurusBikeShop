<UserControl x:Class="AdminSystem.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT: product list ════════════════════════════════════════ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header row -->
            <Grid Grid.Row="0" Margin="0,0,0,14">
                <TextBlock Text="Products" Foreground="#F0F0F0"
                           FontSize="22" FontWeight="Bold"
                           FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
                <Button x:Name="BtnNewProduct" Content="+ New Product"
                        Height="34" Padding="14,0"
                        Background="#CC0000" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        FontFamily="Segoe UI" FontSize="12"
                        HorizontalAlignment="Right"/>
            </Grid>

            <!-- Search box -->
            <TextBox Grid.Row="1" x:Name="TbProductSearch"
                     Height="38" Padding="12,0"
                     Background="#2E2E2E" Foreground="#F0F0F0"
                     BorderBrush="#3A3A3A" BorderThickness="1"
                     FontSize="13" FontFamily="Segoe UI"
                     VerticalContentAlignment="Center"
                     Margin="0,0,0,14"/>

            <!-- Products DataGrid -->
            <Border Grid.Row="2" Background="#242424" CornerRadius="10"
                    BorderThickness="1" BorderBrush="#3A3A3A">
                <DataGrid x:Name="DgProducts"
                          AutoGenerateColumns="False"
                          Background="#242424" Foreground="#F0F0F0"
                          BorderThickness="0" RowHeight="42"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#3A3A3A"
                          CanUserAddRows="False" IsReadOnly="True"
                          SelectionMode="Single" SelectionUnit="FullRow">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"      Value="#1A1A1A"/>
                            <Setter Property="Foreground"      Value="#606060"/>
                            <Setter Property="FontSize"        Value="11"/>
                            <Setter Property="FontWeight"      Value="SemiBold"/>
                            <Setter Property="Padding"         Value="12,10"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#242424"/>
                            <Setter Property="Foreground" Value="#F0F0F0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2C2C2C"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#3A1A1A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding"         Value="12,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontFamily"      Value="Segoe UI"/>
                            <Setter Property="FontSize"        Value="12"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background"  Value="Transparent"/>
                                    <Setter Property="Foreground"  Value="#F0F0F0"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name"
                            Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Category"
                            Binding="{Binding CategoryName}" Width="120"/>
                        <DataGridTextColumn Header="Brand"
                            Binding="{Binding BrandName}" Width="100"/>
                        <DataGridTextColumn Header="Price"
                            Binding="{Binding Price, StringFormat='₱ {0:N2}'}"
                            Width="100"/>
                        <DataGridCheckBoxColumn Header="Active"
                            Binding="{Binding IsActive}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- ═══ RIGHT: Edit form ══════════════════════════════════════════ -->
        <Border Grid.Column="2" Background="#242424" CornerRadius="10"
                Padding="20" BorderThickness="1" BorderBrush="#3A3A3A">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Product Details" Foreground="#F0F0F0"
                               FontSize="14" FontWeight="SemiBold"
                               FontFamily="Segoe UI" Margin="0,0,0,18"/>

                    <TextBlock Text="NAME" Foreground="#606060" FontSize="10"
                               FontWeight="SemiBold" FontFamily="Segoe UI"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="TbProductName"
                             Height="36" Padding="10,0"
                             Background="#2E2E2E" Foreground="#F0F0F0"
                             BorderBrush="#3A3A3A" BorderThickness="1"
                             FontFamily="Segoe UI" FontSize="12"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="PRICE (₱)" Foreground="#606060" FontSize="10"
                               FontWeight="SemiBold" FontFamily="Segoe UI"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="TbProductPrice"
                             Height="36" Padding="10,0"
                             Background="#2E2E2E" Foreground="#F0F0F0"
                             BorderBrush="#3A3A3A" BorderThickness="1"
                             FontFamily="Segoe UI" FontSize="12"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="CATEGORY" Foreground="#606060" FontSize="10"
                               FontWeight="SemiBold" FontFamily="Segoe UI"
                               Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbCategory"
                              Height="36" Padding="10,0"
                              Background="#2E2E2E" Foreground="#F0F0F0"
                              BorderBrush="#3A3A3A" BorderThickness="1"
                              FontFamily="Segoe UI" FontSize="12"
                              Margin="0,0,0,12"
                              DisplayMemberPath="Name"
                              SelectedValuePath="CategoryId"/>

                    <TextBlock Text="BRAND" Foreground="#606060" FontSize="10"
                               FontWeight="SemiBold" FontFamily="Segoe UI"
                               Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbBrand"
                              Height="36" Padding="10,0"
                              Background="#2E2E2E" Foreground="#F0F0F0"
                              BorderBrush="#3A3A3A" BorderThickness="1"
                              FontFamily="Segoe UI" FontSize="12"
                              Margin="0,0,0,12"
                              DisplayMemberPath="BrandName"
                              SelectedValuePath="BrandId"/>

                    <TextBlock Text="DESCRIPTION" Foreground="#606060" FontSize="10"
                               FontWeight="SemiBold" FontFamily="Segoe UI"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="TbProductDesc"
                             Height="80" Padding="10,8"
                             Background="#2E2E2E" Foreground="#F0F0F0"
                             BorderBrush="#3A3A3A" BorderThickness="1"
                             FontFamily="Segoe UI" FontSize="12"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,12"/>

                    <CheckBox x:Name="ChkActive" Content="Active"
                              Foreground="#F0F0F0" FontFamily="Segoe UI"
                              FontSize="12" Margin="0,0,0,6"/>
                    <CheckBox x:Name="ChkFeatured" Content="Featured"
                              Foreground="#F0F0F0" FontFamily="Segoe UI"
                              FontSize="12" Margin="0,0,0,16"/>

                    <TextBlock x:Name="TbProductFormError"
                               Foreground="#CC0000" FontFamily="Segoe UI"
                               FontSize="11" TextWrapping="Wrap"
                               Visibility="Collapsed" Margin="0,0,0,8"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="BtnSaveProduct"
                                Content="Save" Height="38"
                                Background="#CC0000" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                FontFamily="Segoe UI" FontSize="13"
                                FontWeight="SemiBold"/>
                        <Button Grid.Column="2" x:Name="BtnDeactivateProduct"
                                Content="Deactivate" Height="38"
                                Background="#3A3A3A" Foreground="#A0A0A0"
                                BorderThickness="0" Cursor="Hand"
                                FontFamily="Segoe UI" FontSize="12"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
