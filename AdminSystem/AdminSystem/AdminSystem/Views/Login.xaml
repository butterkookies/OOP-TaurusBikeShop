<Window x:Class="AdminSystem.Views.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Taurus Bike Shop — Admin Login"
        Height="520" Width="420"
        MinHeight="480" MinWidth="360"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MinWidth="340" MinHeight="440">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="340" Background="#242424" CornerRadius="12"
                    Padding="36,32" BorderThickness="1" BorderBrush="#3A3A3A">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="50"
                                      Opacity="0.55" ShadowDepth="0"/>
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,0,0,28">
                        <Border Width="42" Height="42" Background="#CC0000"
                                CornerRadius="10" Margin="0,0,12,0">
                            <TextBlock Text="&#x1F402;" FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="TAURUS" Foreground="#F0F0F0"
                                       FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"/>
                            <TextBlock Text="BIKE SHOP ADMIN" Foreground="#606060"
                                       FontSize="10" FontFamily="Segoe UI" Margin="1,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="EMAIL" Foreground="#606060" FontSize="10"
                               FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                    <TextBox x:Name="TbUsername" Height="40" Padding="12,0"
                             Background="#2E2E2E" Foreground="#F0F0F0"
                             BorderBrush="#3A3A3A" BorderThickness="1"
                             FontSize="13" FontFamily="Segoe UI"
                             VerticalContentAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TbUsernameError" Foreground="#CC0000"
                               FontSize="11" FontFamily="Segoe UI"
                               Visibility="Collapsed" Margin="0,0,0,10"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="PASSWORD" Foreground="#606060" FontSize="10"
                               FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,4">
                        <PasswordBox x:Name="PbPassword" Height="40" Padding="12,0"
                                     Background="#2E2E2E" Foreground="#F0F0F0"
                                     BorderBrush="#3A3A3A" BorderThickness="1"
                                     FontSize="13" FontFamily="Segoe UI"
                                     VerticalContentAlignment="Center"/>
                        <TextBox x:Name="TbPasswordVisible" Height="40" Padding="12,0"
                                 Background="#2E2E2E" Foreground="#F0F0F0"
                                 BorderBrush="#3A3A3A" BorderThickness="1"
                                 FontSize="13" FontFamily="Segoe UI"
                                 VerticalContentAlignment="Center"
                                 Visibility="Collapsed"/>
                        <Button x:Name="BtnTogglePassword"
                                Background="Transparent" BorderThickness="0"
                                Width="38" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Focusable="False"
                                Cursor="Hand">
                            <TextBlock x:Name="TbEyeIcon" Text="&#x1F441;"
                                       FontSize="13" Foreground="#606060"/>
                        </Button>
                    </Grid>
                    <TextBlock x:Name="TbPasswordError" Foreground="#CC0000"
                               FontSize="11" FontFamily="Segoe UI"
                               Visibility="Collapsed" Margin="0,0,0,4"
                               TextWrapping="Wrap"/>
                    <Grid Margin="0,6,0,22">
                        <Button x:Name="BtnForgotPassword"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#606060" FontSize="11"
                                FontFamily="Segoe UI" Cursor="Hand"
                                Content="Forgot password?"
                                HorizontalAlignment="Right"/>
                    </Grid>
                    <Button x:Name="BtnLogin"
                            Background="#CC0000" Foreground="White"
                            BorderThickness="0" Height="44"
                            FontSize="13" FontWeight="SemiBold"
                            FontFamily="Segoe UI" Cursor="Hand"
                            Content="Sign In" HorizontalAlignment="Stretch"/>
                    <TextBlock x:Name="TbConnectionError" Foreground="#CC0000"
                               FontSize="11" FontFamily="Segoe UI"
                               Visibility="Collapsed" HorizontalAlignment="Center"
                               Margin="0,12,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            <TextBlock Text="Taurus Bike Shop  &#x2022;  Admin System"
                       Foreground="#333333" FontSize="11" FontFamily="Segoe UI"
                       HorizontalAlignment="Center" VerticalAlignment="Bottom"
                       Margin="0,0,0,14"/>
        </Grid>
    </ScrollViewer>
</Window>
