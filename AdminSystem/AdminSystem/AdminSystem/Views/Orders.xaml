<UserControl x:Class="AdminSystem.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- LEFT COLUMN — filter toolbar + grid                               -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <DockPanel Grid.Column="0">

            <!-- ── Top Toolbar ──────────────────────────────────────────────── -->
            <Border DockPanel.Dock="Top" Background="#242424"
                    BorderThickness="0,0,0,1" BorderBrush="#2E2E2E"
                    Padding="20,12">
                <WrapPanel Orientation="Horizontal">

                    <Button x:Name="BtnFilterAll"
                            Content="All Orders"
                            Tag=""
                            Click="FilterBtn_Click"
                            Background="#CC0000" Foreground="White"
                            BorderThickness="0" Padding="12,6"
                            FontSize="12" FontFamily="Segoe UI"
                            Cursor="Hand" Margin="0,0,6,0"/>

                    <Button x:Name="BtnFilterPending"
                            Content="Pending"
                            Tag="Pending"
                            Click="FilterBtn_Click"
                            Background="#2E2E2E" Foreground="#F0F0F0"
                            BorderThickness="0" Padding="12,6"
                            FontSize="12" FontFamily="Segoe UI"
                            Cursor="Hand" Margin="0,0,6,0"/>

                    <Button x:Name="BtnFilterProcessing"
                            Content="Processing"
                            Tag="Processing"
                            Click="FilterBtn_Click"
                            Background="#2E2E2E" Foreground="#F0F0F0"
                            BorderThickness="0" Padding="12,6"
                            FontSize="12" FontFamily="Segoe UI"
                            Cursor="Hand" Margin="0,0,6,0"/>

                    <Button x:Name="BtnFilterDelivered"
                            Content="Delivered"
                            Tag="Delivered"
                            Click="FilterBtn_Click"
                            Background="#2E2E2E" Foreground="#F0F0F0"
                            BorderThickness="0" Padding="12,6"
                            FontSize="12" FontFamily="Segoe UI"
                            Cursor="Hand" Margin="0,0,6,0"/>

                    <Button x:Name="BtnFilterCancelled"
                            Content="Cancelled"
                            Tag="Cancelled"
                            Click="FilterBtn_Click"
                            Background="#2E2E2E" Foreground="#F0F0F0"
                            BorderThickness="0" Padding="12,6"
                            FontSize="12" FontFamily="Segoe UI"
                            Cursor="Hand" Margin="0,0,12,0"/>

                    <Button x:Name="BtnOrdersRefresh"
                            Content="↻ Refresh"
                            Click="BtnOrdersRefresh_Click"
                            Background="Transparent" Foreground="#888888"
                            BorderBrush="#3A3A3A" BorderThickness="1"
                            Padding="10,5" FontSize="11"
                            FontFamily="Segoe UI" Cursor="Hand"/>
                </WrapPanel>
            </Border>

            <!-- ── Error bar ─────────────────────────────────────────────────── -->
            <Border x:Name="ErrorBar" DockPanel.Dock="Top"
                    Background="#3B1212" Padding="16,8"
                    Visibility="Collapsed">
                <TextBlock x:Name="TbOrderError"
                           Foreground="#CC0000" FontSize="12"
                           FontFamily="Segoe UI" TextWrapping="Wrap"/>
            </Border>

            <!-- ── Orders DataGrid ───────────────────────────────────────────── -->
            <DataGrid x:Name="DgOrders"
                      Margin="20,16,20,20"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Background="#1A1A1A"
                      Foreground="#F0F0F0"
                      BorderThickness="1"
                      BorderBrush="#2E2E2E"
                      RowBackground="#242424"
                      AlternatingRowBackground="#1E1E1E"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#2E2E2E"
                      ColumnHeaderHeight="36"
                      RowHeight="36"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      CanUserResizeRows="False"
                      CanUserAddRows="False"
                      SelectionChanged="DgOrders_SelectionChanged">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"      Value="#1E1E1E"/>
                        <Setter Property="Foreground"      Value="#888888"/>
                        <Setter Property="FontSize"        Value="11"/>
                        <Setter Property="FontFamily"      Value="Segoe UI"/>
                        <Setter Property="FontWeight"      Value="SemiBold"/>
                        <Setter Property="Padding"         Value="12,0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground"        Value="#F0F0F0"/>
                        <Setter Property="FontSize"          Value="12"/>
                        <Setter Property="FontFamily"        Value="Segoe UI"/>
                        <Setter Property="BorderThickness"   Value="0"/>
                        <Setter Property="Padding"           Value="12,0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#CC0000"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Order #"
                        Binding="{Binding OrderNumber}"
                        Width="150"/>
                    <DataGridTextColumn Header="Customer"
                        Binding="{Binding CustomerName}"
                        Width="*"/>
                    <DataGridTextColumn Header="Date"
                        Binding="{Binding OrderDate, StringFormat='{}{0:MMM dd, yyyy}'}"
                        Width="120"/>
                    <DataGridTextColumn Header="Delivery"
                        Binding="{Binding DeliveryMethod}"
                        Width="110"/>
                    <DataGridTextColumn Header="Status"
                        Binding="{Binding OrderStatus}"
                        Width="140"/>
                </DataGrid.Columns>
            </DataGrid>

        </DockPanel>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- RIGHT COLUMN — order action panel                                 -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="1"
                Background="#1E1E1E"
                BorderThickness="1,0,0,0"
                BorderBrush="#2E2E2E">
            <StackPanel Margin="16">

                <!-- Header -->
                <TextBlock Text="Order Actions"
                           Foreground="#F0F0F0"
                           FontSize="14" FontWeight="SemiBold"
                           FontFamily="Segoe UI"
                           Margin="0,0,0,16"/>

                <!-- No-selection hint -->
                <TextBlock x:Name="TbNoSelection"
                           Text="Select an order to manage it."
                           Foreground="#666666"
                           FontSize="12" FontFamily="Segoe UI"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16"/>

                <!-- Detail panel (hidden until an order is selected) -->
                <StackPanel x:Name="PanelOrderDetail" Visibility="Collapsed">

                    <!-- Order # -->
                    <TextBlock x:Name="TbDetailOrderNum"
                               Foreground="#F0F0F0"
                               FontSize="14" FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,4"/>

                    <!-- Customer -->
                    <TextBlock x:Name="TbDetailCustomer"
                               Foreground="#888888"
                               FontSize="12" FontFamily="Segoe UI"
                               Margin="0,0,0,2"/>

                    <!-- Current status badge -->
                    <Border x:Name="BadgeStatus"
                            Background="#2E2E2E" CornerRadius="4"
                            Padding="8,3" HorizontalAlignment="Left"
                            Margin="0,4,0,16">
                        <TextBlock x:Name="TbDetailStatus"
                                   Foreground="#F0F0F0"
                                   FontSize="11" FontFamily="Segoe UI"/>
                    </Border>

                    <!-- Divider -->
                    <Border Height="1" Background="#2E2E2E" Margin="0,0,0,16"/>

                    <!-- ── Approve (→ Processing) ──────────────────────────── -->
                    <Button x:Name="BtnApproveOrder"
                            Content="✔  Approve → Processing"
                            Click="BtnApproveOrder_Click"
                            Background="#CC0000" Foreground="White"
                            BorderThickness="0" Padding="10,8"
                            FontSize="12" FontFamily="Segoe UI"
                            Cursor="Hand"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,8"/>

                    <!-- ── Cancel order ───────────────────────────────────── -->
                    <Button x:Name="BtnCancelOrder"
                            Content="✖  Cancel Order"
                            Click="BtnCancelOrder_Click"
                            Background="#3A1A1A" Foreground="#FF6666"
                            BorderBrush="#CC0000" BorderThickness="1"
                            Padding="10,8"
                            FontSize="12" FontFamily="Segoe UI"
                            Cursor="Hand"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,16"/>

                    <!-- Divider -->
                    <Border Height="1" Background="#2E2E2E" Margin="0,0,0,12"/>

                    <!-- ── Update Status ──────────────────────────────────── -->
                    <TextBlock Text="Set Status"
                               Foreground="#888888"
                               FontSize="11" FontFamily="Segoe UI"
                               Margin="0,0,0,6"/>

                    <ComboBox x:Name="CbOrderStatus"
                              SelectionChanged="CbOrderStatus_SelectionChanged"
                              Background="#2E2E2E" Foreground="#F0F0F0"
                              BorderBrush="#3A3A3A" BorderThickness="1"
                              FontSize="12" FontFamily="Segoe UI"
                              HorizontalAlignment="Stretch"
                              Margin="0,0,0,8">
                        <ComboBoxItem Content="Pending"             Tag="Pending"/>
                        <ComboBoxItem Content="Processing"          Tag="Processing"/>
                        <ComboBoxItem Content="On Hold"             Tag="OnHold"/>
                        <ComboBoxItem Content="Ready for Pickup"    Tag="ReadyForPickup"/>
                        <ComboBoxItem Content="Picked Up"           Tag="PickedUp"/>
                        <ComboBoxItem Content="Shipped"             Tag="Shipped"/>
                        <ComboBoxItem Content="Delivered"           Tag="Delivered"/>
                        <ComboBoxItem Content="Cancelled"           Tag="Cancelled"/>
                    </ComboBox>

                    <Button x:Name="BtnUpdateStatus"
                            Content="Apply Status"
                            Click="BtnUpdateStatus_Click"
                            Background="#242424" Foreground="#F0F0F0"
                            BorderBrush="#3A3A3A" BorderThickness="1"
                            Padding="10,7"
                            FontSize="12" FontFamily="Segoe UI"
                            Cursor="Hand"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,16"
                            IsEnabled="False"/>

                    <!-- Feedback -->
                    <TextBlock x:Name="TbOrderActionSuccess"
                               Foreground="#00CC66"
                               FontSize="11" FontFamily="Segoe UI"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Margin="0,0,0,4"/>

                    <TextBlock x:Name="TbOrderActionError"
                               Foreground="#CC0000"
                               FontSize="11" FontFamily="Segoe UI"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"/>

                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
