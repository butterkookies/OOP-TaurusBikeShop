<!--
    ╔══════════════════════════════════════════════════════════════════╗
    ║  AdminDashboardWindow.xaml                                       ║
    ║  Taurus Bike Shop — Admin POS System                            ║
    ║                                                                  ║
    ║  CHANGES:                                                        ║
    ║  • Responsive layout — scales down gracefully on resize          ║
    ║  • Exit button added to sidebar                                  ║
    ║  • Window Closing event wired for X-button confirmation          ║
    ║  • MinWidth/MinHeight enforced on columns and cards              ║
    ║  • WindowStyle changed to ThreeDBorderWindow (shows min/max/X)  ║
    ║  • WindowState set to Maximized (fills user screen on login)     ║
    ║  • Removed fixed Height/Width (conflict with Maximized state)    ║
    ╚══════════════════════════════════════════════════════════════════╝
-->
<Window x:Class="AdminSystem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Taurus Bike Shop — Admin POS System"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#1A1A1A"
        WindowStyle="ThreeDBorderWindow"
        Closing="Window_Closing">

	<!-- ══════════════════════════════════════════════
         RESOURCE DICTIONARY — all shared styles
         ══════════════════════════════════════════════ -->
	<Window.Resources>

		<!-- ── Colour palette ── -->
		<SolidColorBrush x:Key="BackgroundPrimary"   Color="#1A1A1A"/>
		<SolidColorBrush x:Key="BackgroundSecondary" Color="#242424"/>
		<SolidColorBrush x:Key="BackgroundPanel"     Color="#2C2C2C"/>
		<SolidColorBrush x:Key="BackgroundCard"      Color="#333333"/>
		<SolidColorBrush x:Key="AccentRed"           Color="#CC0000"/>
		<SolidColorBrush x:Key="AccentRedHover"      Color="#E50000"/>
		<SolidColorBrush x:Key="AccentRedDark"       Color="#990000"/>
		<SolidColorBrush x:Key="TextPrimary"         Color="#F0F0F0"/>
		<SolidColorBrush x:Key="TextSecondary"       Color="#A0A0A0"/>
		<SolidColorBrush x:Key="TextMuted"           Color="#666666"/>
		<SolidColorBrush x:Key="BorderSubtle"        Color="#3A3A3A"/>
		<SolidColorBrush x:Key="StatusGreen"         Color="#4CAF50"/>
		<SolidColorBrush x:Key="StatusYellow"        Color="#FFC107"/>
		<SolidColorBrush x:Key="StatusBlue"          Color="#2196F3"/>
		<SolidColorBrush x:Key="StatusPurple"        Color="#9C27B0"/>

		<!-- ── Converter ── -->
		<BooleanToVisibilityConverter x:Key="BoolToVis"/>

		<!-- ── NAV BUTTON ── -->
		<Style x:Key="NavButtonStyle" TargetType="Button">
			<Setter Property="Background"             Value="Transparent"/>
			<Setter Property="Foreground"             Value="{StaticResource TextSecondary}"/>
			<Setter Property="BorderThickness"        Value="0"/>
			<Setter Property="Height"                 Value="48"/>
			<Setter Property="HorizontalContentAlignment" Value="Left"/>
			<Setter Property="Padding"                Value="16,0,12,0"/>
			<Setter Property="FontSize"               Value="12"/>
			<Setter Property="FontFamily"             Value="Segoe UI"/>
			<Setter Property="Cursor"                 Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="NavBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
							<ContentPresenter VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="NavBorder" Property="Background"  Value="#2C2C2C"/>
								<Setter TargetName="NavBorder" Property="BorderBrush" Value="{StaticResource AccentRed}"/>
								<Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ── NAV BUTTON ACTIVE ── -->
		<Style x:Key="NavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
			<Setter Property="Background" Value="#2C2C2C"/>
			<Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="#2C2C2C"
                                BorderThickness="3,0,0,0"
                                BorderBrush="{StaticResource AccentRed}"
                                Padding="{TemplateBinding Padding}">
							<ContentPresenter VerticalAlignment="Center"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ── PRIMARY BUTTON (Red) ── -->
		<Style x:Key="PrimaryButtonStyle" TargetType="Button">
			<Setter Property="Background"      Value="{StaticResource AccentRed}"/>
			<Setter Property="Foreground"      Value="White"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Height"          Value="36"/>
			<Setter Property="Padding"         Value="18,0"/>
			<Setter Property="FontSize"        Value="13"/>
			<Setter Property="FontWeight"      Value="SemiBold"/>
			<Setter Property="FontFamily"      Value="Segoe UI"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="BtnBorder" Property="Background"
                                        Value="{StaticResource AccentRedHover}"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="BtnBorder" Property="Background"
                                        Value="{StaticResource AccentRedDark}"/>
							</Trigger>
							<Trigger Property="IsEnabled" Value="False">
								<Setter TargetName="BtnBorder" Property="Opacity" Value="0.45"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ── GHOST BUTTON (outlined) ── -->
		<Style x:Key="GhostButtonStyle" TargetType="Button">
			<Setter Property="Background"      Value="Transparent"/>
			<Setter Property="Foreground"      Value="{StaticResource TextSecondary}"/>
			<Setter Property="BorderBrush"     Value="{StaticResource BorderSubtle}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Height"          Value="36"/>
			<Setter Property="Padding"         Value="16,0"/>
			<Setter Property="FontSize"        Value="13"/>
			<Setter Property="FontFamily"      Value="Segoe UI"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="GhostBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="GhostBorder"
                                        Property="BorderBrush" Value="{StaticResource AccentRed}"/>
								<Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ── GREEN (approve) small button ── -->
		<Style x:Key="ApproveButtonStyle" TargetType="Button">
			<Setter Property="Background"      Value="Transparent"/>
			<Setter Property="Foreground"      Value="{StaticResource StatusGreen}"/>
			<Setter Property="BorderBrush"     Value="{StaticResource StatusGreen}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Height"          Value="26"/>
			<Setter Property="Padding"         Value="8,0"/>
			<Setter Property="FontSize"        Value="11"/>
			<Setter Property="FontFamily"      Value="Segoe UI"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Margin"          Value="2,0"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="#1A3020"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ── DANGER small button ── -->
		<Style x:Key="DangerButtonStyle" TargetType="Button">
			<Setter Property="Background"      Value="Transparent"/>
			<Setter Property="Foreground"      Value="{StaticResource AccentRed}"/>
			<Setter Property="BorderBrush"     Value="{StaticResource AccentRed}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Height"          Value="26"/>
			<Setter Property="Padding"         Value="8,0"/>
			<Setter Property="FontSize"        Value="11"/>
			<Setter Property="FontFamily"      Value="Segoe UI"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Margin"          Value="2,0"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="#2C1A1A"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ── TABLE ACTION (neutral ghost small) ── -->
		<Style x:Key="TableActionStyle" TargetType="Button">
			<Setter Property="Background"      Value="Transparent"/>
			<Setter Property="Foreground"      Value="{StaticResource TextSecondary}"/>
			<Setter Property="BorderBrush"     Value="{StaticResource BorderSubtle}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Height"          Value="26"/>
			<Setter Property="Padding"         Value="8,0"/>
			<Setter Property="FontSize"        Value="11"/>
			<Setter Property="FontFamily"      Value="Segoe UI"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Margin"          Value="2,0"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="#333333"/>
								<Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ── SEARCH / TEXT BOX ── -->
		<Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
			<Setter Property="Background"      Value="#2C2C2C"/>
			<Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
			<Setter Property="BorderBrush"     Value="{StaticResource BorderSubtle}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Height"          Value="36"/>
			<Setter Property="Padding"         Value="10,0"/>
			<Setter Property="FontSize"        Value="13"/>
			<Setter Property="FontFamily"      Value="Segoe UI"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="CaretBrush"      Value="{StaticResource AccentRed}"/>
			<Style.Triggers>
				<Trigger Property="IsFocused" Value="True">
					<Setter Property="BorderBrush" Value="{StaticResource AccentRed}"/>
				</Trigger>
			</Style.Triggers>
		</Style>

		<!-- ── COMBO BOX ── -->
		<Style x:Key="ComboStyle" TargetType="ComboBox">
			<Setter Property="Background"  Value="#2C2C2C"/>
			<Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
			<Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
			<Setter Property="Height"      Value="36"/>
			<Setter Property="Padding"     Value="8,0"/>
			<Setter Property="FontFamily"  Value="Segoe UI"/>
			<Setter Property="FontSize"    Value="13"/>
		</Style>

		<!-- ── DATA GRID (dark) ── -->
		<Style x:Key="AdminDataGridStyle" TargetType="DataGrid">
			<Setter Property="Background"               Value="#242424"/>
			<Setter Property="Foreground"               Value="{StaticResource TextPrimary}"/>
			<Setter Property="BorderThickness"          Value="0"/>
			<Setter Property="GridLinesVisibility"      Value="Horizontal"/>
			<Setter Property="HorizontalGridLinesBrush" Value="#2E2E2E"/>
			<Setter Property="RowBackground"            Value="#242424"/>
			<Setter Property="AlternatingRowBackground" Value="#272727"/>
			<Setter Property="ColumnHeaderHeight"       Value="40"/>
			<Setter Property="RowHeight"                Value="40"/>
			<Setter Property="SelectionMode"            Value="Extended"/>
			<Setter Property="SelectionUnit"            Value="FullRow"/>
			<Setter Property="AutoGenerateColumns"      Value="False"/>
			<Setter Property="CanUserAddRows"           Value="False"/>
			<Setter Property="IsReadOnly"               Value="True"/>
			<Setter Property="FontFamily"               Value="Segoe UI"/>
			<Setter Property="FontSize"                 Value="13"/>
		</Style>

		<!-- ── STAT CARD ── -->
		<Style x:Key="StatCardStyle" TargetType="Border">
			<Setter Property="Background"      Value="{StaticResource BackgroundCard}"/>
			<Setter Property="CornerRadius"    Value="6"/>
			<Setter Property="Padding"         Value="16,14"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush"     Value="{StaticResource BorderSubtle}"/>
			<Setter Property="MinWidth"        Value="160"/>
		</Style>

		<!-- ── PAGE CARD (module section card) ── -->
		<Style x:Key="PageCard" TargetType="Border">
			<Setter Property="Background"      Value="{StaticResource BackgroundSecondary}"/>
			<Setter Property="CornerRadius"    Value="6"/>
			<Setter Property="Padding"         Value="20"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush"     Value="{StaticResource BorderSubtle}"/>
			<Setter Property="Margin"          Value="0,0,0,16"/>
		</Style>

		<!-- ── SECTION HEADER TEXT ── -->
		<Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
			<Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
			<Setter Property="FontSize"   Value="15"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="FontFamily" Value="Segoe UI"/>
			<Setter Property="Margin"     Value="0,0,0,12"/>
		</Style>

		<!-- ── SIDEBAR SEPARATOR ── -->
		<Style x:Key="SidebarSeparatorStyle" TargetType="Separator">
			<Setter Property="Background" Value="{StaticResource BorderSubtle}"/>
			<Setter Property="Height"     Value="1"/>
			<Setter Property="Margin"     Value="16,8"/>
		</Style>

		<!-- ── TOGGLE SWITCH ── -->
		<Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="CheckBox">
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<Border x:Name="Track" Width="40" Height="22"
                                    CornerRadius="11" Background="#444444">
								<Border x:Name="Thumb" Width="16" Height="16"
                                        CornerRadius="8" Background="#888888"
                                        HorizontalAlignment="Left"
                                        Margin="3,0,0,0"/>
							</Border>
							<ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
						</StackPanel>
						<ControlTemplate.Triggers>
							<Trigger Property="IsChecked" Value="True">
								<Setter TargetName="Track"
                                        Property="Background" Value="{StaticResource AccentRed}"/>
								<Setter TargetName="Thumb"
                                        Property="Background" Value="White"/>
								<Setter TargetName="Thumb"
                                        Property="HorizontalAlignment" Value="Right"/>
								<Setter TargetName="Thumb"
                                        Property="Margin" Value="0,0,3,0"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ── PAGINATION BUTTON ── -->
		<Style x:Key="PageNumBtn" TargetType="Button">
			<Setter Property="Width"           Value="32"/>
			<Setter Property="Height"          Value="32"/>
			<Setter Property="Background"      Value="#333333"/>
			<Setter Property="Foreground"      Value="{StaticResource TextSecondary}"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="FontSize"        Value="12"/>
			<Setter Property="FontFamily"      Value="Segoe UI"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Margin"          Value="2,0"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="#444444"/>
								<Setter Property="Foreground" Value="White"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="PageNumBtnActive" TargetType="Button"
               BasedOn="{StaticResource PageNumBtn}">
			<Setter Property="Background" Value="{StaticResource AccentRed}"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontWeight" Value="Bold"/>
		</Style>

		<!-- ── ACTIVITY FEED CARD ── -->
		<Style x:Key="ActivityItemCard" TargetType="Border">
			<Setter Property="Background"      Value="{StaticResource BackgroundCard}"/>
			<Setter Property="CornerRadius"    Value="5"/>
			<Setter Property="Padding"         Value="12,10"/>
			<Setter Property="Margin"          Value="0,0,0,8"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>

	</Window.Resources>

	<!-- ══════════════════════════════════════════════
         ROOT 3-COLUMN GRID — responsive columns
         Col 0: Sidebar (auto, min 180)
         Col 1: Main content (*)
         Col 2: Activity panel (auto, min 0 — collapses)
         ══════════════════════════════════════════════ -->
	<Grid>
		<Grid.ColumnDefinitions>
			<!-- Sidebar: fixed but compact-friendly -->
			<ColumnDefinition Width="200" MinWidth="180" MaxWidth="220"/>
			<!-- Main content: fills available space -->
			<ColumnDefinition Width="*" MinWidth="400"/>
			<!-- Activity panel: hides below 1100px via MinWidth on window -->
			<ColumnDefinition Width="260" MinWidth="0" MaxWidth="300"/>
		</Grid.ColumnDefinitions>

		<!-- ═══════════════════════════════════════════════════════════
             COLUMN 0 — LEFT SIDEBAR
             ═══════════════════════════════════════════════════════════ -->
		<Border Grid.Column="0"
                Background="{StaticResource BackgroundSecondary}"
                BorderThickness="0,0,1,0"
                BorderBrush="{StaticResource BorderSubtle}">
			<DockPanel LastChildFill="True">

				<!-- ── Brand Header ── -->
				<Border DockPanel.Dock="Top"
                        Background="{StaticResource AccentRed}"
                        Height="60">
					<StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
						<Border Width="28" Height="28" Background="#AA0000"
                                CornerRadius="4" Margin="0,0,8,0">
							<TextBlock Text="🐂" FontSize="16"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
						</Border>
						<StackPanel VerticalAlignment="Center">
							<TextBlock Text="TAURUS"
                                       Foreground="White" FontSize="15"
                                       FontWeight="Bold" FontFamily="Segoe UI"/>
							<TextBlock Text="BIKE SHOP"
                                       Foreground="#FFD0D0" FontSize="9"
                                       FontFamily="Segoe UI"/>
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- ── Admin profile mini card ── -->
				<Border DockPanel.Dock="Top" Background="#1E1E1E" Padding="14,10">
					<StackPanel Orientation="Horizontal">
						<Border Width="32" Height="32" CornerRadius="16"
                                Background="{StaticResource AccentRed}">
							<TextBlock x:Name="AdminAvatarTextBlock"
                                       Text="A" Foreground="White"
                                       FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
						</Border>
						<StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
							<TextBlock x:Name="AdminNameTextBlock"
                                       Text="Admin User"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="11" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"/>
							<TextBlock x:Name="AdminRoleTextBlock"
                                       Text="System Administrator"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="9" FontFamily="Segoe UI"/>
						</StackPanel>
					</StackPanel>
				</Border>

				<Separator Style="{StaticResource SidebarSeparatorStyle}"
                           DockPanel.Dock="Top"/>

				<!-- ── Logout + Exit buttons (pinned to bottom) ── -->
				<StackPanel DockPanel.Dock="Bottom">
					<Separator Style="{StaticResource SidebarSeparatorStyle}"/>
					<!-- EXIT button — closes the application entirely -->
					<Button x:Name="ExitButton"
                            Style="{StaticResource NavButtonStyle}"
                            Height="44">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="✕" FontSize="13" Margin="0,0,10,0"
                                       Foreground="#FF4444"
                                       VerticalAlignment="Center"/>
							<TextBlock Text="Exit Application"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#FF4444"
                                       VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
					<!-- LOGOUT button -->
					<Button x:Name="BtnNavSignOut"
                            Style="{StaticResource NavButtonStyle}"
                            Height="44">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="⏻" FontSize="13" Margin="0,0,10,0"
                                       Foreground="{StaticResource AccentRed}"
                                       VerticalAlignment="Center"/>
							<TextBlock Text="Logout"
                                       FontFamily="Segoe UI" FontSize="12"
                                       VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
				</StackPanel>

				<!-- ── Navigation items ── -->
				<ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
					<StackPanel>
						<!-- Section label: MODULES -->
						<TextBlock Text="MODULES"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="10" FontFamily="Segoe UI"
                                   FontWeight="SemiBold" Margin="16,12,0,4"/>

						<Button x:Name="BtnNavDashboard"
                                Style="{StaticResource NavButtonActiveStyle}"
                                Tag="Dashboard">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="⊞" FontSize="14" Margin="0,0,8,0"
                                           Foreground="{StaticResource AccentRed}"
                                           VerticalAlignment="Center"/>
								<TextBlock Text="Dashboard"
                                           FontFamily="Segoe UI" FontSize="12"
                                           VerticalAlignment="Center"/>
							</StackPanel>
						</Button>

						<Button x:Name="BtnNavOrders"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="PendingOrders">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="📦" FontSize="12" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
								<TextBlock Text="Pending Orders"
                                           FontFamily="Segoe UI" FontSize="12"
                                           VerticalAlignment="Center"/>
								<Border Background="{StaticResource AccentRed}"
                                        CornerRadius="8" Padding="5,1"
                                        Margin="6,0,0,0" VerticalAlignment="Center">
									<TextBlock x:Name="PendingOrdersBadgeTextBlock"
                                               Text="7" Foreground="White"
                                               FontSize="10" FontWeight="Bold"/>
								</Border>
							</StackPanel>
						</Button>

						<Button x:Name="PaymentVerificationNavButton"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="PaymentVerification">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="💳" FontSize="12" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
								<TextBlock Text="Payment Verify"
                                           FontFamily="Segoe UI" FontSize="12"
                                           VerticalAlignment="Center"/>
								<Border Background="{StaticResource StatusYellow}"
                                        CornerRadius="8" Padding="5,1"
                                        Margin="6,0,0,0" VerticalAlignment="Center">
									<TextBlock x:Name="PaymentVerificationBadgeTextBlock"
                                               Text="3" Foreground="#1A1A1A"
                                               FontSize="10" FontWeight="Bold"/>
								</Border>
							</StackPanel>
						</Button>

						<Button x:Name="BtnNavDelivery"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="Logistics">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="🚚" FontSize="12" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
								<TextBlock Text="Logistics"
                                           FontFamily="Segoe UI" FontSize="12"
                                           VerticalAlignment="Center"/>
							</StackPanel>
						</Button>

						<Button x:Name="BtnNavPOS"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="WalkInPOS">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="🛒" FontSize="12" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
								<TextBlock Text="Walk-In POS"
                                           FontFamily="Segoe UI" FontSize="12"
                                           VerticalAlignment="Center"/>
							</StackPanel>
						</Button>

						<Button x:Name="BtnNavInventory"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="Inventory">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="📋" FontSize="12" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
								<TextBlock Text="Inventory"
                                           FontFamily="Segoe UI" FontSize="12"
                                           VerticalAlignment="Center"/>
							</StackPanel>
						</Button>

						<!-- Section label: REPORTS -->
						<Separator Style="{StaticResource SidebarSeparatorStyle}"/>
						<TextBlock Text="REPORTS"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="10" FontFamily="Segoe UI"
                                   FontWeight="SemiBold" Margin="16,4,0,4"/>

						<Button x:Name="OrderHistoryNavButton"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="OrderHistory">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="🕘" FontSize="12" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
								<TextBlock Text="Order History"
                                           FontFamily="Segoe UI" FontSize="12"
                                           VerticalAlignment="Center"/>
							</StackPanel>
						</Button>

						<Button x:Name="BtnNavReports"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="Analytics">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="📊" FontSize="12" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
								<TextBlock Text="Analytics"
                                           FontFamily="Segoe UI" FontSize="12"
                                           VerticalAlignment="Center"/>
							</StackPanel>
						</Button>

						<!-- Section label: SUPPORT -->
						<Separator Style="{StaticResource SidebarSeparatorStyle}"/>
						<TextBlock Text="SUPPORT"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="10" FontFamily="Segoe UI"
                                   FontWeight="SemiBold" Margin="16,4,0,4"/>

						<Button x:Name="BtnNavSupport"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="Support">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="🎫" FontSize="12" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
								<TextBlock Text="Support Tickets"
                                           FontFamily="Segoe UI" FontSize="12"
                                           VerticalAlignment="Center"/>
								<Border Background="{StaticResource StatusBlue}"
                                        CornerRadius="8" Padding="5,1"
                                        Margin="6,0,0,0" VerticalAlignment="Center">
									<TextBlock x:Name="SupportTicketsBadgeTextBlock"
                                               Text="2" Foreground="White"
                                               FontSize="10" FontWeight="Bold"/>
								</Border>
							</StackPanel>
						</Button>

						<!-- Section label: CATALOG + ADMIN -->
						<Separator Style="{StaticResource SidebarSeparatorStyle}"/>
						<TextBlock Text="CATALOG"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="10" FontFamily="Segoe UI"
                                   FontWeight="SemiBold" Margin="16,4,0,4"/>

						<Button x:Name="BtnNavProducts"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="Products">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="🛍" FontSize="12" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
								<TextBlock Text="Products"
                                           FontFamily="Segoe UI" FontSize="12"
                                           VerticalAlignment="Center"/>
							</StackPanel>
						</Button>

						<Button x:Name="BtnNavVouchers"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="Vouchers">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="🎟" FontSize="12" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
								<TextBlock Text="Vouchers"
                                           FontFamily="Segoe UI" FontSize="12"
                                           VerticalAlignment="Center"/>
							</StackPanel>
						</Button>

						<Button x:Name="BtnNavUsers"
                                Style="{StaticResource NavButtonStyle}"
                                Tag="Users">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="👥" FontSize="12" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
								<TextBlock Text="Users"
                                           FontFamily="Segoe UI" FontSize="12"
                                           VerticalAlignment="Center"/>
							</StackPanel>
						</Button>

					</StackPanel>
				</ScrollViewer>
			</DockPanel>
		</Border>

		<!-- ═══════════════════════════════════════════════════════════
             COLUMN 1 — MAIN CONTENT
             ═══════════════════════════════════════════════════════════ -->
		<Grid Grid.Column="1">
			<Grid.RowDefinitions>
				<RowDefinition Height="60"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<!-- ── Top Bar ── -->
			<Border Grid.Row="0"
                    Background="{StaticResource BackgroundSecondary}"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{StaticResource BorderSubtle}">
				<Grid Margin="16,0">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<!-- Page title + breadcrumb -->
					<StackPanel Grid.Column="0" VerticalAlignment="Center">
						<TextBlock x:Name="PageTitleTextBlock"
                                   Text="Admin Dashboard"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="16" FontWeight="SemiBold"
                                   FontFamily="Segoe UI"/>
						<TextBlock x:Name="PageBreadcrumbTextBlock"
                                   Text="Admin → Dashboard"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="10" FontFamily="Segoe UI"/>
					</StackPanel>

					<!-- Top-right controls — hide elements progressively -->
					<StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center">
						<TextBlock x:Name="TbCurrentUser"
                                   Foreground="#F0F0F0" FontSize="12"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
						<!-- Search box hides below ~1100px -->
						<TextBox x:Name="GlobalSearchTextBox"
                                 Style="{StaticResource SearchTextBoxStyle}"
                                 Width="180" Margin="0,0,8,0"/>
						<Button x:Name="NotificationsButton"
                                Style="{StaticResource GhostButtonStyle}"
                                Width="36" Padding="0" Margin="0,0,6,0">
							<Grid>
								<TextBlock Text="🔔" FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
								<Border Width="7" Height="7"
                                        Background="{StaticResource AccentRed}"
                                        CornerRadius="4"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,0,2,0"/>
							</Grid>
						</Button>
						<Button x:Name="RefreshTopBarButton"
                                Style="{StaticResource GhostButtonStyle}"
                                Content="↻ Refresh" Margin="0,0,6,0"/>
						<Border Background="{StaticResource BackgroundCard}"
                                CornerRadius="4" Padding="8,6"
                                BorderThickness="1"
                                BorderBrush="{StaticResource BorderSubtle}">
							<TextBlock x:Name="CurrentDateTimeTextBlock"
                                       Text="--:--:--"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="11" FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
						</Border>
					</StackPanel>
				</Grid>
			</Border>

			<!-- ContentArea: UserControl views are loaded here by Navigate() -->
			<ContentControl x:Name="ContentArea" Grid.Row="1" Background="#1A1A1A"/>
		</Grid>

		<!-- ═══════════════════════════════════════════════════════════
             COLUMN 2 — RIGHT ACTIVITY FEED PANEL
             ═══════════════════════════════════════════════════════════ -->
		<Border Grid.Column="2"
                Background="{StaticResource BackgroundSecondary}"
                BorderThickness="1,0,0,0"
                BorderBrush="{StaticResource BorderSubtle}">
			<DockPanel LastChildFill="True">

				<!-- Panel header -->
				<Border DockPanel.Dock="Top" Padding="14,12"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{StaticResource BorderSubtle}">
					<TextBlock Text="Activity Feed"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="13" FontWeight="SemiBold"
                               FontFamily="Segoe UI"/>
				</Border>

				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel Margin="14,10,14,10">

						<!-- Pending Payments (dynamic) -->
						<TextBlock Text="PENDING PAYMENTS" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,6"/>

						<ItemsControl x:Name="ActivityPendingPaymentsList" Margin="0,0,0,14">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border Style="{StaticResource ActivityItemCard}" BorderBrush="{StaticResource StatusYellow}" Margin="0,0,0,6">
										<Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="*"/>
												<ColumnDefinition Width="Auto"/>
											</Grid.ColumnDefinitions>
											<StackPanel Grid.Column="0">
												<TextBlock Text="{Binding OrderRef}" Foreground="{StaticResource TextPrimary}" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
												<TextBlock Text="{Binding Method}" Foreground="{StaticResource TextSecondary}" FontSize="11" FontFamily="Segoe UI" Margin="0,2,0,0"/>
												<TextBlock Text="{Binding CreatedDisplay}" Foreground="{StaticResource TextMuted}" FontSize="10" FontFamily="Segoe UI" Margin="0,2,0,0"/>
											</StackPanel>
											<StackPanel Grid.Column="1" HorizontalAlignment="Right">
												<TextBlock Text="{Binding AmountDisplay}" Foreground="{StaticResource StatusYellow}" FontSize="12" FontWeight="Bold" FontFamily="Segoe UI" HorizontalAlignment="Right"/>
												<Button Style="{StaticResource PrimaryButtonStyle}" Content="Verify" Height="24" FontSize="10" Margin="0,5,0,0"
												        Tag="{Binding PaymentId}" Click="BtnVerifyPayment_Click"/>
											</StackPanel>
										</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

						<!-- System Alerts -->
						<TextBlock Text="SYSTEM ALERTS" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,6"/>

						<Border x:Name="ActivityLowStockPanel" Background="#2C1A1A" CornerRadius="5" Padding="10,8" Margin="0,0,0,6" BorderThickness="1" BorderBrush="{StaticResource AccentRed}" Visibility="Collapsed">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="⚠" FontSize="13" Foreground="{StaticResource AccentRed}" VerticalAlignment="Top" Margin="0,0,6,0"/>
								<StackPanel>
									<StackPanel Orientation="Horizontal">
										<TextBlock Text="Low Stock Warning — " Foreground="{StaticResource AccentRed}" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
										<TextBlock x:Name="ActivityLowStockBadge" Foreground="{StaticResource AccentRed}" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
									</StackPanel>
									<TextBlock x:Name="ActivityLowStockDetail" Foreground="{StaticResource TextSecondary}" FontSize="10" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,2,0,0"/>
									<Button x:Name="ReviewInventoryButton" Style="{StaticResource GhostButtonStyle}" Content="Review Now" Height="24" FontSize="10" Margin="0,6,0,0" HorizontalAlignment="Left" Tag="Inventory"/>
								</StackPanel>
							</StackPanel>
						</Border>

						<Border Background="#1A1E2C" CornerRadius="5" Padding="10,8" Margin="0,0,0,6" BorderThickness="1" BorderBrush="{StaticResource StatusBlue}">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="🎫" FontSize="13" VerticalAlignment="Top" Margin="0,0,6,0"/>
								<StackPanel>
									<TextBlock Text="Support Tickets" Foreground="{StaticResource StatusBlue}" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
									<TextBlock Text="Check the Support section for open tickets." Foreground="{StaticResource TextSecondary}" FontSize="10" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,2,0,0"/>
									<Button x:Name="ViewTicketButton" Style="{StaticResource GhostButtonStyle}" Content="View Tickets" Height="24" FontSize="10" Margin="0,6,0,0" HorizontalAlignment="Left" Tag="Support"/>
								</StackPanel>
							</StackPanel>
						</Border>

						<!-- System Status -->
						<Border Background="{StaticResource BackgroundCard}" CornerRadius="5" Padding="10,8" Margin="0,6,0,0" BorderThickness="1" BorderBrush="{StaticResource BorderSubtle}">
							<StackPanel>
								<TextBlock Text="SYSTEM STATUS" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,8"/>
								<StackPanel Orientation="Horizontal" Margin="0,0,0,5">
									<Ellipse x:Name="ActivityDbDot" Width="7" Height="7" Fill="{StaticResource StatusGreen}" VerticalAlignment="Center" Margin="0,0,7,0"/>
									<TextBlock x:Name="ActivityDbStatus" Text="Database · Checking..." Foreground="{StaticResource TextSecondary}" FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
								</StackPanel>
								<StackPanel Orientation="Horizontal" Margin="0,0,0,5">
									<Ellipse Width="7" Height="7" Fill="{StaticResource StatusGreen}" VerticalAlignment="Center" Margin="0,0,7,0"/>
									<TextBlock Text="POS Terminal · Active" Foreground="{StaticResource TextSecondary}" FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
								</StackPanel>
								<StackPanel Orientation="Horizontal">
									<Ellipse Width="7" Height="7" Fill="{StaticResource StatusGreen}" VerticalAlignment="Center" Margin="0,0,7,0"/>
									<TextBlock Text="Payment Gateway · Online" Foreground="{StaticResource TextSecondary}" FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
								</StackPanel>
							</StackPanel>
						</Border>

					</StackPanel>
				</ScrollViewer>
			</DockPanel>
		</Border>

	</Grid>
</Window>
