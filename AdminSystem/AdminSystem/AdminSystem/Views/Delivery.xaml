<UserControl x:Class="AdminSystem.Views.DeliveryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT: Deliveries list ════════════════════════════════════ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,14">
                <TextBlock Text="Deliveries" Foreground="#F0F0F0"
                           FontSize="22" FontWeight="Bold"
                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                <Button x:Name="BtnRefreshDeliveries"
                        Content="↻ Refresh" Height="32" Padding="14,0"
                        Background="#3A3A3A" Foreground="#A0A0A0"
                        BorderThickness="0" Cursor="Hand"
                        FontFamily="Segoe UI" FontSize="12"
                        HorizontalAlignment="Right"/>
            </Grid>

            <Border Grid.Row="1" Background="#242424" CornerRadius="10"
                    BorderThickness="1" BorderBrush="#3A3A3A">
                <DataGrid x:Name="DgDeliveries"
                          AutoGenerateColumns="False"
                          Background="#242424" Foreground="#F0F0F0"
                          BorderThickness="0" RowHeight="42"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#3A3A3A"
                          CanUserAddRows="False" IsReadOnly="True"
                          SelectionMode="Single" SelectionUnit="FullRow">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"      Value="#1A1A1A"/>
                            <Setter Property="Foreground"      Value="#606060"/>
                            <Setter Property="FontSize"        Value="11"/>
                            <Setter Property="FontWeight"      Value="SemiBold"/>
                            <Setter Property="Padding"         Value="12,10"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#242424"/>
                            <Setter Property="Foreground" Value="#F0F0F0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2C2C2C"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#3A1A1A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding"         Value="12,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontFamily"      Value="Segoe UI"/>
                            <Setter Property="FontSize"        Value="12"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background"  Value="Transparent"/>
                                    <Setter Property="Foreground"  Value="#F0F0F0"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Order ID"
                            Binding="{Binding OrderId}" Width="80"/>
                        <DataGridTextColumn Header="Courier"
                            Binding="{Binding Courier}" Width="100"/>
                        <DataGridTextColumn Header="Status"
                            Binding="{Binding DeliveryStatus}" Width="140"/>
                        <DataGridCheckBoxColumn Header="Delayed"
                            Binding="{Binding IsDelayed}" Width="80"/>
                        <DataGridTextColumn Header="Created"
                            Binding="{Binding CreatedAt, StringFormat='{}{0:MMM d, yyyy}'}"
                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- ═══ RIGHT: Action Panel ═══════════════════════════════════════ -->
        <Border Grid.Column="2" Background="#242424" CornerRadius="10"
                Padding="20" BorderThickness="1" BorderBrush="#3A3A3A">
            <StackPanel>
                <TextBlock Text="Delivery Actions" Foreground="#F0F0F0"
                           FontSize="14" FontWeight="SemiBold"
                           FontFamily="Segoe UI" Margin="0,0,0,18"/>

                <TextBlock Text="Select a delivery from the list to take action."
                           Foreground="#606060" FontFamily="Segoe UI"
                           FontSize="12" TextWrapping="Wrap"
                           Margin="0,0,0,20"/>

                <TextBlock Text="TRACKING / BOOKING REF"
                           Foreground="#606060" FontSize="10"
                           FontWeight="SemiBold" FontFamily="Segoe UI"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="TbTrackingInput"
                         Height="36" Padding="10,0"
                         Background="#2E2E2E" Foreground="#F0F0F0"
                         BorderBrush="#3A3A3A" BorderThickness="1"
                         FontFamily="Segoe UI" FontSize="12"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,10"/>

                <Button x:Name="BtnAssignTracking"
                        Content="Assign Tracking" Height="38"
                        Background="#2196F3" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        FontFamily="Segoe UI" FontSize="12"
                        Margin="0,0,0,8"/>
                <Button x:Name="BtnMarkDelivered"
                        Content="Mark Delivered" Height="38"
                        Background="#4CAF50" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        FontFamily="Segoe UI" FontSize="12"
                        Margin="0,0,0,8"/>
                <Button x:Name="BtnMarkFailed"
                        Content="Mark Failed" Height="38"
                        Background="#3A3A3A" Foreground="#A0A0A0"
                        BorderThickness="0" Cursor="Hand"
                        FontFamily="Segoe UI" FontSize="12"
                        Margin="0,0,0,16"/>

                <TextBlock x:Name="TbDeliveryMsg"
                           Foreground="#4CAF50" FontFamily="Segoe UI"
                           FontSize="12" TextWrapping="Wrap"
                           Visibility="Collapsed"/>
                <TextBlock x:Name="TbDeliveryError"
                           Foreground="#CC0000" FontFamily="Segoe UI"
                           FontSize="12" TextWrapping="Wrap"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
