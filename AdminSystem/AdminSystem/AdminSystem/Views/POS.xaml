<UserControl x:Class="AdminSystem.Views.POSView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left: product browser -->
            <ColumnDefinition Width="*"/>
            <!-- Right: cart panel -->
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             LEFT — Product Browser
             ══════════════════════════════════════════════════════════ -->
        <DockPanel Grid.Column="0" Margin="20,16,12,20">

            <!-- Search bar -->
            <Border DockPanel.Dock="Top" Background="#242424"
                    CornerRadius="6" Padding="10,8"
                    BorderThickness="1" BorderBrush="#2E2E2E"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TbPosSearch"
                             Grid.Column="0"
                             Background="Transparent"
                             Foreground="#F0F0F0"
                             BorderThickness="0"
                             FontSize="13" FontFamily="Segoe UI"
                             VerticalAlignment="Center"
                             TextChanged="TbPosSearch_TextChanged">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Resources>
                                    <VisualBrush x:Key="PH" TileMode="None"
                                                 Opacity="0.4" Stretch="None"
                                                 AlignmentX="Left">
                                        <VisualBrush.Visual>
                                            <TextBlock Text="Search products..."
                                                       Foreground="#888888"
                                                       FontSize="13"
                                                       FontFamily="Segoe UI"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Style.Resources>
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background" Value="{StaticResource PH}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <Button Grid.Column="1" Content="🔍"
                            Background="Transparent" Foreground="#888888"
                            BorderThickness="0" FontSize="13"
                            Padding="4,0" Cursor="Hand"
                            Click="BtnPosRefresh_Click"/>
                </Grid>
            </Border>

            <!-- Error bar -->
            <Border x:Name="PosErrorBar" DockPanel.Dock="Top"
                    Background="#3B1212" Padding="12,6"
                    Visibility="Collapsed" Margin="0,0,0,8">
                <TextBlock x:Name="TbPosError"
                           Foreground="#CC0000" FontSize="11"
                           FontFamily="Segoe UI" TextWrapping="Wrap"/>
            </Border>

            <!-- Product tiles -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="ProductTilesPanel"
                           Orientation="Horizontal"/>
            </ScrollViewer>
        </DockPanel>

        <!-- ══════════════════════════════════════════════════════════
             RIGHT — Cart Panel
             ══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="1"
                Background="#242424"
                BorderThickness="1,0,0,0"
                BorderBrush="#2E2E2E">
            <DockPanel>

                <!-- Cart header -->
                <Border DockPanel.Dock="Top" Padding="16,12"
                        BorderThickness="0,0,0,1" BorderBrush="#2E2E2E">
                    <Grid>
                        <TextBlock Text="Cart"
                                   Foreground="#F0F0F0" FontSize="14"
                                   FontWeight="SemiBold" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="BtnPosClear"
                                HorizontalAlignment="Right"
                                Content="Clear"
                                Background="Transparent" Foreground="#888888"
                                BorderBrush="#3A3A3A" BorderThickness="1"
                                Padding="8,3" FontSize="11"
                                FontFamily="Segoe UI" Cursor="Hand"
                                Click="BtnPosClear_Click"/>
                    </Grid>
                </Border>

                <!-- Checkout summary footer (docked bottom) -->
                <Border DockPanel.Dock="Bottom"
                        Background="#1E1E1E"
                        BorderThickness="0,1,0,0"
                        BorderBrush="#2E2E2E"
                        Padding="16,14">
                    <StackPanel>

                        <!-- Discount row -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TbPosDiscount"
                                     Grid.Column="0"
                                     Background="#2E2E2E"
                                     Foreground="#F0F0F0"
                                     BorderBrush="#3A3A3A" BorderThickness="1"
                                     Padding="6,4" FontSize="12"
                                     FontFamily="Segoe UI"
                                     VerticalAlignment="Center"
                                     Margin="0,0,6,0"
                                     ToolTip="Discount amount"/>
                            <Button Grid.Column="1"
                                    Content="Apply"
                                    Background="#CC0000" Foreground="White"
                                    BorderThickness="0"
                                    Padding="10,4" FontSize="11"
                                    FontFamily="Segoe UI" Cursor="Hand"
                                    Click="BtnPosApplyDiscount_Click"/>
                        </Grid>

                        <!-- Totals -->
                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="Subtotal"
                                       Foreground="#888888" FontSize="12"
                                       FontFamily="Segoe UI"/>
                            <TextBlock x:Name="TbPosSubtotal"
                                       HorizontalAlignment="Right"
                                       Foreground="#F0F0F0" FontSize="12"
                                       FontFamily="Segoe UI"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="Discount"
                                       Foreground="#888888" FontSize="12"
                                       FontFamily="Segoe UI"/>
                            <TextBlock x:Name="TbPosDiscount2"
                                       HorizontalAlignment="Right"
                                       Foreground="#FFC107" FontSize="12"
                                       FontFamily="Segoe UI"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="VAT (12%)"
                                       Foreground="#888888" FontSize="12"
                                       FontFamily="Segoe UI"/>
                            <TextBlock x:Name="TbPosVAT"
                                       HorizontalAlignment="Right"
                                       Foreground="#F0F0F0" FontSize="12"
                                       FontFamily="Segoe UI"/>
                        </Grid>

                        <!-- Divider -->
                        <Border BorderThickness="0,1,0,0"
                                BorderBrush="#3A3A3A" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="TOTAL DUE"
                                       Foreground="#F0F0F0" FontSize="14"
                                       FontWeight="SemiBold" FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TbPosGrandTotal"
                                       HorizontalAlignment="Right"
                                       Foreground="#4CAF50" FontSize="18"
                                       FontWeight="Bold" FontFamily="Segoe UI"/>
                        </Grid>

                        <!-- Checkout button -->
                        <Button x:Name="BtnPosCheckout"
                                Content="✓  CHECKOUT"
                                Background="#CC0000" Foreground="White"
                                BorderThickness="0"
                                Height="40" FontSize="14"
                                FontWeight="SemiBold" FontFamily="Segoe UI"
                                Cursor="Hand"
                                Click="BtnPosCheckout_Click"/>
                    </StackPanel>
                </Border>

                <!-- Cart DataGrid -->
                <DataGrid x:Name="DgCart"
                          Margin="0"
                          AutoGenerateColumns="False"
                          IsReadOnly="False"
                          Background="#242424"
                          Foreground="#F0F0F0"
                          BorderThickness="0"
                          RowBackground="#242424"
                          AlternatingRowBackground="#1E1E1E"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#2E2E2E"
                          ColumnHeaderHeight="30"
                          RowHeight="44"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          CanUserResizeRows="False"
                          CanUserAddRows="False">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"      Value="#1E1E1E"/>
                            <Setter Property="Foreground"      Value="#888888"/>
                            <Setter Property="FontSize"        Value="10"/>
                            <Setter Property="FontFamily"      Value="Segoe UI"/>
                            <Setter Property="FontWeight"      Value="SemiBold"/>
                            <Setter Property="Padding"         Value="8,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground"        Value="#F0F0F0"/>
                            <Setter Property="FontSize"          Value="11"/>
                            <Setter Property="FontFamily"        Value="Segoe UI"/>
                            <Setter Property="BorderThickness"   Value="0"/>
                            <Setter Property="Padding"           Value="8,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#CC0000"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Item"
                            Binding="{Binding Name}"
                            Width="*"
                            IsReadOnly="True"/>
                        <!-- Qty controls column -->
                        <DataGridTemplateColumn Header="Qty" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                        <Button Content="−"
                                                Tag="{Binding}"
                                                Width="22" Height="22"
                                                FontSize="13"
                                                Background="#3A3A3A"
                                                Foreground="#F0F0F0"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Click="CartQtyBtn_Click"/>
                                        <TextBlock Text="{Binding Quantity}"
                                                   Foreground="#F0F0F0"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Margin="5,0" MinWidth="16"
                                                   TextAlignment="Center"/>
                                        <Button Content="+"
                                                Tag="{Binding}"
                                                Width="22" Height="22"
                                                FontSize="13"
                                                Background="#3A3A3A"
                                                Foreground="#F0F0F0"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Click="CartQtyIncrBtn_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Price"
                            Binding="{Binding SubtotalDisplay}"
                            Width="76"
                            IsReadOnly="True"/>
                        <!-- Remove button -->
                        <DataGridTemplateColumn Header="" Width="30">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✕"
                                            Tag="{Binding}"
                                            Width="20" Height="20"
                                            FontSize="10"
                                            Background="Transparent"
                                            Foreground="#888888"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="CartRemoveBtn_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

            </DockPanel>
        </Border>

    </Grid>
</UserControl>
