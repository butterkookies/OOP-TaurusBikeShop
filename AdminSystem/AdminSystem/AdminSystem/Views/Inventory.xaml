<UserControl x:Class="AdminSystem.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Inventory" Foreground="#F0F0F0"
                   FontSize="22" FontWeight="Bold" FontFamily="Segoe UI"
                   Margin="0,0,0,16"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT: logs + low-stock ════════════════════════════════ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Recent Movements"
                           Foreground="#A0A0A0" FontSize="12"
                           FontFamily="Segoe UI" FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <!-- Inventory log DataGrid -->
                <Border Grid.Row="1" Background="#242424" CornerRadius="10"
                        BorderThickness="1" BorderBrush="#3A3A3A">
                    <DataGrid x:Name="DgInventoryLog"
                              AutoGenerateColumns="False"
                              Background="#242424" Foreground="#F0F0F0"
                              BorderThickness="0" RowHeight="40"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#3A3A3A"
                              CanUserAddRows="False" IsReadOnly="True"
                              SelectionMode="Single">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"      Value="#1A1A1A"/>
                                <Setter Property="Foreground"      Value="#606060"/>
                                <Setter Property="FontSize"        Value="11"/>
                                <Setter Property="FontWeight"      Value="SemiBold"/>
                                <Setter Property="Padding"         Value="12,10"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#242424"/>
                                <Setter Property="Foreground" Value="#F0F0F0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2C2C2C"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding"         Value="12,0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontFamily"      Value="Segoe UI"/>
                                <Setter Property="FontSize"        Value="12"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background"  Value="Transparent"/>
                                        <Setter Property="Foreground"  Value="#F0F0F0"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product"
                                Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Variant"
                                Binding="{Binding VariantName}" Width="120"/>
                            <DataGridTextColumn Header="Type"
                                Binding="{Binding ChangeType}" Width="100"/>
                            <DataGridTextColumn Header="Qty"
                                Binding="{Binding ChangeQuantity}" Width="60"/>
                            <DataGridTextColumn Header="Date"
                                Binding="{Binding CreatedAt, StringFormat='{}{0:MMM d, yyyy}'}"
                                Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Low stock section label -->
                <TextBlock Grid.Row="3" Text="Low Stock Alerts"
                           Foreground="#FFC107" FontSize="12"
                           FontFamily="Segoe UI" FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <!-- Low stock DataGrid -->
                <Border Grid.Row="4" Background="#242424" CornerRadius="10"
                        BorderThickness="1" BorderBrush="#FFC107" MaxHeight="180">
                    <DataGrid x:Name="DgLowStock"
                              AutoGenerateColumns="False"
                              Background="#242424" Foreground="#F0F0F0"
                              BorderThickness="0" RowHeight="38"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              CanUserAddRows="False" IsReadOnly="True"
                              SelectionMode="Single">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"      Value="#1A1A1A"/>
                                <Setter Property="Foreground"      Value="#606060"/>
                                <Setter Property="FontSize"        Value="11"/>
                                <Setter Property="FontWeight"      Value="SemiBold"/>
                                <Setter Property="Padding"         Value="12,8"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#242424"/>
                                <Setter Property="Foreground" Value="#F0F0F0"/>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding"         Value="12,0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontFamily"      Value="Segoe UI"/>
                                <Setter Property="FontSize"        Value="12"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background"  Value="Transparent"/>
                                        <Setter Property="Foreground"  Value="#F0F0F0"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product"
                                Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Variant"
                                Binding="{Binding VariantName}" Width="120"/>
                            <DataGridTextColumn Header="Stock"
                                Binding="{Binding ChangeQuantity}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- ═══ RIGHT: Stock Adjustment Panel ═════════════════════════ -->
            <Border Grid.Column="2" Background="#242424" CornerRadius="10"
                    Padding="20" BorderThickness="1" BorderBrush="#3A3A3A">
                <StackPanel>
                    <TextBlock Text="Stock Adjustment" Foreground="#F0F0F0"
                               FontSize="14" FontWeight="SemiBold"
                               FontFamily="Segoe UI" Margin="0,0,0,18"/>

                    <TextBlock Text="VARIANT ID" Foreground="#606060"
                               FontSize="10" FontWeight="SemiBold"
                               FontFamily="Segoe UI" Margin="0,0,0,5"/>
                    <TextBox x:Name="TbAdjVariantId"
                             Height="36" Padding="10,0"
                             Background="#2E2E2E" Foreground="#F0F0F0"
                             BorderBrush="#3A3A3A" BorderThickness="1"
                             FontFamily="Segoe UI" FontSize="12"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="QUANTITY (+/-)" Foreground="#606060"
                               FontSize="10" FontWeight="SemiBold"
                               FontFamily="Segoe UI" Margin="0,0,0,5"/>
                    <TextBox x:Name="TbAdjQty"
                             Height="36" Padding="10,0"
                             Background="#2E2E2E" Foreground="#F0F0F0"
                             BorderBrush="#3A3A3A" BorderThickness="1"
                             FontFamily="Segoe UI" FontSize="12"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="TYPE" Foreground="#606060"
                               FontSize="10" FontWeight="SemiBold"
                               FontFamily="Segoe UI" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CbAdjType" Height="36"
                              Background="#2E2E2E" Foreground="#F0F0F0"
                              BorderBrush="#3A3A3A" BorderThickness="1"
                              FontFamily="Segoe UI" FontSize="12"
                              Margin="0,0,0,12">
                        <ComboBoxItem Content="Adjustment"/>
                        <ComboBoxItem Content="Damage"/>
                        <ComboBoxItem Content="Loss"/>
                        <ComboBoxItem Content="Return"/>
                    </ComboBox>

                    <TextBlock Text="NOTES" Foreground="#606060"
                               FontSize="10" FontWeight="SemiBold"
                               FontFamily="Segoe UI" Margin="0,0,0,5"/>
                    <TextBox x:Name="TbAdjNotes"
                             Height="70" Padding="10,8"
                             Background="#2E2E2E" Foreground="#F0F0F0"
                             BorderBrush="#3A3A3A" BorderThickness="1"
                             FontFamily="Segoe UI" FontSize="12"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             Margin="0,0,0,14"/>

                    <TextBlock x:Name="TbAdjError"
                               Foreground="#CC0000" FontFamily="Segoe UI"
                               FontSize="11" TextWrapping="Wrap"
                               Visibility="Collapsed" Margin="0,0,0,8"/>
                    <TextBlock x:Name="TbAdjSuccess"
                               Foreground="#4CAF50" FontFamily="Segoe UI"
                               FontSize="11" Visibility="Collapsed"
                               Margin="0,0,0,8"/>

                    <Button x:Name="BtnAdjust" Content="Apply Adjustment"
                            Height="40" Background="#CC0000" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            FontFamily="Segoe UI" FontSize="13"
                            FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
