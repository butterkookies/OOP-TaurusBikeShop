<UserControl x:Class="AdminSystem.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT: Users List ═════════════════════════════════════════ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,14">
                <TextBlock Text="Users" Foreground="#F0F0F0"
                           FontSize="22" FontWeight="Bold"
                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                <Button x:Name="BtnRefreshUsers"
                        Content="↻ Refresh" Height="34" Padding="14,0"
                        Background="#3A3A3A" Foreground="#A0A0A0"
                        BorderThickness="0" Cursor="Hand"
                        FontFamily="Segoe UI" FontSize="12"
                        HorizontalAlignment="Right"
                        Click="BtnRefreshUsers_Click"/>
            </Grid>

            <!-- Error bar -->
            <Border x:Name="UsersErrorBar" Grid.Row="1"
                    Background="#3B1212" Padding="14,8" Margin="0,0,0,8"
                    Visibility="Collapsed">
                <TextBlock x:Name="TbUsersError"
                           Foreground="#CC0000" FontSize="12"
                           FontFamily="Segoe UI" TextWrapping="Wrap"/>
            </Border>

            <!-- DataGrid -->
            <Border Grid.Row="2" Background="#242424" CornerRadius="10"
                    BorderThickness="1" BorderBrush="#3A3A3A">
                <DataGrid x:Name="DgUsers"
                          AutoGenerateColumns="False"
                          Background="#242424" Foreground="#F0F0F0"
                          BorderThickness="0" RowHeight="40"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#3A3A3A"
                          CanUserAddRows="False" IsReadOnly="True"
                          SelectionMode="Single" SelectionUnit="FullRow"
                          SelectionChanged="DgUsers_SelectionChanged">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"      Value="#1A1A1A"/>
                            <Setter Property="Foreground"      Value="#606060"/>
                            <Setter Property="FontSize"        Value="11"/>
                            <Setter Property="FontWeight"      Value="SemiBold"/>
                            <Setter Property="Padding"         Value="12,10"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#242424"/>
                            <Setter Property="Foreground" Value="#F0F0F0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2C2C2C"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#3A1A1A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding"         Value="12,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontFamily"      Value="Segoe UI"/>
                            <Setter Property="FontSize"        Value="12"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background"  Value="Transparent"/>
                                    <Setter Property="Foreground"  Value="#F0F0F0"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"
                            Binding="{Binding UserId}" Width="50"/>
                        <DataGridTextColumn Header="Name"
                            Binding="{Binding FullName}" Width="160"/>
                        <DataGridTextColumn Header="Email"
                            Binding="{Binding Email}" Width="*"/>
                        <DataGridTextColumn Header="Phone"
                            Binding="{Binding Phone}" Width="130"/>
                        <DataGridCheckBoxColumn Header="Verified"
                            Binding="{Binding IsEmailVerified}" Width="80"/>
                        <DataGridCheckBoxColumn Header="Active"
                            Binding="{Binding IsActive}" Width="70"/>
                        <DataGridTextColumn Header="Last Login"
                            Binding="{Binding LastLoginAt, StringFormat='{}{0:MMM d, yyyy}'}"
                            Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- ═══ RIGHT: Detail / Action Panel ════════════════════════════════ -->
        <Border Grid.Column="2" Background="#242424" CornerRadius="10"
                Padding="20" BorderThickness="1" BorderBrush="#3A3A3A"
                VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="User Detail" Foreground="#F0F0F0"
                           FontSize="14" FontWeight="SemiBold"
                           FontFamily="Segoe UI" Margin="0,0,0,16"/>

                <!-- Name -->
                <TextBlock Text="NAME" Foreground="#606060" FontSize="10"
                           FontWeight="SemiBold" FontFamily="Segoe UI"
                           Margin="0,0,0,3"/>
                <TextBlock x:Name="TbDetailName" Foreground="#F0F0F0"
                           FontFamily="Segoe UI" FontSize="13"
                           Margin="0,0,0,12"/>

                <!-- Email -->
                <TextBlock Text="EMAIL" Foreground="#606060" FontSize="10"
                           FontWeight="SemiBold" FontFamily="Segoe UI"
                           Margin="0,0,0,3"/>
                <TextBlock x:Name="TbDetailEmail" Foreground="#D0D0D0"
                           FontFamily="Segoe UI" FontSize="12"
                           TextWrapping="Wrap" Margin="0,0,0,12"/>

                <!-- Phone -->
                <TextBlock Text="PHONE" Foreground="#606060" FontSize="10"
                           FontWeight="SemiBold" FontFamily="Segoe UI"
                           Margin="0,0,0,3"/>
                <TextBlock x:Name="TbDetailPhone" Foreground="#D0D0D0"
                           FontFamily="Segoe UI" FontSize="12"
                           Margin="0,0,0,12"/>

                <!-- Status badges -->
                <TextBlock Text="STATUS" Foreground="#606060" FontSize="10"
                           FontWeight="SemiBold" FontFamily="Segoe UI"
                           Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Border x:Name="BadgeActive" CornerRadius="4"
                            Background="#1A3A1A" Padding="8,3" Margin="0,0,6,0">
                        <TextBlock x:Name="TbBadgeActive" Text="Active"
                                   Foreground="#4CAF50" FontSize="11"
                                   FontFamily="Segoe UI"/>
                    </Border>
                    <Border x:Name="BadgeVerified" CornerRadius="4"
                            Background="#1A2A3A" Padding="8,3">
                        <TextBlock x:Name="TbBadgeVerified" Text="Verified"
                                   Foreground="#2196F3" FontSize="11"
                                   FontFamily="Segoe UI"/>
                    </Border>
                </StackPanel>

                <TextBlock x:Name="TbDetailJoined" Foreground="#606060"
                           FontFamily="Segoe UI" FontSize="11"
                           Margin="0,0,0,20"/>

                <!-- Deactivate button -->
                <Button x:Name="BtnDeactivate"
                        Content="Deactivate User" Height="38"
                        Background="#CC0000" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                        IsEnabled="False"
                        Click="BtnDeactivate_Click"/>

                <!-- Feedback -->
                <TextBlock x:Name="TbUsersSuccess"
                           Foreground="#4CAF50" FontFamily="Segoe UI"
                           FontSize="12" TextWrapping="Wrap"
                           Margin="0,10,0,0" Visibility="Collapsed"/>
                <TextBlock x:Name="TbUsersActionError"
                           Foreground="#CC0000" FontFamily="Segoe UI"
                           FontSize="12" TextWrapping="Wrap"
                           Margin="0,10,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
