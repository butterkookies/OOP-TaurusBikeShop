								</StackPanel>
							</Grid>
						</Border>

						<Border Style="{StaticResource ActivityItemCard}" BorderBrush="{StaticResource StatusYellow}">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<StackPanel Grid.Column="0">
									<TextBlock Text="ORD-20260310-002" Foreground="{StaticResource TextPrimary}" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
									<TextBlock Text="Maria Santos" Foreground="{StaticResource TextSecondary}" FontSize="11" FontFamily="Segoe UI" Margin="0,2,0,0"/>
									<TextBlock Text="BDO Transfer · 09:12 AM" Foreground="{StaticResource TextMuted}" FontSize="10" FontFamily="Segoe UI" Margin="0,2,0,0"/>
								</StackPanel>
								<StackPanel Grid.Column="1" HorizontalAlignment="Right">
									<TextBlock Text="₱ 12,700" Foreground="{StaticResource StatusYellow}" FontSize="12" FontWeight="Bold" FontFamily="Segoe UI" HorizontalAlignment="Right"/>
									<Button x:Name="VerifyPaymentItem2Button" Style="{StaticResource PrimaryButtonStyle}" Content="Verify" Height="24" FontSize="10" Margin="0,5,0,0" Tag="PaymentVerification"/>
								</StackPanel>
							</Grid>
						</Border>

						<Border Style="{StaticResource ActivityItemCard}" BorderBrush="{StaticResource StatusYellow}" Margin="0,0,0,14">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<StackPanel Grid.Column="0">
									<TextBlock Text="ORD-20260309-047" Foreground="{StaticResource TextPrimary}" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
									<TextBlock Text="Roberto Reyes" Foreground="{StaticResource TextSecondary}" FontSize="11" FontFamily="Segoe UI" Margin="0,2,0,0"/>
									<TextBlock Text="PayMaya · 09:30 AM" Foreground="{StaticResource TextMuted}" FontSize="10" FontFamily="Segoe UI" Margin="0,2,0,0"/>
								</StackPanel>
								<StackPanel Grid.Column="1" HorizontalAlignment="Right">
									<TextBlock Text="₱ 3,450" Foreground="{StaticResource StatusYellow}" FontSize="12" FontWeight="Bold" FontFamily="Segoe UI" HorizontalAlignment="Right"/>
									<Button x:Name="VerifyPaymentItem3Button" Style="{StaticResource PrimaryButtonStyle}" Content="Verify" Height="24" FontSize="10" Margin="0,5,0,0" Tag="PaymentVerification"/>
								</StackPanel>
							</Grid>
						</Border>

						<!-- System Alerts -->
						<TextBlock Text="SYSTEM ALERTS" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,6"/>

						<Border Background="#2C1A1A" CornerRadius="5" Padding="10,8" Margin="0,0,0,6" BorderThickness="1" BorderBrush="{StaticResource AccentRed}">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="⚠" FontSize="13" Foreground="{StaticResource AccentRed}" VerticalAlignment="Top" Margin="0,0,6,0"/>
								<StackPanel>
									<TextBlock Text="Low Stock Warning" Foreground="{StaticResource AccentRed}" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
									<TextBlock Text="5 items below minimum threshold." Foreground="{StaticResource TextSecondary}" FontSize="10" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,2,0,0"/>
									<Button x:Name="ReviewInventoryButton" Style="{StaticResource GhostButtonStyle}" Content="Review Now" Height="24" FontSize="10" Margin="0,6,0,0" HorizontalAlignment="Left" Tag="Inventory"/>
								</StackPanel>
							</StackPanel>
						</Border>

						<Border Background="#1A1E2C" CornerRadius="5" Padding="10,8" Margin="0,0,0,6" BorderThickness="1" BorderBrush="{StaticResource StatusBlue}">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="🎫" FontSize="13" VerticalAlignment="Top" Margin="0,0,6,0"/>
								<StackPanel>
									<TextBlock Text="New Support Ticket" Foreground="{StaticResource StatusBlue}" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
									<TextBlock Text="#TKT-0082 — Delivery issue reported." Foreground="{StaticResource TextSecondary}" FontSize="10" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,2,0,0"/>
									<Button x:Name="ViewTicketButton" Style="{StaticResource GhostButtonStyle}" Content="View Ticket" Height="24" FontSize="10" Margin="0,6,0,0" HorizontalAlignment="Left" Tag="Support"/>
								</StackPanel>
							</StackPanel>
						</Border>

						<!-- System Status -->
						<Border Background="{StaticResource BackgroundCard}" CornerRadius="5" Padding="10,8" Margin="0,6,0,0" BorderThickness="1" BorderBrush="{StaticResource BorderSubtle}">
							<StackPanel>
								<TextBlock Text="SYSTEM STATUS" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,8"/>
								<StackPanel Orientation="Horizontal" Margin="0,0,0,5">
									<Ellipse Width="7" Height="7" Fill="{StaticResource StatusGreen}" VerticalAlignment="Center" Margin="0,0,7,0"/>
									<TextBlock Text="User Database · Online" Foreground="{StaticResource TextSecondary}" FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
								</StackPanel>
								<StackPanel Orientation="Horizontal" Margin="0,0,0,5">
									<Ellipse Width="7" Height="7" Fill="{StaticResource StatusGreen}" VerticalAlignment="Center" Margin="0,0,7,0"/>
									<TextBlock Text="POS Terminal · Active" Foreground="{StaticResource TextSecondary}" FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
								</StackPanel>
								<StackPanel Orientation="Horizontal">
									<Ellipse Width="7" Height="7" Fill="{StaticResource StatusGreen}" VerticalAlignment="Center" Margin="0,0,7,0"/>
									<TextBlock Text="Payment Gateway · Online" Foreground="{StaticResource TextSecondary}" FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
								</StackPanel>
							</StackPanel>
						</Border>

					</StackPanel>
				</ScrollViewer>
			</DockPanel>
		</Border>

	</Grid>
</Window>
