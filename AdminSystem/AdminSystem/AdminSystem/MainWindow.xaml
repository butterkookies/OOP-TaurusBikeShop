									<TextBlock x:Name="Analytics_RevenueTrend" Text="↑ 12% vs prev period" Foreground="{StaticResource StatusGreen}" FontSize="11" FontFamily="Segoe UI" Margin="0,3,0,0"/>
								</StackPanel>
							</Border>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,10,10" MinWidth="180">
								<StackPanel>
									<TextBlock Text="ORDERS COMPLETED" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
