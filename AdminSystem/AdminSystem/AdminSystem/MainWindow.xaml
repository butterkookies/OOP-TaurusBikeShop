									<StackPanel Orientation="Horizontal" Margin="0,4,0,0">
										<TextBlock Text="▲ 7%" Foreground="{StaticResource StatusGreen}" FontSize="11" FontWeight="SemiBold"/>
										<TextBlock Text=" ≥ ₱ 10,000" Foreground="{StaticResource TextMuted}" FontSize="11"/>
									</StackPanel>
								</StackPanel>
							</Border>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,10" MinWidth="170">
								<StackPanel>
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*"/>
											<ColumnDefinition Width="Auto"/>
										</Grid.ColumnDefinitions>
										<TextBlock Text="Total Pending Revenue" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI"/>
										<Border Grid.Column="1" Width="28" Height="28" CornerRadius="5" Background="#1A2030">
											<TextBlock Text="₱" Foreground="{StaticResource StatusBlue}" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
									</Grid>
									<TextBlock Text="₱ 284,610" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,6,0,0"/>
									<StackPanel Orientation="Horizontal" Margin="0,4,0,0">
										<TextBlock Text="▲ 18%" Foreground="{StaticResource StatusGreen}" FontSize="11" FontWeight="SemiBold"/>
										<TextBlock Text=" from last week" Foreground="{StaticResource TextMuted}" FontSize="11"/>
									</StackPanel>
								</StackPanel>
							</Border>
						</ItemsControl>

						<!-- Search and Filter panel -->
						<Border Style="{StaticResource PageCard}">
							<StackPanel>
								<TextBlock Text="SEARCH &amp; FILTERS" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,10"/>
								<Grid Margin="0,0,0,10">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="12"/>
										<ColumnDefinition Width="Auto"/>
									</Grid.ColumnDefinitions>
									<Border Background="#2C2C2C" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="4" Height="36">
										<Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="Auto"/>
												<ColumnDefinition Width="*"/>
											</Grid.ColumnDefinitions>
											<TextBlock Text="🔍" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"/>
											<TextBox Grid.Column="1" x:Name="PO_SearchBox" Style="{StaticResource SearchTextBoxStyle}" BorderThickness="0" Background="Transparent" Height="34"/>
										</Grid>
									</Border>
									<Button Grid.Column="2" Style="{StaticResource GhostButtonStyle}" Content="✕ Reset" x:Name="PO_ResetFilters"/>
								</Grid>
								<!-- Filter dropdowns — wrap on small screens -->
								<WrapPanel>
									<StackPanel Margin="0,0,12,8" MinWidth="140">
										<TextBlock Text="Payment Status" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,4"/>
										<ComboBox Style="{StaticResource ComboStyle}" x:Name="PO_PaymentFilter" Width="140">
											<ComboBoxItem IsSelected="True">All Statuses</ComboBoxItem>
											<ComboBoxItem>Pending</ComboBoxItem>
											<ComboBoxItem>Paid</ComboBoxItem>
											<ComboBoxItem>Failed</ComboBoxItem>
											<ComboBoxItem>Refunded</ComboBoxItem>
										</ComboBox>
									</StackPanel>
									<StackPanel Margin="0,0,12,8" MinWidth="140">
										<TextBlock Text="Order Status" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,4"/>
										<ComboBox Style="{StaticResource ComboStyle}" x:Name="PO_OrderStatusFilter" Width="140">
											<ComboBoxItem IsSelected="True">All Statuses</ComboBoxItem>
											<ComboBoxItem>Pending</ComboBoxItem>
											<ComboBoxItem>Processing</ComboBoxItem>
											<ComboBoxItem>Shipped</ComboBoxItem>
											<ComboBoxItem>Completed</ComboBoxItem>
											<ComboBoxItem>Cancelled</ComboBoxItem>
										</ComboBox>
									</StackPanel>
									<StackPanel Margin="0,0,12,8">
										<TextBlock Text="Date From" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,4"/>
										<DatePicker x:Name="PO_DateFrom" Background="#2C2C2C" Foreground="{StaticResource TextPrimary}" Height="36" Width="140"/>
									</StackPanel>
									<StackPanel Margin="0,0,12,8">
										<TextBlock Text="Date To" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,4"/>
										<DatePicker x:Name="PO_DateTo" Background="#2C2C2C" Foreground="{StaticResource TextPrimary}" Height="36" Width="140"/>
									</StackPanel>
									<StackPanel VerticalAlignment="Bottom" Margin="0,0,0,10">
										<TextBlock Text="High Value Only" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,8"/>
										<CheckBox Style="{StaticResource ToggleSwitchStyle}" x:Name="PO_HighValueToggle">
											<TextBlock Text="≥ ₱10K" Foreground="{StaticResource TextSecondary}" FontSize="12" FontFamily="Segoe UI"/>
										</CheckBox>
									</StackPanel>
								</WrapPanel>
							</StackPanel>
						</Border>

						<!-- Bulk Action Bar -->
						<Border x:Name="PO_BulkBar"
                                Background="#2C1A1A" BorderBrush="{StaticResource AccentRed}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="14,8" Margin="0,0,0,10"
                                Visibility="Collapsed">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
									<TextBlock x:Name="PO_SelectedCountLabel" Text="0 orders selected" Foreground="{StaticResource AccentRed}" FontWeight="SemiBold" FontSize="12" FontFamily="Segoe UI"/>
									<TextBlock Text=" — choose action:" Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI"/>
								</StackPanel>
								<StackPanel Grid.Column="2" Orientation="Horizontal">
									<Button x:Name="PO_BulkApprove" Style="{StaticResource ApproveButtonStyle}" Content="✔ Approve" Height="30" Padding="10,0" Margin="0,0,5,0"/>
									<Button x:Name="PO_BulkReject" Style="{StaticResource DangerButtonStyle}" Content="✖ Reject" Height="30" Padding="10,0" Margin="0,0,5,0"/>
									<Button x:Name="PO_BulkLogistics" Style="{StaticResource GhostButtonStyle}" Content="🚚 Logistics" Height="30" Padding="10,0" Margin="0,0,5,0"/>
									<Button x:Name="PO_BulkExport" Style="{StaticResource GhostButtonStyle}" Content="⤓ Export" Height="30" Padding="10,0" Margin="0,0,5,0"/>
									<Button x:Name="PO_ClearSelection" Style="{StaticResource GhostButtonStyle}" Content="✕" Height="30" Width="30" Padding="0"/>
								</StackPanel>
							</Grid>
						</Border>

						<!-- Orders DataGrid -->
						<Border Style="{StaticResource PageCard}" Padding="0">
							<DataGrid x:Name="DgOrders" Style="{StaticResource AdminDataGridStyle}" Height="300" SelectionChanged="DgOrders_SelectionChanged">
								<DataGrid.Columns>
									<DataGridCheckBoxColumn Width="34" CanUserResize="False"/>
									<DataGridTemplateColumn Header="ORDER ID" Width="105" CanUserResize="False">
										<DataGridTemplateColumn.CellTemplate>
											<DataTemplate>
												<TextBlock Text="{Binding OrderId}" Foreground="{StaticResource AccentRed}" FontWeight="SemiBold" FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="10,0"/>
											</DataTemplate>
										</DataGridTemplateColumn.CellTemplate>
									</DataGridTemplateColumn>
									<DataGridTemplateColumn Header="CUSTOMER" Width="145">
										<DataGridTemplateColumn.CellTemplate>
											<DataTemplate>
												<StackPanel VerticalAlignment="Center" Margin="4,0">
													<TextBlock Text="{Binding CustomerName}" Foreground="{StaticResource TextPrimary}" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI"/>
													<TextBlock Text="{Binding CustomerEmail}" Foreground="{StaticResource TextMuted}" FontSize="10" FontFamily="Segoe UI"/>
												</StackPanel>
											</DataTemplate>
										</DataGridTemplateColumn.CellTemplate>
									</DataGridTemplateColumn>
									<DataGridTemplateColumn Header="ORDER DATE" Width="110" CanUserResize="False">
										<DataGridTemplateColumn.CellTemplate>
											<DataTemplate>
												<StackPanel VerticalAlignment="Center" Margin="4,0">
													<TextBlock Text="{Binding OrderDate, StringFormat='MMM dd, yyyy'}" Foreground="{StaticResource TextSecondary}" FontSize="12" FontFamily="Segoe UI"/>
													<TextBlock Text="{Binding OrderDate, StringFormat='hh:mm tt'}" Foreground="{StaticResource TextMuted}" FontSize="10" FontFamily="Segoe UI"/>
												</StackPanel>
											</DataTemplate>
										</DataGridTemplateColumn.CellTemplate>
									</DataGridTemplateColumn>
									<DataGridTextColumn Header="ITEMS" Binding="{Binding ItemCount}" Width="55" CanUserResize="False"/>
									<DataGridTemplateColumn Header="TOTAL" Width="105" CanUserResize="False">
										<DataGridTemplateColumn.CellTemplate>
											<DataTemplate>
												<TextBlock Text="{Binding TotalAmount, StringFormat='₱ {0:N2}'}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="4,0"/>
											</DataTemplate>
										</DataGridTemplateColumn.CellTemplate>
									</DataGridTemplateColumn>
									<DataGridTemplateColumn Header="PAYMENT" Width="100" CanUserResize="False">
										<DataGridTemplateColumn.CellTemplate>
											<DataTemplate>
												<Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0">
													<Border.Style>
														<Style TargetType="Border">
															<Setter Property="Background" Value="#2C2000"/>
															<Style.Triggers>
																<DataTrigger Binding="{Binding PaymentStatus}" Value="Paid">
																	<Setter Property="Background" Value="#1A3020"/>
																</DataTrigger>
																<DataTrigger Binding="{Binding PaymentStatus}" Value="Failed">
																	<Setter Property="Background" Value="#2C1A1A"/>
																</DataTrigger>
																<DataTrigger Binding="{Binding PaymentStatus}" Value="Refunded">
																	<Setter Property="Background" Value="#0D2137"/>
																</DataTrigger>
															</Style.Triggers>
														</Style>
													</Border.Style>
													<TextBlock Text="{Binding PaymentStatus}" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI">
														<TextBlock.Style>
															<Style TargetType="TextBlock">
																<Setter Property="Foreground" Value="{StaticResource StatusYellow}"/>
																<Style.Triggers>
																	<DataTrigger Binding="{Binding PaymentStatus}" Value="Paid">
																		<Setter Property="Foreground" Value="{StaticResource StatusGreen}"/>
																	</DataTrigger>
																	<DataTrigger Binding="{Binding PaymentStatus}" Value="Failed">
																		<Setter Property="Foreground" Value="{StaticResource AccentRed}"/>
																	</DataTrigger>
																	<DataTrigger Binding="{Binding PaymentStatus}" Value="Refunded">
																		<Setter Property="Foreground" Value="{StaticResource StatusBlue}"/>
																	</DataTrigger>
																</Style.Triggers>
															</Style>
														</TextBlock.Style>
													</TextBlock>
												</Border>
											</DataTemplate>
										</DataGridTemplateColumn.CellTemplate>
									</DataGridTemplateColumn>
									<DataGridTemplateColumn Header="STATUS" Width="105" CanUserResize="False">
										<DataGridTemplateColumn.CellTemplate>
											<DataTemplate>
												<Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0">
													<Border.Style>
														<Style TargetType="Border">
															<Setter Property="Background" Value="#333333"/>
															<Style.Triggers>
																<DataTrigger Binding="{Binding OrderStatus}" Value="Processing">
																	<Setter Property="Background" Value="#0D2137"/>
																</DataTrigger>
																<DataTrigger Binding="{Binding OrderStatus}" Value="Shipped">
																	<Setter Property="Background" Value="#22103A"/>
																</DataTrigger>
																<DataTrigger Binding="{Binding OrderStatus}" Value="Completed">
																	<Setter Property="Background" Value="#1A3020"/>
																</DataTrigger>
																<DataTrigger Binding="{Binding OrderStatus}" Value="Cancelled">
																	<Setter Property="Background" Value="#2C1A1A"/>
																</DataTrigger>
															</Style.Triggers>
														</Style>
													</Border.Style>
													<TextBlock Text="{Binding OrderStatus}" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI">
														<TextBlock.Style>
															<Style TargetType="TextBlock">
																<Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
																<Style.Triggers>
																	<DataTrigger Binding="{Binding OrderStatus}" Value="Processing">
																		<Setter Property="Foreground" Value="{StaticResource StatusBlue}"/>
																	</DataTrigger>
																	<DataTrigger Binding="{Binding OrderStatus}" Value="Shipped">
																		<Setter Property="Foreground" Value="{StaticResource StatusPurple}"/>
																	</DataTrigger>
																	<DataTrigger Binding="{Binding OrderStatus}" Value="Completed">
																		<Setter Property="Foreground" Value="{StaticResource StatusGreen}"/>
																	</DataTrigger>
																	<DataTrigger Binding="{Binding OrderStatus}" Value="Cancelled">
																		<Setter Property="Foreground" Value="{StaticResource AccentRed}"/>
																	</DataTrigger>
																</Style.Triggers>
															</Style>
														</TextBlock.Style>
													</TextBlock>
												</Border>
											</DataTemplate>
										</DataGridTemplateColumn.CellTemplate>
									</DataGridTemplateColumn>
									<DataGridTemplateColumn Header="ACTIONS" Width="*">
										<DataGridTemplateColumn.CellTemplate>
											<DataTemplate>
												<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
													<Button Style="{StaticResource TableActionStyle}" Content="View" Tag="{Binding OrderId}"/>
													<Button Style="{StaticResource ApproveButtonStyle}" Content="Approve" Tag="{Binding OrderId}"/>
													<Button Style="{StaticResource DangerButtonStyle}" Content="Reject" Tag="{Binding OrderId}"/>
													<Button Style="{StaticResource TableActionStyle}" Content="Logistics" Tag="{Binding OrderId}"/>
												</StackPanel>
											</DataTemplate>
										</DataGridTemplateColumn.CellTemplate>
									</DataGridTemplateColumn>
								</DataGrid.Columns>
							</DataGrid>
						</Border>

						<!-- Pagination -->
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>
							<StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
								<TextBlock Text="Showing " Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI"/>
								<TextBlock Text="1–25 " Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI"/>
								<TextBlock Text="of 142 orders" Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI"/>
							</StackPanel>
							<StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
								<TextBlock Text="Per page:" Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,6,0"/>
								<ComboBox Style="{StaticResource ComboStyle}" Width="60" Height="30" Margin="0,0,10,0">
									<ComboBoxItem>10</ComboBoxItem>
									<ComboBoxItem IsSelected="True">25</ComboBoxItem>
									<ComboBoxItem>50</ComboBoxItem>
								</ComboBox>
								<Button Style="{StaticResource PageNumBtn}" Content="‹" x:Name="PO_PrevPage"/>
								<Button Style="{StaticResource PageNumBtnActive}" Content="1"/>
								<Button Style="{StaticResource PageNumBtn}" Content="2"/>
								<Button Style="{StaticResource PageNumBtn}" Content="3"/>
								<Button Style="{StaticResource PageNumBtn}" Content="›" x:Name="PO_NextPage"/>
							</StackPanel>
						</Grid>
					</StackPanel>
				</ScrollViewer>

				<!-- ══════════ PAGE: PAYMENT VERIFICATION ══════════ -->
				<ScrollViewer x:Name="PagePaymentVerification"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              Padding="20,16">
					<StackPanel>
						<TextBlock Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,14" Text="Payment Verification — Review incoming payment confirmations"/>
						<ItemsControl Margin="0,0,0,14">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<WrapPanel/>
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,10,10" Background="#1A3020" MinWidth="180">
								<StackPanel>
									<TextBlock Text="Verified Today" Foreground="{StaticResource StatusGreen}" FontSize="11" FontFamily="Segoe UI"/>
									<TextBlock Text="₱ 48,200" Foreground="{StaticResource StatusGreen}" FontSize="20" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
									<TextBlock Text="18 transactions" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI"/>
								</StackPanel>
							</Border>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,10,10" Background="#2C2000" MinWidth="180">
								<StackPanel>
									<TextBlock Text="Awaiting Review" Foreground="{StaticResource StatusYellow}" FontSize="11" FontFamily="Segoe UI"/>
									<TextBlock Text="3 payments" Foreground="{StaticResource StatusYellow}" FontSize="20" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
									<TextBlock Text="Needs attention" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI"/>
								</StackPanel>
							</Border>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,10" Background="#2C1A1A" MinWidth="180">
								<StackPanel>
									<TextBlock Text="Flagged / Failed" Foreground="{StaticResource AccentRed}" FontSize="11" FontFamily="Segoe UI"/>
									<TextBlock Text="1 payment" Foreground="{StaticResource AccentRed}" FontSize="20" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
									<TextBlock Text="Requires investigation" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI"/>
								</StackPanel>
							</Border>
						</ItemsControl>
						<Border Style="{StaticResource PageCard}">
							<StackPanel>
								<TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Unverified Payments"/>
								<DataGrid x:Name="DgPayments" Style="{StaticResource AdminDataGridStyle}" Height="220">
									<DataGrid.Columns>
										<DataGridTextColumn Header="Ref #"     Binding="{Binding RefNo}"    Width="110"/>
										<DataGridTextColumn Header="Customer"  Binding="{Binding Customer}" Width="*"/>
										<DataGridTextColumn Header="Order #"   Binding="{Binding OrderId}"  Width="90"/>
										<DataGridTextColumn Header="Amount"    Binding="{Binding Amount}"   Width="100"/>
										<DataGridTextColumn Header="Method"    Binding="{Binding Method}"   Width="100"/>
										<DataGridTextColumn Header="Submitted" Binding="{Binding Date}"     Width="110"/>
										<DataGridTextColumn Header="Status"    Binding="{Binding Status}"   Width="90"/>
									</DataGrid.Columns>
								</DataGrid>
							</StackPanel>
						</Border>
						<Border Style="{StaticResource PageCard}">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="240"/>
								</Grid.ColumnDefinitions>
								<StackPanel Grid.Column="0" Margin="0,0,16,0">
									<TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Proof of Payment"/>
									<Border Background="#1A1A1A" CornerRadius="6" Height="120" BorderThickness="1" BorderBrush="{StaticResource BorderSubtle}">
										<TextBlock Text="Select a payment to view attached proof" Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center"/>
									</Border>
								</StackPanel>
								<StackPanel Grid.Column="1">
									<TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Actions"/>
									<TextBlock Text="Notes:" Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,4"/>
									<TextBox Style="{StaticResource SearchTextBoxStyle}" Height="55" TextWrapping="Wrap" Margin="0,0,0,10"/>
									<Button Style="{StaticResource PrimaryButtonStyle}" Content="✔ Confirm Verified" HorizontalAlignment="Left" Margin="0,0,0,6"/>
									<Button Style="{StaticResource GhostButtonStyle}"   Content="✖ Reject Payment"  HorizontalAlignment="Left"/>
								</StackPanel>
							</Grid>
						</Border>
					</StackPanel>
				</ScrollViewer>

				<!-- ══════════ PAGE: LOGISTICS ══════════ -->
				<ScrollViewer x:Name="PageLogistics"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              Padding="20,16">
					<StackPanel>
						<TextBlock Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,14" Text="Logistics Management — Shipment tracking and courier assignment"/>
						<ItemsControl Margin="0,0,0,14">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<WrapPanel/>
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,10,10" MinWidth="150">
								<StackPanel>
									<TextBlock Text="To Ship" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI"/>
									<TextBlock Text="8" Foreground="{StaticResource StatusYellow}" FontSize="26" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
								</StackPanel>
							</Border>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,10,10" MinWidth="150">
								<StackPanel>
									<TextBlock Text="In Transit" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI"/>
									<TextBlock Text="15" Foreground="{StaticResource StatusBlue}" FontSize="26" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
								</StackPanel>
							</Border>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,10,10" MinWidth="150">
								<StackPanel>
									<TextBlock Text="Delivered Today" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI"/>
									<TextBlock Text="22" Foreground="{StaticResource StatusGreen}" FontSize="26" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
								</StackPanel>
							</Border>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,10" MinWidth="150">
								<StackPanel>
									<TextBlock Text="Failed / Returned" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI"/>
									<TextBlock Text="2" Foreground="{StaticResource AccentRed}" FontSize="26" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
								</StackPanel>
							</Border>
						</ItemsControl>
						<Border Style="{StaticResource PageCard}">
							<StackPanel>
								<Grid Margin="0,0,0,10">
									<TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Shipment Tracking" Margin="0"/>
									<Button Style="{StaticResource PrimaryButtonStyle}" Content="+ Assign Courier" HorizontalAlignment="Right"/>
								</Grid>
								<DataGrid x:Name="DgLogistics" Style="{StaticResource AdminDataGridStyle}" Height="240">
									<DataGrid.Columns>
										<DataGridTextColumn Header="Tracking #" Binding="{Binding TrackingNo}" Width="120"/>
										<DataGridTextColumn Header="Order #"    Binding="{Binding OrderId}"    Width="90"/>
										<DataGridTextColumn Header="Customer"   Binding="{Binding Customer}"   Width="*"/>
										<DataGridTextColumn Header="Courier"    Binding="{Binding Courier}"    Width="100"/>
										<DataGridTextColumn Header="Status"     Binding="{Binding Status}"     Width="100"/>
										<DataGridTextColumn Header="ETA"        Binding="{Binding ETA}"        Width="90"/>
									</DataGrid.Columns>
								</DataGrid>
							</StackPanel>
						</Border>
						<Border Style="{StaticResource PageCard}">
							<StackPanel>
								<TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Update Shipment"/>
								<WrapPanel>
									<StackPanel Margin="0,0,10,8" MinWidth="160">
										<TextBlock Text="Tracking Number" Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,4"/>
										<TextBox Style="{StaticResource SearchTextBoxStyle}" Width="160"/>
									</StackPanel>
									<StackPanel Margin="0,0,10,8" MinWidth="140">
										<TextBlock Text="Courier" Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,4"/>
										<ComboBox Style="{StaticResource ComboStyle}" Width="140">
											<ComboBoxItem Content="J&amp;T Express"/>
											<ComboBoxItem Content="LBC"/>
											<ComboBoxItem Content="Lalamove"/>
											<ComboBoxItem Content="Grab Express"/>
										</ComboBox>
									</StackPanel>
									<StackPanel Margin="0,0,10,8" MinWidth="160">
										<TextBlock Text="Delivery Status" Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,4"/>
										<ComboBox Style="{StaticResource ComboStyle}" Width="160">
											<ComboBoxItem Content="Preparing"/>
											<ComboBoxItem Content="Picked Up"/>
											<ComboBoxItem Content="In Transit"/>
											<ComboBoxItem Content="Out for Delivery"/>
											<ComboBoxItem Content="Delivered"/>
