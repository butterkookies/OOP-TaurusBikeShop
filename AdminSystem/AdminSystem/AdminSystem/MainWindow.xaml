									<TextBlock Text="Viewing: " Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI"/>
									<TextBlock x:Name="Analytics_ActivePeriodLabel" Text="This Month" Foreground="{StaticResource AccentRed}" FontSize="12" FontWeight="SemiBold" FontFamily="Segoe UI"/>
									<TextBlock x:Name="Analytics_DateRangeLabel" Text=" · Mar 1 – Mar 10, 2026" Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI"/>
								</StackPanel>
							</Grid>
						</Border>

						<!-- Primary KPI cards -->
						<ItemsControl Margin="0,0,0,14">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<WrapPanel/>
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,10,10" MinWidth="180">
								<StackPanel>
									<TextBlock Text="TOTAL REVENUE" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
