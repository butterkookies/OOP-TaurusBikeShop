							</StackPanel>
						</Border>
					</StackPanel>
				</ScrollViewer>

				<!-- ══════════ PAGE: WALK-IN POS ══════════ -->
				<Grid x:Name="PageWalkInPOS" Visibility="Collapsed">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="260" MinWidth="220" MaxWidth="300"/>
					</Grid.ColumnDefinitions>
					<ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="20,16">
						<StackPanel>
							<TextBlock Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,14" Text="Walk-In Point of Sale — Process in-store transactions"/>
							<Border Background="#2C2C2C" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="4" Height="36" Margin="0,0,0,14">
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="Auto"/>
										<ColumnDefinition Width="*"/>
									</Grid.ColumnDefinitions>
									<TextBlock Text="🔍" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"/>
									<TextBox Grid.Column="1" Style="{StaticResource SearchTextBoxStyle}" BorderThickness="0" Background="Transparent" Height="34"/>
								</Grid>
							</Border>
							<TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Products"/>
							<!-- ══ PRODUCT CARDS — entire card is clickable ══
                                     Each Button uses a custom Template that renders as a
                                     dark card with hover highlight. x:Name matches the
                                     catalogue key in code-behind so no CS changes needed. -->
							<UniformGrid x:Name="PosProductGrid" Columns="3">

								<!-- Shared card button style defined inline via Template -->
								<UniformGrid.Resources>
									<Style x:Key="PosCardBtn" TargetType="Button">
										<Setter Property="Background"      Value="#333333"/>
										<Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
										<Setter Property="BorderThickness" Value="1"/>
										<Setter Property="BorderBrush"     Value="{StaticResource BorderSubtle}"/>
										<Setter Property="Cursor"          Value="Hand"/>
										<Setter Property="Padding"         Value="12"/>
										<Setter Property="HorizontalContentAlignment" Value="Stretch"/>
										<Setter Property="VerticalContentAlignment"   Value="Stretch"/>
										<Setter Property="Template">
											<Setter.Value>
												<ControlTemplate TargetType="Button">
													<Border x:Name="CardBorder"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="8"
                                                            Padding="{TemplateBinding Padding}">
														<ContentPresenter/>
													</Border>
													<ControlTemplate.Triggers>
														<Trigger Property="IsMouseOver" Value="True">
															<Setter TargetName="CardBorder" Property="Background"    Value="#3D3D3D"/>
															<Setter TargetName="CardBorder" Property="BorderBrush"   Value="{StaticResource AccentRed}"/>
														</Trigger>
														<Trigger Property="IsPressed" Value="True">
															<Setter TargetName="CardBorder" Property="Background" Value="#2A2A2A"/>
														</Trigger>
													</ControlTemplate.Triggers>
												</ControlTemplate>
											</Setter.Value>
										</Setter>
									</Style>
								</UniformGrid.Resources>

								<Button x:Name="BtnAddBike" Style="{StaticResource PosCardBtn}" Margin="0,0,8,8">
									<StackPanel>
										<Border Background="{StaticResource BackgroundPanel}" CornerRadius="6" Height="48" Margin="0,0,0,8">
											<TextBlock Text="🚲" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
										<TextBlock Text="Road Bike Frame" Foreground="{StaticResource TextPrimary}" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
										<TextBlock Text="₱ 4,500" Foreground="{StaticResource StatusGreen}" FontSize="12" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,3,0,0"/>
										<Border Background="{StaticResource AccentRed}" CornerRadius="4" Height="28" Margin="0,8,0,0">
											<TextBlock Text="+ Add" Foreground="White" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
									</StackPanel>
								</Button>

								<Button x:Name="BtnAddGear" Style="{StaticResource PosCardBtn}" Margin="0,0,8,8">
									<StackPanel>
										<Border Background="{StaticResource BackgroundPanel}" CornerRadius="6" Height="48" Margin="0,0,0,8">
											<TextBlock Text="⚙" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
										<TextBlock Text="Gear Set 21-Speed" Foreground="{StaticResource TextPrimary}" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
										<TextBlock Text="₱ 1,200" Foreground="{StaticResource StatusGreen}" FontSize="12" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,3,0,0"/>
										<Border Background="{StaticResource AccentRed}" CornerRadius="4" Height="28" Margin="0,8,0,0">
											<TextBlock Text="+ Add" Foreground="White" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
									</StackPanel>
								</Button>

								<Button x:Name="BtnAddBrake" Style="{StaticResource PosCardBtn}" Margin="0,0,0,8">
									<StackPanel>
										<Border Background="{StaticResource BackgroundPanel}" CornerRadius="6" Height="48" Margin="0,0,0,8">
											<TextBlock Text="🔧" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
										<TextBlock Text="Brake Kit" Foreground="{StaticResource TextPrimary}" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
										<TextBlock Text="₱ 850" Foreground="{StaticResource StatusGreen}" FontSize="12" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,3,0,0"/>
										<Border Background="{StaticResource AccentRed}" CornerRadius="4" Height="28" Margin="0,8,0,0">
											<TextBlock Text="+ Add" Foreground="White" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
									</StackPanel>
								</Button>

								<Button x:Name="BtnAddHelmet" Style="{StaticResource PosCardBtn}" Margin="0,0,8,0">
									<StackPanel>
										<Border Background="{StaticResource BackgroundPanel}" CornerRadius="6" Height="48" Margin="0,0,0,8">
											<TextBlock Text="🪖" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
										<TextBlock Text="Helmet Pro" Foreground="{StaticResource TextPrimary}" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
										<TextBlock Text="₱ 1,800" Foreground="{StaticResource StatusGreen}" FontSize="12" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,3,0,0"/>
										<Border Background="{StaticResource AccentRed}" CornerRadius="4" Height="28" Margin="0,8,0,0">
											<TextBlock Text="+ Add" Foreground="White" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
									</StackPanel>
								</Button>

								<Button x:Name="BtnAddRepair" Style="{StaticResource PosCardBtn}" Margin="0,0,8,0">
									<StackPanel>
										<Border Background="{StaticResource BackgroundPanel}" CornerRadius="6" Height="48" Margin="0,0,0,8">
											<TextBlock Text="🧰" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
										<TextBlock Text="Repair Kit" Foreground="{StaticResource TextPrimary}" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
										<TextBlock Text="₱ 450" Foreground="{StaticResource StatusGreen}" FontSize="12" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,3,0,0"/>
										<Border Background="{StaticResource AccentRed}" CornerRadius="4" Height="28" Margin="0,8,0,0">
											<TextBlock Text="+ Add" Foreground="White" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
									</StackPanel>
								</Button>

								<Button x:Name="BtnAddLight" Style="{StaticResource PosCardBtn}" Margin="0">
									<StackPanel>
										<Border Background="{StaticResource BackgroundPanel}" CornerRadius="6" Height="48" Margin="0,0,0,8">
											<TextBlock Text="💡" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
										<TextBlock Text="Bike Light Set" Foreground="{StaticResource TextPrimary}" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
										<TextBlock Text="₱ 680" Foreground="{StaticResource StatusGreen}" FontSize="12" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,3,0,0"/>
										<Border Background="{StaticResource AccentRed}" CornerRadius="4" Height="28" Margin="0,8,0,0">
											<TextBlock Text="+ Add" Foreground="White" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI" HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
									</StackPanel>
								</Button>

							</UniformGrid>
						</StackPanel>
					</ScrollViewer>
					<!-- Cart panel -->
					<Border Grid.Column="1" Background="{StaticResource BackgroundSecondary}" BorderThickness="1,0,0,0" BorderBrush="{StaticResource BorderSubtle}">
						<DockPanel Margin="14">
							<TextBlock DockPanel.Dock="Top" Text="Current Sale" Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,12"/>
							<StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
								<TextBlock Text="Customer Name" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,4"/>
								<TextBox x:Name="PosCustomerNameBox" Style="{StaticResource SearchTextBoxStyle}"/>
							</StackPanel>
							<StackPanel DockPanel.Dock="Bottom">
								<Separator Background="{StaticResource BorderSubtle}" Height="1" Margin="0,0,0,10"/>
								<Grid Margin="0,0,0,5">
									<TextBlock Text="Subtotal:" Foreground="{StaticResource TextSecondary}" FontFamily="Segoe UI" FontSize="12"/>
									<TextBlock x:Name="PosSubtotalText" Text="₱ 0.00" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Right" FontFamily="Segoe UI" FontSize="12"/>
								</Grid>

								<!-- ── Coupon row ── -->
								<Grid Margin="0,0,0,5">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="6"/>
										<ColumnDefinition Width="Auto"/>
										<ColumnDefinition Width="4"/>
										<ColumnDefinition Width="Auto"/>
									</Grid.ColumnDefinitions>
									<TextBox x:Name="PosCouponBox"
                                             Grid.Column="0"
                                             Style="{StaticResource SearchTextBoxStyle}"
                                             Height="30" FontSize="11"
                                             Tag="Enter coupon code..."/>
									<Button x:Name="BtnApplyCoupon"
                                            Grid.Column="2"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Content="Apply" Height="30"
                                            Padding="8,0" FontSize="11"/>
									<Button x:Name="BtnCreateCoupon"
                                            Grid.Column="4"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Content="+ New" Height="30"
                                            Padding="8,0" FontSize="11"/>
								</Grid>

								<!-- Active coupon badge — hidden until a coupon is applied -->
								<Border x:Name="PosCouponBadge"
                                        Visibility="Collapsed"
                                        Background="#1A3020"
                                        BorderBrush="{StaticResource StatusGreen}"
                                        BorderThickness="1" CornerRadius="4"
                                        Padding="8,5" Margin="0,0,0,5">
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*"/>
											<ColumnDefinition Width="Auto"/>
										</Grid.ColumnDefinitions>
										<StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
											<TextBlock Text="🏷 " FontSize="11"/>
											<TextBlock x:Name="PosCouponBadgeLabel"
                                                       Text="SAVE10 — ₱ 0.00 off"
                                                       Foreground="{StaticResource StatusGreen}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       FontFamily="Segoe UI"/>
										</StackPanel>
										<Button x:Name="BtnRemoveCoupon"
                                                Grid.Column="1"
                                                Content="✕"
                                                Width="18" Height="18"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="{StaticResource StatusGreen}"
                                                FontSize="10" Padding="0"
                                                Cursor="Hand"
                                                VerticalContentAlignment="Center"
                                                HorizontalContentAlignment="Center"/>
									</Grid>
								</Border>

								<Grid Margin="0,0,0,5">
									<TextBlock Text="Discount:" Foreground="{StaticResource TextSecondary}" FontFamily="Segoe UI" FontSize="12"/>
									<TextBlock x:Name="PosDiscountText" Text="— ₱ 0.00" Foreground="{StaticResource StatusGreen}" HorizontalAlignment="Right" FontFamily="Segoe UI" FontSize="12"/>
								</Grid>
								<Grid Margin="0,0,0,12">
									<TextBlock Text="TOTAL:" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="Bold" FontFamily="Segoe UI"/>
									<TextBlock x:Name="PosTotalText" Text="₱ 0.00" Foreground="{StaticResource StatusGreen}" FontSize="15" FontWeight="Bold" HorizontalAlignment="Right" FontFamily="Segoe UI"/>
								</Grid>
								<TextBlock Text="Payment Method" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,4"/>
								<ComboBox x:Name="PosPaymentCombo" Style="{StaticResource ComboStyle}" Margin="0,0,0,10">
									<ComboBoxItem Content="Cash" IsSelected="True"/>
									<ComboBoxItem Content="GCash"/>
									<ComboBoxItem Content="Maya"/>
									<ComboBoxItem Content="Card"/>
								</ComboBox>
								<Button x:Name="BtnProcessPayment" Style="{StaticResource PrimaryButtonStyle}" Content="Process Payment" HorizontalAlignment="Stretch" Height="40" Margin="0,0,0,6"/>
								<Button x:Name="BtnClearCart" Style="{StaticResource GhostButtonStyle}" Content="Clear Cart" HorizontalAlignment="Stretch"/>
							</StackPanel>
							<ScrollViewer VerticalScrollBarVisibility="Auto">
								<StackPanel x:Name="PosCartList">
									<TextBlock Text="Cart is empty" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,24,0,0" FontFamily="Segoe UI" FontSize="12"/>
								</StackPanel>
							</ScrollViewer>
						</DockPanel>
					</Border>
				</Grid>

				<!-- ══════════ PAGE: INVENTORY ══════════ -->
				<ScrollViewer x:Name="PageInventory"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              Padding="20,16">
					<StackPanel>
						<TextBlock Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,14" Text="Inventory Management — Stock levels, SKUs, product catalogue"/>
						<ItemsControl Margin="0,0,0,14">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<WrapPanel/>
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,10,10" MinWidth="150">
								<StackPanel>
									<TextBlock Text="Total SKUs" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI"/>
									<TextBlock Text="142" Foreground="{StaticResource TextPrimary}" FontSize="26" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
								</StackPanel>
							</Border>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,10,10" MinWidth="150">
								<StackPanel>
									<TextBlock Text="In Stock" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI"/>
									<TextBlock Text="137" Foreground="{StaticResource StatusGreen}" FontSize="26" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
								</StackPanel>
							</Border>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,10,10" MinWidth="150">
								<StackPanel>
									<TextBlock Text="Low Stock" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI"/>
									<TextBlock Text="5" Foreground="{StaticResource StatusYellow}" FontSize="26" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
								</StackPanel>
							</Border>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,10" MinWidth="150">
								<StackPanel>
									<TextBlock Text="Out of Stock" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI"/>
									<TextBlock Text="0" Foreground="{StaticResource AccentRed}" FontSize="26" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
								</StackPanel>
							</Border>
						</ItemsControl>
						<Border Style="{StaticResource PageCard}">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="140"/>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<TextBox Grid.Column="0" Style="{StaticResource SearchTextBoxStyle}" Margin="0,0,6,0"/>
								<ComboBox Grid.Column="1" Style="{StaticResource ComboStyle}" Margin="0,0,6,0">
									<ComboBoxItem Content="All Categories" IsSelected="True"/>
									<ComboBoxItem Content="Bikes"/>
									<ComboBoxItem Content="Parts"/>
									<ComboBoxItem Content="Accessories"/>
								</ComboBox>
								<Button Grid.Column="2" Style="{StaticResource GhostButtonStyle}" Content="⤓ Export" Margin="0,0,6,0"/>
								<Button Grid.Column="3" Style="{StaticResource PrimaryButtonStyle}" Content="+ Add Product"/>
							</Grid>
						</Border>
						<Border Style="{StaticResource PageCard}">
							<DataGrid x:Name="DgInventory" Style="{StaticResource AdminDataGridStyle}" Height="260">
								<DataGrid.Columns>
									<DataGridTextColumn Header="SKU"        Binding="{Binding SKU}"       Width="80"/>
									<DataGridTextColumn Header="Product"    Binding="{Binding Product}"   Width="*"/>
									<DataGridTextColumn Header="Category"   Binding="{Binding Category}"  Width="100"/>
									<DataGridTextColumn Header="In Stock"   Binding="{Binding Stock}"     Width="75"/>
									<DataGridTextColumn Header="Reorder At" Binding="{Binding ReorderAt}" Width="85"/>
									<DataGridTextColumn Header="Price"      Binding="{Binding Price}"     Width="90"/>
									<DataGridTextColumn Header="Supplier"   Binding="{Binding Supplier}"  Width="*"/>
									<DataGridTextColumn Header="Status"     Binding="{Binding Status}"    Width="80"/>
								</DataGrid.Columns>
							</DataGrid>
						</Border>
						<Border Style="{StaticResource PageCard}">
							<StackPanel>
								<TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Add / Edit Product"/>
								<WrapPanel>
									<StackPanel Margin="0,0,10,8" MinWidth="180">
										<TextBlock Text="Product Name" Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,4"/>
										<TextBox Style="{StaticResource SearchTextBoxStyle}" Width="180"/>
									</StackPanel>
									<StackPanel Margin="0,0,10,8" MinWidth="140">
										<TextBlock Text="Category" Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,4"/>
