									<TextBlock x:Name="Analytics_OrdersTrend" Text="↑ 8 more than prev period" Foreground="{StaticResource StatusBlue}" FontSize="11" FontFamily="Segoe UI" Margin="0,3,0,0"/>
								</StackPanel>
							</Border>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,10,10" MinWidth="180">
								<StackPanel>
									<TextBlock Text="AVG. ORDER VALUE" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
									<TextBlock x:Name="Analytics_AvgOrder" Text="₱ 1,641" Foreground="{StaticResource StatusYellow}" FontSize="20" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,5,0,0"/>
									<TextBlock x:Name="Analytics_AvgOrderTrend" Text="↓ 2% vs prev period" Foreground="{StaticResource AccentRed}" FontSize="11" FontFamily="Segoe UI" Margin="0,3,0,0"/>
								</StackPanel>
							</Border>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,10" MinWidth="180">
								<StackPanel>
									<TextBlock Text="NEW CUSTOMERS" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
									<TextBlock x:Name="Analytics_Customers" Text="34" Foreground="#CE93D8" FontSize="20" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,5,0,0"/>
									<TextBlock x:Name="Analytics_CustomersTrend" Text="↑ 6 more than prev period" Foreground="#CE93D8" FontSize="11" FontFamily="Segoe UI" Margin="0,3,0,0"/>
								</StackPanel>
							</Border>
						</ItemsControl>

						<!-- Secondary KPI cards -->
						<ItemsControl Margin="0,0,0,14">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<WrapPanel/>
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,10,10" MinWidth="160">
								<StackPanel>
									<TextBlock Text="WALK-IN SALES" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
									<TextBlock x:Name="Analytics_WalkIn" Text="₱ 38,400" Foreground="{StaticResource TextPrimary}" FontSize="17" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,5,0,0"/>
									<TextBlock x:Name="Analytics_WalkInSub" Text="24 transactions" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI" Margin="0,3,0,0"/>
								</StackPanel>
							</Border>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,10,10" MinWidth="160">
								<StackPanel>
									<TextBlock Text="ONLINE SALES" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
									<TextBlock x:Name="Analytics_Online" Text="₱ 104,400" Foreground="{StaticResource TextPrimary}" FontSize="17" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,5,0,0"/>
									<TextBlock x:Name="Analytics_OnlineSub" Text="63 transactions" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI" Margin="0,3,0,0"/>
								</StackPanel>
							</Border>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,10,10" MinWidth="160">
								<StackPanel>
									<TextBlock Text="REFUNDS ISSUED" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
									<TextBlock x:Name="Analytics_Refunds" Text="₱ 4,200" Foreground="{StaticResource AccentRed}" FontSize="17" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,5,0,0"/>
									<TextBlock x:Name="Analytics_RefundsSub" Text="3 refunds" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI" Margin="0,3,0,0"/>
								</StackPanel>
							</Border>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,10" MinWidth="160">
								<StackPanel>
									<TextBlock Text="CANCELLED ORDERS" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
									<TextBlock x:Name="Analytics_Cancelled" Text="7" Foreground="{StaticResource StatusYellow}" FontSize="17" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,5,0,0"/>
									<TextBlock x:Name="Analytics_CancelledSub" Text="↓ 2 vs prev period" Foreground="{StaticResource StatusGreen}" FontSize="11" FontFamily="Segoe UI" Margin="0,3,0,0"/>
								</StackPanel>
							</Border>
						</ItemsControl>

						<!-- Chart placeholders -->
						<Grid Margin="0,0,0,14">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="2*" MinWidth="280"/>
								<ColumnDefinition Width="*" MinWidth="200"/>
							</Grid.ColumnDefinitions>
							<Border Grid.Column="0" Style="{StaticResource PageCard}" Margin="0,0,10,0">
								<StackPanel>
									<Grid Margin="0,0,0,10">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*"/>
											<ColumnDefinition Width="Auto"/>
										</Grid.ColumnDefinitions>
										<TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Sales Over Time" Margin="0"/>
										<TextBlock Grid.Column="1" x:Name="Analytics_ChartPeriodLabel" Text="This Month" Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
									</Grid>
									<Border Background="{StaticResource BackgroundPrimary}" CornerRadius="6" Height="180" BorderThickness="1" BorderBrush="{StaticResource BorderSubtle}">
										<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
											<TextBlock Text="📈" FontSize="28" HorizontalAlignment="Center"/>
											<TextBlock x:Name="Analytics_ChartHint" Text="Bind LiveCharts2 CartesianChart here" Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI" HorizontalAlignment="Center" Margin="0,6,0,0"/>
											<TextBlock x:Name="Analytics_ChartSubHint" Text="Data source: This Month" Foreground="{StaticResource AccentRed}" FontSize="11" FontFamily="Segoe UI" HorizontalAlignment="Center" Margin="0,3,0,0"/>
										</StackPanel>
									</Border>
								</StackPanel>
							</Border>
							<Border Grid.Column="1" Style="{StaticResource PageCard}" Margin="0">
								<StackPanel>
									<TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Top Products"/>
									<Border Background="{StaticResource BackgroundPrimary}" CornerRadius="6" Height="180" BorderThickness="1" BorderBrush="{StaticResource BorderSubtle}">
										<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
											<TextBlock Text="🥧" FontSize="28" HorizontalAlignment="Center"/>
											<TextBlock Text="Bind PieChart here" Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI" HorizontalAlignment="Center" Margin="0,6,0,0"/>
										</StackPanel>
									</Border>
								</StackPanel>
							</Border>
						</Grid>

						<!-- Product performance table -->
						<Border Style="{StaticResource PageCard}">
							<StackPanel>
								<Grid Margin="0,0,0,10">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="Auto"/>
									</Grid.ColumnDefinitions>
									<TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Product Performance" Margin="0"/>
									<Button Grid.Column="1" Style="{StaticResource GhostButtonStyle}" Content="⤓ Export" Height="30" FontSize="12" Padding="10,0"/>
								</Grid>
								<DataGrid x:Name="DgAnalytics" Style="{StaticResource AdminDataGridStyle}" Height="190">
									<DataGrid.Columns>
										<DataGridTextColumn Header="Product"    Binding="{Binding Product}" Width="*"/>
										<DataGridTextColumn Header="Units Sold" Binding="{Binding Sold}"    Width="85"/>
										<DataGridTextColumn Header="Revenue"    Binding="{Binding Revenue}" Width="110"/>
										<DataGridTextColumn Header="Walk-In"    Binding="{Binding WalkIn}"  Width="80"/>
										<DataGridTextColumn Header="Online"     Binding="{Binding Online}"  Width="80"/>
										<DataGridTextColumn Header="Stock Left" Binding="{Binding Stock}"   Width="80"/>
										<DataGridTextColumn Header="Trend"      Binding="{Binding Trend}"   Width="70"/>
									</DataGrid.Columns>
								</DataGrid>
							</StackPanel>
						</Border>
					</StackPanel>
				</ScrollViewer>

				<!-- ══════════ PAGE: SUPPORT TICKETS ══════════ -->
				<ScrollViewer x:Name="PageSupport"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              Padding="20,16">
					<StackPanel>
						<TextBlock Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,14" Text="Support Tickets — Manage customer support requests and escalations"/>
						<ItemsControl Margin="0,0,0,14">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<WrapPanel/>
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,10,10" Background="#2C1A1A" MinWidth="180">
								<StackPanel>
									<TextBlock Text="Urgent / Open" Foreground="{StaticResource AccentRed}" FontSize="11" FontFamily="Segoe UI"/>
									<TextBlock Text="2" Foreground="{StaticResource AccentRed}" FontSize="26" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
									<TextBlock Text="Needs immediate attention" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI"/>
								</StackPanel>
							</Border>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,10,10" Background="#2C2000" MinWidth="180">
								<StackPanel>
									<TextBlock Text="In Progress" Foreground="{StaticResource StatusYellow}" FontSize="11" FontFamily="Segoe UI"/>
									<TextBlock Text="4" Foreground="{StaticResource StatusYellow}" FontSize="26" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
									<TextBlock Text="Being handled" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI"/>
								</StackPanel>
							</Border>
							<Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,10" Background="#1A3020" MinWidth="180">
								<StackPanel>
									<TextBlock Text="Resolved Today" Foreground="{StaticResource StatusGreen}" FontSize="11" FontFamily="Segoe UI"/>
									<TextBlock Text="3" Foreground="{StaticResource StatusGreen}" FontSize="26" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,4,0,0"/>
									<TextBlock Text="Closed tickets" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI"/>
								</StackPanel>
							</Border>
						</ItemsControl>
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="260" MinWidth="200"/>
							</Grid.ColumnDefinitions>
							<Border Grid.Column="0" Style="{StaticResource PageCard}" Margin="0,0,10,0">
								<StackPanel>
									<TextBlock Style="{StaticResource SectionHeaderStyle}" Text="All Tickets"/>
									<DataGrid x:Name="DgSupport" Style="{StaticResource AdminDataGridStyle}" Height="320">
										<DataGrid.Columns>
											<DataGridTextColumn Header="Ticket #" Binding="{Binding TicketId}" Width="75"/>
											<DataGridTextColumn Header="Customer" Binding="{Binding Customer}" Width="*"/>
											<DataGridTextColumn Header="Subject"  Binding="{Binding Subject}"  Width="*"/>
											<DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="70"/>
											<DataGridTextColumn Header="Status"   Binding="{Binding Status}"   Width="80"/>
											<DataGridTextColumn Header="Created"  Binding="{Binding Created}"  Width="95"/>
										</DataGrid.Columns>
									</DataGrid>
								</StackPanel>
							</Border>
							<Border Grid.Column="1" Style="{StaticResource PageCard}" Margin="0">
								<StackPanel>
									<TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Reply to Ticket"/>
									<TextBlock Text="Select a ticket to respond." Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI" FontSize="12" Margin="0,0,0,10"/>
									<TextBlock Text="Message:" Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,4"/>
									<TextBox Style="{StaticResource SearchTextBoxStyle}" Height="100" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>
									<TextBlock Text="Update Status:" Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,4"/>
									<ComboBox Style="{StaticResource ComboStyle}" Margin="0,0,0,12">
										<ComboBoxItem Content="Open" IsSelected="True"/>
										<ComboBoxItem Content="In Progress"/>
										<ComboBoxItem Content="Resolved"/>
										<ComboBoxItem Content="Closed"/>
									</ComboBox>
									<Button Style="{StaticResource PrimaryButtonStyle}" Content="Send Reply" HorizontalAlignment="Stretch" Height="38"/>
								</StackPanel>
							</Border>
						</Grid>
					</StackPanel>
				</ScrollViewer>

			</Grid>
			<!-- END PAGE HOST -->
		</Grid>

		<!-- ═══════════════════════════════════════════════════════════
             COLUMN 2 — RIGHT ACTIVITY FEED PANEL
             ═══════════════════════════════════════════════════════════ -->
		<Border Grid.Column="2"
                Background="{StaticResource BackgroundSecondary}"
                BorderThickness="1,0,0,0"
                BorderBrush="{StaticResource BorderSubtle}">
			<DockPanel LastChildFill="True">

				<!-- Panel header -->
				<Border DockPanel.Dock="Top" Padding="14,12"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{StaticResource BorderSubtle}">
					<TextBlock Text="Activity Feed"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="13" FontWeight="SemiBold"
                               FontFamily="Segoe UI"/>
				</Border>

				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel Margin="14,10,14,10">

						<!-- Pending Payments -->
						<TextBlock Text="PENDING PAYMENTS" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,6"/>

						<Border Style="{StaticResource ActivityItemCard}" BorderBrush="{StaticResource StatusYellow}">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<StackPanel Grid.Column="0">
									<TextBlock Text="ORD-20260310-001" Foreground="{StaticResource TextPrimary}" FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"/>
									<TextBlock Text="Juan dela Cruz" Foreground="{StaticResource TextSecondary}" FontSize="11" FontFamily="Segoe UI" Margin="0,2,0,0"/>
									<TextBlock Text="GCash · 08:45 AM" Foreground="{StaticResource TextMuted}" FontSize="10" FontFamily="Segoe UI" Margin="0,2,0,0"/>
								</StackPanel>
								<StackPanel Grid.Column="1" HorizontalAlignment="Right">
