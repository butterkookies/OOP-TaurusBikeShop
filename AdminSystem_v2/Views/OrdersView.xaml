<UserControl x:Class="AdminSystem_v2.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AdminSystem_v2.Converters"
             Background="#111827">

    <UserControl.Resources>
        <converters:StatusToColorConverter    x:Key="StatusColor"/>
        <converters:EqualityConverter         x:Key="EqualityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── DataGrid row ── -->
        <Style x:Key="OrderRow" TargetType="DataGridRow">
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="Foreground"        Value="#E5E7EB"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A2234"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E3A5F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── DataGrid cell — removes focus highlight so row colour shows ── -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#E5E7EB"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── DataGrid text padding (applied via ElementStyle on text columns) ── -->
        <Style x:Key="GridCellText" TargetType="TextBlock">
            <Setter Property="Padding"            Value="12,0"/>
            <Setter Property="VerticalAlignment"  Value="Center"/>
            <Setter Property="TextTrimming"       Value="CharacterEllipsis"/>
        </Style>

        <!-- ── Detail panel typography ── -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,0,2"/>
        </Style>
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#E5E7EB"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Margin"       Value="0,0,0,12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>   <!-- Toolbar         -->
            <RowDefinition Height="Auto"/> <!-- Messages        -->
            <RowDefinition Height="Auto"/> <!-- Status badges   -->
            <RowDefinition Height="Auto"/> <!-- Type filter     -->
            <RowDefinition Height="Auto"/> <!-- Bulk bar        -->
            <RowDefinition Height="*"/>    <!-- Main content    -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════
             ROW 0 — TOOLBAR
             ══════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1A2234"
                BorderBrush="#374151" BorderThickness="0,0,0,1" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Online Orders" Foreground="#F9FAFB"
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding Orders.Count, StringFormat='({0})'}"
                               Foreground="#6B7280" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding RefreshCommand}"
                        ToolTip="Refresh orders list"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Height="36" Padding="12,0">
                    <TextBlock Text="&#x21BB;" Foreground="#9CA3AF"
                               FontSize="16" VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 1 — STATUS MESSAGES
             ══════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#1C3A2A" Padding="20,8"
                Visibility="{Binding HasSuccess, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding SuccessMessage}" Foreground="#6EE7B7" FontSize="13"/>
        </Border>
        <Border Grid.Row="1" Background="#3B1010" Padding="20,8"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" FontSize="13"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 2 — STATUS BADGE BAR
             Dynamic count badges, double as filter chips.
             ══════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#1A2234" Padding="16,10"
                BorderBrush="#374151" BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding StatusBadges}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Borderless button wrapper -->
                            <Button Command="{Binding DataContext.SelectStatusCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Label}"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Padding="0" Margin="0,0,8,0"
                                    FocusVisualStyle="{x:Null}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Button.Template>
                                
                                <Border CornerRadius="18" Padding="12,0" Height="36">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#242D40"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <!-- Mute opacity if Count is 0 -->
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Count}" Value="0">
                                                    <Setter Property="Opacity" Value="0.6"/>
                                                </DataTrigger>
                                                <!-- Highlight active filter -->
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                            <Binding Path="DataContext.SelectedStatusFilter"
                                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                            <Binding Path="Label"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Background" Value="#313B53"/>
                                                    <Setter Property="BorderBrush" Value="#4B5563"/>
                                                </DataTrigger>
                                                <!-- Hover effect if not active -->
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="#2C364C"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Semantic Accent Dot -->
                                        <Ellipse Width="6" Height="6" Fill="{Binding AccentColor}" 
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                 
                                        <!-- Label text -->
                                        <TextBlock Text="{Binding DisplayLabel}" FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#A0AEC0"/>
                                                    <Style.Triggers>
                                                        <!-- Active filter text -->
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                                    <Binding Path="DataContext.SelectedStatusFilter"
                                                                             RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                    <Binding Path="Label"/>
                                                                </MultiBinding>
                                                            </DataTrigger.Binding>
                                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        
                                        <!-- Badge Count -->
                                        <Border CornerRadius="4" Padding="6,2" Margin="6,0,0,0"
                                                VerticalAlignment="Center">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding AccentColor.Color}" Opacity="0.15"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding Count}"
                                                       Foreground="{Binding AccentColor}"
                                                       FontSize="11" FontWeight="Bold"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 3 — ORDER TYPE FILTER (Delivery / Pickup)
             Persistent tabs to segregate order views.
             ══════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#111827" Padding="16,8"
                BorderBrush="#374151" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Order Type:" Foreground="#6B7280" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>

                <!-- All -->
                <Button Command="{Binding SelectTypeCommand}" CommandParameter="All"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Padding="0" Margin="0,0,6,0" FocusVisualStyle="{x:Null}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter/>
                        </ControlTemplate>
                    </Button.Template>
                    <Border CornerRadius="6" Padding="12,6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#1A2234"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                <Binding Path="DataContext.SelectedTypeFilter"
                                                         RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                <Binding Source="All"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="BorderBrush" Value="#9CA3AF"/>
                                        <Setter Property="Background" Value="#374151"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#9CA3AF" Margin="0,0,6,0"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="All" Foreground="#D1D5DB" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Button>

                <!-- Delivery -->
                <Button Command="{Binding SelectTypeCommand}" CommandParameter="Delivery"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Padding="0" Margin="0,0,6,0" FocusVisualStyle="{x:Null}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter/>
                        </ControlTemplate>
                    </Button.Template>
                    <Border CornerRadius="6" Padding="12,6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#1A2234"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                <Binding Path="DataContext.SelectedTypeFilter"
                                                         RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                <Binding Source="Delivery"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="BorderBrush" Value="#93C5FD"/>
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#93C5FD" Margin="0,0,6,0"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="Delivery" Foreground="#D1D5DB" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Button>

                <!-- Pickup -->
                <Button Command="{Binding SelectTypeCommand}" CommandParameter="Pickup"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Padding="0" Margin="0,0,6,0" FocusVisualStyle="{x:Null}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter/>
                        </ControlTemplate>
                    </Button.Template>
                    <Border CornerRadius="6" Padding="12,6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#1A2234"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                <Binding Path="DataContext.SelectedTypeFilter"
                                                         RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                <Binding Source="Pickup"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="BorderBrush" Value="#A5B4FC"/>
                                        <Setter Property="Background" Value="#312E81"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#A5B4FC" Margin="0,0,6,0"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="Pickup" Foreground="#D1D5DB" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Button>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 4 — BULK ACTION BAR
             Visible when at least one row is checked.
             ══════════════════════════════════════ -->
        <Border Grid.Row="4" Background="#1E3A5F" Padding="16,8"
                BorderBrush="#3B82F6" BorderThickness="0,0,0,1"
                Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
            <DockPanel>

                <!-- Right side — Deselect All and Cancel -->
                <Button DockPanel.Dock="Right" Content="Deselect All"
                        Command="{Binding DeselectAllCommand}"
                        Height="32" Padding="12,0" Cursor="Hand"
                        Background="Transparent" BorderThickness="1"
                        BorderBrush="#3B82F6" Foreground="#93C5FD" FontSize="12"
                        Margin="8,0,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2563EB"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button DockPanel.Dock="Right" Content="Cancel Orders"
                        Command="{Binding BulkCancelCommand}"
                        Style="{StaticResource DangerButton}"
                        Margin="8,0,0,0"/>

                    <!-- Left — selection count + status-update buttons -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Foreground="#60A5FA" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,16,0">
                        <Run Text="{Binding SelectionCount, Mode=OneWay}"/>
                        <Run Text=" selected"/>
                    </TextBlock>

                    <TextBlock Text="Update To:" Foreground="#9CA3AF" FontSize="12" 
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding BulkStatuses}"
                              SelectedItem="{Binding SelectedBulkStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Width="140" Height="36" Padding="12,0" Margin="0,0,12,0"
                              VerticalContentAlignment="Center" 
                              ToolTip="Select target status"/>
                    
                    <Button Content="Apply Update"
                            Command="{Binding ApplyBulkUpdateCommand}"
                            Style="{StaticResource PrimaryButton}" Height="36" Padding="12,0"
                            Margin="0,0,6,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 5 — MAIN CONTENT
             DataGrid (fills all available width) | auto-collapsing detail pane
             ══════════════════════════════════════ -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <!-- Col 0: list — always fills remaining width -->
                <ColumnDefinition Width="*" MinWidth="400"/>
                <!-- Col 1: detail panel — Auto collapses to 0 when Visibility=Collapsed -->
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════
                 COL 0 — ORDER DATAGRID
                 ═══════════════════════════════ -->
            <Grid Grid.Column="0">

                <DataGrid ItemsSource="{Binding Orders}"
                          SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="True"
                          CanUserResizeRows="False"
                          CanUserReorderColumns="False"
                          Background="#111827"
                          RowBackground="#111827"
                          AlternatingRowBackground="#0D1525"
                          Foreground="#E5E7EB"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#1F2937"
                          HeadersVisibility="Column"
                          RowHeight="46"
                          RowStyle="{StaticResource OrderRow}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"      Value="#1A2234"/>
                            <Setter Property="Foreground"      Value="#9CA3AF"/>
                            <Setter Property="FontSize"        Value="11"/>
                            <Setter Property="FontWeight"      Value="SemiBold"/>
                            <Setter Property="Padding"         Value="12,10"/>
                            <Setter Property="BorderBrush"     Value="#374151"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="Cursor"          Value="Arrow"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>

                        <!-- ── Checkbox column ── -->
                        <DataGridTemplateColumn Width="46" CanUserResize="False" CanUserSort="False">
                            <DataGridTemplateColumn.Header>
                                <!-- Select-all header checkbox binds to ViewModel.IsAllSelected -->
                                <CheckBox IsChecked="{Binding DataContext.IsAllSelected,
                                          RelativeSource={RelativeSource AncestorType=UserControl},
                                          Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay,
                                              UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- ── Order number ── -->
                        <DataGridTextColumn Header="Order #"
                                            Binding="{Binding Order.OrderNumber}"
                                            Width="130"
                                            ElementStyle="{StaticResource GridCellText}"/>

                        <!-- ── Customer ── -->
                        <DataGridTextColumn Header="Customer"
                                            Binding="{Binding Order.CustomerName}"
                                            Width="*"
                                            ElementStyle="{StaticResource GridCellText}"/>

                        <!-- ── Date + Time ── -->
                        <DataGridTextColumn Header="Date"
                                            Binding="{Binding Order.OrderDate, StringFormat='MMM d, yyyy  h:mm tt'}"
                                            Width="165"
                                            ElementStyle="{StaticResource GridCellText}"/>

                        <!-- ── Items count ── -->
                        <DataGridTextColumn Header="Items"
                                            Binding="{Binding Order.ItemCount}"
                                            Width="55"
                                            ElementStyle="{StaticResource GridCellText}"/>

                        <!-- ── Delivery type badge ── -->
                        <DataGridTemplateColumn Header="Type" Width="95"
                                                SortMemberPath="Order.DeliveryType">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="7,3"
                                            HorizontalAlignment="Left" VerticalAlignment="Center"
                                            Margin="12,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#134E4A"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Order.DeliveryType}" Value="Pickup">
                                                        <Setter Property="Background" Value="#312E81"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Order.DeliveryType}" FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#5EEAD4"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Order.DeliveryType}" Value="Pickup">
                                                            <Setter Property="Foreground" Value="#A5B4FC"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- ── Payment method (structured: Online > GCash) ── -->
                        <DataGridTextColumn Header="Payment"
                                            Binding="{Binding Order.PaymentMethodDisplay}"
                                            Width="140"
                                            ElementStyle="{StaticResource GridCellText}"/>

                        <!-- ── Status badge ── -->
                        <DataGridTemplateColumn Header="Status" Width="150"
                                                SortMemberPath="Order.OrderStatus">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="8,3"
                                            Background="#1F2937"
                                            HorizontalAlignment="Left" VerticalAlignment="Center"
                                            Margin="12,0">
                                        <TextBlock Text="{Binding Order.OrderStatus}"
                                                   Foreground="{Binding Order.OrderStatus,
                                                       Converter={StaticResource StatusColor}}"
                                                   FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty state (shown when filter yields no orders) -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Orders.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="&#x1F4CB;" FontSize="36"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="No orders found for this filter."
                               Foreground="#4B5563" FontSize="14"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Loading overlay -->
                <Border Background="#CC111827"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True"
                                     Width="180" Height="3"
                                     Background="#374151" Foreground="#3B82F6"
                                     BorderThickness="0" Margin="0,0,0,10"/>
                        <TextBlock Text="Loading..." Foreground="#9CA3AF"
                                   FontSize="13" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </Grid>

            <!-- ═══════════════════════════════
                 COL 1 — DETAIL PANEL
                 Width="440" forces the Auto column to 440 when Visible.
                 Visibility=Collapsed collapses the Auto column to 0
                 so the DataGrid fills the full window width.
                 ═══════════════════════════════ -->
            <Border Grid.Column="1"
                    Width="440" MinWidth="320"
                    BorderBrush="#374151" BorderThickness="1,0,0,0"
                    Background="#0D1525"
                    Visibility="{Binding IsDetailVisible, Converter={StaticResource BoolToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20" DataContext="{Binding SelectedOrder}">

                        <!-- ── Order header ── -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding OrderNumber}"
                                           Foreground="#F9FAFB"
                                           FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="{Binding OrderDate, StringFormat='Placed {0:MMMM d, yyyy  h:mm tt}'}"
                                           Foreground="#6B7280" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <!-- Status badge (large) -->
                            <Border Grid.Column="1" CornerRadius="6" Padding="10,5"
                                    Background="#1A2234" VerticalAlignment="Top" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="7" Height="7" Margin="0,0,6,0"
                                             VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <Binding Path="OrderStatus"
                                                     Converter="{StaticResource StatusColor}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock Text="{Binding OrderStatus}"
                                               Foreground="{Binding OrderStatus,
                                                   Converter={StaticResource StatusColor}}"
                                               FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <!-- X close button -->
                            <Button Grid.Column="2" VerticalAlignment="Top"
                                    Command="{Binding DataContext.CloseDetailCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Width="28" Height="28"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" FocusVisualStyle="{x:Null}"
                                    ToolTip="Close">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#374151"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="&#x2715;" Foreground="#9CA3AF" FontSize="13"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                        </Grid>

                        <Separator Background="#374151" Margin="0,0,0,16"/>

                        <!-- ── Customer + Totals ── -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Customer -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CUSTOMER" Style="{StaticResource SectionLabel}"/>

                                <TextBlock Text="Name" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding CustomerName}"    Style="{StaticResource FieldValue}"/>

                                <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding CustomerEmail}"   Style="{StaticResource FieldValue}"/>

                                <TextBlock Text="Phone" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding ContactPhone, TargetNullValue='&#x2014;'}"
                                           Style="{StaticResource FieldValue}"/>
                            </StackPanel>

                            <!-- Totals -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="TOTALS" Style="{StaticResource SectionLabel}"/>

                                <TextBlock Text="Subtotal"  Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding SubTotal, StringFormat='&#x20B1;{0:N2}'}"
                                           Style="{StaticResource FieldValue}"/>

                                <TextBlock Text="Discount"  Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding DiscountAmount, StringFormat='&#x2212;&#x20B1;{0:N2}'}"
                                           Style="{StaticResource FieldValue}"/>

                                <TextBlock Text="Shipping"  Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding ShippingFee, StringFormat='&#x20B1;{0:N2}'}"
                                           Style="{StaticResource FieldValue}"/>

                                <Separator Background="#374151" Margin="0,0,0,8"/>
                                <TextBlock Text="Grand Total" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding GrandTotal, StringFormat='&#x20B1;{0:N2}'}"
                                           Foreground="#34D399" FontSize="14" FontWeight="Bold"
                                           Margin="0,0,0,12"/>
                            </StackPanel>
                        </Grid>

                        <!-- ── Payment info ── -->
                        <TextBlock Text="Payment" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="{Binding PaymentMethodDisplay}" Style="{StaticResource FieldValue}"
                                   FontWeight="SemiBold"/>

                        <!-- ── Delivery / Pickup info ── -->
                        <Border Background="#1F2937" CornerRadius="8" Padding="14"
                                Margin="0,0,0,16" BorderThickness="1" BorderBrush="#374151">
                            <StackPanel>
                                <TextBlock Text="{Binding DeliveryType, StringFormat='{}{0} INFO'}"
                                           Style="{StaticResource SectionLabel}"/>

                                <!-- Pickup details -->
                                <StackPanel DataContext="{Binding Pickup}">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.DeliveryType,
                                                             RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                                             Value="Pickup">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Ready At"   Style="{StaticResource FieldLabel}"/>
                                            <TextBlock Style="{StaticResource FieldValue}">
                                                <TextBlock.Text>
                                                    <Binding Path="PickupReadyAt"
                                                             TargetNullValue="Not yet set"
                                                             StringFormat="{}{0:MMM d, h:mm tt}"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Expires At" Style="{StaticResource FieldLabel}"/>
                                            <TextBlock Style="{StaticResource FieldValue}">
                                                <TextBlock.Text>
                                                    <Binding Path="PickupExpiresAt"
                                                             TargetNullValue="Not yet set"
                                                             StringFormat="{}{0:MMM d, h:mm tt}"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="Confirmed At" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Style="{StaticResource FieldValue}">
                                        <TextBlock.Text>
                                            <Binding Path="PickupConfirmedAt"
                                                     TargetNullValue="Not yet confirmed"
                                                     StringFormat="{}{0:MMM d, yyyy  h:mm tt}"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Delivery details -->
                                <StackPanel DataContext="{Binding Delivery}">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.DeliveryType,
                                                             RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                                             Value="Delivery">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Courier"        Style="{StaticResource FieldLabel}"/>
                                            <TextBlock Text="{Binding Courier, TargetNullValue='Not assigned'}"
                                                       Style="{StaticResource FieldValue}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Courier Status" Style="{StaticResource FieldLabel}"/>
                                            <TextBlock Text="{Binding DeliveryStatus, TargetNullValue='&#x2014;'}"
                                                       Style="{StaticResource FieldValue}"/>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="Tracking"     Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Text="{Binding TrackingInfo, TargetNullValue='&#x2014;'}"
                                               Style="{StaticResource FieldValue}"/>
                                    <TextBlock Text="Est. Delivery" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Style="{StaticResource FieldValue}">
                                        <TextBlock.Text>
                                            <Binding Path="EstimatedDeliveryTime"
                                                     TargetNullValue="Not set"
                                                     StringFormat="{}{0:MMM d, yyyy}"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <!-- No courier yet placeholder -->
                                <TextBlock Foreground="#4B5563" FontSize="13"
                                           Text="No courier assigned yet."
                                           HorizontalAlignment="Center"
                                           Margin="0,4">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding DataContext.DeliveryType,
                                                                   RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                                                   Value="Delivery"/>
                                                        <Condition Binding="{Binding DataContext.SelectedOrder.Delivery,
                                                                   RelativeSource={RelativeSource AncestorType=UserControl},
                                                                   Converter={StaticResource BoolToVis}}"
                                                                   Value="Collapsed"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Delivery Instructions (optional — shown when non-empty) -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <!-- Collapse when empty string -->
                                                <DataTrigger Binding="{Binding DataContext.SelectedOrder.DeliveryInstructions,
                                                             RelativeSource={RelativeSource AncestorType=UserControl},
                                                             TargetNullValue=''}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <!-- Collapse when null -->
                                                <DataTrigger Binding="{Binding DataContext.SelectedOrder.DeliveryInstructions,
                                                             RelativeSource={RelativeSource AncestorType=UserControl}}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="Delivery Instructions" Style="{StaticResource FieldLabel}" Margin="0,8,0,2"/>
                                    <TextBlock Text="{Binding DataContext.SelectedOrder.DeliveryInstructions,
                                               RelativeSource={RelativeSource AncestorType=UserControl},
                                               TargetNullValue='&#x2014;'}"
                                               Style="{StaticResource FieldValue}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── Order items ── -->
                        <TextBlock Text="ORDER ITEMS" Style="{StaticResource SectionLabel}"/>

                        <DataGrid ItemsSource="{Binding Items}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Background="#1F2937"
                                  Foreground="#E5E7EB"
                                  BorderBrush="#374151" BorderThickness="1"
                                  RowBackground="#1F2937"
                                  AlternatingRowBackground="#172032"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#374151"
                                  HeadersVisibility="Column"
                                  CanUserResizeRows="False"
                                  SelectionMode="Single"
                                  FontSize="12"
                                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  Margin="0,0,0,16">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"      Value="#111827"/>
                                    <Setter Property="Foreground"      Value="#9CA3AF"/>
                                    <Setter Property="FontSize"        Value="10"/>
                                    <Setter Property="FontWeight"      Value="SemiBold"/>
                                    <Setter Property="Padding"         Value="10,7"/>
                                    <Setter Property="BorderBrush"     Value="#374151"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding"         Value="10,7"/>
                                    <Setter Property="Foreground"      Value="#E5E7EB"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#1E3A5F"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product"
                                                    Binding="{Binding DisplayName}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="Qty"
                                                    Binding="{Binding Quantity}"
                                                    Width="48"/>
                                <DataGridTextColumn Header="Unit Price"
                                                    Binding="{Binding UnitPrice, StringFormat='&#x20B1;{0:N2}'}"
                                                    Width="90"/>
                                <DataGridTextColumn Header="Subtotal"
                                                    Binding="{Binding Subtotal, StringFormat='&#x20B1;{0:N2}'}"
                                                    Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- ── Payment Proof (visible only when a proof was submitted) ── -->
                        <Border Margin="0,0,0,12" CornerRadius="8" Padding="14"
                                BorderThickness="1" BorderBrush="#D97706" Background="#1C1408">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <!-- Default: visible. Collapse only when URL is null or empty. -->
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PaymentProofUrl}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding PaymentProofUrl}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="PAYMENT PROOF" Style="{StaticResource SectionLabel}"
                                           Foreground="#D97706"/>

                                <!-- Method + Status row -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Method" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock Text="{Binding PaymentProofMethod, TargetNullValue='—'}"
                                                   Style="{StaticResource FieldValue}" Margin="0"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Payment Status" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock Text="{Binding PaymentStatus, TargetNullValue='—'}"
                                                   Foreground="#FCD34D" FontSize="13" FontWeight="SemiBold"
                                                   Margin="0"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Thumbnail image (clicks to open lightbox) -->
                                <Border CornerRadius="6" Margin="0,0,0,10"
                                        Background="#111827" BorderThickness="1" BorderBrush="#374151"
                                        HorizontalAlignment="Left">
                                    <ToggleButton x:Name="ImageLightboxToggle" Cursor="Hand"
                                                  ToolTip="Click to view full image">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Image MaxHeight="120" Stretch="Uniform"
                                                       Source="{Binding PaymentProofUrl, TargetNullValue={x:Null}}">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PaymentProofUrl}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding PaymentProofUrl}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Border>

                                <!-- PDF fallback label (when proof is PDF, Image won't render) -->
                                <TextBlock Foreground="#9CA3AF" FontSize="12" TextWrapping="Wrap"
                                           Margin="0,0,0,6"
                                           Text="📄 PDF proof submitted. Open the URL in a browser to view it.">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PaymentProofUrl}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Proof URL Button -->
                                <Button Command="{Binding DataContext.OpenPaymentProofCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding PaymentProofUrl}"
                                        Content="Open Payment Proof in Browser"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="0,0,0,4"
                                        HorizontalAlignment="Left"
                                        ToolTip="{Binding PaymentProofUrl}"/>
                            </StackPanel>
                        </Border>

                        <!-- ── Action buttons ── -->
                        <Border Background="#1F2937" CornerRadius="8" Padding="14"
                                BorderThickness="1" BorderBrush="#374151">
                            <StackPanel>
                                <TextBlock Text="ACTIONS" Style="{StaticResource SectionLabel}"/>
                                <WrapPanel>

                                    <!-- Added "Process Order" button for Pending / On Hold -->
                                    <Button Content="Mark as Processing"
                                            Command="{Binding DataContext.MarkProcessingCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Visibility="{Binding DataContext.CanMarkProcessing,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"
                                            Style="{StaticResource PrimaryButton}"
                                            Margin="0,0,8,8"/>

                                    <Button Content="✓ Approve Payment"
                                            Command="{Binding DataContext.ApprovePaymentCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Visibility="{Binding DataContext.CanApprovePayment,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"
                                            Style="{StaticResource PrimaryButton}"
                                            Background="#065F46" BorderBrush="#34D399"
                                            Margin="0,0,8,8"/>

                                    <Button Content="⏸ Hold Payment"
                                            Command="{Binding DataContext.HoldPaymentCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Visibility="{Binding DataContext.CanHoldPayment,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"
                                            Style="{StaticResource DangerButton}"
                                            Margin="0,0,8,8"/>

                                    <Button Content="Mark Ready for Pickup"
                                            Command="{Binding DataContext.MarkReadyForPickupCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Visibility="{Binding DataContext.CanMarkReadyForPickup,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"
                                            Style="{StaticResource PrimaryButton}"
                                            Margin="0,0,8,8"/>

                                    <Button Content="Confirm Pickup"
                                            Command="{Binding DataContext.ConfirmPickupCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Visibility="{Binding DataContext.CanConfirmPickup,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"
                                            Style="{StaticResource PrimaryButton}"
                                            Margin="0,0,8,8"/>

                                    <Button Content="Mark as Out for Delivery"
                                            Command="{Binding DataContext.MarkOutForDeliveryCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Visibility="{Binding DataContext.CanMarkOutForDelivery,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"
                                            Style="{StaticResource PrimaryButton}"
                                            Margin="0,0,8,8"/>

                                    <Button Content="Mark as Delivered"
                                            Command="{Binding DataContext.MarkDeliveredCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Visibility="{Binding DataContext.CanMarkDelivered,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"
                                            Style="{StaticResource PrimaryButton}"
                                            Margin="0,0,8,8"/>

                                    <Button Content="Cancel Order"
                                            Command="{Binding DataContext.CancelOrderCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Visibility="{Binding DataContext.CanCancelOrder,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"
                                            Style="{StaticResource DangerButton}"
                                            Margin="0,0,8,8"/>

                                </WrapPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>

    <!-- ══════════════════════════════════════
         FULL-SCREEN IMAGE LIGHTBOX
         ══════════════════════════════════════ -->
    <Grid Grid.RowSpan="6" Panel.ZIndex="999"
          Visibility="{Binding IsChecked, ElementName=ImageLightboxToggle, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
        
        <!-- Darkened/Blurred Background (Click to close) -->
        <Border Background="#D8000000" Cursor="Hand">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick" 
                              Command="{x:Static ApplicationCommands.NotACommand}"/>
            </Border.InputBindings>
        </Border>

        <!-- Use a button spanning the full background to easily unset toggles -->
        <Button Background="#E6000000" BorderThickness="0" Cursor="Hand"
                FocusVisualStyle="{x:Null}">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
            <Button.Style>
                <Style TargetType="Button"/>
            </Button.Style>
        </Button>

        <!-- A better WPF way: make the background itself a ToggleButton bound to the same state -->
        <ToggleButton Background="#E6000000" BorderThickness="0" Cursor="Hand"
                      IsChecked="{Binding IsChecked, ElementName=ImageLightboxToggle, Mode=TwoWay}"
                      FocusVisualStyle="{x:Null}">
            <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}"/>
                </ControlTemplate>
            </ToggleButton.Template>
        </ToggleButton>

        <!-- The Image itself (centered, ignored by clicks so clicking it doesn't close) -->
        <Image Source="{Binding SelectedOrder.PaymentProofUrl, TargetNullValue={x:Null}}"
               Stretch="Uniform" MaxWidth="1200" MaxHeight="800"
               Margin="40" HorizontalAlignment="Center" VerticalAlignment="Center"
               IsHitTestVisible="False">
            <Image.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="Black" Opacity="0.8"/>
            </Image.Effect>
        </Image>
        
        <!-- Visible X Button at top right for clarity -->
        <ToggleButton IsChecked="{Binding IsChecked, ElementName=ImageLightboxToggle, Mode=TwoWay}"
                      HorizontalAlignment="Right" VerticalAlignment="Top"
                      Margin="30" Width="40" Height="40"
                      Background="#33FFFFFF" Cursor="Hand"
                      FocusVisualStyle="{x:Null}">
            <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}" CornerRadius="20">
                        <TextBlock Text="&#x2715;" Foreground="White" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#66FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </ToggleButton.Template>
        </ToggleButton>
    </Grid>

    </Grid>
</UserControl>
