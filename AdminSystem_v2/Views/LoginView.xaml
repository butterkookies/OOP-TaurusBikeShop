<Window x:Class="AdminSystem_v2.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:AdminSystem_v2.Converters"
        Title="Taurus Bike Shop — Admin Login"
        Height="520" Width="420"
        MinHeight="480" MinWidth="360"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#111827">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Input style -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background"   Value="#1F2937"/>
            <Setter Property="Foreground"   Value="#F9FAFB"/>
            <Setter Property="BorderBrush"  Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="10,0"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Height"       Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"   Value="#F9FAFB"/>
        </Style>

        <Style x:Key="PasswordStyle" TargetType="PasswordBox">
            <Setter Property="Background"   Value="#1F2937"/>
            <Setter Property="Foreground"   Value="#F9FAFB"/>
            <Setter Property="BorderBrush"  Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="10,0"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Height"       Value="40"/>
        </Style>

        <!-- Primary button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"   Value="#DC2626"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontSize"     Value="14"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Height"       Value="42"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Opacity="{TemplateBinding IsEnabled, Converter={StaticResource BoolToVisibility}}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B91C1C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#6B7280"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Error text -->
        <Style x:Key="ErrorText" TargetType="TextBlock">
            <Setter Property="Foreground"    Value="#EF4444"/>
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="TextWrapping"  Value="Wrap"/>
            <Setter Property="Margin"        Value="0,2,0,6"/>
        </Style>

        <!-- Label text -->
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#9CA3AF"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MinWidth="340" MinHeight="440">

            <!-- LOGIN CARD -->
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="340"
                    Background="#1F2937"
                    CornerRadius="10"
                    Padding="32"
                    BorderThickness="1"
                    BorderBrush="#374151">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" Opacity="0.5" ShadowDepth="0"/>
                </Border.Effect>

                <StackPanel>

                    <!-- BRAND -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,28">

                        <Border Width="42" Height="42"
                                Background="#DC2626"
                                CornerRadius="8"
                                Margin="0,0,12,0">
                            <TextBlock Text="T"
                                       Foreground="White"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="TAURUS"
                                       Foreground="#F9FAFB"
                                       FontSize="15"
                                       FontWeight="Bold"/>
                            <TextBlock Text="BIKE SHOP ADMIN"
                                       Foreground="#6B7280"
                                       FontSize="10"
                                       Margin="1,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- EMAIL -->
                    <TextBlock Text="EMAIL" Style="{StaticResource LabelText}"/>
                    <TextBox Style="{StaticResource InputStyle}"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding EmailError}"
                               Style="{StaticResource ErrorText}"
                               Visibility="{Binding HasEmailError, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- PASSWORD -->
                    <TextBlock Text="PASSWORD" Style="{StaticResource LabelText}" Margin="0,4,0,4"/>
                    <Grid Margin="0,0,0,4">

                        <!-- Hidden password box (bound via code-behind helper) -->
                        <PasswordBox x:Name="PbPassword"
                                     Style="{StaticResource PasswordStyle}"
                                     Visibility="{Binding IsPasswordVisible,
                                         Converter={StaticResource BoolToVisibility},
                                         ConverterParameter=Invert}"/>

                        <!-- Visible plain-text box -->
                        <TextBox Style="{StaticResource InputStyle}"
                                 Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding IsPasswordVisible,
                                     Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Toggle eye button -->
                        <Button Background="Transparent"
                                BorderThickness="0"
                                Width="36"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Cursor="Hand"
                                Command="{Binding TogglePasswordCommand}">
                            <TextBlock FontSize="13"
                                       Foreground="#6B7280">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#x1F441;"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                                <Setter Property="Text" Value="&#x1F576;"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                    </Grid>

                    <TextBlock Text="{Binding PasswordError}"
                               Style="{StaticResource ErrorText}"
                               Visibility="{Binding HasPasswordError, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- FORGOT PASSWORD -->
                    <Button Background="Transparent"
                            BorderThickness="0"
                            Foreground="#6B7280"
                            FontSize="11"
                            Cursor="Hand"
                            Content="Forgot password?"
                            HorizontalAlignment="Right"
                            Margin="0,4,0,16"
                            Command="{Binding ForgotPasswordCommand}"/>

                    <!-- LOGIN BUTTON -->
                    <Button Style="{StaticResource PrimaryButton}"
                            IsEnabled="{Binding IsNotLoading}"
                            Command="{Binding LoginCommand}">
                        <Button.Content>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Sign In"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                <Setter Property="Text" Value="Signing in..."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button.Content>
                    </Button>

                    <!-- CONNECTION ERROR -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               Style="{StaticResource ErrorText}"
                               Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>

                </StackPanel>
            </Border>

            <!-- FOOTER -->
            <TextBlock Text="Taurus Bike Shop  •  Admin System"
                       Foreground="#4B5563"
                       FontSize="10"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,12"/>

        </Grid>
    </ScrollViewer>
</Window>
