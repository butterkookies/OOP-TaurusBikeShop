<Window x:Class="AdminSystem_v2.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:AdminSystem_v2.Helpers"
        Title="Taurus Bike Shop — Admin System"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#111827"
        Closing="Window_Closing">

    <Window.Resources>

        <!-- ── NAV BUTTON ── -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background"              Value="Transparent"/>
            <Setter Property="Foreground"              Value="#9CA3AF"/>
            <Setter Property="BorderBrush"             Value="Transparent"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="Height"                  Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                 Value="12,0"/>
            <Setter Property="FontSize"                Value="13"/>
            <Setter Property="Cursor"                  Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"   Value="#1F2937"/>
                                <Setter TargetName="Bd" Property="BorderBrush"  Value="#DC2626"/>
                                <Setter Property="Foreground"                   Value="#F9FAFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── SIDEBAR SECTION LABEL ── -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#4B5563"/>
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Margin"       Value="12,10,12,4"/>
        </Style>

        <!-- ── SIDEBAR SEPARATOR ── -->
        <Style x:Key="SidebarSep" TargetType="Separator">
            <Setter Property="Background" Value="#374151"/>
            <Setter Property="Height"     Value="1"/>
            <Setter Property="Margin"     Value="12,4"/>
        </Style>

        <!-- ── GHOST BUTTON (sign out / exit) ── -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background"              Value="Transparent"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="Height"                  Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                 Value="12,0"/>
            <Setter Property="FontSize"                Value="13"/>
            <Setter Property="Cursor"                  Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F2937"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ══════════════════════════════════════
         ROOT: Sidebar | Content
         ══════════════════════════════════════ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*" MinWidth="400"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════
             COL 0 — SIDEBAR
             ═══════════════════════════════ -->
        <Border Grid.Column="0"
                Background="#1F2937"
                BorderThickness="0,0,1,0"
                BorderBrush="#374151">
            <DockPanel LastChildFill="True">

                <!-- Brand header -->
                <Border DockPanel.Dock="Top"
                        Background="#DC2626"
                        Height="60">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Border Width="28" Height="28"
                                Background="#B91C1C"
                                CornerRadius="6"
                                Margin="0,0,8,0">
                            <TextBlock Text="T"
                                       Foreground="White"
                                       FontSize="16" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="TAURUS"
                                       Foreground="White"
                                       FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="BIKE SHOP"
                                       Foreground="#FECACA"
                                       FontSize="9"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Admin profile card -->
                <Border DockPanel.Dock="Top"
                        Background="#111827"
                        Padding="12,10">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="32" Height="32"
                                CornerRadius="16"
                                Background="#DC2626">
                            <TextBlock Text="{Binding UserInitials}"
                                       Foreground="White"
                                       FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding UserFullName}"
                                       Foreground="#F9FAFB"
                                       FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding UserRole}"
                                       Foreground="#6B7280"
                                       FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Separator Style="{StaticResource SidebarSep}" DockPanel.Dock="Top"/>

                <!-- Exit + Sign out pinned to bottom -->
                <StackPanel DockPanel.Dock="Bottom">
                    <Separator Style="{StaticResource SidebarSep}"/>

                    <Button Style="{StaticResource GhostButton}"
                            Command="{Binding ExitCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2715;" Foreground="#EF4444"
                                       FontSize="12" Margin="0,0,10,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Exit Application" Foreground="#EF4444"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource GhostButton}"
                            Command="{Binding SignOutCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x23FB;" Foreground="#DC2626"
                                       FontSize="12" Margin="0,0,10,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Sign Out" Foreground="#9CA3AF"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Nav items -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <TextBlock Text="MODULES" Style="{StaticResource SectionLabel}"/>

                        <!-- Dashboard -->
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Dashboard">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage}" Value="Dashboard">
                                            <Setter Property="Background"  Value="#1F2937"/>
                                <Setter Property="Foreground"  Value="#F9FAFB"/>
                                <Setter Property="BorderBrush" Value="#DC2626"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x229E;" Foreground="#DC2626"
                                           FontSize="14" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Dashboard" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Separator Style="{StaticResource SidebarSep}"/>
                        <TextBlock Text="SALES" Style="{StaticResource SectionLabel}"/>

                        <!-- POS -->
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="POS">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage}" Value="POS">
                                            <Setter Property="Background"  Value="#1F2937"/>
                                            <Setter Property="Foreground"  Value="#F9FAFB"/>
                                            <Setter Property="BorderBrush" Value="#DC2626"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4B3;" FontSize="13"
                                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="POS" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Orders -->
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Orders">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage}" Value="Orders">
                                            <Setter Property="Background"  Value="#1F2937"/>
                                <Setter Property="Foreground"  Value="#F9FAFB"/>
                                <Setter Property="BorderBrush" Value="#DC2626"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4E6;" FontSize="13"
                                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Orders" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Reports -->
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Reports">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage}" Value="Reports">
                                            <Setter Property="Background"  Value="#1F2937"/>
                                <Setter Property="Foreground"  Value="#F9FAFB"/>
                                <Setter Property="BorderBrush" Value="#DC2626"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4CA;" FontSize="13"
                                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Reports" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Vouchers -->
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Vouchers">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage}" Value="Vouchers">
                                            <Setter Property="Background"  Value="#1F2937"/>
                                            <Setter Property="Foreground"  Value="#F9FAFB"/>
                                            <Setter Property="BorderBrush" Value="#DC2626"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F3AB;" FontSize="13"
                                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Vouchers" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Payment Accounts -->
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Payment Accounts">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage}" Value="Payment Accounts">
                                            <Setter Property="Background"  Value="#1F2937"/>
                                            <Setter Property="Foreground"  Value="#F9FAFB"/>
                                            <Setter Property="BorderBrush" Value="#DC2626"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4B3;" FontSize="13"
                                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Payment Accounts" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Separator Style="{StaticResource SidebarSep}"/>
                        <TextBlock Text="CATALOG" Style="{StaticResource SectionLabel}"/>

                        <!-- Products -->
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Products">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage}" Value="Products">
                                            <Setter Property="Background"  Value="#1F2937"/>
                                <Setter Property="Foreground"  Value="#F9FAFB"/>
                                <Setter Property="BorderBrush" Value="#DC2626"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F6CD;" FontSize="13"
                                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                                 <TextBlock Text="Products" FontSize="13"
                                            VerticalAlignment="Center"/>
                             </StackPanel>
                         </Button>
                         
                         <!-- Support -->
                         <Button Command="{Binding NavigateCommand}"
                                 CommandParameter="Support Tickets">
                             <Button.Style>
                                 <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                     <Style.Triggers>
                                         <DataTrigger Binding="{Binding ActivePage}" Value="Support Tickets">
                                             <Setter Property="Background"  Value="#1F2937"/>
                                             <Setter Property="Foreground"  Value="#F9FAFB"/>
                                             <Setter Property="BorderBrush" Value="#DC2626"/>
                                         </DataTrigger>
                                     </Style.Triggers>
                                 </Style>
                             </Button.Style>
                             <StackPanel Orientation="Horizontal">
                                 <TextBlock Text="&#x1F4AC;" FontSize="13"
                                            Margin="0,0,8,0" VerticalAlignment="Center"/>
                                 <TextBlock Text="Support" FontSize="13"
                                            VerticalAlignment="Center"/>
                             </StackPanel>
                         </Button>

                         <Separator Style="{StaticResource SidebarSep}"/>
                        <TextBlock Text="TEAM" Style="{StaticResource SectionLabel}"/>

                        <!-- Staff (Admin only) -->
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Staff"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage}" Value="Staff">
                                            <Setter Property="Background"  Value="#1F2937"/>
                                <Setter Property="Foreground"  Value="#F9FAFB"/>
                                <Setter Property="BorderBrush" Value="#DC2626"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F465;" FontSize="13"
                                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Staff" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════
             COL 1 — CONTENT AREA
             ═══════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0"
                    Background="#1F2937"
                    BorderThickness="0,0,0,1"
                    BorderBrush="#374151">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PageTitle}"
                                   Foreground="#F9FAFB"
                                   FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding PageBreadcrumb}"
                                   Foreground="#6B7280"
                                   FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="{Binding UserFullName}"
                               Foreground="#9CA3AF"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Page content — DataTemplate resolves the correct View per ViewModel type -->
            <ContentControl Grid.Row="1"
                            Content="{Binding CurrentViewModel}"/>
        </Grid>

    </Grid>
</Window>
