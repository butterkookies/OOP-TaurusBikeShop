<Window x:Class="AdminSystem_v2.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:AdminSystem_v2.Helpers"
        Title="Taurus Bike Shop — Admin System"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#141414"
        Closing="Window_Closing">

    <Window.Resources>

        <!-- ── NAV BUTTON ── -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="Foreground"                 Value="#9CA3AF"/>
            <Setter Property="BorderBrush"                Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Height"                     Value="44"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                    Value="16,0"/>
            <Setter Property="FontSize"                   Value="13"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                CornerRadius="0,6,6,0"
                                Margin="0,1,8,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#252525"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#DC2626"/>
                                <Setter Property="Foreground"                   Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── SIDEBAR SECTION LABEL ── -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#2E2E2E"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="16,12,12,4"/>
        </Style>

        <!-- ── SIDEBAR SEPARATOR ── -->
        <Style x:Key="SidebarSep" TargetType="Separator">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Height"     Value="1"/>
            <Setter Property="Margin"     Value="12,6"/>
        </Style>

        <!-- ── GHOST BUTTON (sign out / exit) ── -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Height"                     Value="44"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                    Value="16,0"/>
            <Setter Property="FontSize"                   Value="13"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="0,6,6,0"
                                Margin="0,1,8,1">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252525"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ══════════════════════════════════════
         ROOT: Sidebar | Content
         ══════════════════════════════════════ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*" MinWidth="400"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════
             COL 0 — SIDEBAR
             ═══════════════════════════════ -->
        <Border Grid.Column="0"
                Background="#0F0F0F"
                BorderThickness="0,0,1,0"
                BorderBrush="#2A2A2A">
            <DockPanel LastChildFill="True">

                <!-- Brand header -->
                <Border DockPanel.Dock="Top" Height="64">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7F0000" Offset="0"/>
                            <GradientStop Color="#DC2626" Offset="0.6"/>
                            <GradientStop Color="#B91C1C" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Margin="16,0">
                        <Border Width="32" Height="32"
                                Background="#991B1B"
                                CornerRadius="8"
                                Margin="0,0,10,0">
                            <TextBlock Text="T"
                                       Foreground="White"
                                       FontSize="18" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="TAURUS"
                                       Foreground="White"
                                       FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="BIKE SHOP ADMIN"
                                       Foreground="#FECACA"
                                       FontSize="9" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Admin profile card -->
                <Border DockPanel.Dock="Top"
                        Background="#1C1C1C"
                        Padding="16,12"
                        BorderBrush="#2A2A2A"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar -->
                        <Border Grid.Column="0"
                                Width="36" Height="36"
                                CornerRadius="18"
                                Background="#DC2626">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Opacity="0.5"
                                                  ShadowDepth="0" Color="#DC2626"/>
                            </Border.Effect>
                            <TextBlock Text="{Binding UserInitials}"
                                       Foreground="White"
                                       FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding UserFullName}"
                                       Foreground="#F9FAFB"
                                       FontSize="13" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <!-- Role badge -->
                            <Border CornerRadius="3" Padding="5,1"
                                    Background="#1E2E3E"
                                    HorizontalAlignment="Left"
                                    Margin="0,3,0,0">
                                <TextBlock Text="{Binding UserRole}"
                                           Foreground="#60A5FA"
                                           FontSize="10" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Exit + Sign out pinned to bottom -->
                <StackPanel DockPanel.Dock="Bottom">
                    <Separator Style="{StaticResource SidebarSep}"/>

                    <Button Style="{StaticResource GhostButton}"
                            Command="{Binding ExitCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2715;" Foreground="#EF4444"
                                       FontSize="12" Margin="0,0,10,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Exit Application" Foreground="#EF4444"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource GhostButton}"
                            Command="{Binding SignOutCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x23FB;" Foreground="#DC2626"
                                       FontSize="12" Margin="0,0,10,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Sign Out" Foreground="#9CA3AF"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Version tag -->
                    <TextBlock Text="Admin System v2"
                               Foreground="#2A2A2A"
                               FontSize="10"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,8"/>
                </StackPanel>

                <!-- Nav items -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,4,0,0">

                        <TextBlock Text="MODULES" Style="{StaticResource SectionLabel}"/>

                        <!-- Dashboard -->
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Dashboard">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage}" Value="Dashboard">
                                            <Setter Property="Background"  Value="#1E2E3E"/>
                                            <Setter Property="Foreground"  Value="#F9FAFB"/>
                                            <Setter Property="BorderBrush" Value="#3B82F6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x229E;" Foreground="#DC2626"
                                           FontSize="14" Margin="0,0,10,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Dashboard" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Separator Style="{StaticResource SidebarSep}"/>
                        <TextBlock Text="SALES" Style="{StaticResource SectionLabel}"/>

                        <!-- POS -->
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="POS">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage}" Value="POS">
                                            <Setter Property="Background"  Value="#1E3A5F"/>
                                            <Setter Property="Foreground"  Value="#F9FAFB"/>
                                            <Setter Property="BorderBrush" Value="#3B82F6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4B3;" FontSize="13"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Point of Sale" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Orders -->
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Orders">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage}" Value="Orders">
                                            <Setter Property="Background"  Value="#1E3A5F"/>
                                            <Setter Property="Foreground"  Value="#F9FAFB"/>
                                            <Setter Property="BorderBrush" Value="#3B82F6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4E6;" FontSize="13"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Orders" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Reports -->
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Reports">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage}" Value="Reports">
                                            <Setter Property="Background"  Value="#1E3A5F"/>
                                            <Setter Property="Foreground"  Value="#F9FAFB"/>
                                            <Setter Property="BorderBrush" Value="#3B82F6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4CA;" FontSize="13"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Reports" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Vouchers -->
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Vouchers">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage}" Value="Vouchers">
                                            <Setter Property="Background"  Value="#1E3A5F"/>
                                            <Setter Property="Foreground"  Value="#F9FAFB"/>
                                            <Setter Property="BorderBrush" Value="#3B82F6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F3AB;" FontSize="13"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Vouchers" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Payment Accounts (Admin only) -->
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Payment Accounts"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage}" Value="Payment Accounts">
                                            <Setter Property="Background"  Value="#1E3A5F"/>
                                            <Setter Property="Foreground"  Value="#F9FAFB"/>
                                            <Setter Property="BorderBrush" Value="#3B82F6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4B0;" FontSize="13"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Payment Accounts" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Separator Style="{StaticResource SidebarSep}"/>
                        <TextBlock Text="CATALOG" Style="{StaticResource SectionLabel}"/>

                        <!-- Products -->
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Products">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage}" Value="Products">
                                            <Setter Property="Background"  Value="#1E3A5F"/>
                                            <Setter Property="Foreground"  Value="#F9FAFB"/>
                                            <Setter Property="BorderBrush" Value="#3B82F6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F6CD;" FontSize="13"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Products" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Support -->
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Support Tickets">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage}" Value="Support Tickets">
                                            <Setter Property="Background"  Value="#1E3A5F"/>
                                            <Setter Property="Foreground"  Value="#F9FAFB"/>
                                            <Setter Property="BorderBrush" Value="#3B82F6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4AC;" FontSize="13"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Support" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Separator Style="{StaticResource SidebarSep}"/>
                        <TextBlock Text="TEAM" Style="{StaticResource SectionLabel}"/>

                        <!-- Staff (Admin only) -->
                        <Button Command="{Binding NavigateCommand}"
                                CommandParameter="Staff"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePage}" Value="Staff">
                                            <Setter Property="Background"  Value="#1E3A5F"/>
                                            <Setter Property="Foreground"  Value="#F9FAFB"/>
                                            <Setter Property="BorderBrush" Value="#3B82F6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F465;" FontSize="13"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Staff" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════
             COL 1 — CONTENT AREA
             ═══════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0"
                    Background="#1C1C1C"
                    BorderThickness="0,0,0,1"
                    BorderBrush="#2A2A2A">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PageTitle}"
                                   Foreground="#F9FAFB"
                                   FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding PageBreadcrumb}"
                                   Foreground="#4B5563"
                                   FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Right side: user info chip -->
                    <Border Grid.Column="1"
                            VerticalAlignment="Center"
                            Background="#0F0F0F"
                            CornerRadius="20"
                            Padding="10,6"
                            BorderBrush="#2A2A2A"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="22" Height="22"
                                    CornerRadius="11"
                                    Background="#DC2626"
                                    Margin="0,0,8,0">
                                <TextBlock Text="{Binding UserInitials}"
                                           Foreground="White"
                                           FontSize="10" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding UserFullName}"
                                       Foreground="#9CA3AF"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Page content -->
            <ContentControl Grid.Row="1"
                            Content="{Binding CurrentViewModel}"/>
        </Grid>

    </Grid>
</Window>
