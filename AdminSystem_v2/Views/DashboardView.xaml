<UserControl x:Class="AdminSystem_v2.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AdminSystem_v2.Converters"
             Background="#111827">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">

            <!-- Header -->
            <TextBlock Text="Overview"
                       Foreground="#F9FAFB"
                       FontSize="20" FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Live snapshot of your store."
                       Foreground="#6B7280"
                       FontSize="12"
                       Margin="0,0,0,24"/>

            <!-- ── STAT CARDS ── -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Products -->
                <Border Grid.Column="0"
                        Background="#1F2937"
                        CornerRadius="8"
                        Padding="20"
                        BorderThickness="1"
                        BorderBrush="#374151">
                    <StackPanel>
                        <TextBlock Text="TOTAL PRODUCTS"
                                   Foreground="#6B7280"
                                   FontSize="10" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalProducts}"
                                   Foreground="#F9FAFB"
                                   FontSize="36" FontWeight="Bold"
                                   Margin="0,8,0,4"/>
                        <TextBlock Text="Active products in catalog"
                                   Foreground="#4B5563"
                                   FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Low Stock -->
                <Border Grid.Column="2"
                        CornerRadius="8"
                        Padding="20"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background"   Value="#1F2937"/>
                            <Setter Property="BorderBrush"  Value="#374151"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LowStockCount}" Value="0">
                                    <Setter Property="Background"  Value="#1F2937"/>
                                    <Setter Property="BorderBrush" Value="#374151"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="LOW STOCK ALERTS"
                                   Foreground="#6B7280"
                                   FontSize="10" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding LowStockCount}"
                                   FontSize="36" FontWeight="Bold"
                                   Margin="0,8,0,4">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#22C55E"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LowStockCount}" Value="0">
                                            <Setter Property="Foreground" Value="#22C55E"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Foreground="#4B5563" FontSize="11">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Variants below reorder threshold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LowStockCount}" Value="0">
                                            <Setter Property="Text" Value="All stock levels healthy"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── LOW STOCK TABLE ── -->
            <Border Background="#1F2937"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="#374151"
                    Padding="0,0,0,8">
                <StackPanel>

                    <!-- Table header row -->
                    <Grid Margin="20,16,20,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Low Stock Variants"
                                       Foreground="#F9FAFB"
                                       FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="Variants at or below their reorder threshold"
                                       Foreground="#6B7280"
                                       FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Refresh button -->
                        <Button Grid.Column="1"
                                Command="{Binding RefreshCommand}"
                                IsEnabled="{Binding IsNotLoading}"
                                Background="#374151"
                                Foreground="#D1D5DB"
                                BorderThickness="0"
                                Padding="12,6"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#4B5563"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="Bd" Property="Background" Value="#1F2937"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x21BB;" FontSize="12" Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Refresh" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Separator Background="#374151" Height="1" Margin="0"/>

                    <!-- Loading indicator -->
                    <TextBlock Text="Loading..."
                               Foreground="#6B7280"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0,20"
                               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Error message -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#EF4444"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,16"
                               TextWrapping="Wrap"
                               Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Empty state -->
                    <StackPanel HorizontalAlignment="Center"
                                Margin="0,24"
                                Visibility="{Binding IsNotLoading, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LowStockCount}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="✓  All stock levels are healthy"
                                   Foreground="#22C55E"
                                   FontSize="13"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Column headers -->
                    <Grid Margin="20,10,20,4"
                          Visibility="{Binding IsNotLoading, Converter={StaticResource BoolToVisibility}}">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LowStockCount}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="PRODUCT"       Style="{StaticResource {x:Type TextBlock}}" Foreground="#4B5563" FontSize="10" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="VARIANT"       Foreground="#4B5563" FontSize="10" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="STOCK"         Foreground="#4B5563" FontSize="10" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="3" Text="THRESHOLD"     Foreground="#4B5563" FontSize="10" FontWeight="SemiBold"/>
                    </Grid>

                    <!-- Low stock rows -->
                    <ItemsControl ItemsSource="{Binding LowStockItems}"
                                  Margin="0,0,0,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="0,1,0,0"
                                        BorderBrush="#374151">
                                    <Grid Margin="20,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding ProductName}"
                                                   Foreground="#F9FAFB"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding VariantName}"
                                                   Foreground="#9CA3AF"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>

                                        <!-- Stock quantity — red if zero, yellow otherwise -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding StockQuantity}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#EAB308"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StockQuantity}" Value="0">
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding ReorderThreshold}"
                                                   Foreground="#6B7280"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
