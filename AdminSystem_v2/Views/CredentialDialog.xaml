<Window x:Class="AdminSystem_v2.Views.CredentialDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm Admin Credentials"
        Height="380" Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <!-- Floating card with drop shadow -->
    <Border Background="#1A2234"
            CornerRadius="14"
            BorderBrush="#2D3748"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" Opacity="0.7" ShadowDepth="0" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <!-- Red accent stripe -->
                <RowDefinition Height="5"/>
                <!-- Content -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top accent stripe -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#DC2626" Offset="0"/>
                        <GradientStop Color="#991B1B" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Main content -->
            <StackPanel Grid.Row="1" Margin="28,20,28,28">

                <!-- Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Border Width="36" Height="36" CornerRadius="8"
                            Background="#DC2626" Margin="0,0,12,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Color="#DC2626"
                                              Opacity="0.5" ShadowDepth="0"/>
                        </Border.Effect>
                        <TextBlock Text="&#x1F512;" FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Admin Verification"
                                   Foreground="#F9FAFB"
                                   FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="Re-enter your credentials to continue"
                                   Foreground="#4B5563"
                                   FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <!-- Action description -->
                <Border Background="#0F1829" CornerRadius="6"
                        Padding="12,8" Margin="0,0,0,20"
                        BorderBrush="#1E2D45" BorderThickness="1">
                    <TextBlock x:Name="ActionDescription"
                               Foreground="#9CA3AF" FontSize="12"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Email (read-only) -->
                <TextBlock Text="ADMIN EMAIL"
                           Foreground="#374151"
                           FontSize="10" FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <Border CornerRadius="8" BorderThickness="1"
                        BorderBrush="#1E2D45" Background="#0F1829"
                        Height="36" Margin="0,0,0,14"
                        Padding="12,0">
                    <TextBox x:Name="EmailField"
                             IsReadOnly="True"
                             Background="Transparent"
                             Foreground="#4B5563"
                             BorderThickness="0"
                             FontSize="13"
                             VerticalAlignment="Center"
                             VerticalContentAlignment="Center"/>
                </Border>

                <!-- Password -->
                <TextBlock Text="PASSWORD"
                           Foreground="#4B5563"
                           FontSize="10" FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <Border CornerRadius="8" BorderThickness="1"
                        Height="36" Margin="0,0,0,0"
                        Padding="12,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush"  Value="#374151"/>
                            <Setter Property="Background"   Value="#0D1526"/>
                        </Style>
                    </Border.Style>
                    <PasswordBox x:Name="PasswordField"
                                 KeyDown="PasswordField_KeyDown"
                                 Background="Transparent"
                                 Foreground="#E5E7EB"
                                 BorderThickness="0"
                                 FontSize="13"
                                 VerticalAlignment="Center"
                                 VerticalContentAlignment="Center"/>
                </Border>

                <!-- Error message (fixed height — no layout jump) -->
                <Border Height="28" Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚠ " Foreground="#EF4444" FontSize="11"
                                   Visibility="{Binding ElementName=ErrorText, Path=Visibility}"/>
                        <TextBlock x:Name="ErrorText"
                                   Foreground="#EF4444" FontSize="11"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Buttons -->
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cancel -->
                    <Button Grid.Column="0"
                            Content="Cancel"
                            Click="Cancel_Click"
                            Height="38" Cursor="Hand"
                            FontSize="13" FontWeight="SemiBold"
                            Foreground="#D1D5DB"
                            BorderThickness="1"
                            BorderBrush="#374151">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="#1E2D45"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#253352"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Confirm -->
                    <Button Grid.Column="2"
                            Click="Confirm_Click"
                            Height="38" Cursor="Hand"
                            FontSize="13" FontWeight="SemiBold"
                            Foreground="White"
                            BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        CornerRadius="8">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#DC2626" Offset="0"/>
                                            <GradientStop Color="#B91C1C" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2713;  " FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Confirm" FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </Grid>

            </StackPanel>
        </Grid>
    </Border>
</Window>
