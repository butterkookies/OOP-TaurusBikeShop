<Window x:Class="AdminSystem_v2.Views.CredentialDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm Admin Credentials"
        Height="320" Width="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#1F2937" CornerRadius="12"
            BorderBrush="#374151" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Opacity="0.6" ShadowDepth="0"/>
        </Border.Effect>

        <StackPanel Margin="28">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <Border Width="32" Height="32" CornerRadius="6"
                        Background="#DC2626" Margin="0,0,10,0">
                    <TextBlock Text="&#x1F512;" FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Confirm Admin Credentials"
                           Foreground="#F9FAFB"
                           FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Action description -->
            <TextBlock x:Name="ActionDescription"
                       Foreground="#9CA3AF" FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"/>

            <!-- Email (read-only) -->
            <TextBlock Text="ADMIN EMAIL" Foreground="#9CA3AF"
                       FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="EmailField"
                     IsReadOnly="True"
                     Background="#111827" Foreground="#6B7280"
                     BorderBrush="#374151" BorderThickness="1"
                     Padding="10,0" FontSize="13" Height="38"
                     VerticalContentAlignment="Center"
                     Margin="0,0,0,14"/>

            <!-- Password -->
            <TextBlock Text="PASSWORD" Foreground="#9CA3AF"
                       FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordField"
                         Background="#1F2937" Foreground="#F9FAFB"
                         BorderBrush="#374151" BorderThickness="1"
                         Padding="10,0" FontSize="13" Height="38"
                         CaretBrush="#F9FAFB"
                         KeyDown="PasswordField_KeyDown"/>

            <!-- Error message -->
            <TextBlock x:Name="ErrorText"
                       Foreground="#EF4444" FontSize="11"
                       Margin="0,6,0,0"
                       Visibility="Collapsed"/>

            <!-- Buttons -->
            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Cancel"
                        Click="Cancel_Click"
                        Height="38" Cursor="Hand"
                        FontSize="13" FontWeight="SemiBold"
                        Foreground="#D1D5DB" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#374151"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#4B5563"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="2" Content="Confirm"
                        Click="Confirm_Click"
                        Height="38" Cursor="Hand"
                        FontSize="13" FontWeight="SemiBold"
                        Foreground="White" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#DC2626"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#B91C1C"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

        </StackPanel>
    </Border>
</Window>
