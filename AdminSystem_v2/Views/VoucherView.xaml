<UserControl x:Class="AdminSystem_v2.Views.VoucherView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#111827">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── Tab button ── -->
        <Style x:Key="TabBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="Padding"         Value="20,0"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#D1D5DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Card border ── -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="#1F2937"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="BorderBrush"     Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="20"/>
        </Style>

        <!-- ── DataGrid ── -->
        <Style x:Key="VGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="IsReadOnly"               Value="True"/>
            <Setter Property="Background"               Value="#1F2937"/>
            <Setter Property="Foreground"               Value="#E5E7EB"/>
            <Setter Property="BorderBrush"              Value="#374151"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="RowBackground"            Value="#1F2937"/>
            <Setter Property="AlternatingRowBackground" Value="#172032"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#374151"/>
            <Setter Property="HeadersVisibility"        Value="Column"/>
            <Setter Property="CanUserResizeRows"        Value="False"/>
            <Setter Property="SelectionMode"            Value="Single"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"      Value="#111827"/>
                        <Setter Property="Foreground"      Value="#9CA3AF"/>
                        <Setter Property="FontSize"        Value="11"/>
                        <Setter Property="FontWeight"      Value="SemiBold"/>
                        <Setter Property="Padding"         Value="12,8"/>
                        <Setter Property="BorderBrush"     Value="#374151"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding"         Value="12,8"/>
                        <Setter Property="Foreground"      Value="#E5E7EB"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1E3A5F"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Small action button ── -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"    Value="#374151"/>
            <Setter Property="Foreground"    Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"       Value="10,4"/>
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4B5563"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- tab bar -->
            <RowDefinition Height="Auto"/> <!-- status -->
            <RowDefinition Height="*"/>    <!-- content -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════
             ROW 0 — TAB BAR
             ══════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1F2937"
                BorderBrush="#374151" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">

                <Button Command="{Binding ShowVouchersTabCommand}" Content="Manage Vouchers">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TabBtn}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsVouchersTab}" Value="True">
                                    <Setter Property="Foreground"  Value="#F9FAFB"/>
                                    <Setter Property="BorderBrush" Value="#DC2626"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Command="{Binding ShowAssignTabCommand}" Content="Assign to Customers">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TabBtn}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAssignTab}" Value="True">
                                    <Setter Property="Foreground"  Value="#F9FAFB"/>
                                    <Setter Property="BorderBrush" Value="#DC2626"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 1 — STATUS
             ══════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#1C3A2A" Padding="20,8"
                Visibility="{Binding HasSuccess, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding SuccessMessage}" Foreground="#6EE7B7" FontSize="13"/>
        </Border>
        <Border Grid.Row="1" Background="#3B1010" Padding="20,8"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" FontSize="13"/>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 2 — CONTENT
             ══════════════════════════════════════ -->
        <Grid Grid.Row="2">

            <!-- Loading overlay -->
            <Border Background="#80111827" Panel.ZIndex="10"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Loading..." Foreground="#9CA3AF"
                           FontSize="14" HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- ════════════════════════════
                 MANAGE VOUCHERS TAB
                 ════════════════════════════ -->
            <Grid Visibility="{Binding IsVouchersTab, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ── Left: list ── -->
                <Grid Grid.Column="0" Margin="20,16,12,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search box with placeholder overlay -->
                        <Grid Grid.Column="0">
                            <TextBox Text="{Binding ListSearch, UpdateSourceTrigger=PropertyChanged}"

                                     x:Name="VoucherListSearch"/>
                            <TextBlock Text="Search vouchers by code..."
                                       Foreground="#4B5563" FontSize="13"
                                       Margin="12,0" VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ListSearch}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ListSearch}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <Button Grid.Column="1"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Content="&#x21BB; Refresh"/>

                        <Button Grid.Column="3"
                                Command="{Binding NewVoucherCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Content="+ New Voucher"/>

                    </Grid>

                    <!-- Vouchers DataGrid -->
                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                        <DataGrid ItemsSource="{Binding FilteredVouchers}"
                                  Style="{StaticResource VGrid}">
                            <DataGrid.Columns>

                                <DataGridTextColumn Header="CODE"
                                                    Binding="{Binding Code}"
                                                    Width="110"/>

                                <DataGridTextColumn Header="DISCOUNT"
                                                    Binding="{Binding DiscountDisplay}"
                                                    Width="100"/>

                                <DataGridTextColumn Header="VALID PERIOD"
                                                    Binding="{Binding ValidPeriod}"
                                                    Width="220"/>

                                <DataGridTextColumn Header="MAX USES"
                                                    Binding="{Binding MaxUsesDisplay}"
                                                    Width="90"/>

                                <DataGridTextColumn Header="USED"
                                                    Binding="{Binding TimesUsed}"
                                                    Width="60"/>

                                <DataGridTextColumn Header="ASSIGNED"
                                                    Binding="{Binding AssignedCount}"
                                                    Width="80"/>

                                <DataGridTextColumn Header="MIN ORDER"
                                                    Binding="{Binding MinOrderDisplay}"
                                                    Width="90"/>

                                <!-- Status badge -->
                                <DataGridTemplateColumn Header="STATUS" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="8,3" Margin="4,3"
                                                    HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#14532D"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusDisplay}" Value="Inactive">
                                                                <Setter Property="Background" Value="#374151"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusDisplay}" Value="Expired">
                                                                <Setter Property="Background" Value="#450A0A"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusDisplay}" Value="Scheduled">
                                                                <Setter Property="Background" Value="#1E3A5F"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding StatusDisplay}" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#86EFAC"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StatusDisplay}" Value="Inactive">
                                                                    <Setter Property="Foreground" Value="#9CA3AF"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusDisplay}" Value="Expired">
                                                                    <Setter Property="Foreground" Value="#FCA5A5"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusDisplay}" Value="Scheduled">
                                                                    <Setter Property="Foreground" Value="#93C5FD"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Actions -->
                                <DataGridTemplateColumn Header="ACTIONS" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                                <Button Content="Edit"
                                                        Style="{StaticResource ActionBtn}"
                                                        Command="{Binding DataContext.EditVoucherCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Margin="0,0,6,0"/>
                                                <Button Command="{Binding DataContext.ToggleActiveCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource ActionBtn}">
                                                            <Setter Property="Content" Value="Deactivate"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                    <Setter Property="Content"     Value="Activate"/>
                                                                    <Setter Property="Background"  Value="#14532D"/>
                                                                    <Setter Property="Foreground"  Value="#86EFAC"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

                <!-- ── Right: Create / Edit form panel ── -->
                <Border Grid.Column="1" Width="380"
                        Background="#1F2937"
                        BorderBrush="#374151" BorderThickness="1,0,0,0"
                        Visibility="{Binding IsFormOpen, Converter={StaticResource BoolToVis}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24">

                            <!-- Form header -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding FormTitle}"
                                           Foreground="#F9FAFB"
                                           FontSize="16" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Command="{Binding CancelFormCommand}"
                                        Style="{StaticResource ActionBtn}"
                                        Content="&#x2715;" Width="28"/>
                            </Grid>

                            <!-- Code + Generate -->
                            <TextBlock Text="VOUCHER CODE" Style="{StaticResource FieldLabel}"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}"

                                         CharacterCasing="Upper"/>
                                <Button Grid.Column="2"
                                        Command="{Binding GenerateCodeCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Content="Generate" Height="38"/>
                            </Grid>

                            <!-- Description -->
                            <TextBlock Text="DESCRIPTION (optional)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"

                                     Height="72" TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Margin="0,0,0,14"/>

                            <!-- Discount Type -->
                            <TextBlock Text="DISCOUNT TYPE" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding DiscountTypes}"
                                      SelectedItem="{Binding DiscountType}"

                                      Margin="0,0,0,14"/>

                            <!-- Discount Value -->
                            <TextBlock Foreground="#9CA3AF" FontSize="12" FontWeight="SemiBold"
                                       Margin="0,0,0,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="DISCOUNT VALUE (₱)"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPercentage}" Value="True">
                                                <Setter Property="Text" Value="DISCOUNT VALUE (%)"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox Text="{Binding DiscountValueText, UpdateSourceTrigger=PropertyChanged}"

                                     Margin="0,0,0,14"/>

                            <!-- Min Order Amount -->
                            <TextBlock Text="MINIMUM ORDER AMOUNT (optional)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding MinOrderText, UpdateSourceTrigger=PropertyChanged}"

                                     Margin="0,0,0,14"/>

                            <!-- Max Uses / Per User -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="MAX TOTAL USES" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding MaxUsesText, UpdateSourceTrigger=PropertyChanged}"

                                             Tag="Unlimited"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="MAX PER USER" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding MaxUsesPerUserText, UpdateSourceTrigger=PropertyChanged}"

                                             Tag="Unlimited"/>
                                </StackPanel>
                            </Grid>

                            <!-- Start / End Dates -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="START DATE" Style="{StaticResource FieldLabel}"/>
                                    <DatePicker SelectedDate="{Binding StartDate}"
                                                Height="38" Background="#111827"
                                                Foreground="#F9FAFB" BorderBrush="#374151"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="END DATE (optional)" Style="{StaticResource FieldLabel}"/>
                                    <DatePicker SelectedDate="{Binding EndDate}"
                                                Height="38" Background="#111827"
                                                Foreground="#F9FAFB" BorderBrush="#374151"/>
                                </StackPanel>
                            </Grid>

                            <!-- Is Active toggle -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <CheckBox IsChecked="{Binding FormIsActive}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0">
                                    <CheckBox.Resources>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="Foreground" Value="#D1D5DB"/>
                                        </Style>
                                    </CheckBox.Resources>
                                </CheckBox>
                                <TextBlock Text="Active (voucher is usable)"
                                           Foreground="#9CA3AF" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Save / Cancel -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Command="{Binding CancelFormCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Content="Cancel"/>
                                <Button Grid.Column="2"
                                        Command="{Binding SaveVoucherCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Content="Save Voucher"/>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

            </Grid>

            <!-- ════════════════════════════
                 ASSIGN TO CUSTOMERS TAB
                 ════════════════════════════ -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsAssignTab, Converter={StaticResource BoolToVis}}">
                <StackPanel Margin="28">

                    <!-- Header -->
                    <TextBlock Text="Assign Voucher to Customers"
                               Foreground="#F9FAFB"
                               FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Assign a voucher code to registered customers and queue a notification."
                               Foreground="#6B7280" FontSize="12" Margin="0,0,0,24"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ── Left column: voucher + options ── -->
                        <Border Grid.Column="0" Style="{StaticResource Card}">
                            <StackPanel>

                                <TextBlock Text="SELECT VOUCHER" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,6">
                                    <ComboBox ItemsSource="{Binding Vouchers}"
                                              SelectedItem="{Binding AssignVoucher}"
>
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Foreground="#E5E7EB" FontSize="12">
                                                    <Run Text="{Binding Code, Mode=OneWay}" FontWeight="SemiBold"/>
                                                    <Run Text="  —  " Foreground="#4B5563"/>
                                                    <Run Text="{Binding DiscountDisplay, Mode=OneWay}" Foreground="#34D399"/>
                                                    <Run Text="  |  Used: " Foreground="#6B7280"/>
                                                    <Run Text="{Binding TimesUsed, Mode=OneWay}"/>
                                                    <Run Text="/" Foreground="#6B7280"/>
                                                    <Run Text="{Binding MaxUsesDisplay, Mode=OneWay}"/>
                                                    <Run Text="  |  " Foreground="#6B7280"/>
                                                    <Run Text="{Binding StatusDisplay, Mode=OneWay}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <!-- Placeholder when nothing selected -->
                                    <TextBlock Text="Select Voucher"
                                               Foreground="#4B5563" FontSize="13"
                                               Margin="12,0" VerticalAlignment="Center"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AssignVoucher}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <!-- Voucher details preview -->
                                <Border Background="#111827" CornerRadius="6" Padding="12,8"
                                        Margin="0,0,0,20"
                                        Visibility="{Binding AssignVoucher, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Foreground="#9CA3AF" FontSize="12">
                                            <Run Text="Discount: "/>
                                            <Run Text="{Binding AssignVoucher.DiscountDisplay, Mode=OneWay}"
                                                 Foreground="#34D399"/>
                                        </TextBlock>
                                        <TextBlock Foreground="#9CA3AF" FontSize="12">
                                            <Run Text="Valid: "/>
                                            <Run Text="{Binding AssignVoucher.ValidPeriod, Mode=OneWay}"
                                                 Foreground="#D1D5DB"/>
                                        </TextBlock>
                                        <TextBlock Foreground="#9CA3AF" FontSize="12">
                                            <Run Text="Status: "/>
                                            <Run Text="{Binding AssignVoucher.StatusDisplay, Mode=OneWay}"
                                                 Foreground="#D1D5DB"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Override expiry -->
                                <TextBlock Text="OVERRIDE EXPIRY FOR THESE USERS (optional)"
                                           Style="{StaticResource FieldLabel}"/>
                                <DatePicker SelectedDate="{Binding AssignExpiresAt}"
                                            Height="38" Background="#111827"
                                            Foreground="#F9FAFB" BorderBrush="#374151"
                                            Margin="0,0,0,24"/>

                                <!-- Notification options -->
                                <TextBlock Text="SEND NOTIFICATION VIA" Style="{StaticResource FieldLabel}"/>
                                <Border Background="#111827" CornerRadius="6" Padding="14,12"
                                        Margin="0,0,0,8">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <CheckBox IsChecked="{Binding SendInApp}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,10,0"/>
                                            <StackPanel>
                                                <TextBlock Text="Website Notification"
                                                           Foreground="#F9FAFB" FontSize="13"/>
                                                <TextBlock Text="Appears in the customer's in-app notification bell."
                                                           Foreground="#6B7280" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox IsChecked="{Binding SendEmail}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,10,0"/>
                                            <StackPanel>
                                                <TextBlock Text="Email (Gmail)"
                                                           Foreground="#F9FAFB" FontSize="13"/>
                                                <TextBlock Text="Queued for delivery — requires Gmail SMTP to be configured."
                                                           Foreground="#6B7280" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Assign button -->
                                <Button Command="{Binding AssignCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Height="42" Margin="0,16,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x1F3AB;" FontSize="14"
                                                   Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Assign &amp; Notify"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                            </StackPanel>
                        </Border>

                        <!-- ── Right column: customer search ── -->
                        <Border Grid.Column="2" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Search input + dropdown -->
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="SEARCH CUSTOMERS" Style="{StaticResource FieldLabel}"/>
                                    <Grid>
                                        <Grid>
                                            <TextBox Text="{Binding UserSearch, UpdateSourceTrigger=PropertyChanged}"
/>
                                            <TextBlock Text="Search users..."
                                                       Foreground="#4B5563" FontSize="13"
                                                       Margin="12,0" VerticalAlignment="Center"
                                                       IsHitTestVisible="False">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding UserSearch}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding UserSearch}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                        <!-- Dropdown results -->
                                        <Border Margin="0,38,0,0" Panel.ZIndex="20"
                                                Background="#1F2937" BorderBrush="#374151"
                                                BorderThickness="1" CornerRadius="0,0,6,6"
                                                Visibility="{Binding IsUserDropdownOpen, Converter={StaticResource BoolToVis}}">
                                            <ItemsControl ItemsSource="{Binding UserResults}"
                                                          MaxHeight="200">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Command="{Binding DataContext.AddUserCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Background="Transparent"
                                                                BorderThickness="0" Cursor="Hand"
                                                                HorizontalContentAlignment="Left">
                                                            <Border Padding="12,8">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsMouseOver,
                                                                                         RelativeSource={RelativeSource AncestorType=Button}}"
                                                                                         Value="True">
                                                                                <Setter Property="Background" Value="#374151"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Name}"
                                                                               Foreground="#F9FAFB" FontSize="13"/>
                                                                    <TextBlock Foreground="#6B7280" FontSize="11">
                                                                        <Run Text="{Binding Email, Mode=OneWay}"/>
                                                                        <Run Text=" · "/>
                                                                        <Run Text="{Binding TypeLabel, Mode=OneWay}"
                                                                             Foreground="#60A5FA"/>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </Border>
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <ContentPresenter/>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <!-- Selected count -->
                                <TextBlock Grid.Row="1" Margin="0,16,0,8"
                                           Foreground="#6B7280" FontSize="12">
                                    <Run Text="SELECTED CUSTOMERS —"/>
                                    <Run Text="{Binding SelectedUsers.Count, Mode=OneWay}"
                                         Foreground="#9CA3AF"/>
                                </TextBlock>

                                <!-- Selected users list -->
                                <Border Grid.Row="2" Background="#111827"
                                        CornerRadius="6" MinHeight="120">
                                    <ItemsControl ItemsSource="{Binding SelectedUsers}"
                                                  Margin="4">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="10,8" Margin="2">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding Name}"
                                                                       Foreground="#F9FAFB" FontSize="13"/>
                                                            <TextBlock Text="{Binding Email}"
                                                                       Foreground="#6B7280" FontSize="11"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1"
                                                                Content="&#x2715;"
                                                                Command="{Binding DataContext.RemoveUserCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Background="Transparent"
                                                                Foreground="#EF4444"
                                                                BorderThickness="0"
                                                                FontSize="12" Cursor="Hand"
                                                                VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>

                            </Grid>
                        </Border>

                    </Grid>
                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>
