<UserControl x:Class="AdminSystem_v2.Views.VoucherView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#141414">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── Tab button ── -->
        <Style x:Key="TabBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="Padding"         Value="20,0"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#D1D5DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Card border ── -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="#1C1C1C"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="BorderBrush"     Value="#2D3748"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="20"/>
        </Style>

        <!-- ── DataGrid ── -->
        <Style x:Key="VGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="IsReadOnly"               Value="True"/>
            <Setter Property="Background"               Value="#1C1C1C"/>
            <Setter Property="Foreground"               Value="#E5E7EB"/>
            <Setter Property="BorderBrush"              Value="#2D3748"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="RowBackground"            Value="#1C1C1C"/>
            <Setter Property="AlternatingRowBackground" Value="#0F0F0F"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E2E2E"/>
            <Setter Property="HeadersVisibility"        Value="Column"/>
            <Setter Property="CanUserResizeRows"        Value="False"/>
            <Setter Property="SelectionMode"            Value="Single"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"      Value="#141414"/>
                        <Setter Property="Foreground"      Value="#9CA3AF"/>
                        <Setter Property="FontSize"        Value="11"/>
                        <Setter Property="FontWeight"      Value="SemiBold"/>
                        <Setter Property="Padding"         Value="12,8"/>
                        <Setter Property="BorderBrush"     Value="#2E2E2E"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding"         Value="12,8"/>
                        <Setter Property="Foreground"      Value="#E5E7EB"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1E2E3E"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Small action button ── -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"    Value="#2E2E2E"/>
            <Setter Property="Foreground"    Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"       Value="10,4"/>
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A4A4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Status filter pill ── -->
        <Style x:Key="PillBtn" TargetType="Button">
            <Setter Property="Background"      Value="#1E1E1E"/>
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="BorderBrush"     Value="#2E2E2E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="14,5"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"  Value="#2E2E2E"/>
                                <Setter Property="Foreground"  Value="#F9FAFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- tab bar -->
            <RowDefinition Height="Auto"/> <!-- status -->
            <RowDefinition Height="*"/>    <!-- content -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════
             ROW 0 — TAB BAR
             ══════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1C1C1C"
                BorderBrush="#2E2E2E" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">

                <Button Command="{Binding ShowVouchersTabCommand}" Content="Manage Vouchers">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TabBtn}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsVouchersTab}" Value="True">
                                    <Setter Property="Foreground"  Value="#F9FAFB"/>
                                    <Setter Property="BorderBrush" Value="#DC2626"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Command="{Binding ShowAssignTabCommand}" Content="Assign to Customers">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TabBtn}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAssignTab}" Value="True">
                                    <Setter Property="Foreground"  Value="#F9FAFB"/>
                                    <Setter Property="BorderBrush" Value="#DC2626"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 1 — STATUS
             ══════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#1C3A2A" Padding="20,8"
                Visibility="{Binding HasSuccess, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding SuccessMessage}" Foreground="#6EE7B7" FontSize="13"/>
        </Border>
        <Border Grid.Row="1" Background="#3B1010" Padding="20,8"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" FontSize="13"/>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 2 — CONTENT
             ══════════════════════════════════════ -->
        <Grid Grid.Row="2">

            <!-- Loading overlay -->
            <Border Background="#80141414" Panel.ZIndex="10"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Loading..." Foreground="#9CA3AF"
                           FontSize="14" HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- ════════════════════════════
                 MANAGE VOUCHERS TAB
                 ════════════════════════════ -->
            <Grid Visibility="{Binding IsVouchersTab, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ── Left: list ── -->
                <Grid Grid.Column="0" Margin="20,16,12,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Grid Grid.Row="0" Margin="0,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                        </Grid.RowDefinitions>

                        <!-- ─ Search + Refresh + New Voucher ─ -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Search box with placeholder overlay -->
                            <Border Grid.Column="0"
                                    Background="#141414" CornerRadius="8"
                                    BorderBrush="#2E2E2E" BorderThickness="1"
                                    Height="36" Padding="10,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#x1F50D;"
                                               FontSize="13" Foreground="#4A4A4A"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Grid Grid.Column="1">
                                        <TextBox Text="{Binding ListSearch, UpdateSourceTrigger=PropertyChanged}"
                                                 x:Name="VoucherListSearch"
                                                 Background="Transparent" Foreground="White"
                                                 BorderThickness="0" FontSize="13"
                                                 Padding="0" VerticalContentAlignment="Center"
                                                 CaretBrush="White"/>
                                        <TextBlock Text="Search by code, description or status…"
                                                   Foreground="#4A4A4A" FontSize="13"
                                                   Margin="2,0" VerticalAlignment="Center"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ListSearch}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ListSearch}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Button Grid.Column="2"
                                    Command="{Binding RefreshCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Content="&#x21BB; Refresh"/>

                            <Button Grid.Column="4"
                                    Command="{Binding NewVoucherCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Content="+ New Voucher"/>
                        </Grid>

                        <!-- ─ Status filter pills (merged with counts, Orders-style) ─ -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="2,0">
                            <TextBlock Text="Status:" Foreground="#6B7280" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>

                            <!-- All -->
                            <Button Command="{Binding SetStatusFilterCommand}" CommandParameter="All"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Padding="0" Margin="0,0,6,0" FocusVisualStyle="{x:Null}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Button.Template>
                                <Border CornerRadius="6" Padding="12,6">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1C1C1C"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusFilter}" Value="All">
                                                    <Setter Property="BorderBrush" Value="#9CA3AF"/>
                                                    <Setter Property="Background" Value="#2E2E2E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="#9CA3AF" Margin="0,0,6,0"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock Text="All" Foreground="#D1D5DB" FontSize="12"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Button>

                            <!-- Active -->
                            <Button Command="{Binding SetStatusFilterCommand}" CommandParameter="Active"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Padding="0" Margin="0,0,6,0" FocusVisualStyle="{x:Null}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Button.Template>
                                <Border CornerRadius="6" Padding="12,6">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1C1C1C"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusFilter}" Value="Active">
                                                    <Setter Property="BorderBrush" Value="#34D399"/>
                                                    <Setter Property="Background" Value="#052e16"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="#34D399" Margin="0,0,6,0"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock Text="Active" Foreground="#D1D5DB" FontSize="12"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <Border CornerRadius="4" Padding="6,2" Margin="6,0,0,0"
                                                Background="#052e16" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ActiveCount}" Foreground="#34D399"
                                                       FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Button>

                            <!-- Inactive -->
                            <Button Command="{Binding SetStatusFilterCommand}" CommandParameter="Inactive"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Padding="0" Margin="0,0,6,0" FocusVisualStyle="{x:Null}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Button.Template>
                                <Border CornerRadius="6" Padding="12,6">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1C1C1C"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusFilter}" Value="Inactive">
                                                    <Setter Property="BorderBrush" Value="#6B7280"/>
                                                    <Setter Property="Background" Value="#2E2E2E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="#6B7280" Margin="0,0,6,0"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock Text="Inactive" Foreground="#D1D5DB" FontSize="12"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <Border CornerRadius="4" Padding="6,2" Margin="6,0,0,0"
                                                Background="#1E1E1E" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding InactiveCount}" Foreground="#6B7280"
                                                       FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Button>

                            <!-- Expired -->
                            <Button Command="{Binding SetStatusFilterCommand}" CommandParameter="Expired"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Padding="0" Margin="0,0,6,0" FocusVisualStyle="{x:Null}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Button.Template>
                                <Border CornerRadius="6" Padding="12,6">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1C1C1C"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusFilter}" Value="Expired">
                                                    <Setter Property="BorderBrush" Value="#EF4444"/>
                                                    <Setter Property="Background" Value="#450a0a"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="#EF4444" Margin="0,0,6,0"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock Text="Expired" Foreground="#D1D5DB" FontSize="12"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <Border CornerRadius="4" Padding="6,2" Margin="6,0,0,0"
                                                Background="#450a0a" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ExpiredCount}" Foreground="#EF4444"
                                                       FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Button>

                            <!-- Scheduled -->
                            <Button Command="{Binding SetStatusFilterCommand}" CommandParameter="Scheduled"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Padding="0" FocusVisualStyle="{x:Null}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Button.Template>
                                <Border CornerRadius="6" Padding="12,6">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1C1C1C"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusFilter}" Value="Scheduled">
                                                    <Setter Property="BorderBrush" Value="#60A5FA"/>
                                                    <Setter Property="Background" Value="#1E2E3E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="#60A5FA" Margin="0,0,6,0"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock Text="Scheduled" Foreground="#D1D5DB" FontSize="12"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <Border CornerRadius="4" Padding="6,2" Margin="6,0,0,0"
                                                Background="#1E2E3E" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ScheduledCount}" Foreground="#60A5FA"
                                                       FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </StackPanel>

                    </Grid>



                    <!-- Vouchers DataGrid -->
                    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                        <DataGrid ItemsSource="{Binding FilteredVouchers}"
                                  SelectedItem="{Binding SelectedVoucher, Mode=TwoWay}"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  Style="{StaticResource VGrid}"
                                  Cursor="Hand">
                            <DataGrid.InputBindings>
                                <MouseBinding MouseAction="LeftDoubleClick"
                                              Command="{Binding EditVoucherCommand}"
                                              CommandParameter="{Binding SelectedVoucher}"/>
                            </DataGrid.InputBindings>
                            <DataGrid.Columns>

                                <DataGridTextColumn Header="CODE"
                                                    Binding="{Binding Code}"
                                                    Width="110"/>

                                <DataGridTextColumn Header="DESCRIPTION"
                                                    Binding="{Binding Description}"
                                                    Width="*"/>

                                <DataGridTextColumn Header="DISCOUNT"
                                                    Binding="{Binding DiscountDisplay}"
                                                    Width="100"/>

                                <DataGridTextColumn Header="VALID PERIOD"
                                                    Binding="{Binding ValidPeriod}"
                                                    Width="220"/>

                                <DataGridTextColumn Header="MAX USES"
                                                    Binding="{Binding MaxUsesDisplay}"
                                                    Width="90"/>

                                <DataGridTextColumn Header="USED"
                                                    Binding="{Binding TimesUsed}"
                                                    Width="60"/>

                                <DataGridTextColumn Header="ASSIGNED"
                                                    Binding="{Binding AssignedCount}"
                                                    Width="80"/>

                                <DataGridTextColumn Header="MIN ORDER"
                                                    Binding="{Binding MinOrderDisplay}"
                                                    Width="90"/>

                                <!-- Status badge -->
                                <DataGridTemplateColumn Header="STATUS" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="8,3" Margin="4,3"
                                                    HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#14532D"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusDisplay}" Value="Inactive">
                                                                <Setter Property="Background" Value="#2E2E2E"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusDisplay}" Value="Expired">
                                                                <Setter Property="Background" Value="#450A0A"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusDisplay}" Value="Scheduled">
                                                                <Setter Property="Background" Value="#1E2E3E"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding StatusDisplay}" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#86EFAC"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StatusDisplay}" Value="Inactive">
                                                                    <Setter Property="Foreground" Value="#9CA3AF"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusDisplay}" Value="Expired">
                                                                    <Setter Property="Foreground" Value="#FCA5A5"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusDisplay}" Value="Scheduled">
                                                                    <Setter Property="Foreground" Value="#93C5FD"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Actions -->
                                <DataGridTemplateColumn Header="ACTIONS" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                                <Button Command="{Binding DataContext.ToggleActiveCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource ActionBtn}">
                                                            <Setter Property="Content" Value="Deactivate"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                    <Setter Property="Content"     Value="Activate"/>
                                                                    <Setter Property="Background"  Value="#14532D"/>
                                                                    <Setter Property="Foreground"  Value="#86EFAC"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

                <!-- ── Right: Create / Edit form panel ── -->
                <Border Grid.Column="1" Width="380"
                        Background="#1C1C1C"
                        BorderBrush="#2D3748" BorderThickness="1,0,0,0"
                        Visibility="{Binding IsFormOpen, Converter={StaticResource BoolToVis}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24">

                            <!-- Form header -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding FormTitle}"
                                           Foreground="#F9FAFB"
                                           FontSize="16" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Command="{Binding CancelFormCommand}"
                                        Style="{StaticResource ActionBtn}"
                                        Content="&#x2715;" Width="28"/>
                            </Grid>

                            <!-- Code + Generate -->
                            <TextBlock Text="VOUCHER CODE" Style="{StaticResource FieldLabel}"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}"

                                         CharacterCasing="Upper"/>
                                <Button Grid.Column="2"
                                        Command="{Binding GenerateCodeCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Content="Generate" Height="38"/>
                            </Grid>

                            <!-- Description -->
                            <TextBlock Text="DESCRIPTION (optional)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"

                                     Height="72" TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Margin="0,0,0,14"/>

                            <!-- Discount Type -->
                            <TextBlock Text="DISCOUNT TYPE" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding DiscountTypes}"
                                      SelectedItem="{Binding DiscountType}"

                                      Margin="0,0,0,14"/>

                            <!-- Discount Value -->
                            <TextBlock Foreground="#9CA3AF" FontSize="12" FontWeight="SemiBold"
                                       Margin="0,0,0,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="DISCOUNT VALUE (₱)"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPercentage}" Value="True">
                                                <Setter Property="Text" Value="DISCOUNT VALUE (%)"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox Text="{Binding DiscountValueText, UpdateSourceTrigger=PropertyChanged}"

                                     Margin="0,0,0,14"/>

                            <!-- Min Order Amount -->
                            <TextBlock Text="MINIMUM ORDER AMOUNT (optional)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding MinOrderText, UpdateSourceTrigger=PropertyChanged}"

                                     Margin="0,0,0,14"/>

                            <!-- Max Uses / Per User -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="MAX TOTAL USES" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding MaxUsesText, UpdateSourceTrigger=PropertyChanged}"

                                             Tag="Unlimited"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="MAX PER USER" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding MaxUsesPerUserText, UpdateSourceTrigger=PropertyChanged}"

                                             Tag="Unlimited"/>
                                </StackPanel>
                            </Grid>

                            <!-- Start / End Dates -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="START DATE" Style="{StaticResource FieldLabel}"/>
                                    <DatePicker SelectedDate="{Binding StartDate}"
                                                Height="38" Background="#141414"
                                                Foreground="#F9FAFB" BorderBrush="#2E2E2E"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="END DATE (optional)" Style="{StaticResource FieldLabel}"/>
                                    <DatePicker SelectedDate="{Binding EndDate}"
                                                Height="38" Background="#141414"
                                                Foreground="#F9FAFB" BorderBrush="#2E2E2E"/>
                                </StackPanel>
                            </Grid>

                            <!-- Is Active toggle -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <CheckBox IsChecked="{Binding FormIsActive}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0">
                                    <CheckBox.Resources>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="Foreground" Value="#D1D5DB"/>
                                        </Style>
                                    </CheckBox.Resources>
                                </CheckBox>
                                <TextBlock Text="Active (voucher is usable)"
                                           Foreground="#9CA3AF" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Save / Cancel -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Command="{Binding CancelFormCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Content="Cancel"/>
                                <Button Grid.Column="2"
                                        Command="{Binding SaveVoucherCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Content="Save Voucher"/>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

            </Grid>

            <!-- ════════════════════════════
                 ASSIGN TO CUSTOMERS TAB
                 ════════════════════════════ -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsAssignTab, Converter={StaticResource BoolToVis}}">
                <StackPanel Margin="28">

                    <!-- Header -->
                    <TextBlock Text="Assign Voucher to Customers"
                               Foreground="#F9FAFB"
                               FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Assign a voucher code to registered customers and queue a notification."
                               Foreground="#6B7280" FontSize="12" Margin="0,0,0,24"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ── Left column: voucher + options ── -->
                        <Border Grid.Column="0" Style="{StaticResource Card}">
                            <StackPanel>

                                <TextBlock Text="SELECT VOUCHER" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,6">
                                    <ComboBox ItemsSource="{Binding AssignableVouchers}"
                                              SelectedItem="{Binding AssignVoucher}"
>
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Foreground="#E5E7EB" FontSize="12">
                                                    <Run Text="{Binding Code, Mode=OneWay}" FontWeight="SemiBold"/>
                                                    <Run Text="  —  " Foreground="#4A4A4A"/>
                                                    <Run Text="{Binding DiscountDisplay, Mode=OneWay}" Foreground="#34D399"/>
                                                    <Run Text="  |  Used: " Foreground="#6B7280"/>
                                                    <Run Text="{Binding TimesUsed, Mode=OneWay}"/>
                                                    <Run Text="/" Foreground="#6B7280"/>
                                                    <Run Text="{Binding MaxUsesDisplay, Mode=OneWay}"/>
                                                    <Run Text="  |  " Foreground="#6B7280"/>
                                                    <Run Text="{Binding StatusDisplay, Mode=OneWay}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <!-- Placeholder when nothing selected -->
                                    <TextBlock Text="Select Voucher"
                                               Foreground="#4A4A4A" FontSize="13"
                                               Margin="12,0" VerticalAlignment="Center"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AssignVoucher}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <!-- Voucher details preview -->
                                <Border Background="#141414" CornerRadius="6" Padding="12,8"
                                        Margin="0,0,0,20"
                                        Visibility="{Binding AssignVoucher, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Foreground="#9CA3AF" FontSize="12">
                                            <Run Text="Discount: "/>
                                            <Run Text="{Binding AssignVoucher.DiscountDisplay, Mode=OneWay}"
                                                 Foreground="#34D399"/>
                                        </TextBlock>
                                        <TextBlock Foreground="#9CA3AF" FontSize="12">
                                            <Run Text="Valid: "/>
                                            <Run Text="{Binding AssignVoucher.ValidPeriod, Mode=OneWay}"
                                                 Foreground="#D1D5DB"/>
                                        </TextBlock>
                                        <TextBlock Foreground="#9CA3AF" FontSize="12">
                                            <Run Text="Status: "/>
                                            <Run Text="{Binding AssignVoucher.StatusDisplay, Mode=OneWay}"
                                                 Foreground="#D1D5DB"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Override expiry -->
                                <TextBlock Text="OVERRIDE EXPIRY FOR THESE USERS (optional)"
                                           Style="{StaticResource FieldLabel}"/>
                                <DatePicker SelectedDate="{Binding AssignExpiresAt}"
                                            Height="38" Background="#141414"
                                            Foreground="#F9FAFB" BorderBrush="#2E2E2E"
                                            Margin="0,0,0,24"/>

                                <!-- Notification options -->
                                <TextBlock Text="SEND NOTIFICATION VIA" Style="{StaticResource FieldLabel}"/>
                                <Border Background="#141414" CornerRadius="6" Padding="14,12"
                                        Margin="0,0,0,8">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <CheckBox IsChecked="{Binding SendInApp}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,10,0"/>
                                            <StackPanel>
                                                <TextBlock Text="Website Notification"
                                                           Foreground="#F9FAFB" FontSize="13"/>
                                                <TextBlock Text="Appears in the customer's in-app notification bell."
                                                           Foreground="#6B7280" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox IsChecked="{Binding SendEmail}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,10,0"/>
                                            <StackPanel>
                                                <TextBlock Text="Email (Gmail)"
                                                           Foreground="#F9FAFB" FontSize="13"/>
                                                <TextBlock Text="Queued for delivery — requires Gmail SMTP to be configured."
                                                           Foreground="#6B7280" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Assign button -->
                                <Button Command="{Binding AssignCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Height="42" Margin="0,16,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x1F3AB;" FontSize="14"
                                                   Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Assign &amp; Notify"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                            </StackPanel>
                        </Border>

                        <!-- ── Right column: customer search ── -->
                        <Border Grid.Column="2" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Search input + Popup dropdown -->
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="SEARCH CUSTOMERS" Style="{StaticResource FieldLabel}"/>
                                    <Grid>
                                        <!-- Search TextBox -->
                                        <Border Background="#0D1526" CornerRadius="8"
                                                BorderBrush="#2E2E2E" BorderThickness="1"
                                                Height="38" Padding="10,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#x1F50D;"
                                                           FontSize="13" Foreground="#4A4A4A"
                                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <Grid Grid.Column="1">
                                                    <TextBox x:Name="UserSearchBox"
                                                             Text="{Binding UserSearch, UpdateSourceTrigger=PropertyChanged}"
                                                             Background="Transparent" Foreground="White"
                                                             BorderThickness="0" FontSize="13"
                                                             Padding="0" VerticalContentAlignment="Center"
                                                             CaretBrush="White"/>
                                                    <TextBlock Text="Type a name or email…"
                                                               Foreground="#4A4A4A" FontSize="13"
                                                               Margin="2,0" VerticalAlignment="Center"
                                                               IsHitTestVisible="False">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding UserSearch}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding UserSearch}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <!-- Popup dropdown — floats above layout, no shifting -->
                                        <Popup x:Name="UserSearchPopup"
                                               PlacementTarget="{Binding ElementName=UserSearchBox}"
                                               Placement="Bottom"
                                               StaysOpen="True"
                                               AllowsTransparency="True"
                                               IsOpen="{Binding IsUserDropdownOpen}">
                                            <Border MinWidth="300"
                                                    Background="#1C1C1C" BorderBrush="#2E2E2E"
                                                    BorderThickness="1" CornerRadius="0,0,8,8">
                                                <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl ItemsSource="{Binding UserResults}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Button Command="{Binding DataContext.AddUserCommand,
                                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Background="Transparent"
                                                                        BorderThickness="0" Cursor="Hand"
                                                                        HorizontalContentAlignment="Left">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="HoverBorder" Padding="12,9"
                                                                                    Background="Transparent">
                                                                                <StackPanel>
                                                                                    <TextBlock Text="{Binding Name}"
                                                                                               Foreground="#F9FAFB" FontSize="13"
                                                                                               FontWeight="SemiBold"/>
                                                                                    <TextBlock Foreground="#6B7280" FontSize="11">
                                                                                        <Run Text="{Binding Email, Mode=OneWay}"/>
                                                                                        <Run Text=" · "/>
                                                                                        <Run Text="{Binding TypeLabel, Mode=OneWay}"
                                                                                             Foreground="#60A5FA"/>
                                                                                    </TextBlock>
                                                                                </StackPanel>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="HoverBorder" Property="Background" Value="#2E2E2E"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                </StackPanel>

                                <!-- Selected count -->
                                <TextBlock Grid.Row="1" Margin="0,16,0,8"
                                           Foreground="#6B7280" FontSize="12">
                                    <Run Text="SELECTED CUSTOMERS —"/>
                                    <Run Text="{Binding SelectedUsers.Count, Mode=OneWay}"
                                         Foreground="#9CA3AF"/>
                                </TextBlock>

                                <!-- Selected users list -->
                                <Border Grid.Row="2" Background="#141414"
                                        CornerRadius="6" MinHeight="120">
                                    <ItemsControl ItemsSource="{Binding SelectedUsers}"
                                                  Margin="6">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,7" Margin="2"
                                                        Background="#1C1C1C"
                                                        CornerRadius="8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Avatar circle with initial -->
                                                        <Border Grid.Column="0"
                                                                Width="32" Height="32"
                                                                CornerRadius="16"
                                                                Background="#DC2626"
                                                                Margin="0,0,10,0">
                                                            <TextBlock Text="{Binding Initial, Mode=OneWay}"
                                                                       Foreground="White"
                                                                       FontSize="13" FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>

                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       Foreground="#F9FAFB" FontSize="13"
                                                                       FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding Email}"
                                                                       Foreground="#6B7280" FontSize="11"/>
                                                        </StackPanel>

                                                        <Button Grid.Column="2"
                                                                Content="&#x2715;"
                                                                Command="{Binding DataContext.RemoveUserCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Background="Transparent"
                                                                Foreground="#6B7280"
                                                                BorderThickness="0"
                                                                FontSize="14" Cursor="Hand"
                                                                VerticalAlignment="Center"
                                                                Padding="4"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>

                            </Grid>
                        </Border>

                    </Grid>
                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>
