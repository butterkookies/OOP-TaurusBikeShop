<UserControl x:Class="AdminSystem_v2.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AdminSystem_v2.Converters"
             xmlns:oxy="http://oxyplot.org/wpf"
             Background="#141414">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:StatusToColorConverter x:Key="StatusColor"/>

        <!-- ── Section tab button ── -->
        <Style x:Key="TabBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="Padding"         Value="20,0"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#D1D5DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Toggle pill button (source / period) ── -->
        <Style x:Key="PillBtn" TargetType="Button">
            <Setter Property="Background"      Value="#2E2E2E"/>
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A4A4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active state for source pills (red accent) -->
        <Style x:Key="PillBtnActiveRed" TargetType="Button" BasedOn="{StaticResource PillBtn}">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="#F9FAFB"/>
        </Style>

        <!-- Active state for period pills (blue accent) -->
        <Style x:Key="PillBtnActiveBlue" TargetType="Button" BasedOn="{StaticResource PillBtn}">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="Foreground" Value="#F9FAFB"/>
        </Style>

        <!-- ── Stat card ── -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background"      Value="#1C1C1C"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="20"/>
            <Setter Property="BorderBrush"     Value="#2D3748"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ── DataGrid shared style ── -->
        <Style x:Key="ReportGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="IsReadOnly"               Value="True"/>
            <Setter Property="Background"               Value="#1C1C1C"/>
            <Setter Property="Foreground"               Value="#E5E7EB"/>
            <Setter Property="BorderBrush"              Value="#2D3748"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="RowBackground"            Value="#1C1C1C"/>
            <Setter Property="AlternatingRowBackground" Value="#0F0F0F"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E2E2E"/>
            <Setter Property="HeadersVisibility"        Value="Column"/>
            <Setter Property="CanUserResizeRows"        Value="False"/>
            <Setter Property="SelectionMode"            Value="Single"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"      Value="#141414"/>
                        <Setter Property="Foreground"      Value="#9CA3AF"/>
                        <Setter Property="FontSize"        Value="11"/>
                        <Setter Property="FontWeight"      Value="SemiBold"/>
                        <Setter Property="Padding"         Value="12,8"/>
                        <Setter Property="BorderBrush"     Value="#2E2E2E"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding"         Value="12,8"/>
                        <Setter Property="Foreground"      Value="#E5E7EB"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1E2E3E"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>    <!-- section tab bar -->
            <RowDefinition Height="Auto"/>  <!-- status messages -->
            <RowDefinition Height="*"/>     <!-- content -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════
             ROW 0 — SECTION TAB BAR
             ══════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1C1C1C"
                BorderBrush="#2E2E2E" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">

                <Button Command="{Binding ShowSalesTabCommand}" Content="Sales Report">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TabBtn}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSalesTab}" Value="True">
                                    <Setter Property="Foreground"  Value="#F9FAFB"/>
                                    <Setter Property="BorderBrush" Value="#DC2626"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Command="{Binding ShowInventoryTabCommand}" Content="Inventory Report">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TabBtn}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsInventoryTab}" Value="True">
                                    <Setter Property="Foreground"  Value="#F9FAFB"/>
                                    <Setter Property="BorderBrush" Value="#DC2626"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 1 — STATUS MESSAGES
             ══════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#1C3A2A" Padding="20,8"
                Visibility="{Binding HasSuccess, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding SuccessMessage}" Foreground="#6EE7B7" FontSize="13"/>
        </Border>
        <Border Grid.Row="1" Background="#3B1010" Padding="20,8"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" FontSize="13"/>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 2 — CONTENT
             ══════════════════════════════════════ -->
        <Grid Grid.Row="2">

            <!-- Loading overlay -->
            <Border Background="#80141414" Panel.ZIndex="10"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Loading..." Foreground="#9CA3AF"
                           FontSize="14" HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- ════════════════════
                 SALES REPORT TAB
                 ════════════════════ -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsSalesTab, Converter={StaticResource BoolToVis}}">
                <StackPanel Margin="28">

                    <!-- Header row -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Sales Report" Foreground="#F9FAFB"
                                       FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Foreground="#6B7280" FontSize="12" Margin="0,2,0,0">
                                <Run Text="Showing:"/>
                                <Run Text="{Binding SourceLabel, Mode=OneWay}" Foreground="#9CA3AF"/>
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding ExportSalesReportCommand}"
                                Style="{StaticResource SecondaryButton}"
                                VerticalAlignment="Bottom"
                                ToolTip="Export the current sales report to Excel (.xlsx)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2B07;" FontSize="12" Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Export to Excel" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- ── Source toggle + Period toggle ── -->
                    <Border Background="#1C1C1C" CornerRadius="10" Padding="16,12"
                            BorderThickness="1" BorderBrush="#2D3748" Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Source label + pills -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="SOURCE" Foreground="#6B7280"
                                           FontSize="10" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Width="70"/>
                                <StackPanel Orientation="Horizontal">

                                    <Button Content="Online Orders"
                                            Command="{Binding SetSourceOnlineCommand}"
                                            Margin="0,0,6,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PillBtn}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOnlineSource}" Value="True">
                                                        <Setter Property="Background" Value="#DC2626"/>
                                                        <Setter Property="Foreground" Value="#F9FAFB"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Content="Walk-in (POS)"
                                            Command="{Binding SetSourceWalkInCommand}"
                                            Margin="0,0,6,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PillBtn}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsWalkInSource}" Value="True">
                                                        <Setter Property="Background" Value="#DC2626"/>
                                                        <Setter Property="Foreground" Value="#F9FAFB"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Content="Combined"
                                            Command="{Binding SetSourceCombinedCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PillBtn}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCombinedSource}" Value="True">
                                                        <Setter Property="Background" Value="#DC2626"/>
                                                        <Setter Property="Foreground" Value="#F9FAFB"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                </StackPanel>
                            </StackPanel>

                            <!-- Period label + pills -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal">
                                <TextBlock Text="PERIOD" Foreground="#6B7280"
                                           FontSize="10" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Width="70"/>
                                <StackPanel Orientation="Horizontal">

                                    <Button Content="Daily"
                                            Command="{Binding SetPeriodDailyCommand}"
                                            Margin="0,0,6,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PillBtn}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDaily}" Value="True">
                                                        <Setter Property="Background" Value="#1D4ED8"/>
                                                        <Setter Property="Foreground" Value="#F9FAFB"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Content="Weekly"
                                            Command="{Binding SetPeriodWeeklyCommand}"
                                            Margin="0,0,6,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PillBtn}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsWeekly}" Value="True">
                                                        <Setter Property="Background" Value="#1D4ED8"/>
                                                        <Setter Property="Foreground" Value="#F9FAFB"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Content="Monthly"
                                            Command="{Binding SetPeriodMonthlyCommand}"
                                            Margin="0,0,6,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PillBtn}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMonthly}" Value="True">
                                                        <Setter Property="Background" Value="#1D4ED8"/>
                                                        <Setter Property="Foreground" Value="#F9FAFB"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Content="Yearly"
                                            Command="{Binding SetPeriodYearlyCommand}"
                                            Margin="0,0,6,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PillBtn}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsYearly}" Value="True">
                                                        <Setter Property="Background" Value="#1D4ED8"/>
                                                        <Setter Property="Foreground" Value="#F9FAFB"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Content="Custom"
                                            Command="{Binding SetPeriodCustomCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PillBtn}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCustomPeriod}" Value="True">
                                                        <Setter Property="Background" Value="#1D4ED8"/>
                                                        <Setter Property="Foreground" Value="#F9FAFB"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                </StackPanel>
                            </StackPanel>

                            <!-- Custom date range (only visible when Custom period selected) -->
                            <StackPanel Grid.Row="4" Orientation="Horizontal"
                                        Visibility="{Binding IsCustomPeriod, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="FROM" Foreground="#6B7280"
                                           FontSize="10" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Width="70"/>
                                <DatePicker SelectedDate="{Binding FromDate}"
                                            Width="150" Height="36"
                                            Background="#0D1526" Foreground="#F9FAFB"
                                            BorderBrush="#2E2E2E" FontSize="13"
                                            Margin="0,0,16,0"/>
                                <TextBlock Text="TO" Foreground="#6B7280"
                                           FontSize="10" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <DatePicker SelectedDate="{Binding ToDate}"
                                            Width="150" Height="36"
                                            Background="#0D1526" Foreground="#F9FAFB"
                                            BorderBrush="#2E2E2E" FontSize="13"
                                            Margin="0,0,16,0"/>
                                <Button Content="Run Report"
                                        Command="{Binding RunSalesReportCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Height="36" Width="120"
                                        VerticalAlignment="Center"/>
                            </StackPanel>

                        </Grid>
                    </Border>

                    <!-- ── Summary cards ── -->
                    <UniformGrid Rows="1" Columns="3" Margin="0,0,0,20">

                        <!-- Total Orders -->
                        <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="TOTAL ORDERS" Foreground="#6B7280"
                                           FontSize="10" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SalesSummary.TotalOrders, FallbackValue='—'}"
                                           Foreground="#F9FAFB"
                                           FontSize="36" FontWeight="Bold" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding OrdersCardLabel}"
                                           Foreground="#4A4A4A" FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <!-- Total Revenue -->
                        <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="TOTAL REVENUE" Foreground="#6B7280"
                                           FontSize="10" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SalesSummary.TotalRevenue,
                                               StringFormat='₱{0:N0}', FallbackValue='—'}"
                                           Foreground="#34D399"
                                           FontSize="28" FontWeight="Bold" Margin="0,8,0,4"/>
                                <TextBlock Foreground="#4A4A4A" FontSize="11">
                                    <Run Text="Avg "/>
                                    <Run Text="{Binding SalesSummary.AvgOrderValue,
                                                StringFormat='₱{0:N2}', FallbackValue='—', Mode=OneWay}"/>
                                    <Run Text=" / order"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Gross / Discounts -->
                        <Border Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="GROSS / DISCOUNTS" Foreground="#6B7280"
                                           FontSize="10" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SalesSummary.GrossRevenue,
                                               StringFormat='₱{0:N0}', FallbackValue='—'}"
                                           Foreground="#F9FAFB"
                                           FontSize="28" FontWeight="Bold" Margin="0,8,0,4"/>
                                <TextBlock Foreground="#4A4A4A" FontSize="11">
                                    <Run Text="Discounts "/>
                                    <Run Foreground="#EF4444"
                                         Text="{Binding SalesSummary.TotalDiscounts,
                                                StringFormat='−₱{0:N2}', FallbackValue='—', Mode=OneWay}"/>
                                    <Run Text="  Shipping "/>
                                    <Run Foreground="#60A5FA"
                                         Text="{Binding SalesSummary.TotalShipping,
                                                StringFormat='₱{0:N2}', FallbackValue='—', Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                    </UniformGrid>

                    <!-- ── Revenue trend chart ── -->
                    <Border Style="{StaticResource StatCard}" Margin="0,0,0,20" Padding="16,12">
                        <StackPanel>
                            <TextBlock Text="REVENUE TREND" Foreground="#6B7280"
                                       FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <oxy:PlotView Model="{Binding ChartModel}"
                                          Height="220"
                                          Background="Transparent"
                                          IsMouseWheelEnabled="False"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Two-column: breakdown | top products ── -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="340"/>
                        </Grid.ColumnDefinitions>

                        <!-- Breakdown table -->
                        <Border Grid.Column="0" Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="{Binding BreakdownLabel}" Foreground="#6B7280"
                                           FontSize="10" FontWeight="SemiBold" Margin="0,0,0,12"/>

                                <DataGrid ItemsSource="{Binding DailySales}"
                                          Style="{StaticResource ReportGrid}"
                                          MaxHeight="400">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Date"
                                                            Binding="{Binding SaleDateDisplay}"
                                                            Width="*"/>
                                        <DataGridTextColumn Header="Orders"
                                                            Binding="{Binding OrderCount}"
                                                            Width="70"/>
                                        <DataGridTextColumn Header="Revenue"
                                                            Binding="{Binding Revenue, StringFormat='₱{0:N2}'}"
                                                            Width="120"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Text="No data — select a period or run a custom report."
                                           Foreground="#4A4A4A" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,16"
                                           Visibility="{Binding DailySales.Count,
                                               Converter={StaticResource BoolToVis},
                                               ConverterParameter=Inverse}"/>
                            </StackPanel>
                        </Border>

                        <!-- Top products -->
                        <Border Grid.Column="2" Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="TOP 10 PRODUCTS" Foreground="#6B7280"
                                           FontSize="10" FontWeight="SemiBold" Margin="0,0,0,12"/>

                                <DataGrid ItemsSource="{Binding TopProducts}"
                                          Style="{StaticResource ReportGrid}"
                                          MaxHeight="400">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Product"
                                                            Binding="{Binding ProductName}"
                                                            Width="*"/>
                                        <DataGridTextColumn Header="Units"
                                                            Binding="{Binding UnitsSold}"
                                                            Width="60"/>
                                        <DataGridTextColumn Header="Revenue"
                                                            Binding="{Binding Revenue, StringFormat='₱{0:N2}'}"
                                                            Width="110"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Text="No data for selected range."
                                           Foreground="#4A4A4A" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,16"
                                           Visibility="{Binding TopProducts.Count,
                                               Converter={StaticResource BoolToVis},
                                               ConverterParameter=Inverse}"/>
                            </StackPanel>
                        </Border>

                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- ════════════════════
                 INVENTORY REPORT TAB
                 ════════════════════ -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsInventoryTab, Converter={StaticResource BoolToVis}}">
                <StackPanel Margin="28">

                    <!-- Header -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Inventory Report" Foreground="#F9FAFB"
                                       FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="Stock levels for all active product variants."
                                       Foreground="#6B7280" FontSize="12"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding RefreshInventoryCommand}"
                                Style="{StaticResource SecondaryButton}"
                                VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x21BB;" FontSize="12" Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Refresh" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Inventory summary cards -->
                    <UniformGrid Rows="1" Columns="5" Margin="0,0,0,24">

                        <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="TOTAL VARIANTS" Foreground="#6B7280"
                                           FontSize="9" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding InvTotal}" Foreground="#F9FAFB"
                                           FontSize="28" FontWeight="Bold" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="IN STOCK" Foreground="#6B7280"
                                           FontSize="9" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding InvInStock}" Foreground="#22C55E"
                                           FontSize="28" FontWeight="Bold" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="LOW STOCK" Foreground="#6B7280"
                                           FontSize="9" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding InvLowStock}" Foreground="#EAB308"
                                           FontSize="28" FontWeight="Bold" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="OUT OF STOCK" Foreground="#6B7280"
                                           FontSize="9" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding InvOutOfStock}" Foreground="#EF4444"
                                           FontSize="28" FontWeight="Bold" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="TOTAL VALUE" Foreground="#6B7280"
                                           FontSize="9" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding InvTotalValue, StringFormat='₱{0:N0}'}"
                                           Foreground="#60A5FA"
                                           FontSize="22" FontWeight="Bold" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                    </UniformGrid>

                    <!-- Inventory DataGrid -->
                    <Border Style="{StaticResource StatCard}" Padding="0">
                        <DataGrid ItemsSource="{Binding InventoryItems}"
                                  Style="{StaticResource ReportGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product"
                                                    Binding="{Binding ProductName}"
                                                    Width="*" MinWidth="120"/>
                                <DataGridTextColumn Header="Variant"
                                                    Binding="{Binding VariantName}"
                                                    Width="120"/>
                                <DataGridTextColumn Header="SKU"
                                                    Binding="{Binding SKU}"
                                                    Width="100"/>
                                <DataGridTextColumn Header="Category"
                                                    Binding="{Binding CategoryName}"
                                                    Width="110"/>
                                <DataGridTextColumn Header="Stock"
                                                    Binding="{Binding StockQuantity}"
                                                    Width="70"/>
                                <DataGridTextColumn Header="Threshold"
                                                    Binding="{Binding ReorderThreshold}"
                                                    Width="80"/>
                                <DataGridTextColumn Header="Unit Price"
                                                    Binding="{Binding Price, StringFormat='₱{0:N2}'}"
                                                    Width="100"/>
                                <DataGridTextColumn Header="Stock Value"
                                                    Binding="{Binding StockValue, StringFormat='₱{0:N2}'}"
                                                    Width="110"/>

                                <!-- Status column with colour coding -->
                                <DataGridTemplateColumn Header="Status" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="8,3" Margin="4,3"
                                                    HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#14532D"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StockStatus}" Value="LowStock">
                                                                <Setter Property="Background" Value="#713F12"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StockStatus}" Value="OutOfStock">
                                                                <Setter Property="Background" Value="#450A0A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding StockStatus}" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#86EFAC"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StockStatus}" Value="LowStock">
                                                                    <Setter Property="Foreground" Value="#FDE68A"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StockStatus}" Value="OutOfStock">
                                                                    <Setter Property="Foreground" Value="#FCA5A5"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>
