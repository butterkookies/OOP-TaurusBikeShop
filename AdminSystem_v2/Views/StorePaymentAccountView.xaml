<UserControl x:Class="AdminSystem_v2.Views.StorePaymentAccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AdminSystem_v2.Converters"
             Background="#141414">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- =============== LEFT: LIST =============== -->
        <Border Grid.Column="0"
                Background="#1C1C1C"
                CornerRadius="10"
                BorderBrush="#2D3748"
                BorderThickness="1">
            <DockPanel LastChildFill="True">

                <!-- Header -->
                <Grid DockPanel.Dock="Top" Margin="14,12,14,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Store Payment Accounts"
                               Foreground="#F9FAFB"
                               FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Style="{StaticResource SecondaryButton}"
                            Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Margin="0,0,6,0"/>
                    <Button Grid.Column="2"
                            Style="{StaticResource PrimaryButton}"
                            Content="New"
                            Command="{Binding NewCommand}"/>
                </Grid>

                <!-- Messages -->
                <StackPanel DockPanel.Dock="Top" Margin="14,0,14,10">
                    <Border Background="#7F1D1D" CornerRadius="6" Padding="10,6"
                            Visibility="{Binding HasError, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#FCA5A5"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                    <Border Background="#064E3B" CornerRadius="6" Padding="10,6"
                            Margin="0,6,0,0"
                            Visibility="{Binding HasSuccess, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="{Binding SuccessMessage}"
                                   Foreground="#6EE7B7"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>

                <!-- List -->
                <ListBox ItemsSource="{Binding Accounts}"
                         SelectedItem="{Binding Selected, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Margin="8,0,8,10">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background"      Value="Transparent"/>
                            <Setter Property="Padding"         Value="0"/>
                            <Setter Property="Margin"          Value="0,2"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Padding="10,8">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#141414"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#0F172A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding MethodDisplay}"
                                                   Foreground="#F9FAFB"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding BankName, StringFormat=' • {0}'}"
                                                   Foreground="#9CA3AF" FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding AccountName}"
                                               Foreground="#D1D5DB" FontSize="12" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding AccountNumber}"
                                               Foreground="#9CA3AF" FontSize="11" FontFamily="Consolas"/>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Padding="8,2" CornerRadius="10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#2E2E2E"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Background" Value="#065F46"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding StatusDisplay}"
                                               FontSize="10" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#9CA3AF"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Foreground" Value="#A7F3D0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- =============== RIGHT: EDIT FORM =============== -->
        <Border Grid.Column="1"
                Background="#1C1C1C"
                CornerRadius="10"
                BorderBrush="#2D3748"
                BorderThickness="1"
                Margin="14,0,0,0"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolVis}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="18">

                    <TextBlock Text="Edit account"
                               Foreground="#F9FAFB"
                               FontSize="15" FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="Payment method" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding PaymentMethods}"
                              SelectedItem="{Binding FormMethod, Mode=TwoWay}"
                              Margin="0,0,0,12"/>

                    <TextBlock Text="Account name (shown to customer)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FormAccountName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Account number" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FormAccountNumber, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="11"
                             PreviewTextInput="AccountNumber_PreviewTextInput"
                             DataObject.Pasting="AccountNumber_Pasting"
                             Margin="0,0,0,4"/>
                    <TextBlock Foreground="#6B7280" FontSize="11"
                               TextWrapping="Wrap" Margin="0,0,0,12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="GCash: 11 digits, starts with 09 (e.g. 09123456789)."/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FormMethod}" Value="BankTransfer">
                                        <Setter Property="Text" Value="BPI: exactly 10 digits, numbers only."/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Text="Bank name (required for Bank Transfer)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FormBankName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="QR image URL (optional)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FormQrImageUrl, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Customer instructions (optional)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FormInstructions, UpdateSourceTrigger=PropertyChanged}"
                             Height="70"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             Padding="8"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Display order (lower = shown first)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FormDisplayOrder, UpdateSourceTrigger=PropertyChanged}"
                             Width="80"
                             HorizontalAlignment="Left"
                             Margin="0,0,0,12"/>

                    <CheckBox Content="Active (shown to customers for this method)"
                              IsChecked="{Binding FormIsActive, Mode=TwoWay}"
                              Foreground="#D1D5DB"
                              Margin="0,0,0,20"/>

                    <TextBlock Text="Only one Active row per method is allowed. Activating this row will deactivate any other active row of the same method automatically."
                               Foreground="#6B7280"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="0,0,0,18"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource PrimaryButton}"
                                Content="Save"
                                Command="{Binding SaveCommand}"
                                Margin="0,0,8,0"/>
                        <Button Style="{StaticResource SecondaryButton}"
                                Content="Cancel"
                                Command="{Binding CancelCommand}"
                                Margin="0,0,8,0"/>
                        <Button Style="{StaticResource DangerButton}"
                                Content="Delete"
                                Command="{Binding DeleteCommand}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Empty-state placeholder when nothing is selected -->
        <Border Grid.Column="1"
                Background="#1C1C1C"
                CornerRadius="10"
                BorderBrush="#2D3748"
                BorderThickness="1"
                Margin="14,0,0,0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Select an account on the left, or click New to add one."
                           Foreground="#6B7280" FontSize="13"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
