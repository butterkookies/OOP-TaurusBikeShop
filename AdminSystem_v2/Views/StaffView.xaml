<UserControl x:Class="AdminSystem_v2.Views.StaffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AdminSystem_v2.Converters"
             Background="#111827">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>

        <!-- ── Role chip style ── -->
        <Style x:Key="RoleChip" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="BorderBrush"     Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"  Value="#1F2937"/>
                                <Setter Property="Foreground"  Value="#F9FAFB"/>
                                <Setter Property="BorderBrush" Value="#6B7280"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoleChipActive" TargetType="Button" BasedOn="{StaticResource RoleChip}">
            <Setter Property="Background"  Value="#1E3A5F"/>
            <Setter Property="Foreground"  Value="#60A5FA"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
        </Style>

        <!-- ── User list item ── -->
        <Style x:Key="UserListItem" TargetType="ListBoxItem">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="Padding"       Value="0"/>
            <Setter Property="Margin"        Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="12,10" Margin="0,0,0,1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"      Value="#1E3A5F"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="3,0,0,0"/>
                                <Setter TargetName="Bd" Property="BorderBrush"     Value="#3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F2937"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Detail section header ── -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#4B5563"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,10"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,0,2"/>
        </Style>

        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#E5E7EB"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Margin"       Value="0,0,0,12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════
             ROW 0 — TOOLBAR
             ══════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1F2937" BorderBrush="#374151"
                BorderThickness="0,0,0,1" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Staff Accounts" Foreground="#F9FAFB"
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding AddStaffCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Content="+ Add Staff" Margin="0,0,10,0"/>
                    <Button Command="{Binding RefreshCommand}"
                            ToolTip="Refresh staff list"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Padding="8,0">
                        <TextBlock Text="&#x21BB;" Foreground="#9CA3AF" FontSize="16"
                                   VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 1 — STATUS MESSAGES
             ══════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#1C3A2A" Padding="20,8"
                Visibility="{Binding HasSuccess, Converter={StaticResource BoolVis}}">
            <TextBlock Text="{Binding SuccessMessage}" Foreground="#6EE7B7" FontSize="13"/>
        </Border>
        <Border Grid.Row="1" Background="#3B1010" Padding="20,8"
                Visibility="{Binding HasError, Converter={StaticResource BoolVis}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" FontSize="13"/>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 2 — SPLIT: LIST | DETAIL
             ══════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="240"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="360"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════
                 COL 0 — USER LIST
                 ═══════════════════════════ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Role filter chips -->
                <Border Grid.Row="0" Background="#1F2937" Padding="10,8"
                        BorderBrush="#374151" BorderThickness="0,0,0,1">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding RoleFilters}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}"
                                            Command="{Binding DataContext.SelectRoleCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource RoleChip}">
                                                <Style.Triggers>
                                                    <DataTrigger
                                                        Binding="{Binding DataContext.SelectedRoleFilter,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        Value="{Binding}">
                                                        <Setter Property="Style" Value="{StaticResource RoleChipActive}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Search box -->
                <Border Grid.Row="1" Background="#1F2937" Padding="10,8"
                        BorderBrush="#374151" BorderThickness="0,0,0,1">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}"
                             Tag="Search by name or email...">
                        <TextBox.Resources>
                            <Style TargetType="TextBox" BasedOn="{StaticResource FormTextBox}">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </Border>

                <!-- User list -->
                <ListBox Grid.Row="2"
                         ItemsSource="{Binding FilteredUsers}"
                         SelectedItem="{Binding SelectedUser}"
                         Background="#111827"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource UserListItem}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Avatar circle -->
                                <Border Grid.Column="0" Width="36" Height="36"
                                        CornerRadius="18" Background="#374151"
                                        Margin="0,0,10,0" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#374151"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                    <Setter Property="Background" Value="#1F2937"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Initials}"
                                               Foreground="#9CA3AF"
                                               FontSize="13" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- Name + email -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FullName}"
                                               Foreground="#F9FAFB"
                                               FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Email}"
                                               Foreground="#6B7280"
                                               FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Role + active badge stack -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="6,0,0,0">
                                    <!-- Role badge -->
                                    <Border CornerRadius="4" Padding="6,2" Margin="0,0,0,3">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1E3A5F"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="Admin">
                                                        <Setter Property="Background" Value="#450A0A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="Manager">
                                                        <Setter Property="Background" Value="#3B2000"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Role}" FontSize="10" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#60A5FA"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Role}" Value="Admin">
                                                            <Setter Property="Foreground" Value="#F87171"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Role}" Value="Manager">
                                                            <Setter Property="Foreground" Value="#FB923C"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <!-- Active / Inactive badge -->
                                    <Border CornerRadius="4" Padding="6,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#064E3B"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Background" Value="#1F2937"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="10" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"       Value="Active"/>
                                                    <Setter Property="Foreground" Value="#34D399"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Text"       Value="Inactive"/>
                                                            <Setter Property="Foreground" Value="#6B7280"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>

                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </Grid>

            <!-- ── Splitter ── -->
            <GridSplitter Grid.Column="1" Width="1"
                          Background="#374151" ResizeBehavior="PreviousAndNext"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- ═══════════════════════════
                 COL 2 — DETAIL PANEL
                 ═══════════════════════════ -->
            <Grid Grid.Column="2">

                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding IsDetailVisible,
                                         Converter={StaticResource BoolVis},
                                         ConverterParameter=Invert}">
                    <TextBlock Text="&#x1F464;" FontSize="36"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Select a staff member to view details"
                               Foreground="#4B5563" FontSize="14"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Detail content -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding IsDetailVisible, Converter={StaticResource BoolVis}}">
                    <StackPanel Margin="24" DataContext="{Binding SelectedUser}">

                        <!-- ── User header (avatar + name) ── -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="56" Height="56"
                                    CornerRadius="28" Background="#DC2626"
                                    Margin="0,0,16,0" VerticalAlignment="Top">
                                <TextBlock Text="{Binding Initials}"
                                           Foreground="White"
                                           FontSize="22" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding FullName}"
                                           Foreground="#F9FAFB"
                                           FontSize="20" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Email}"
                                           Foreground="#6B7280" FontSize="13"
                                           Margin="0,3,0,0"/>
                                <TextBlock Text="{Binding CreatedAt, StringFormat='Joined {0:MMMM d, yyyy}'}"
                                           Foreground="#4B5563" FontSize="11"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Separator Background="#374151" Margin="0,0,0,20"/>

                        <!-- ── Role change ── -->
                        <Border Background="#1F2937" CornerRadius="8" Padding="16"
                                Margin="0,0,0,16" BorderThickness="1" BorderBrush="#374151">
                            <StackPanel>
                                <TextBlock Text="ROLE" Style="{StaticResource SectionLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0"
                                              ItemsSource="{Binding DataContext.StaffRoleNames,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              SelectedItem="{Binding DataContext.SelectedRole,
                                                             RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              Style="{StaticResource FormComboBox}"/>
                                    <Button Grid.Column="2"
                                            Content="Save Role"
                                            Command="{Binding DataContext.SaveRoleCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Style="{StaticResource PrimaryButton}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ── Account status toggle ── -->
                        <Border Background="#1F2937" CornerRadius="8" Padding="16"
                                Margin="0,0,0,16" BorderThickness="1" BorderBrush="#374151">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="ACCOUNT STATUS" Style="{StaticResource SectionLabel}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#34D399"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Fill" Value="#6B7280"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock VerticalAlignment="Center" FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"       Value="Active — account can log in"/>
                                                    <Setter Property="Foreground" Value="#E5E7EB"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Text"       Value="Inactive — login is disabled"/>
                                                            <Setter Property="Foreground" Value="#6B7280"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Command="{Binding DataContext.ToggleActiveCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        VerticalAlignment="Center">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                            <Setter Property="Content" Value="Deactivate"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                    <Setter Property="Content"     Value="Activate"/>
                                                    <Setter Property="Background"  Value="#064E3B"/>
                                                    <Setter Property="Foreground"  Value="#34D399"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- ── Password reset ── -->
                        <Border Background="#1F2937" CornerRadius="8" Padding="16"
                                Margin="0,0,0,16" BorderThickness="1" BorderBrush="#374151">
                            <StackPanel>
                                <TextBlock Text="RESET PASSWORD" Style="{StaticResource SectionLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding DataContext.NewPasswordText,
                                                    RelativeSource={RelativeSource AncestorType=UserControl},
                                                    UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource FormTextBox}"
                                             Tag="New password (min. 8 chars)"/>
                                    <Button Grid.Column="2"
                                            Content="Reset Password"
                                            Command="{Binding DataContext.ResetPasswordCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Style="{StaticResource DangerButton}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ── Info grid (phone, last login) ── -->
                        <Border Background="#1F2937" CornerRadius="8" Padding="16"
                                Margin="0,0,0,16" BorderThickness="1" BorderBrush="#374151">
                            <StackPanel>
                                <TextBlock Text="ACCOUNT INFO" Style="{StaticResource SectionLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Phone" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock Text="{Binding PhoneNumber, TargetNullValue='—'}"
                                                   Style="{StaticResource FieldValue}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Last Login" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock Style="{StaticResource FieldValue}">
                                            <TextBlock.Text>
                                                <Binding Path="LastLoginAt" TargetNullValue="Never"
                                                         StringFormat="{}{0:MMM d, yyyy  h:mm tt}"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- Loading overlay -->
                <Border Background="#80111827"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}">
                    <TextBlock Text="Loading..." Foreground="#9CA3AF"
                               FontSize="14" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

            </Grid>

        </Grid>

        <!-- ══════════════════════════════════════
             ADD STAFF MODAL OVERLAY
             ══════════════════════════════════════ -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              Background="#CC111827"
              Visibility="{Binding IsCreating, Converter={StaticResource BoolVis}}">

            <Border Background="#1F2937" CornerRadius="12"
                    BorderBrush="#374151" BorderThickness="1"
                    Width="440" VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="28">
                <StackPanel>

                    <TextBlock Text="Add Staff Account"
                               Foreground="#F9FAFB"
                               FontSize="18" FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <!-- First + Last name row -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="First Name" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding NewFirstName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBox}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Last Name" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding NewLastName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBox}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Email -->
                    <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding NewEmail, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}"
                             Margin="0,0,0,14"/>

                    <!-- Phone -->
                    <TextBlock Text="Phone (optional)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding NewPhone, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}"
                             Margin="0,0,0,14"/>

                    <!-- Role -->
                    <TextBlock Text="Role" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding StaffRoleNames}"
                              SelectedItem="{Binding NewRole}"
                              Style="{StaticResource FormComboBox}"
                              Margin="0,0,0,14"/>

                    <!-- Password -->
                    <TextBlock Text="Password (min. 8 chars)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}"
                             Margin="0,0,0,24"/>

                    <!-- Action buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="Cancel"
                                Command="{Binding CancelNewStaffCommand}"
                                Style="{StaticResource SecondaryButton}"/>
                        <Button Grid.Column="2"
                                Content="Create Account"
                                Command="{Binding SaveNewStaffCommand}"
                                Style="{StaticResource PrimaryButton}"/>
                    </Grid>

                </StackPanel>
            </Border>

        </Grid>

    </Grid>
</UserControl>
