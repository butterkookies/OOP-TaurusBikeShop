{
  "ConnectionStrings": {

"Taurus-bike-shop-sqlserver-2026": "SET_VIA_USER_SECRETS_OR_ENVIRONMENT_VARIABLE"
},
  "Session": {

    "IdleTimeoutMinutes": 30,
    "Cookie": {
      "Name": ".TaurusBikeShop.Session",
      "HttpOnly": true,
      "IsEssential": true,
      "SecurePolicy": "Always",
      "SameSite": "Lax"
    }
  },
  "Authentication": {
    "Cookie": {
      "Name": ".TaurusBikeShop.Auth",
      "LoginPath": "/Customer/Login",
      "LogoutPath": "/Customer/Logout",
      "AccessDeniedPath": "/Customer/Login",
      "ExpireTimeSpan": "01:00:00",
      "SlidingExpiration": true
    }
  },
  "GoogleCloudStorage": {

    "BucketName": "taurus-bikeshop-assets",
    "ProductImageFolder": "products",
    "PaymentProofFolder": "payment-proofs",
    "SupportAttachmentFolder": "support-attachments"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "CloudinarySettings": {
      "CloudName": "dhsecafme",
      "ApiKey": "SET_VIA_USER_SECRETS_OR_ENVIRONMENT_VARIABLE",
      "ApiSecret": "SET_VIA_USER_SECRETS_OR_ENVIRONMENT_VARIABLE"
  },

  "AllowedHosts": "*"
}