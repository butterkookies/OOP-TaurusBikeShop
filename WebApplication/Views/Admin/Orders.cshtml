@using WebApplication.Models.Entities
@model IEnumerable<Order>
@{
    Layout = null;
    var statusFilter = ViewBag.StatusFilter as string ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Orders - Admin Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { background:#0B0B0B; color:#F0F0F0; font-family:'Segoe UI',sans-serif; }
        .sidebar { width:220px; min-height:100vh; background:#111; border-right:1px solid #1e1e1e; padding:20px 0; position:fixed; top:0; left:0; }
        .sidebar-brand { font-size:18px; font-weight:700; letter-spacing:.2em; color:#E10600; text-transform:uppercase; padding:12px 20px 24px; }
        .sidebar a { display:block; padding:10px 20px; color:#888; font-size:13px; letter-spacing:.08em; text-transform:uppercase; text-decoration:none; transition:color .2s; }
        .sidebar a:hover, .sidebar a.active { color:#F0F0F0; background:#1a1a1a; }
        .main-content { margin-left:220px; padding:32px; }
        table { background:#111; border-radius:8px; overflow:hidden; }
        th { background:#1a1a1a; color:#888; font-size:12px; letter-spacing:.1em; text-transform:uppercase; border-color:#222 !important; }
        td { border-color:#1e1e1e !important; color:#ccc; font-size:14px; vertical-align:middle; }
        .badge-status { font-size:11px; padding:4px 8px; border-radius:4px; letter-spacing:.05em; text-transform:uppercase; }
        .badge-pending { background:#2a2000; color:#ffc107; }
        .badge-processing { background:#002a1a; color:#28a745; }
        .badge-verification { background:#1a1a00; color:#fd7e14; }
        .badge-rejected { background:#2a0000; color:#dc3545; }
        .filter-btn { font-size:12px; letter-spacing:.08em; text-transform:uppercase; padding:5px 12px; }
    </style>
</head>
<body>

<div class="sidebar">
    <div class="sidebar-brand">&#9650; Admin</div>
    <a href="/Admin/Dashboard">Dashboard</a>
    <a href="/Admin/Orders" class="active">Orders</a>
    <a href="/Admin/Payments">Payments</a>
    <a href="/Admin/Logout" style="color:#555;">Logout</a>
</div>

<div class="main-content">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 style="font-size:22px; font-weight:700; margin:0;">Orders</h2>
    </div>

    <div class="mb-3 d-flex gap-2 flex-wrap">
        <a href="/Admin/Orders" class="btn btn-sm btn-outline-secondary filter-btn @(string.IsNullOrEmpty(statusFilter) ? "active" : "")">All</a>
        <a href="/Admin/Orders?status=Pending" class="btn btn-sm btn-outline-warning filter-btn">Pending</a>
        <a href="/Admin/Orders?status=PendingVerification" class="btn btn-sm btn-outline-warning filter-btn">Pending Verification</a>
        <a href="/Admin/Orders?status=Processing" class="btn btn-sm btn-outline-success filter-btn">Processing</a>
        <a href="/Admin/Orders?status=PaymentRejected" class="btn btn-sm btn-outline-danger filter-btn">Payment Rejected</a>
        <a href="/Admin/Orders?status=Shipped" class="btn btn-sm btn-outline-info filter-btn">Shipped</a>
        <a href="/Admin/Orders?status=Delivered" class="btn btn-sm btn-outline-secondary filter-btn">Delivered</a>
    </div>

    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0">
            <thead>
                <tr>
                    <th>Order #</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Total</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">No orders found.</td>
                    </tr>
                }
                @foreach (var order in Model)
                {
                    var badgeClass = order.OrderStatus switch
                    {
                        "Processing"           => "badge-processing",
                        "PendingVerification"  => "badge-verification",
                        "PaymentRejected"      => "badge-rejected",
                        _                      => "badge-pending"
                    };
                    <tr>
                        <td style="font-family:monospace; color:#F0F0F0;">@order.OrderNumber</td>
                        <td>@(order.User?.FullName ?? "Walk-in")<br /><small class="text-muted">@order.User?.Email</small></td>
                        <td>@order.OrderDate.ToString("MMM d, yyyy")</td>
                        <td><span class="badge-status @badgeClass">@order.OrderStatus</span></td>
                        <td>&#8369;@order.TotalAmount.ToString("N2")</td>
                        <td>
                            <a href="/Admin/OrderDetail/@order.OrderId" class="btn btn-sm btn-outline-secondary" style="font-size:12px;">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
