@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login - Taurus Bike Shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { background:#0B0B0B; color:#F0F0F0; font-family:'Segoe UI',sans-serif; }
        .login-card { max-width:400px; margin:80px auto; background:#111; border:1px solid #2a2a2a; border-radius:8px; padding:36px; }
        .brand { font-size:22px; font-weight:700; letter-spacing:.2em; color:#E10600; text-transform:uppercase; margin-bottom:8px; }
        .form-control { background:#1a1a1a !important; border-color:#333 !important; color:#F0F0F0 !important; }
        .form-control:focus { border-color:#E10600 !important; box-shadow:none !important; }
        .btn-admin { background:#E10600; border:none; color:#fff; font-weight:600; letter-spacing:.1em; }
        .btn-admin:hover { background:#b80500; color:#fff; }
        label { color:#aaa; font-size:13px; }
    </style>
</head>
<body>
<div class="login-card">
    <div class="text-center mb-4">
        <div class="brand">&#9650; TAURUS</div>
        <p class="text-muted" style="font-size:13px; letter-spacing:.1em; text-transform:uppercase;">Admin Panel</p>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger py-2" style="font-size:14px;">@ViewBag.Error</div>
    }

    <form method="post" action="/Admin/Login">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label for="email">Email Address</label>
            <input type="email" class="form-control" id="email" name="email" placeholder="admin@taurusbike.com" required />
        </div>
        <div class="mb-4">
            <label for="password">Password</label>
            <input type="password" class="form-control" id="password" name="password" placeholder="Password" required />
        </div>
        <button type="submit" class="btn btn-admin w-100">Sign In</button>
    </form>
</div>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
