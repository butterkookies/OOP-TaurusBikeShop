@* WebApplication/Views/Shared/_Navbar.cshtml *@
@{
    bool isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    string? userName = isAuthenticated ? User.Identity!.Name : null;
}

<header class="tbs-header">
    <nav class="navbar navbar-expand-lg tbs-navbar" aria-label="Main navigation">
        <div class="container">

            @* Logo *@
            <a class="navbar-brand tbs-brand" asp-controller="Home" asp-action="Index">
                <img src="~/FULL-COLOR.png" alt="Taurus Bike Shop" class="tbs-brand__logo" />
            </a>

            @* Mobile toggle *@
            <button class="navbar-toggler tbs-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="tbs-toggler__bar"></span>
                <span class="tbs-toggler__bar"></span>
                <span class="tbs-toggler__bar"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">

                @* Main nav links *@
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 tbs-nav">
                    <li class="nav-item">
                        <a class="nav-link tbs-nav__link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link tbs-nav__link" asp-controller="Product" asp-action="List">Catalog</a>
                    </li>
                </ul>

                @* Right-side actions *@
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 tbs-nav tbs-nav--right align-items-center">

                    @* Wishlist — authenticated only *@
                    @if (isAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link tbs-nav__icon-link"
                               asp-controller="Wishlist"
                               asp-action="ViewWishlist"
                               title="Wishlist"
                               aria-label="View wishlist">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                                     fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                    <path d="M8 2.748l-.717-.737C5.6.281 2.514.878 1.4 3.053c-.523 1.023-.641 2.5.314 4.385.92 1.815 2.834 3.989 6.286 6.357 3.452-2.368 5.365-4.542 6.286-6.357.955-1.886.838-3.362.314-4.385C13.486.878 10.4.28 8.717 2.01L8 2.748zM8 15C-7.333 4.868 3.279-3.04 7.824 1.143c.06.055.119.112.176.171a3.12 3.12 0 0 1 .176-.17C12.72-3.042 23.333 4.867 8 15z"/>
                                </svg>
                            </a>
                        </li>
                    }

                    @* Cart badge *@
                    <li class="nav-item">
                        <a class="nav-link tbs-nav__icon-link tbs-cart-link"
                           asp-controller="Cart"
                           asp-action="ViewCart"
                           title="Shopping Cart"
                           aria-label="View cart">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                                 fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                            </svg>
                            <span class="tbs-cart-badge" id="cart-badge" aria-label="cart items">0</span>
                        </a>
                    </li>

                    @* Auth links *@
                    @if (isAuthenticated)
                    {
                        <li class="nav-item dropdown tbs-user-dropdown">
                            <button class="nav-link tbs-nav__user-btn dropdown-toggle"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false"
                                    type="button">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                     fill="currentColor" viewBox="0 0 16 16" class="me-1" aria-hidden="true">
                                    <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                                    <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"/>
                                </svg>
                                <span class="tbs-nav__user-name">@userName</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end tbs-dropdown">
                                <li>
                                    <a class="dropdown-item" asp-controller="Customer" asp-action="Dashboard">
                                        Dashboard
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Order" asp-action="History">
                                        My Orders
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Customer" asp-action="Profile">
                                        Profile
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item tbs-dropdown__logout"
                                       asp-controller="Customer"
                                       asp-action="Logout">
                                        Sign Out
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link tbs-nav__link" asp-controller="Customer" asp-action="Login">
                                Sign In
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn tbs-btn-accent ms-2" asp-controller="Customer" asp-action="Register">
                                Register
                            </a>
                        </li>
                    }

                </ul>
            </div>
        </div>
    </nav>
</header>
