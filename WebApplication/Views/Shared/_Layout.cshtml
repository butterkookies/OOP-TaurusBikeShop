@* WebApplication/Views/Shared/_Layout.cshtml *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Taurus Bike Shop — Premium bicycles, frames, and components in the Philippines." />
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} — Taurus Bike Shop" : "Taurus Bike Shop")</title>

    @* Fonts: Inter + Roboto Mono from Google Fonts *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Roboto+Mono:wght@400;500;600&display=swap"
          rel="stylesheet" />

    @* Tailwind output — the ONLY stylesheet *@
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    @* Dark mode: prevent FOUC — run before paint *@
    <script>
      (function(){
        var t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
</head>
<body class="font-body text-charcoal bg-white dark:bg-midnight dark:text-neutral-200 antialiased">

    @await Html.PartialAsync("~/Views/Customer/Partials/_NotificationAlert.cshtml")

    @await Html.PartialAsync("_Navbar")

    <main class="min-h-[calc(100vh-160px)]">
        @RenderBody()
    </main>

    @await Html.PartialAsync("_Footer")

    @* Core scripts *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/utils.js" asp-append-version="true"></script>
    <script src="~/js/app.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
