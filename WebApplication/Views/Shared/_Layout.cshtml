<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Taurus Bike Shop</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApplication.styles.css" asp-append-version="true" />
    @* Google Fonts — shared across all pages *@
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@300;400;500;600&family=Barlow+Condensed:wght@400;600;700&display=swap" rel="stylesheet">

    <style>
        /* ── GLOBAL DARK THEME OVERRIDE ──────────────────────────────
           These rules override Bootstrap's default white body.
           Placed here so they apply on every page that uses _Layout.
        ─────────────────────────────────────────────────────────────── */
        html,
        body {
            background-color: #0B0B0B !important;
            color: #F0F0F0 !important;
            font-family: 'Barlow', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        /* Transparent wrappers so page backgrounds bleed through */
        body > .container-fluid,
        body > div,
        main[role="main"] {
            background: transparent !important;
        }

        /* Remove Bootstrap's default link blue inside our dark theme */
        a { color: #aaaaaa; }
        a:hover { color: #E10600; }

        /* ── NAVBAR ── */
        .taurus-nav {
            background-color: #111111 !important;
            border-bottom: 1px solid #2a2a2a !important;
            padding: 0 16px;
        }

        .taurus-nav .navbar-brand {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 22px;
            letter-spacing: 0.12em;
            color: #E10600 !important;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .taurus-nav .navbar-brand:hover { color: #FF1A17 !important; }

        .taurus-nav .nav-link {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: #888888 !important;
            padding: 8px 14px !important;
            transition: color 0.2s;
        }

        .taurus-nav .nav-link:hover,
        .taurus-nav .nav-link.active {
            color: #F0F0F0 !important;
        }

        .taurus-nav .nav-link.nav-cta {
            color: #E10600 !important;
            border: 1px solid #E1060040;
            border-radius: 3px;
            margin-left: 8px;
        }

        .taurus-nav .nav-link.nav-cta:hover {
            background: #E1060015;
            color: #FF1A17 !important;
        }

        .taurus-nav .navbar-toggler {
            border-color: #444;
        }

        .taurus-nav .navbar-toggler-icon {
            filter: invert(1);
        }

        /* ── FOOTER ── */
        .taurus-footer {
            background-color: #0D0D0D;
            border-top: 1px solid #1e1e1e !important;
            color: #444444;
            padding: 20px 0;
            margin-top: 60px;
        }

        .taurus-footer a {
            color: #555555;
            text-decoration: none;
            transition: color 0.2s;
        }

        .taurus-footer a:hover { color: #E10600; }

        .taurus-footer__brand {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 16px;
            letter-spacing: 0.12em;
            color: #E10600;
        }
    </style>
</head>

<body>

    @* ── NAVBAR ── *@
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm taurus-nav">
            <div class="container-fluid">

                @* Brand / Logo *@
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="#E10600">
                        <polygon points="12 2 22 22 2 22"/>
                    </svg>
                    TAURUS
                </a>

                @* Mobile toggle *@
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                @* Nav links *@
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Customer" asp-action="ProductCatalog">Catalog</a>
                        </li>
                    </ul>

                    @* Auth links — right side *@
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Customer" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-cta" asp-area="" asp-controller="Customer" asp-action="Register">Register</a>
                        </li>
                    </ul>
                </div>

            </div>
        </nav>
    </header>

    @* ── MAIN CONTENT ──────────────────────────────────────────────────────
       container-fluid + px-0 so full-width pages (Login, Register, Catalog)
       are not constrained by Bootstrap's default container padding.
       Pages that need a narrow container should wrap themselves.
    ─────────────────────────────────────────────────────────────────────── *@
    <div class="container-fluid px-0" style="background:transparent;">
        <main role="main" class="pb-3" style="background:transparent;">
            @RenderBody()
        </main>
    </div>

    @* ── FOOTER ── *@
    <footer class="taurus-footer">
        <div class="container">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <span>
                    <span class="taurus-footer__brand">&#9650; TAURUS BIKE SHOP</span>
                    <span style="margin-left:12px; font-size:12px;">&copy; 2026 All rights reserved.</span>
                </span>
                <span style="font-size:12px;">
                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                </span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
