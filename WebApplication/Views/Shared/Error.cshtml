@* WebApplication/Views/Shared/Error.cshtml *@
@model WebApplication.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container tbs-error-page">
    <div class="tbs-error-page__inner">
        <div class="tbs-error-page__icon" aria-hidden="true">&#9651;</div>
        <h1 class="tbs-error-page__title">Something went wrong</h1>
        <p class="tbs-error-page__message">
            We hit an unexpected issue. Our team has been notified.
            Please try again, or return to the homepage.
        </p>

        @if (Model.ShowRequestId)
        {
            <p class="tbs-error-page__request-id">
                <small>Request ID: <code>@Model.RequestId</code></small>
            </p>
        }

        <div class="tbs-error-page__actions">
            <a asp-controller="Home" asp-action="Index" class="btn tbs-btn-primary">
                Back to Homepage
            </a>
            <button type="button" class="btn tbs-btn-outline" onclick="history.back()">
                Go Back
            </button>
        </div>
    </div>
</div>
