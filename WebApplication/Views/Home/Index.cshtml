                <p class="idx-value-desc">
                    Walk in or pick up your online order at our shop at your convenience.
                </p>
            </div>

        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════
   CTA — Glass panel over gradient, NOT solid crimson bg
   Routes corrected to Customer controller
   ═══════════════════════════════════════════════════════════════ *@
<section id="cta" class="idx-cta-section tg-reveal">
    <div class="idx-container">
        <div class="glass-t3 idx-cta-panel">

            @* Decorative crimson glow behind panel — via Index.css *@
            <div class="idx-cta-glow" aria-hidden="true"></div>

            <div class="idx-cta-content">
                <p class="idx-eyebrow">Get Started</p>
                <h2 class="idx-cta-headline">
                    Find Your<br />Perfect <span class="idx-crimson">Build</span>
                </h2>
                <p class="idx-cta-sub">
                    Create a free account to save your wishlist, track your order,
                    and get access to exclusive deals. Already a member?
                    <a asp-controller="Customer" asp-action="Login"
                       class="idx-cta-inline-link">Sign in</a>.
                </p>
                <div class="idx-cta-actions">
                    <a asp-controller="Customer" asp-action="Register"
                       class="btn-primary tg-btn btn-glow">
                        Create Account
                    </a>
                    <a asp-controller="Product" asp-action="List"
                       class="btn-ghost tg-btn">
                        Browse Without Account
                    </a>
                </div>
            </div>

            @* Right: decorative stat column *@
            <div class="idx-cta-stat-col" aria-hidden="true">
                <div class="idx-cta-stat">
                    <span class="idx-cta-stat__value">148</span>
                    <span class="idx-cta-stat__label">Products</span>
                </div>
                <div class="idx-cta-stat-divider"></div>
                <div class="idx-cta-stat">
                    <span class="idx-cta-stat__value">43</span>
                    <span class="idx-cta-stat__label">Brands</span>
                </div>
                <div class="idx-cta-stat-divider"></div>
                <div class="idx-cta-stat">
                    <span class="idx-cta-stat__value">PH</span>
                    <span class="idx-cta-stat__label">Delivery</span>
                </div>
            </div>

        </div>
    </div>
</section>
