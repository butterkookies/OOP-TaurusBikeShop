                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M1 2.5A1.5 1.5 0 0 1 2.5 1h3A1.5 1.5 0 0 1 7 2.5v3A1.5 1.5 0 0 1 5.5 7h-3A1.5 1.5 0 0 1 1 5.5v-3zm8 0A1.5 1.5 0 0 1 10.5 1h3A1.5 1.5 0 0 1 15 2.5v3A1.5 1.5 0 0 1 13.5 7h-3A1.5 1.5 0 0 1 9 5.5v-3zm-8 8A1.5 1.5 0 0 1 2.5 9h3A1.5 1.5 0 0 1 7 10.5v3A1.5 1.5 0 0 1 5.5 15h-3A1.5 1.5 0 0 1 1 13.5v-3zm8 0A1.5 1.5 0 0 1 10.5 9h3a1.5 1.5 0 0 1 1.5 1.5v3a1.5 1.5 0 0 1-1.5 1.5h-3A1.5 1.5 0 0 1 9 13.5v-3z"/>
                    </svg>
                </div>
                <h3 class="idx-category-card__title">Frames</h3>
                <p class="idx-category-card__desc">
                    Alloy and carbon framesets for MTB, gravel, and trail builds.
                </p>
                <span class="idx-category-card__arrow" aria-hidden="true">&rarr;</span>
            </a>

            <a asp-controller="Product" asp-action="List" asp-route-categoryCode="FORK"
               class="glass-card idx-category-card">
                <div class="idx-category-card__icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872l-.1-.34zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z"/>
                    </svg>
                </div>
                <h3 class="idx-category-card__title">Forks</h3>
                <p class="idx-category-card__desc">
                    Air and coil suspension forks — 100mm to 140mm travel.
                </p>
                <span class="idx-category-card__arrow" aria-hidden="true">&rarr;</span>
            </a>

            <a asp-controller="Product" asp-action="List" asp-route-categoryCode="UPGKIT"
               class="glass-card idx-category-card">
                <div class="idx-category-card__icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
                    </svg>
                </div>
                <h3 class="idx-category-card__title">Upgrade Kits</h3>
                <p class="idx-category-card__desc">
                    Complete 9–12 speed drivetrain bundles — drop-in upgrades.
                </p>
                <span class="idx-category-card__arrow" aria-hidden="true">&rarr;</span>
            </a>

            <a asp-controller="Product" asp-action="List" asp-route-categoryCode="TIRE"
               class="glass-card idx-category-card">
                <div class="idx-category-card__icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                        <path d="M8 13A5 5 0 1 1 8 3a5 5 0 0 1 0 10zm0 1A6 6 0 1 0 8 2a6 6 0 0 0 0 12z"/>
                        <path d="M8 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6zm0 1a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"/>
                        <path d="M9.5 8a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z"/>
                    </svg>
                </div>
                <h3 class="idx-category-card__title">Tires &amp; Tubes</h3>
                <p class="idx-category-card__desc">
                    MTB, gravel, and BMX tires plus tubes for all wheel sizes.
                </p>
                <span class="idx-category-card__arrow" aria-hidden="true">&rarr;</span>
            </a>

            <a asp-controller="Product" asp-action="List"
               class="glass-card idx-category-card idx-category-card--all">
                <div class="idx-category-card__icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M3 9.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/>
                    </svg>
                </div>
                <h3 class="idx-category-card__title">All Categories</h3>
                <p class="idx-category-card__desc">
                    Hubs, handlebars, saddles, chains, rims, grips, pedals, and more.
                </p>
                <span class="idx-category-card__arrow" aria-hidden="true">&rarr;</span>
            </a>

        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════
   FEATURED PRODUCTS — Floating glass card grid
   ═══════════════════════════════════════════════════════════════ *@
@if (Model != null && Model.Any())
{
    <section id="featured" class="idx-section idx-featured tg-reveal">
        <div class="idx-container">

            <div class="idx-section-header">
                <h2 class="idx-section-title">Featured Picks</h2>
                <a asp-controller="Product" asp-action="List" asp-route-featured="true"
                   class="idx-view-all-link">
                    View all &rarr;
                </a>
            </div>

            <div class="idx-product-grid">
                @foreach (WebApplication.Models.ViewModels.ProductViewModel product in Model)
                {
                    @await Html.PartialAsync("~/Views/Customer/Partials/_ProductCard.cshtml", product)
                }
            </div>

        </div>
    </section>
}

@* ═══════════════════════════════════════════════════════════════
   ABOUT — Two-column editorial + glass stat cards
   ═══════════════════════════════════════════════════════════════ *@
<section id="about" class="idx-section idx-section--lg tg-reveal">
    <div class="idx-container">
        <div class="idx-about-grid">

            @* Left: editorial copy *@
            <div class="idx-about__copy">
                <p class="idx-eyebrow">Our Story</p>
                <h2 class="idx-about__headline">
                    Built Different.<br />Built <span class="idx-crimson">Philippine.</span>
                </h2>
                <p class="idx-about__body">
                    Taurus Bike Shop was founded by riders, for riders.
                    We carry the finest international and local brands —
                    from Shimano and Maxxis to Pinewood and Sagmit —
                    and deliver them to your door anywhere in the Philippines.
                </p>
                <a asp-controller="Product" asp-action="List"
                   class="btn-primary tg-btn btn-glow">
                    Explore the Shop
                </a>
            </div>

            @* Right: 2×2 stat cards *@
            <div class="idx-stat-grid">
                <div class="tg-stat-card idx-stat-card tg-reveal tg-fade-up--d1">
                    <p class="tg-stat-value tg-stat-value--primary">148</p>
                    <p class="tg-stat-label">Products in Stock</p>
                </div>
                <div class="tg-stat-card idx-stat-card tg-reveal tg-fade-up--d2">
                    <p class="tg-stat-value tg-stat-value--primary">43</p>
                    <p class="tg-stat-label">Premium Brands</p>
                </div>
                <div class="tg-stat-card idx-stat-card tg-reveal tg-fade-up--d3">
                    <p class="tg-stat-value tg-stat-value--primary">13</p>
                    <p class="tg-stat-label">Categories</p>
                </div>
                <div class="tg-stat-card idx-stat-card tg-reveal tg-fade-up--d4">
                    <p class="tg-stat-value tg-stat-value--primary">PH</p>
                    <p class="tg-stat-label">Nationwide Delivery</p>
                </div>
            </div>

        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════
   VALUE PROPS — Glass icon cards
   ═══════════════════════════════════════════════════════════════ *@
