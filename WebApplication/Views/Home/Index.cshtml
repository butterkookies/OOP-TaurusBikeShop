@* WebApplication/Views/Home/Index.cshtml *@
@model IEnumerable<WebApplication.Models.ViewModels.ProductViewModel>
@{
    ViewData["Title"] = "Home";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/product-card.css" asp-append-version="true" />
    <style>
        /*
         * Homepage wallpaper — page-specific override.
         * Stacks: dark tint (68%) → wallpaper image (fixed, cover)
         * The tg-bg orbs (::before / ::after) layer on top via z-index.
         * Glass cards then backdrop-filter: blur() against the frosted image.
         */
        body {
            background-color: #0D0D1A;
            background-image:
                linear-gradient(rgba(8, 6, 18, 0.68), rgba(8, 6, 18, 0.68)),
                url('/mobile wallpaper.png');
            background-size: cover;
            background-position: center top;
            background-attachment: fixed;
            background-repeat: no-repeat;
        }
    </style>
}

@* ═══════════════════════════════════════════════════════════════
   HERO — Magazine editorial, full-viewport
   ═══════════════════════════════════════════════════════════════ *@
<section id="hero" class="idx-hero">

    @* Atmospheric radial glow pseudo-elements via Index.css ::before / ::after *@
    @* Oversized typographic watermark — stays behind all content *@
    <span class="hero-bg-text" aria-hidden="true">TAURUS</span>

    <div class="idx-container idx-hero__inner">

        <p class="idx-hero__eyebrow hero-anim hero-anim-d0">
            Philippines' Premier Bike Shop
        </p>

        <h1 class="idx-hero__headline hero-anim hero-anim-d1">
            Built for the <span class="idx-crimson">Ride.</span>
        </h1>

        <p class="idx-hero__sub hero-anim hero-anim-d2">
            Premium bicycles and components — from trail shredders to road racers.
            Delivered via Lalamove and LBC nationwide.
        </p>

        <div class="idx-hero__ctas hero-anim hero-anim-d3">
            <a asp-controller="Product" asp-action="List"
               class="btn-primary tg-btn btn-glow">
                Shop Now
            </a>
            <a asp-controller="Product" asp-action="List" asp-route-categoryCode="UNIT"
               class="btn-ghost tg-btn">
                View Complete Bikes
            </a>
        </div>

        <div class="idx-hero__stats hero-anim hero-anim-d4">
            <div class="idx-hero__stat">
                <strong class="idx-hero__stat-value">148</strong>
                <span class="idx-hero__stat-label">Products</span>
            </div>
            <div class="idx-hero__stat">
                <strong class="idx-hero__stat-value">43</strong>
                <span class="idx-hero__stat-label">Brands</span>
            </div>
            <div class="idx-hero__stat">
                <strong class="idx-hero__stat-value">13</strong>
                <span class="idx-hero__stat-label">Categories</span>
            </div>
        </div>

    </div>
</section>

@* ═══════════════════════════════════════════════════════════════
