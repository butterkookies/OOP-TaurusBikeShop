@* WebApplication/Views/Home/Index.cshtml *@
@model IEnumerable<WebApplication.Models.ViewModels.ProductViewModel>
@{
    ViewData["Title"] = "Home";
}

@* HERO *@
<section id="hero">
    <p>Philippines' Premier Bike Shop</p>
    <h1>Built for the Ride.</h1>
    <p>Premium bicycles and components — from trail shredders to road racers. Delivered via Lalamove and LBC nationwide.</p>
    <div>
        <a asp-controller="Product" asp-action="List">Shop Now</a>
        <a asp-controller="Product" asp-action="List" asp-route-categoryCode="UNIT">View Complete Bikes</a>
    </div>
    <div>
        <span>148 Products</span>
        <span>43 Brands</span>
        <span>13 Categories</span>
    </div>
</section>

@* CATEGORIES *@
<section id="categories">
    <h2>Shop by Category</h2>
    <div>
        <a asp-controller="Product" asp-action="List" asp-route-categoryCode="UNIT">
            <h3>Complete Bikes</h3>
            <p>Fully assembled MTB, gravel, and CX builds ready to ride.</p>
        </a>
        <a asp-controller="Product" asp-action="List" asp-route-categoryCode="FRAME">
            <h3>Frames</h3>
            <p>Alloy and carbon framesets for MTB, gravel, and trail builds.</p>
        </a>
        <a asp-controller="Product" asp-action="List" asp-route-categoryCode="FORK">
            <h3>Forks</h3>
            <p>Air and coil suspension forks — 100mm to 140mm travel.</p>
        </a>
        <a asp-controller="Product" asp-action="List" asp-route-categoryCode="UPGKIT">
            <h3>Upgrade Kits</h3>
            <p>Complete 9–12 speed drivetrain bundles — drop-in upgrades.</p>
        </a>
        <a asp-controller="Product" asp-action="List" asp-route-categoryCode="TIRE">
            <h3>Tires &amp; Tubes</h3>
            <p>MTB, gravel, and BMX tires plus tubes for all wheel sizes.</p>
        </a>
        <a asp-controller="Product" asp-action="List">
            <h3>All Categories</h3>
            <p>Hubs, handlebars, saddles, chains, rims, grips, pedals, and more.</p>
        </a>
    </div>
</section>

@* FEATURED PRODUCTS *@
@if (Model != null && Model.Any())
{
    <section id="featured">
        <h2>Featured Picks</h2>
        <a asp-controller="Product" asp-action="List" asp-route-featured="true">View all</a>
        <div class="row g-4">
            @foreach (WebApplication.Models.ViewModels.ProductViewModel product in Model)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    @await Html.PartialAsync("~/Views/Customer/Partials/_ProductCard.cshtml", product)
                </div>
            }
        </div>
    </section>
}

@* ABOUT *@
<section id="about">
    <h2>Built Different. Built Philippine.</h2>
    <p>
        Taurus Bike Shop was founded by riders, for riders.
        We carry the finest international and local brands —
        from Shimano and Maxxis to Pinewood and Sagmit —
        and deliver them to your door anywhere in the Philippines.
    </p>
    <a asp-controller="Product" asp-action="List">Explore the Shop</a>
    <div>
        <div><strong>148</strong> Products in Stock</div>
        <div><strong>43</strong> Premium Brands</div>
        <div><strong>13</strong> Categories</div>
        <div><strong>PH</strong> Nationwide Delivery</div>
    </div>
</section>

@* VALUE PROPS *@
<section id="why-us">
    <h2>The Taurus Advantage</h2>
    <div>
        <div>
            <h5>Premium Quality</h5>
            <p>Curated brands trusted by serious riders — from trail shredders to race builds.</p>
        </div>
        <div>
            <h5>Nationwide Delivery</h5>
            <p>Lalamove and LBC delivery across every island in the Philippines.</p>
        </div>
        <div>
            <h5>Secure Payment</h5>
            <p>GCash and bank transfer — fast, safe, and hassle-free checkout.</p>
        </div>
        <div>
            <h5>Store Pickup</h5>
            <p>Walk in or pick up your online order at our shop at your convenience.</p>
        </div>
    </div>
</section>

@* CTA *@
<section id="cta">
    <h2>Find Your Perfect Build</h2>
    <p>
        Create a free account to save your wishlist, track your order, and get access to exclusive deals.
        Already a member? <a asp-controller="Account" asp-action="Login">Sign in</a>.
    </p>
    <div>
        <a asp-controller="Account" asp-action="Register">Create Account</a>
        <a asp-controller="Product" asp-action="List">Browse Without Account</a>
    </div>
</section>
