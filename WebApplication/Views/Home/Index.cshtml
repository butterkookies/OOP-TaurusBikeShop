@* WebApplication/Views/Home/Index.cshtml *@
@model IEnumerable<WebApplication.Models.ViewModels.ProductViewModel>
@{
    ViewData["Title"] = "Home";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Index.css" asp-append-version="true" />
}

@* HERO *@
<section id="hero">
    <div class="home-container">
        <p class="hero__eyebrow">Philippines' Premier Bike Shop</p>
        <h1 class="hero__title">Built for the <span>Ride.</span></h1>
        <p class="hero__sub">
            Premium bicycles and components — from trail shredders to road racers.
            Delivered via Lalamove and LBC nationwide.
        </p>
        <div class="hero__actions">
            <a asp-controller="Product" asp-action="List" class="hero__btn-primary">Shop Now</a>
            <a asp-controller="Product" asp-action="List" asp-route-categoryCode="UNIT" class="hero__btn-outline">View Complete Bikes</a>
        </div>
        <div class="hero__stats">
            <div class="hero__stat">
                <strong>148</strong>
                <span>Products</span>
            </div>
            <div class="hero__stat">
                <strong>43</strong>
                <span>Brands</span>
            </div>
            <div class="hero__stat">
                <strong>13</strong>
                <span>Categories</span>
            </div>
        </div>
    </div>
</section>

@* CATEGORIES *@
<section id="categories">
    <div class="home-container">
        <div class="section-header">
            <h2 class="section-title">Shop by Category</h2>
        </div>
        <div class="categories__grid">
            <a asp-controller="Product" asp-action="List" asp-route-categoryCode="UNIT" class="category-card">
                <h3>Complete Bikes</h3>
                <p>Fully assembled MTB, gravel, and CX builds ready to ride.</p>
            </a>
            <a asp-controller="Product" asp-action="List" asp-route-categoryCode="FRAME" class="category-card">
                <h3>Frames</h3>
                <p>Alloy and carbon framesets for MTB, gravel, and trail builds.</p>
            </a>
            <a asp-controller="Product" asp-action="List" asp-route-categoryCode="FORK" class="category-card">
                <h3>Forks</h3>
                <p>Air and coil suspension forks — 100mm to 140mm travel.</p>
            </a>
            <a asp-controller="Product" asp-action="List" asp-route-categoryCode="UPGKIT" class="category-card">
                <h3>Upgrade Kits</h3>
                <p>Complete 9–12 speed drivetrain bundles — drop-in upgrades.</p>
            </a>
            <a asp-controller="Product" asp-action="List" asp-route-categoryCode="TIRE" class="category-card">
                <h3>Tires &amp; Tubes</h3>
                <p>MTB, gravel, and BMX tires plus tubes for all wheel sizes.</p>
            </a>
            <a asp-controller="Product" asp-action="List" class="category-card">
                <h3>All Categories</h3>
                <p>Hubs, handlebars, saddles, chains, rims, grips, pedals, and more.</p>
            </a>
        </div>
    </div>
</section>

@* FEATURED PRODUCTS *@
@if (Model != null && Model.Any())
{
    <section id="featured">
        <div class="home-container">
            <div class="section-header">
                <h2 class="section-title">Featured Picks</h2>
                <a asp-controller="Product" asp-action="List" asp-route-featured="true" class="section-link">View all &rarr;</a>
            </div>
            <div class="row g-4">
                @foreach (WebApplication.Models.ViewModels.ProductViewModel product in Model)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        @await Html.PartialAsync("~/Views/Customer/Partials/_ProductCard.cshtml", product)
                    </div>
                }
            </div>
        </div>
    </section>
}

@* ABOUT *@
<section id="about">
    <div class="home-container">
        <div class="about__inner">
            <div class="about__text">
                <p class="about__eyebrow">Our Story</p>
                <h2 class="about__title">Built Different.<br />Built Philippine.</h2>
                <p class="about__body">
                    Taurus Bike Shop was founded by riders, for riders.
                    We carry the finest international and local brands —
                    from Shimano and Maxxis to Pinewood and Sagmit —
                    and deliver them to your door anywhere in the Philippines.
                </p>
                <a asp-controller="Product" asp-action="List" class="about__cta">Explore the Shop</a>
            </div>
            <div class="about__stats">
                <div class="about__stat">
                    <strong>148</strong>
                    <span>Products in Stock</span>
                </div>
                <div class="about__stat">
                    <strong>43</strong>
                    <span>Premium Brands</span>
                </div>
                <div class="about__stat">
                    <strong>13</strong>
                    <span>Categories</span>
                </div>
                <div class="about__stat">
                    <strong>PH</strong>
                    <span>Nationwide Delivery</span>
                </div>
            </div>
        </div>
    </div>
</section>

@* VALUE PROPS *@
<section id="why-us">
    <div class="home-container">
        <h2 class="section-title" style="text-align:center">The Taurus Advantage</h2>
        <div class="why-us__grid">
            <div class="why-us__card">
                <div class="why-us__icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M5.338 1.59a61.44 61.44 0 0 0-2.837.856.481.481 0 0 0-.328.39c-.554 4.157.726 7.19 2.253 9.188a10.725 10.725 0 0 0 2.287 2.233c.346.244.652.42.893.533.12.057.218.095.293.118a.55.55 0 0 0 .101.025.615.615 0 0 0 .1-.025c.076-.023.174-.061.294-.118.24-.113.547-.29.893-.533a10.726 10.726 0 0 0 2.287-2.233c1.527-1.997 2.807-5.031 2.253-9.188a.48.48 0 0 0-.328-.39c-.651-.213-1.75-.56-2.837-.855C9.552 1.29 8.531 1.067 8 1.067c-.53 0-1.552.223-2.662.524zM5.072.56C6.157.265 7.31 0 8 0s1.843.265 2.928.56c1.11.3 2.229.655 2.887.87a1.54 1.54 0 0 1 1.044 1.262c.596 4.477-.787 7.795-2.465 9.99a11.775 11.775 0 0 1-2.517 2.453 7.159 7.159 0 0 1-1.048.625c-.28.132-.581.24-.829.24s-.548-.108-.829-.24a7.158 7.158 0 0 1-1.048-.625 11.777 11.777 0 0 1-2.517-2.453C1.928 10.487.545 7.169 1.141 2.692A1.54 1.54 0 0 1 2.185 1.43 62.456 62.456 0 0 1 5.072.56z"/>
                        <path d="M10.854 5.146a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7.5 7.793l2.646-2.647a.5.5 0 0 1 .708 0z"/>
                    </svg>
                </div>
                <h5>Premium Quality</h5>
                <p>Curated brands trusted by serious riders — from trail shredders to race builds.</p>
            </div>
            <div class="why-us__card">
                <div class="why-us__icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/>
                    </svg>
                </div>
                <h5>Nationwide Delivery</h5>
                <p>Lalamove and LBC delivery across every island in the Philippines.</p>
            </div>
            <div class="why-us__card">
                <div class="why-us__icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11 1a2 2 0 0 0-2 2v4a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h5V3a3 3 0 0 1 6 0v4a.5.5 0 0 1-1 0V3a2 2 0 0 0-2-2z"/>
                    </svg>
                </div>
                <h5>Secure Payment</h5>
                <p>GCash and bank transfer — fast, safe, and hassle-free checkout.</p>
            </div>
            <div class="why-us__card">
                <div class="why-us__icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8.354 1.146a.5.5 0 0 0-.708 0l-6 6A.5.5 0 0 0 1.5 7.5v7a.5.5 0 0 0 .5.5h4.5a.5.5 0 0 0 .5-.5v-4h2v4a.5.5 0 0 0 .5.5H14a.5.5 0 0 0 .5-.5v-7a.5.5 0 0 0-.146-.354L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293L8.354 1.146zM2.5 14V7.707l5.5-5.5 5.5 5.5V14H10v-4a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5v4H2.5z"/>
                    </svg>
                </div>
                <h5>Store Pickup</h5>
                <p>Walk in or pick up your online order at our shop at your convenience.</p>
            </div>
        </div>
    </div>
</section>

@* CTA *@
<section id="cta">
    <div class="home-container">
        <h2 class="cta__title">Find Your Perfect Build</h2>
        <p class="cta__sub">
            Create a free account to save your wishlist, track your order, and get access to exclusive deals.
            Already a member? <a asp-controller="Account" asp-action="Login">Sign in</a>.
        </p>
        <div class="cta__actions">
            <a asp-controller="Account" asp-action="Register" class="cta__btn-dark">Create Account</a>
            <a asp-controller="Product" asp-action="List" class="cta__btn-ghost">Browse Without Account</a>
        </div>
    </div>
</section>
