@* WebApplication/Views/Home/Index.cshtml *@
@model IEnumerable<WebApplication.Models.ViewModels.ProductViewModel>
@{
    ViewData["Title"] = "Home";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Index.css" asp-append-version="true" />
}

@* =====================================================================
   ATMOSPHERIC BACKGROUND LAYERS
   ===================================================================== *@
<div class="bg-overlay" aria-hidden="true"></div>
<div class="bg-grid" aria-hidden="true"></div>
<div class="bg-red-glow" aria-hidden="true"></div>

@* =====================================================================
   HERO SECTION
   ===================================================================== *@
<section class="hero" id="hero">
    <div class="hero__inner">

        @* — LEFT: Copy — *@
        <div class="hero__content">
            <p class="hero__eyebrow">
                <span class="eyebrow-dash"></span>
                Philippines' Premier Bike Shop
            </p>
            <h1 class="hero__title">
                <span class="hero__title-line">Built for</span>
                <span class="hero__title-line hero__title-line--red">the Ride.</span>
            </h1>
            <p class="hero__desc">
                Premium bicycles and components — from trail shredders to road racers.
                Delivered via Lalamove and LBC nationwide.
            </p>
            <div class="hero__cta-row">
                <a asp-controller="Product" asp-action="List" class="btn-primary">
                    Shop Now
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M3 8h10M9 4l4 4-4 4"/>
                    </svg>
                </a>
                <a asp-controller="Product" asp-action="List"
                   asp-route-categoryCode="UNIT"
                   class="btn-ghost">
                    View Complete Bikes
                </a>
            </div>
            <div class="hero__stats">
                <div class="hero-stat">
                    <span class="hero-stat__number">148</span>
                    <span class="hero-stat__label">Products</span>
                </div>
                <div class="hero-stat__sep" aria-hidden="true"></div>
                <div class="hero-stat">
                    <span class="hero-stat__number">43</span>
                    <span class="hero-stat__label">Brands</span>
                </div>
                <div class="hero-stat__sep" aria-hidden="true"></div>
                <div class="hero-stat">
                    <span class="hero-stat__number">13</span>
                    <span class="hero-stat__label">Categories</span>
                </div>
            </div>
        </div>

        @* — RIGHT: Animated Wheel Graphic — *@
        <div class="hero__graphic" aria-hidden="true">
            <div class="wheel-wrap">
                <svg class="wheel-svg" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
                    @* Outer rim *@
                    <circle cx="200" cy="200" r="185" fill="none" stroke="#E10600" stroke-width="10" opacity="0.85"/>
                    <circle cx="200" cy="200" r="175" fill="none" stroke="#ffffff08" stroke-width="1"/>
                    @* Inner rim *@
                    <circle cx="200" cy="200" r="160" fill="none" stroke="#E10600" stroke-width="2" opacity="0.3"/>
                    @* Hub *@
                    <circle cx="200" cy="200" r="28" fill="#161616" stroke="#E10600" stroke-width="3" opacity="0.9"/>
                    <circle cx="200" cy="200" r="14" fill="#E10600" opacity="0.6"/>
                    @* Spokes — 16 spokes *@
                    <g stroke="#E10600" stroke-width="1.5" opacity="0.55">
                        <line x1="200" y1="28"  x2="200" y2="172"/>
                        <line x1="200" y1="228" x2="200" y2="372"/>
                        <line x1="28"  y1="200" x2="172" y2="200"/>
                        <line x1="228" y1="200" x2="372" y2="200"/>
                        <line x1="86"  y1="86"  x2="180" y2="180"/>
                        <line x1="314" y1="314" x2="220" y2="220"/>
                        <line x1="314" y1="86"  x2="220" y2="180"/>
                        <line x1="86"  y1="314" x2="180" y2="220"/>
                        @* 16-spoke secondary set *@
                        <line x1="57"  y1="136" x2="175" y2="188"/>
                        <line x1="343" y1="264" x2="225" y2="212"/>
                        <line x1="136" y1="57"  x2="188" y2="175"/>
                        <line x1="264" y1="343" x2="212" y2="225"/>
                        <line x1="57"  y1="264" x2="175" y2="212"/>
                        <line x1="343" y1="136" x2="225" y2="188"/>
                        <line x1="264" y1="57"  x2="212" y2="175"/>
                        <line x1="136" y1="343" x2="188" y2="225"/>
                    </g>
                    @* Tick marks on outer rim *@
                    <g stroke="#ffffff20" stroke-width="1">
                        @for (int i = 0; i < 36; i++)
                        {
                            double angle = i * 10.0 * Math.PI / 180.0;
                            double x1 = 200 + 183 * Math.Sin(angle);
                            double y1 = 200 - 183 * Math.Cos(angle);
                            double x2 = 200 + 175 * Math.Sin(angle);
                            double y2 = 200 - 175 * Math.Cos(angle);
                            <line x1="@x1.ToString("F1")" y1="@y1.ToString("F1")"
                                  x2="@x2.ToString("F1")" y2="@y2.ToString("F1")"/>
                        }
                    </g>
                </svg>
                <div class="wheel-badge">
                    <span class="wheel-badge__sym">🔴</span>
                    <span class="wheel-badge__text">TAURUS</span>
                </div>
            </div>
        </div>
    </div>

    @* Scroll hint *@
    <div class="scroll-hint" aria-hidden="true">
        <span class="scroll-hint__line"></span>
        <span class="scroll-hint__text">Scroll</span>
    </div>
</section>

@* =====================================================================
   CATEGORIES SECTION
   ===================================================================== *@
<section class="categories" id="categories">
    <div class="section-inner">
        <div class="section-header">
            <p class="section-header__eyebrow">Browse the Lineup</p>
            <h2 class="section-header__title">Shop by Category</h2>
            <div class="section-header__divider"></div>
        </div>

        <div class="category-grid">
            @* Complete Bikes *@
            <a asp-controller="Product" asp-action="List"
               asp-route-categoryCode="UNIT"
               class="cat-card cat-card--featured">
                <span class="cat-card__badge">Popular</span>
                <span class="cat-card__number">01</span>
                <div class="cat-card__icon-wrap">
                    <svg class="cat-card__icon" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="6" cy="17" r="3"/><circle cx="18" cy="17" r="3"/>
                        <path d="M6 17l3-9 3 4 3-7 3 2"/>
                    </svg>
                </div>
                <h3 class="cat-card__title">Complete Bikes</h3>
                <p class="cat-card__desc">Fully assembled MTB, gravel, and CX builds ready to ride.</p>
                <span class="cat-card__link">
                    Browse Bikes
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 8h10M9 4l4 4-4 4"/>
                    </svg>
                </span>
                <div class="cat-card__accent"></div>
            </a>

            @* Frames *@
            <a asp-controller="Product" asp-action="List"
               asp-route-categoryCode="FRAME"
               class="cat-card">
                <span class="cat-card__number">02</span>
                <div class="cat-card__icon-wrap">
                    <svg class="cat-card__icon" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 19l4-9 5 3 4-6 3 3"/><circle cx="4" cy="19" r="1.5"/><circle cx="20" cy="16" r="1.5"/>
                    </svg>
                </div>
                <h3 class="cat-card__title">Frames</h3>
                <p class="cat-card__desc">Alloy and carbon framesets for MTB, gravel, and trail builds.</p>
                <span class="cat-card__link">
                    Browse Frames
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 8h10M9 4l4 4-4 4"/>
                    </svg>
                </span>
                <div class="cat-card__accent"></div>
            </a>

            @* Forks *@
            <a asp-controller="Product" asp-action="List"
               asp-route-categoryCode="FORK"
               class="cat-card">
                <span class="cat-card__number">03</span>
                <div class="cat-card__icon-wrap">
                    <svg class="cat-card__icon" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 3v6m0 0l-3 10m3-10l3 10m-6 0a3 3 0 006 0"/>
                    </svg>
                </div>
                <h3 class="cat-card__title">Forks</h3>
                <p class="cat-card__desc">Air and coil suspension forks — 100mm to 140mm travel.</p>
                <span class="cat-card__link">
                    Browse Forks
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 8h10M9 4l4 4-4 4"/>
                    </svg>
                </span>
                <div class="cat-card__accent"></div>
            </a>

            @* Upgrade Kits *@
            <a asp-controller="Product" asp-action="List"
               asp-route-categoryCode="UPGKIT"
               class="cat-card cat-card--featured">
                <span class="cat-card__badge">New</span>
                <span class="cat-card__number">04</span>
                <div class="cat-card__icon-wrap">
                    <svg class="cat-card__icon" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3-3a1 1 0 000-1.4l-1.6-1.6a1 1 0 00-1.4 0l-3 3z"/>
                        <path d="M5 19l6.5-6.5M15 5l4 4-7 7-4-1-1-4 8-6z"/>
                    </svg>
                </div>
                <h3 class="cat-card__title">Upgrade Kits</h3>
                <p class="cat-card__desc">Complete 9–12 speed drivetrain bundles — drop-in upgrades.</p>
                <span class="cat-card__link">
                    Browse Kits
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 8h10M9 4l4 4-4 4"/>
                    </svg>
                </span>
                <div class="cat-card__accent"></div>
            </a>

            @* Tires *@
            <a asp-controller="Product" asp-action="List"
               asp-route-categoryCode="TIRE"
               class="cat-card">
                <span class="cat-card__number">05</span>
                <div class="cat-card__icon-wrap">
                    <svg class="cat-card__icon" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3"/>
                        <path d="M12 3v3M12 18v3M3 12h3M18 12h3"/>
                    </svg>
                </div>
                <h3 class="cat-card__title">Tires & Tubes</h3>
                <p class="cat-card__desc">MTB, gravel, and BMX tires plus tubes for all wheel sizes.</p>
                <span class="cat-card__link">
                    Browse Tires
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 8h10M9 4l4 4-4 4"/>
                    </svg>
                </span>
                <div class="cat-card__accent"></div>
            </a>

            @* View All *@
            <a asp-controller="Product" asp-action="List" class="cat-card cat-card--all">
                <span class="cat-card__number">+8</span>
                <div class="cat-card__icon-wrap">
                    <svg class="cat-card__icon" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                        <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
                    </svg>
                </div>
                <h3 class="cat-card__title">All Categories</h3>
                <p class="cat-card__desc">Hubs, handlebars, saddles, chains, rims, grips, pedals, and more.</p>
                <span class="cat-card__link">
                    View All
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 8h10M9 4l4 4-4 4"/>
                    </svg>
                </span>
                <div class="cat-card__accent"></div>
            </a>
        </div>
    </div>
</section>

@* =====================================================================
   FEATURED PRODUCTS
   ===================================================================== *@
@if (Model != null && Model.Any())
{
    <section class="featured-section" id="featured">
        <div class="section-inner">
            <div class="section-header section-header--split">
                <div>
                    <p class="section-header__eyebrow">Handpicked for You</p>
                    <h2 class="section-header__title">Featured Picks</h2>
                </div>
                <a asp-controller="Product" asp-action="List"
                   asp-route-featured="true"
                   class="btn-ghost btn-ghost--sm">
                    View all
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M3 8h10M9 4l4 4-4 4"/>
                    </svg>
                </a>
            </div>
            <div class="row g-4 featured-grid">
                @foreach (WebApplication.Models.ViewModels.ProductViewModel product in Model)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        @await Html.PartialAsync("~/Views/Customer/Partials/_ProductCard.cshtml", product)
                    </div>
                }
            </div>
        </div>
    </section>
}

@* =====================================================================
   BRAND / ABOUT STRIP
   ===================================================================== *@
<section class="brand-strip" id="about">
    <div class="brand-strip__inner">
        <div class="brand-strip__copy">
            <p class="brand-strip__eyebrow">Our Story</p>
            <h2 class="brand-strip__title">Built Different.<br/>Built Philippine.</h2>
            <p class="brand-strip__text">
                Taurus Bike Shop was founded by riders, for riders.
                We carry the finest international and local brands —
                from Shimano and Maxxis to Pinewood and Sagmit —
                and deliver them to your door anywhere in the Philippines.
            </p>
            <a asp-controller="Product" asp-action="List" class="btn-primary">
                Explore the Shop
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 8h10M9 4l4 4-4 4"/>
                </svg>
            </a>
        </div>
        <div class="brand-strip__stats-col">
            <div class="big-stat">
                <span class="big-stat__num">148</span>
                <span class="big-stat__lbl">Products in Stock</span>
            </div>
            <div class="big-stat">
                <span class="big-stat__num">43</span>
                <span class="big-stat__lbl">Premium Brands</span>
            </div>
            <div class="big-stat">
                <span class="big-stat__num">13</span>
                <span class="big-stat__lbl">Categories</span>
            </div>
            <div class="big-stat">
                <span class="big-stat__num">PH</span>
                <span class="big-stat__lbl">Nationwide Delivery</span>
            </div>
        </div>
    </div>
</section>

@* =====================================================================
   VALUE PROPOSITIONS
   ===================================================================== *@
<section class="value-props" id="why-us">
    <div class="section-inner">
        <div class="section-header">
            <p class="section-header__eyebrow">Why Taurus?</p>
            <h2 class="section-header__title">The Taurus Advantage</h2>
            <div class="section-header__divider"></div>
        </div>
        <div class="value-grid">
            <div class="value-card">
                <div class="value-card__icon-wrap" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/>
                    </svg>
                </div>
                <h5 class="value-card__title">Premium Quality</h5>
                <p class="value-card__body">Curated brands trusted by serious riders — from trail shredders to race builds.</p>
            </div>
            <div class="value-card">
                <div class="value-card__icon-wrap" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14M12 5l7 7-7 7"/><path d="M5 19H3a2 2 0 01-2-2V7a2 2 0 012-2h2"/>
                    </svg>
                </div>
                <h5 class="value-card__title">Nationwide Delivery</h5>
                <p class="value-card__body">Lalamove and LBC delivery across every island in the Philippines.</p>
            </div>
            <div class="value-card">
                <div class="value-card__icon-wrap" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="5" width="20" height="14" rx="2"/>
                        <path d="M2 10h20"/>
                    </svg>
                </div>
                <h5 class="value-card__title">Secure Payment</h5>
                <p class="value-card__body">GCash and bank transfer — fast, safe, and hassle-free checkout.</p>
            </div>
            <div class="value-card">
                <div class="value-card__icon-wrap" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                        <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                </div>
                <h5 class="value-card__title">Store Pickup</h5>
                <p class="value-card__body">Walk in or pick up your online order at our shop at your convenience.</p>
            </div>
        </div>
    </div>
</section>

@* =====================================================================
   CALL TO ACTION
   ===================================================================== *@
<section class="cta-section" id="cta">
    <div class="cta-section__inner">
        @* Decorative spinning wheel *@
        <svg class="cta-deco-wheel" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="200" cy="200" r="185" fill="none" stroke="#E10600" stroke-width="6"/>
            <circle cx="200" cy="200" r="155" fill="none" stroke="#E10600" stroke-width="1" opacity="0.4"/>
            <circle cx="200" cy="200" r="28" fill="none" stroke="#E10600" stroke-width="4"/>
            <g stroke="#E10600" stroke-width="1.5" opacity="0.7">
                <line x1="200" y1="28"  x2="200" y2="172"/>
                <line x1="200" y1="228" x2="200" y2="372"/>
                <line x1="28"  y1="200" x2="172" y2="200"/>
                <line x1="228" y1="200" x2="372" y2="200"/>
                <line x1="86"  y1="86"  x2="180" y2="180"/>
                <line x1="314" y1="314" x2="220" y2="220"/>
                <line x1="314" y1="86"  x2="220" y2="180"/>
                <line x1="86"  y1="314" x2="180" y2="220"/>
            </g>
        </svg>

        <p class="cta-section__eyebrow">Ready to Ride?</p>
        <h2 class="cta-section__title">Find Your Perfect Build</h2>
        <p class="cta-section__sub">
            Create a free account to save your wishlist, track your order, and get access to exclusive deals.
            Already a member? <a asp-controller="Account" asp-action="Login" class="cta-login-link">Sign in</a>.
        </p>
        <div class="cta-section__actions">
            <a asp-controller="Account" asp-action="Register" class="btn-primary">
                Create Account
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 8h10M9 4l4 4-4 4"/>
                </svg>
            </a>
            <a asp-controller="Product" asp-action="List" class="btn-ghost">
                Browse Without Account
            </a>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/customer.js" asp-append-version="true"></script>
    <script src="~/js/Index.js" asp-append-version="true"></script>
}
