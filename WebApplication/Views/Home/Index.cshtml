@* WebApplication/Views/Home/Index.cshtml *@
@model IEnumerable<WebApplication.Models.ViewModels.ProductViewModel>
@{
    ViewData["Title"] = "Home";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Index.css" asp-append-version="true" />
}

@* =====================================================================
   HERO SECTION
   ===================================================================== *@
<section class="tbs-hero">
    <div class="tbs-hero__bg" aria-hidden="true"></div>
    <div class="container tbs-hero__container">
        <div class="tbs-hero__content">
            <p class="tbs-hero__eyebrow">Philippines' Premier Bike Shop</p>
            <h1 class="tbs-hero__title">
                Built for<br />
                <span class="tbs-hero__title-accent">the Ride.</span>
            </h1>
            <p class="tbs-hero__body">
                Premium bicycles and components — from trail shredders to road racers.
                Delivered via Lalamove and LBC nationwide.
            </p>
            <div class="tbs-hero__cta">
                <a asp-controller="Product" asp-action="List" class="btn tbs-btn-accent tbs-btn-lg">
                    Shop Now
                </a>
                <a asp-controller="Product" asp-action="List"
                   asp-route-categoryCode="UNIT"
                   class="btn tbs-btn-outline-light tbs-btn-lg">
                    View Complete Bikes
                </a>
            </div>
        </div>
    </div>
</section>

@* =====================================================================
   CATEGORY TILES
   ===================================================================== *@
<section class="tbs-categories">
    <div class="container">
        <h2 class="tbs-section-title">Shop by Category</h2>
        <div class="row g-3 tbs-categories__grid">
            <div class="col-6 col-md-4 col-lg-2">
                <a asp-controller="Product" asp-action="List"
                   asp-route-categoryCode="UNIT"
                   class="tbs-category-tile">
                    <span class="tbs-category-tile__icon">🚲</span>
                    <span class="tbs-category-tile__label">Complete Bikes</span>
                </a>
            </div>
            <div class="col-6 col-md-4 col-lg-2">
                <a asp-controller="Product" asp-action="List"
                   asp-route-categoryCode="FRAME"
                   class="tbs-category-tile">
                    <span class="tbs-category-tile__icon">🔩</span>
                    <span class="tbs-category-tile__label">Frames</span>
                </a>
            </div>
            <div class="col-6 col-md-4 col-lg-2">
                <a asp-controller="Product" asp-action="List"
                   asp-route-categoryCode="FORK"
                   class="tbs-category-tile">
                    <span class="tbs-category-tile__icon">⚙️</span>
                    <span class="tbs-category-tile__label">Forks</span>
                </a>
            </div>
            <div class="col-6 col-md-4 col-lg-2">
                <a asp-controller="Product" asp-action="List"
                   asp-route-categoryCode="UPGKIT"
                   class="tbs-category-tile">
                    <span class="tbs-category-tile__icon">🛠️</span>
                    <span class="tbs-category-tile__label">Upgrade Kits</span>
                </a>
            </div>
            <div class="col-6 col-md-4 col-lg-2">
                <a asp-controller="Product" asp-action="List"
                   asp-route-categoryCode="TIRE"
                   class="tbs-category-tile">
                    <span class="tbs-category-tile__icon">⭕</span>
                    <span class="tbs-category-tile__label">Tires</span>
                </a>
            </div>
            <div class="col-6 col-md-4 col-lg-2">
                <a asp-controller="Product" asp-action="List"
                   class="tbs-category-tile tbs-category-tile--all">
                    <span class="tbs-category-tile__icon">➕</span>
                    <span class="tbs-category-tile__label">View All</span>
                </a>
            </div>
        </div>
    </div>
</section>

@* =====================================================================
   FEATURED PRODUCTS
   ===================================================================== *@
@if (Model != null && Model.Any())
{
    <section class="tbs-featured">
        <div class="container">
            <div class="tbs-section-header">
                <h2 class="tbs-section-title">Featured Picks</h2>
                <a asp-controller="Product" asp-action="List"
                   asp-route-featured="true"
                   class="tbs-section-link">
                    View all &rarr;
                </a>
            </div>
            <div class="row g-4 tbs-featured__grid">
                @foreach (WebApplication.Models.ViewModels.ProductViewModel product in Model)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        @await Html.PartialAsync("_ProductCard", product)
                    </div>
                }
            </div>
        </div>
    </section>
}

@* =====================================================================
   VALUE PROPOSITIONS
   ===================================================================== *@
<section class="tbs-value-props">
    <div class="container">
        <div class="row g-4 tbs-value-props__grid">
            <div class="col-6 col-md-3">
                <div class="tbs-value-prop">
                    <div class="tbs-value-prop__icon" aria-hidden="true">🏆</div>
                    <h5 class="tbs-value-prop__title">Premium Quality</h5>
                    <p class="tbs-value-prop__body">Curated brands trusted by serious riders.</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="tbs-value-prop">
                    <div class="tbs-value-prop__icon" aria-hidden="true">🚚</div>
                    <h5 class="tbs-value-prop__title">Nationwide Delivery</h5>
                    <p class="tbs-value-prop__body">Lalamove and LBC delivery across the Philippines.</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="tbs-value-prop">
                    <div class="tbs-value-prop__icon" aria-hidden="true">💳</div>
                    <h5 class="tbs-value-prop__title">Secure Payment</h5>
                    <p class="tbs-value-prop__body">GCash and bank transfer — fast and safe.</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="tbs-value-prop">
                    <div class="tbs-value-prop__icon" aria-hidden="true">🏪</div>
                    <h5 class="tbs-value-prop__title">Store Pickup</h5>
                    <p class="tbs-value-prop__body">Walk in or pick up your online order in store.</p>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/customer.js" asp-append-version="true"></script>
}
