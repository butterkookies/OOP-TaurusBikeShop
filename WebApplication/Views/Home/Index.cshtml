@* WebApplication/Views/Home/Index.cshtml *@
@model IEnumerable<WebApplication.Models.ViewModels.ProductViewModel>
@{
    ViewData["Title"] = "Home";
}

@Html.AntiForgeryToken()

@* ═══════════════════════════════════════════════════════════════
   HERO — Cal.com-inspired minimal editorial
   ═══════════════════════════════════════════════════════════════ *@
<section class="relative overflow-hidden bg-white dark:bg-midnight min-h-[85vh] flex items-center">
    
    @* CRIMSON GLOW MESH BACKGROUND *@
    <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none flex items-center justify-center select-none" aria-hidden="true">
        @* Primary center crimson massive orb *@
        <div class="absolute w-[80vw] h-[80vw] max-w-[800px] max-h-[800px] bg-red-600/15 dark:bg-red-600/20 rounded-full blur-[100px] md:blur-[140px] transform-gpu -translate-y-12 animate-pulse" style="animation-duration: 6s;"></div>
        
        @* Offset bright rose accent orb *@
        <div class="absolute w-[50vw] h-[50vw] max-w-[600px] max-h-[600px] bg-rose-500/10 dark:bg-rose-500/15 rounded-full blur-[90px] md:blur-[120px] transform-gpu translate-x-1/3 md:translate-x-1/2 translate-y-1/4 animate-pulse" style="animation-duration: 8s; animation-delay: 2s;"></div>
        
        @* Core deep crimson dark anchor *@
        <div class="absolute w-[60vw] h-[60vw] max-w-[500px] max-h-[500px] bg-red-800/10 dark:bg-red-800/20 rounded-full blur-[80px] transform-gpu -translate-x-1/3 translate-y-1/3 animate-pulse" style="animation-duration: 10s; animation-delay: 4s;"></div>
        
        @* DIRECT BACKLIGHT STRICTLY FOR DARK MODE 3D REFRACTION *@
        <div class="hidden dark:block absolute w-96 h-96 bg-red-500/30 rounded-full blur-3xl transform-gpu right-10 md:right-40 animate-pulse" style="animation-duration: 5s;"></div>
    </div>

    @* BULLETPROOF 3D IFRAME OVERLAY *@
    <div class="absolute top-0 right-0 bottom-0 w-full md:w-1/2 z-30 pointer-events-auto bg-transparent">
        <iframe src="https://my.spline.design/untitled-Hfjh923H9TxLIhMAQ5Ghu6xM/" frameborder="0" width="100%" height="100%" class="w-full h-full bg-transparent border-none outline-none block" allowtransparency="true"></iframe>
    </div>

    <div class="max-w-[1200px] w-full mx-auto px-6 py-24 md:py-32 lg:py-40 relative z-20 pointer-events-none">

        <!-- Ensure interactive elements like buttons reclaim pointer-events so they're clickable over the 3D canvas -->
        <p class="text-sm font-medium tracking-widest uppercase text-error dark:text-red-400 mb-4 pointer-events-auto w-max" data-reveal>
            Ride Local. Ride Hard.
        </p>

        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-semibold leading-[1.08] text-charcoal dark:text-white max-w-3xl" data-reveal="delay-1">
            Taurus<br /><span class="text-mid-gray">Bike Shop</span>
        </h1>

        <p class="mt-6 text-lg text-mid-gray leading-relaxed max-w-xl" data-reveal="delay-2">
            Everything a serious rider needs — bikes, frames, components, and parts —
            shipped anywhere in the Philippines via Lalamove and LBC.
        </p>

        <div class="mt-10 flex flex-wrap gap-4 pointer-events-auto w-max" data-reveal="delay-3">
            <a asp-controller="Product" asp-action="List" class="btn-dark btn-lg">
                Shop Now
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <a asp-controller="Product" asp-action="List" asp-route-categoryCode="UNIT" class="btn-ghost btn-lg">
                View Complete Bikes
            </a>
        </div>

        <div class="mt-16 flex gap-12 md:gap-16" data-reveal="delay-3">
            <div>
                <p class="font-display text-3xl md:text-4xl font-semibold text-charcoal dark:text-white">148</p>
                <p class="text-sm text-mid-gray mt-1">Products</p>
            </div>
            <div>
                <p class="font-display text-3xl md:text-4xl font-semibold text-charcoal dark:text-white">43</p>
                <p class="text-sm text-mid-gray mt-1">Brands</p>
            </div>
            <div>
                <p class="font-display text-3xl md:text-4xl font-semibold text-charcoal dark:text-white">13</p>
                <p class="text-sm text-mid-gray mt-1">Categories</p>
            </div>
        </div>

    </div>
</section>

@* ═══════════════════════════════════════════════════════════════
   CATEGORIES — Shadow card grid
   ═══════════════════════════════════════════════════════════════ *@
<section class="bg-light-gray dark:bg-midnight py-20 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6">

        <h2 class="font-display text-3xl font-semibold text-charcoal dark:text-white mb-10" data-reveal>
            Shop by Category
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" data-reveal="delay-1">

            <a asp-controller="Product" asp-action="List" asp-route-categoryCode="UNIT"
               class="cal-card group p-6 flex flex-col gap-3 hover:-translate-y-0.5">
                <div class="w-10 h-10 rounded-lg bg-charcoal/[0.06] dark:bg-white/10 flex items-center justify-center text-charcoal dark:text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="5.5" cy="17.5" r="3.5"/><circle cx="18.5" cy="17.5" r="3.5"/><path d="M15 6a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm-3 11.5V14l-5-5 6-2"/></svg>
                </div>
                <h3 class="font-display text-lg font-semibold text-charcoal dark:text-white" style="letter-spacing:0.2px">Complete Bikes</h3>
                <p class="text-sm text-mid-gray leading-relaxed">Fully assembled MTB, gravel, and CX builds ready to ride.</p>
                <span class="mt-auto text-sm font-medium text-charcoal/60 group-hover:text-charcoal transition-colors dark:text-white/40 dark:group-hover:text-white">&rarr;</span>
            </a>

            <a asp-controller="Product" asp-action="List" asp-route-categoryCode="FRAME"
               class="cal-card group p-6 flex flex-col gap-3 hover:-translate-y-0.5">
                <div class="w-10 h-10 rounded-lg bg-charcoal/[0.06] dark:bg-white/10 flex items-center justify-center text-charcoal dark:text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                </div>
                <h3 class="font-display text-lg font-semibold text-charcoal dark:text-white" style="letter-spacing:0.2px">Frames</h3>
                <p class="text-sm text-mid-gray leading-relaxed">Alloy and carbon framesets for MTB, gravel, and trail builds.</p>
                <span class="mt-auto text-sm font-medium text-charcoal/60 group-hover:text-charcoal transition-colors dark:text-white/40 dark:group-hover:text-white">&rarr;</span>
            </a>

            <a asp-controller="Product" asp-action="List" asp-route-categoryCode="FORK"
               class="cal-card group p-6 flex flex-col gap-3 hover:-translate-y-0.5">
                <div class="w-10 h-10 rounded-lg bg-charcoal/[0.06] dark:bg-white/10 flex items-center justify-center text-charcoal dark:text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                </div>
                <h3 class="font-display text-lg font-semibold text-charcoal dark:text-white" style="letter-spacing:0.2px">Forks</h3>
                <p class="text-sm text-mid-gray leading-relaxed">Air and coil suspension forks — 100mm to 140mm travel.</p>
                <span class="mt-auto text-sm font-medium text-charcoal/60 group-hover:text-charcoal transition-colors dark:text-white/40 dark:group-hover:text-white">&rarr;</span>
            </a>

            <a asp-controller="Product" asp-action="List" asp-route-categoryCode="UPGKIT"
               class="cal-card group p-6 flex flex-col gap-3 hover:-translate-y-0.5">
                <div class="w-10 h-10 rounded-lg bg-charcoal/[0.06] dark:bg-white/10 flex items-center justify-center text-charcoal dark:text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </div>
                <h3 class="font-display text-lg font-semibold text-charcoal dark:text-white" style="letter-spacing:0.2px">Upgrade Kits</h3>
                <p class="text-sm text-mid-gray leading-relaxed">Complete 9–12 speed drivetrain bundles — drop-in upgrades.</p>
                <span class="mt-auto text-sm font-medium text-charcoal/60 group-hover:text-charcoal transition-colors dark:text-white/40 dark:group-hover:text-white">&rarr;</span>
            </a>

            <a asp-controller="Product" asp-action="List" asp-route-categoryCode="TIRE"
               class="cal-card group p-6 flex flex-col gap-3 hover:-translate-y-0.5">
                <div class="w-10 h-10 rounded-lg bg-charcoal/[0.06] dark:bg-white/10 flex items-center justify-center text-charcoal dark:text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                </div>
                <h3 class="font-display text-lg font-semibold text-charcoal dark:text-white" style="letter-spacing:0.2px">Tires &amp; Tubes</h3>
                <p class="text-sm text-mid-gray leading-relaxed">MTB, gravel, and BMX tires plus tubes for all wheel sizes.</p>
                <span class="mt-auto text-sm font-medium text-charcoal/60 group-hover:text-charcoal transition-colors dark:text-white/40 dark:group-hover:text-white">&rarr;</span>
            </a>

            <a asp-controller="Product" asp-action="List"
               class="cal-card group p-6 flex flex-col gap-3 hover:-translate-y-0.5 border-2 border-dashed border-charcoal/10 dark:border-white/10 shadow-none hover:shadow-card">
                <div class="w-10 h-10 rounded-lg bg-charcoal/[0.06] dark:bg-white/10 flex items-center justify-center text-charcoal dark:text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/></svg>
                </div>
                <h3 class="font-display text-lg font-semibold text-charcoal dark:text-white" style="letter-spacing:0.2px">All Categories</h3>
                <p class="text-sm text-mid-gray leading-relaxed">Hubs, handlebars, saddles, chains, rims, grips, pedals, and more.</p>
                <span class="mt-auto text-sm font-medium text-charcoal/60 group-hover:text-charcoal transition-colors dark:text-white/40 dark:group-hover:text-white">&rarr;</span>
            </a>

        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════
   FEATURED PRODUCTS
   ═══════════════════════════════════════════════════════════════ *@
@if (Model != null && Model.Any())
{
    <section class="bg-white dark:bg-midnight py-20 md:py-24">
        <div class="max-w-[1200px] mx-auto px-6">

            <div class="flex items-center justify-between mb-10" data-reveal>
                <h2 class="font-display text-3xl font-semibold text-charcoal dark:text-white">Featured Picks</h2>
                <a asp-controller="Product" asp-action="List" asp-route-featured="true"
                   class="text-sm font-medium text-mid-gray hover:text-charcoal transition-colors dark:hover:text-white">
                    View all &rarr;
                </a>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5" data-reveal="delay-1">
                @foreach (WebApplication.Models.ViewModels.ProductViewModel product in Model)
                {
                    @await Html.PartialAsync("~/Views/Customer/Partials/_ProductCard.cshtml", product)
                }
            </div>

        </div>
    </section>
}

@* ═══════════════════════════════════════════════════════════════
   ABOUT — Two-column editorial + stat cards
   ═══════════════════════════════════════════════════════════════ *@
<section class="bg-light-gray dark:bg-midnight py-20 md:py-28">
    <div class="max-w-[1200px] mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

            @* Left: editorial copy *@
            <div data-reveal>
                <p class="text-sm font-medium tracking-widest uppercase text-mid-gray mb-3">Our Story</p>
                <h2 class="font-display text-4xl md:text-5xl font-semibold leading-tight text-charcoal dark:text-white">
                    Built by Riders.<br />Built Filipino.
                </h2>
                <p class="mt-6 text-base text-mid-gray leading-relaxed">
                    Taurus Bike Shop started with one mission: put the right gear in the hands of Filipino riders.
                    From Shimano drivetrains and Maxxis rubber to Pinewood frames and Sagmit builds —
                    we stock it, we ship it, and we stand behind it.
                </p>
                <a asp-controller="Product" asp-action="List" class="btn-dark btn-lg mt-8 inline-flex">
                    Explore the Shop
                </a>
            </div>

            @* Right: 2x2 stat cards *@
            <div class="grid grid-cols-2 gap-5">
                <div class="cal-card-static p-6 text-center" data-reveal="delay-1">
                    <p class="font-display text-4xl font-semibold text-charcoal dark:text-white">148</p>
                    <p class="text-sm text-mid-gray mt-2">Products in Stock</p>
                </div>
                <div class="cal-card-static p-6 text-center" data-reveal="delay-2">
                    <p class="font-display text-4xl font-semibold text-charcoal dark:text-white">43</p>
                    <p class="text-sm text-mid-gray mt-2">Premium Brands</p>
                </div>
                <div class="cal-card-static p-6 text-center" data-reveal="delay-3">
                    <p class="font-display text-4xl font-semibold text-charcoal dark:text-white">13</p>
                    <p class="text-sm text-mid-gray mt-2">Categories</p>
                </div>
                <div class="cal-card-static p-6 text-center" data-reveal="delay-3">
                    <p class="font-display text-4xl font-semibold text-charcoal dark:text-white">PH</p>
                    <p class="text-sm text-mid-gray mt-2">Nationwide Delivery</p>
                </div>
            </div>

        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════
   VALUE PROPS — Icon cards
   ═══════════════════════════════════════════════════════════════ *@
<section class="bg-white dark:bg-midnight py-20 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6">

        <h2 class="font-display text-3xl font-semibold text-charcoal dark:text-white text-center mb-12" data-reveal>
            Why Riders Choose Taurus
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">

            <div class="cal-card-static p-6" data-reveal="delay-1">
                <div class="w-10 h-10 rounded-lg bg-charcoal/[0.06] dark:bg-white/10 flex items-center justify-center text-charcoal dark:text-white mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <h5 class="font-display font-semibold text-charcoal dark:text-white mb-2" style="letter-spacing:0.2px">Premium Quality</h5>
                <p class="text-sm text-mid-gray leading-relaxed">Curated brands trusted by serious riders — from trail shredders to race builds.</p>
            </div>

            <div class="cal-card-static p-6" data-reveal="delay-2">
                <div class="w-10 h-10 rounded-lg bg-charcoal/[0.06] dark:bg-white/10 flex items-center justify-center text-charcoal dark:text-white mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <h5 class="font-display font-semibold text-charcoal dark:text-white mb-2" style="letter-spacing:0.2px">Nationwide Delivery</h5>
                <p class="text-sm text-mid-gray leading-relaxed">Lalamove and LBC delivery across every island in the Philippines.</p>
            </div>

            <div class="cal-card-static p-6" data-reveal="delay-3">
                <div class="w-10 h-10 rounded-lg bg-charcoal/[0.06] dark:bg-white/10 flex items-center justify-center text-charcoal dark:text-white mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                </div>
                <h5 class="font-display font-semibold text-charcoal dark:text-white mb-2" style="letter-spacing:0.2px">Secure Payment</h5>
                <p class="text-sm text-mid-gray leading-relaxed">GCash and bank transfer — fast, safe, and hassle-free checkout.</p>
            </div>

            <div class="cal-card-static p-6" data-reveal="delay-3">
                <div class="w-10 h-10 rounded-lg bg-charcoal/[0.06] dark:bg-white/10 flex items-center justify-center text-charcoal dark:text-white mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </div>
                <h5 class="font-display font-semibold text-charcoal dark:text-white mb-2" style="letter-spacing:0.2px">Store Pickup</h5>
                <p class="text-sm text-mid-gray leading-relaxed">Walk in or pick up your online order at our shop at your convenience.</p>
            </div>

        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════
   CTA — Final push (only shown to guests)
   ═══════════════════════════════════════════════════════════════ *@
@if (!(User.Identity?.IsAuthenticated ?? false))
{
<section class="bg-charcoal dark:bg-midnight py-20 md:py-28">
    <div class="max-w-[1200px] mx-auto px-6">
        <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">

            <div class="flex-1" data-reveal>
                <p class="text-sm font-medium tracking-widest uppercase text-white/50 mb-3">Get Started</p>
                <h2 class="font-display text-4xl md:text-5xl font-semibold leading-tight text-white">
                    Your Next Build<br />Starts Here
                </h2>
                <p class="mt-6 text-base text-white/60 leading-relaxed max-w-lg">
                    Join thousands of Filipino riders who save their wishlist, track every order,
                    and unlock exclusive deals — all in one place. Already a member?
                    <a asp-controller="Customer" asp-action="Login"
                       class="text-white underline underline-offset-2 hover:text-white/80">Sign in</a>.
                </p>
                <div class="mt-8 flex flex-wrap gap-4">
                    <a asp-controller="Customer" asp-action="Register" class="btn-white btn-lg">
                        Create Account
                    </a>
                    <a asp-controller="Product" asp-action="List" class="btn-ghost btn-lg !text-white/70 !border-white/20 hover:!border-white/50 hover:!text-white hover:!bg-white/5">
                        Browse Without Account
                    </a>
                </div>
            </div>

            @* Right: stat column *@
            <div class="flex lg:flex-col gap-8 lg:gap-6 shrink-0" data-reveal="delay-1" aria-hidden="true">
                <div class="text-center">
                    <p class="font-display text-4xl font-semibold text-white">148</p>
                    <p class="text-xs text-white/40 mt-1">Products</p>
                </div>
                <div class="w-px lg:w-12 h-12 lg:h-px bg-white/10"></div>
                <div class="text-center">
                    <p class="font-display text-4xl font-semibold text-white">43</p>
                    <p class="text-xs text-white/40 mt-1">Brands</p>
                </div>
                <div class="w-px lg:w-12 h-12 lg:h-px bg-white/10"></div>
                <div class="text-center">
                    <p class="font-display text-4xl font-semibold text-white">PH</p>
                    <p class="text-xs text-white/40 mt-1">Delivery</p>
                </div>
            </div>

        </div>
    </div>
</section>
}

@section Scripts {
    <script src="~/js/product-catalog.js" asp-append-version="true"></script>
}
