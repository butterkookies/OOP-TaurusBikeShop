@* WebApplication/Views/Customer/Partials/_SupportTicketCard.cshtml *@
@model WebApplication.Models.ViewModels.SupportTicketViewModel

<a asp-controller="Support"
   asp-action="Detail"
   asp-route-ticketId="@Model.TicketId"
   class="tbs-ticket-card">

    <div class="tbs-ticket-card__main">
        <div class="tbs-ticket-card__header">
            <span class="tbs-ticket-card__id">#@Model.TicketId</span>
            @await Html.PartialAsync(
                "~/Views/Customer/Partials/_TicketStatusBadge.cshtml",
                Model.Status)
        </div>
        <h3 class="tbs-ticket-card__subject">@Model.Subject</h3>
        <div class="tbs-ticket-card__meta">
            <span class="tbs-ticket-card__category">@Model.Category</span>
            @if (Model.OrderId.HasValue)
            {
                <span class="tbs-ticket-card__order">
                    📦 Order @(Model.OrderNumber ?? $"#{Model.OrderId}")
                </span>
            }
        </div>
    </div>

    <div class="tbs-ticket-card__aside">
        <span class="tbs-ticket-card__date">@Model.FormattedCreatedAt</span>
        <span class="tbs-ticket-card__arrow" aria-hidden="true">›</span>
    </div>

</a>
