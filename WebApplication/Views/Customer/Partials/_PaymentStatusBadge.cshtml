@* WebApplication/Views/Customer/Partials/_PaymentStatusBadge.cshtml *@
@model string
@{
    string css = Model switch
    {
        "Pending"              => "cal-badge-warning",
        "VerificationPending"  => "cal-badge-warning",
        "VerificationRejected" => "cal-badge-error",
        "Completed"            => "cal-badge-success",
        "Failed"               => "cal-badge-error",
        _                      => "cal-badge-muted"
    };
    string label = Model switch
    {
        "VerificationPending"  => "Awaiting Verification",
        "VerificationRejected" => "Rejected",
        _                      => Model
    };
}
<span class="cal-badge @css" aria-label="Payment status: @label">@label</span>
