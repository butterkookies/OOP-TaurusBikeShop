@* WebApplication/Views/Customer/Partials/_TicketStatusBadge.cshtml *@
@model string
@{
    string css = Model switch
    {
        "Open"             => "cal-badge-info",
        "InProgress"       => "cal-badge-warning",
        "AwaitingResponse" => "cal-badge-warning",
        "Resolved"         => "cal-badge-success",
        "Closed"           => "cal-badge-muted",
        _                  => "cal-badge-muted"
    };
    string label = Model switch
    {
        "InProgress"       => "In Progress",
        "AwaitingResponse" => "Awaiting Response",
        _                  => Model
    };
}
<span class="cal-badge @css" aria-label="Ticket status: @label">@label</span>