@* WebApplication/Views/Customer/Partials/_ReviewForm.cshtml *@
@model WebApplication.Models.ViewModels.ReviewViewModel

<div class="cal-card-static p-6">
    <h3 class="font-display text-lg font-semibold text-charcoal dark:text-white mb-5" style="letter-spacing:0.2px">Write a Review</h3>

    <form asp-action="Submit" asp-controller="Review" method="post" id="review-form" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ProductId" />
        <input type="hidden" asp-for="OrderId" />

        @* Star rating picker *@
        <div class="mb-5">
            <label class="cal-label">Your Rating</label>
            <div class="cal-star-picker" id="rating-picker" role="radiogroup" aria-label="Select rating"
                 aria-invalid="@(ViewData.ModelState["Rating"]?.Errors.Count > 0 ? "true" : "false")"
                 aria-describedby="Rating-error">
                @for (int i = 5; i >= 1; i--)
                {
                    <input type="radio" name="Rating" id="star-@i" value="@i"
                           class="cal-star-picker__input" @(Model.Rating == i ? "checked" : "") required />
                    <label for="star-@i" class="cal-star-picker__label"
                           title="@i star@(i != 1 ? "s" : "")" aria-label="@i star@(i != 1 ? "s" : "")">★</label>
                }
            </div>
            <span asp-validation-for="Rating" id="Rating-error" role="alert" class="cal-field-error"></span>
        </div>

        @* Comment *@
        <div class="mb-5">
            <label asp-for="Comment" class="cal-label">
                Your Review <span class="cal-label-opt">(optional, min 10 characters)</span>
            </label>
            <textarea asp-for="Comment"
                      class="cal-input cal-textarea"
                      rows="4"
                      placeholder="Share your experience with this product…"
                      maxlength="1000"
                      aria-invalid="@(ViewData.ModelState["Comment"]?.Errors.Count > 0 ? "true" : "false")"
                      aria-describedby="Comment-error"></textarea>
            <div class="flex justify-end mt-1">
                <span class="text-xs text-mid-gray"><span id="review-char-count">0</span> / 1000</span>
            </div>
            <span asp-validation-for="Comment" id="Comment-error" role="alert" class="cal-field-error"></span>
        </div>

        <button type="submit" class="btn-dark">Submit Review</button>
    </form>
</div>

<script>
(function () {
    var form      = document.getElementById('review-form');
    if (!form) return;

    var picker    = document.getElementById('rating-picker');
    var ratingErr = document.getElementById('Rating-error');
    var textarea  = form.querySelector('textarea[name="Comment"]');
    var charEl    = document.getElementById('review-char-count');

    if (textarea && charEl) {
        charEl.textContent = textarea.value.length;
        textarea.addEventListener('input', function () { charEl.textContent = this.value.length; });
    }

    form.addEventListener('submit', function (e) {
        var selected = form.querySelector('input[name="Rating"]:checked');
        if (!selected) {
            e.preventDefault();
            if (picker)    picker.setAttribute('aria-invalid', 'true');
            if (ratingErr) ratingErr.textContent = 'Please select a star rating before submitting your review.';
            if (picker)    picker.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    });

    form.querySelectorAll('input[name="Rating"]').forEach(function (radio) {
        radio.addEventListener('change', function () {
            if (picker)    picker.setAttribute('aria-invalid', 'false');
            if (ratingErr) ratingErr.textContent = '';
        });
    });
})();
</script>
