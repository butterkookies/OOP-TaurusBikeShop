@* WebApplication/Views/Customer/Partials/_OTPModal.cshtml *@
@* Model: string email (the email address the OTP was sent to) *@
@model string

<div class="modal fade" id="otpModal" tabindex="-1"
     aria-labelledby="otpModalLabel" aria-modal="true" role="dialog">
    <div class="modal-dialog modal-dialog-centered tbs-otp-dialog">
        <div class="modal-content tbs-otp-modal">

            <div class="tbs-otp-modal__header">
                <div class="tbs-otp-modal__icon" aria-hidden="true">&#9993;</div>
                <h2 class="tbs-otp-modal__title" id="otpModalLabel">Check Your Email</h2>
                <p class="tbs-otp-modal__subtitle">
                    We sent a 6-digit code to<br />
                    <strong>@Model</strong>
                </p>
            </div>

            <div class="tbs-otp-modal__body">

                @* OTP verification form *@
                <form asp-action="VerifyOTP" asp-controller="Customer" method="post"
                      id="otp-verify-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="email" value="@Model" />

                    <div class="tbs-otp-modal__inputs" aria-label="Enter your 6-digit code">
                        <input type="text"
                               name="code"
                               id="otp-code-input"
                               class="tbs-otp-modal__code-input"
                               maxlength="6"
                               inputmode="numeric"
                               autocomplete="one-time-code"
                               pattern="[0-9]{6}"
                               placeholder="______"
                               required
                               aria-label="6-digit verification code" />
                    </div>

                    <p class="tbs-otp-modal__error" id="otp-error" role="alert" style="display:none;"></p>

                    <button type="submit" class="btn tbs-btn-accent tbs-btn-full" id="otp-verify-btn">
                        Verify Code
                    </button>
                </form>

                @* Countdown and resend *@
                <div class="tbs-otp-modal__footer">
                    <p class="tbs-otp-modal__countdown">
                        Code expires in <span id="otp-countdown" class="tbs-otp-modal__countdown-value">10:00</span>
                    </p>
                    <p class="tbs-otp-modal__resend">
                        Didn't receive it?
                        <button type="button" class="tbs-otp-modal__resend-btn"
                                id="otp-resend-btn" disabled>
                            Resend Code
                        </button>
                    </p>
                </div>

            </div>
        </div>
    </div>
</div>
