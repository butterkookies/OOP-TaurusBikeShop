@* WebApplication/Views/Customer/Partials/_OTPModal.cshtml *@
@* Model: string email (the email address the OTP was sent to) *@
@model string

<div class="cal-modal-backdrop" id="otpModal" hidden
     aria-labelledby="otpModalLabel" aria-modal="true" role="dialog">
    <div class="cal-modal" onclick="event.stopPropagation()">

        <div class="p-8 text-center">
            <div class="w-14 h-14 rounded-full bg-charcoal/[0.06] dark:bg-white/10 flex items-center justify-center mx-auto mb-5 text-2xl">
                ✉
            </div>
            <h2 class="font-display text-xl font-semibold text-charcoal dark:text-white mb-2" id="otpModalLabel">Check Your Email</h2>
            <p class="text-sm text-mid-gray">
                We sent a 6-digit code to<br />
                <strong class="text-charcoal dark:text-white">@Model</strong>
            </p>
        </div>

        <div class="px-8 pb-8">
            <form asp-action="VerifyOTP" asp-controller="Customer" method="post" id="otp-verify-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@Model" />

                <div class="mb-4">
                    <input type="text" name="code" id="otp-code-input"
                           class="cal-input text-center text-2xl tracking-[0.5em] font-mono"
                           maxlength="6" inputmode="numeric" autocomplete="one-time-code"
                           pattern="[0-9]{6}" placeholder="______" required
                           aria-label="6-digit verification code"
                           aria-invalid="false" aria-describedby="otp-error" />
                </div>

                <p class="cal-field-error text-center" id="otp-error" role="alert"></p>

                <button type="submit" class="btn-dark btn-full mt-2" id="otp-verify-btn">
                    Verify Code
                </button>
            </form>

            <div class="text-center mt-5 text-sm text-mid-gray">
                <p>
                    Code expires in <span id="otp-countdown" class="font-mono font-medium text-charcoal dark:text-white">10:00</span>
                </p>
                <p class="mt-2">
                    Didn't receive it?
                    <button type="button" id="otp-resend-btn" disabled
                            class="font-medium text-charcoal hover:underline disabled:opacity-40 disabled:cursor-not-allowed dark:text-white">
                        Resend Code
                    </button>
                </p>
            </div>
        </div>

    </div>
</div>

<script>
(function () {
    var input  = document.getElementById('otp-code-input');
    var errEl  = document.getElementById('otp-error');
    var form   = document.getElementById('otp-verify-form');
    if (!input || !form) return;

    input.addEventListener('input', function () {
        if (input.checkValidity()) {
            input.setAttribute('aria-invalid', 'false');
            if (errEl) errEl.textContent = '';
        }
    });

    form.addEventListener('submit', function (e) {
        if (!input.checkValidity()) {
            e.preventDefault();
            input.setAttribute('aria-invalid', 'true');
            if (errEl) errEl.textContent = 'Please enter the 6-digit code sent to your email.';
            input.focus();
        }
    });
})();
</script>
