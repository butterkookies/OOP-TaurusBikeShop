@* WebApplication/Views/Customer/Partials/_ReviewList.cshtml *@
@* Model: IReadOnlyList<ReviewItemViewModel> — rendered by LoadMore AJAX *@
@model IReadOnlyList<WebApplication.Models.ViewModels.ReviewItemViewModel>

@foreach (WebApplication.Models.ViewModels.ReviewItemViewModel review in Model)
{
    <div class="tbs-review-card">
        <div class="tbs-review-card__header">
            <div class="tbs-stars tbs-stars--sm" aria-label="@review.Rating out of 5">
                @for (int i = 1; i <= 5; i++)
                {
                    <span class="tbs-star @(i <= review.Rating ? "tbs-star--filled" : "")">★</span>
                }
            </div>
            <span class="tbs-review-card__verified">✓ Verified Purchase</span>
        </div>
        @if (!string.IsNullOrWhiteSpace(review.Comment))
        {
            <p class="tbs-review-card__comment">@review.Comment</p>
        }
        <div class="tbs-review-card__meta">
            <strong>@review.UserName</strong>
            <span>@review.CreatedAt</span>
        </div>
    </div>
}
