@* WebApplication/Views/Customer/Partials/_OrderSummary.cshtml *@
@model WebApplication.Models.ViewModels.CheckoutViewModel

<div class="tbs-order-summary tbs-order-summary--checkout">
    <h2 class="tbs-order-summary__title">Order Summary</h2>

    <ul class="tbs-order-summary__items">
        @foreach (WebApplication.Models.ViewModels.CartItemViewModel item in Model.CartItems)
        {
            <li class="tbs-order-summary__item">
                <span class="tbs-order-summary__item-name">
                    @item.ProductName
                    @if (!string.IsNullOrWhiteSpace(item.VariantName))
                    {
                        <span class="tbs-order-summary__item-variant">(@item.VariantName)</span>
                    }
                    <span class="tbs-order-summary__item-qty">&times;@item.Quantity</span>
                </span>
                <span class="tbs-order-summary__item-total">@item.FormattedLineTotal</span>
            </li>
        }
    </ul>

    <div class="tbs-order-summary__divider"></div>

    <div class="tbs-order-summary__row">
        <span>Subtotal</span>
        <span id="checkout-subtotal-value">@Model.FormattedSubTotal</span>
    </div>

    <div class="tbs-order-summary__row tbs-order-summary__row--discount"
         id="checkout-discount-row-wrapper"
         style="@(Model.DiscountAmount > 0 ? "" : "display:none")">
        <span>Voucher Discount</span>
        <span id="checkout-discount-row">−₱@Model.DiscountAmount.ToString("N2")</span>
    </div>

    <div class="tbs-order-summary__row">
        <span>Shipping</span>
        <span id="checkout-shipping-fee">
            @(Model.ShippingFee > 0 ? $"₱{Model.ShippingFee:N2}" : "TBD")
        </span>
    </div>

    <div class="tbs-order-summary__divider"></div>

    <div class="tbs-order-summary__row tbs-order-summary__row--total">
        <span>Total</span>
        <span id="checkout-grand-total-row">@Model.FormattedSubTotal</span>
    </div>

    <p class="tbs-order-summary__payment-note">
        GCash &bull; Bank Transfer
    </p>
</div>
