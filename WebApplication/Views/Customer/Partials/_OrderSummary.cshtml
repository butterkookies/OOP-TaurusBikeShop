@* WebApplication/Views/Customer/Partials/_OrderSummary.cshtml *@
@model WebApplication.Models.ViewModels.CheckoutViewModel

<div class="cal-card-static p-6 sticky top-24">
    <h2 class="font-display text-lg font-semibold text-charcoal dark:text-white mb-5" style="letter-spacing:0.2px">Order Summary</h2>

    <ul class="space-y-3 mb-5">
        @foreach (WebApplication.Models.ViewModels.CartItemViewModel item in Model.CartItems)
        {
            <li class="flex items-start gap-3 text-sm">
                <span class="flex-1 min-w-0 text-charcoal dark:text-white">
                    @item.ProductName
                    @if (!string.IsNullOrWhiteSpace(item.VariantName))
                    {
                        <span class="text-mid-gray">(@item.VariantName)</span>
                    }
                    <span class="text-mid-gray">&times;@item.Quantity</span>
                </span>
                <span class="text-charcoal dark:text-white font-medium whitespace-nowrap">@item.FormattedLineTotal</span>
            </li>
        }
    </ul>

    <hr class="cal-divider" />

    <div class="space-y-2 text-sm">
        <div class="flex justify-between">
            <span class="text-mid-gray">Subtotal</span>
            <span class="text-charcoal dark:text-white" id="checkout-subtotal-value">@Model.FormattedSubTotal</span>
        </div>

        <div class="flex justify-between @(Model.DiscountAmount > 0 ? "" : "hidden")" id="checkout-discount-row-wrapper">
            <span class="text-mid-gray">Voucher Discount</span>
            <span class="text-success" id="checkout-discount-row">−₱@Model.DiscountAmount.ToString("N2")</span>
        </div>

        <div class="flex justify-between" id="checkout-shipping-row">
            <span class="text-mid-gray">Shipping</span>
            <span class="text-mid-gray italic" id="checkout-shipping-fee">@Model.FormattedShippingFee</span>
        </div>
    </div>

    <hr class="cal-divider" />

    <div class="flex justify-between text-base font-semibold">
        <span class="text-charcoal dark:text-white">Total (excl. shipping)</span>
        <span class="font-display text-charcoal dark:text-white" id="checkout-grand-total-row">@Model.FormattedGrandTotal</span>
    </div>

    <p class="text-xs text-mid-gray text-center mt-4">GCash &bull; Bank Transfer</p>
</div>
