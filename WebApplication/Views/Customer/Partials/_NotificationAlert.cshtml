@* WebApplication/Views/Customer/Partials/_NotificationAlert.cshtml *@
@* Alert container driven by showToast() in utils.js.
   Also reads TempData["error"] / TempData["success"] / TempData["info"]
   set by server-side redirects and fires showToast() on DOMContentLoaded. *@
@{
    string? toastError   = TempData["error"]   as string;
    string? toastSuccess = TempData["success"] as string;
    string? toastInfo    = TempData["info"]    as string;
}

<div class="notification-alert" id="notificationAlert" style="display:none">
    <span class="close-alert" id="closeAlert">&times;</span>
    <p id="alertMessage"></p>
</div>

<script>
    (function () {
        const alertBox = document.getElementById('notificationAlert');
        const closeBtn = document.getElementById('closeAlert');

        if (closeBtn) {
            closeBtn.addEventListener('click', () => { alertBox.style.display = 'none'; });
        }
    })();
</script>

@if (!string.IsNullOrEmpty(toastError))
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            showToast('error', '@Html.Raw(toastError!.Replace("\\", "\\\\").Replace("'", "\\'"))');
        });
    </script>
}
@if (!string.IsNullOrEmpty(toastSuccess))
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            showToast('success', '@Html.Raw(toastSuccess!.Replace("\\", "\\\\").Replace("'", "\\'"))');
        });
    </script>
}
@if (!string.IsNullOrEmpty(toastInfo))
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            showToast('info', '@Html.Raw(toastInfo!.Replace("\\", "\\\\").Replace("'", "\\'"))');
        });
    </script>
}
