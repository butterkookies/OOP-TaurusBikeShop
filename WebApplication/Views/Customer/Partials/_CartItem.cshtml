@* WebApplication/Views/Cart/Partials/_CartItem.cshtml *@
@model WebApplication.Models.ViewModels.CartItemViewModel

<div class="flex items-center gap-4 px-5 py-4" id="cart-item-@Model.CartItemId" data-cart-item-id="@Model.CartItemId" data-unit-price="@Model.UnitPrice" data-quantity="@Model.Quantity">

    @* Select checkbox *@
    <input type="checkbox"
           class="cart-item-select h-4 w-4 shrink-0 rounded border-border-ring accent-charcoal cursor-pointer dark:border-white/20"
           data-cart-item-id="@Model.CartItemId"
           checked
           aria-label="Select @Model.ProductName for checkout" />

    @* Product image *@
    <div class="w-16 h-16 bg-light-gray dark:bg-neutral-800 rounded-lg overflow-hidden shrink-0">
        @if (Model.ImageUrl != null)
        {
            <img src="@Model.ImageUrl" alt="@Model.ProductName" class="w-full h-full object-cover" loading="lazy" />
        }
        else
        {
            <div class="w-full h-full flex items-center justify-center text-mid-gray text-lg">△</div>
        }
    </div>

    @* Info *@
    <div class="flex-1 min-w-0">
        <h3 class="text-sm font-medium text-charcoal dark:text-white truncate">
            <a asp-controller="Product" asp-action="Detail" asp-route-id="@Model.ProductId"
               class="hover:underline">@Model.ProductName</a>
        </h3>
        @if (!string.IsNullOrWhiteSpace(Model.VariantName))
        {
            <p class="text-xs text-mid-gray">@Model.VariantName</p>
        }
        <p class="text-xs text-mid-gray mt-0.5">@Model.FormattedUnitPrice each</p>
    </div>

    @* Qty stepper *@
    <div class="cal-qty shrink-0">
        <button type="button" class="cal-qty-btn" data-action="decrease" data-cart-item-id="@Model.CartItemId" aria-label="Decrease quantity">−</button>
        <input type="number" class="cal-qty-val" value="@Model.Quantity" min="1" max="@Model.StockQuantity" data-cart-item-id="@Model.CartItemId" data-max-stock="@Model.StockQuantity" aria-label="Quantity" />
        <button type="button" class="cal-qty-btn" data-action="increase" data-cart-item-id="@Model.CartItemId" aria-label="Increase quantity">+</button>
    </div>

    @* Line total *@
    <div class="text-sm font-semibold text-charcoal dark:text-white whitespace-nowrap w-24 text-right" id="line-total-@Model.CartItemId">
        @Model.FormattedLineTotal
    </div>

    @* Remove *@
    <button type="button"
            class="cart-item-remove w-8 h-8 flex items-center justify-center text-mid-gray hover:text-error transition-colors shrink-0"
            data-cart-item-id="@Model.CartItemId"
            aria-label="Remove @Model.ProductName from cart">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
    </button>

</div>
