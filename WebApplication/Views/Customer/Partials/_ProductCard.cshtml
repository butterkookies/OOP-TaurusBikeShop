@* WebApplication/Views/Customer/Partials/_ProductCard.cshtml *@
@model WebApplication.Models.ViewModels.ProductViewModel

<div class="tbs-product-card @(Model.IsOutOfStock ? "tbs-product-card--oos" : "")" data-product-id="@Model.ProductId">

    @* ── Left: full-bleed image ────────────────────────────── *@
    <a asp-controller="Product" asp-action="Detail" asp-route-id="@Model.ProductId" class="tbs-product-card__img-wrap"
           tabindex="-1" aria-hidden="true">

        @if (Model.PrimaryImageUrl != null)
        {
            <img src="@Model.PrimaryImageUrl" alt="@Model.Name" class="tbs-product-card__img" loading="lazy" />
        }
        else
        {
            <div class="tbs-product-card__img-placeholder" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16"
                     aria-hidden="true">
                    <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z" />
                    <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z" />
                </svg>
            </div>
        }

        @* Right-edge fade so image bleeds into content panel *@
        <div class="tbs-product-card__img-fade" aria-hidden="true"></div>

        @* Stock badge — top-left over image *@
        @if (Model.IsOutOfStock)
        {
            <span class="tbs-product-card__badge tbs-product-card__badge--oos">Out of Stock</span>
        }
        else if (Model.IsLowStock)
        {
            <span class="tbs-product-card__badge tbs-product-card__badge--low">Low Stock</span>
        }

    </a>

    @* ── Right: content panel ──────────────────────────────── *@
    <div class="tbs-product-card__body">

        <button type="button" class="tbs-product-card__wishlist @(Model.IsInWishlist ? "is-active" : "")"
                data-product-id="@Model.ProductId"
                aria-label="@(Model.IsInWishlist ? "Remove from wishlist" : "Add to wishlist")"
                aria-pressed="@(Model.IsInWishlist ? "true" : "false")">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"
                 aria-hidden="true">
                <path
                d="M8 2.748l-.717-.737C5.6.281 2.514.878 1.4 3.053c-.523 1.023-.641 2.5.314 4.385.92 1.815 2.834 3.989 6.286 6.357 3.452-2.368 5.365-4.542 6.286-6.357.955-1.886.838-3.362.314-4.385C13.486.878 10.4.28 8.717 2.01L8 2.748zM8 15C-7.333 4.868 3.279-3.04 7.824 1.143c.06.055.119.112.176.171a3.12 3.12 0 0 1 .176-.17C12.72-3.042 23.333 4.867 8 15z" />
            </svg>
        </button>

        <div class="tbs-product-card__meta">
            @if (Model.Brand != null)
            {
                <p class="tbs-product-card__brand">@Model.Brand</p>
            }
            <h3 class="tbs-product-card__name">
                <a asp-controller="Product" asp-action="Detail" asp-route-id="@Model.ProductId">@Model.Name</a>
            </h3>
        </div>

        <div class="tbs-product-card__footer">
            <span class="tbs-product-card__price">@Model.FormattedPrice</span>
            @if (!Model.IsOutOfStock)
            {
                <button type="button" class="tbs-product-card__cta" data-product-id="@Model.ProductId"
                        aria-label="Add @Model.Name to cart">
                    Add to Cart
                </button>
            }
            else
            {
                <button type="button" class="tbs-product-card__cta tbs-product-card__cta--disabled" disabled>
                    Out of Stock
                </button>
            }
        </div>

    </div>

</div>
