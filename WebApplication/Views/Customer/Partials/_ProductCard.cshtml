@* WebApplication/Views/Customer/Partials/_ProductCard.cshtml *@
@model WebApplication.Models.ViewModels.ProductViewModel

<div class="tbs-product-card @(Model.IsOutOfStock ? "tbs-product-card--oos" : "")" data-product-id="@Model.ProductId">

    @* ── Image zone — wrapper keeps the link and floating controls in one
          positioning context WITHOUT nesting buttons inside an <a> tag ── *@
    <div class="tbs-product-card__img-zone">

        <a asp-controller="Product" asp-action="Detail" asp-route-id="@Model.ProductId"
           class="tbs-product-card__img-wrap" tabindex="-1" aria-hidden="true">

            @if (Model.PrimaryImageUrl != null)
            {
                <img src="@Model.PrimaryImageUrl" alt="@Model.Name" class="tbs-product-card__img" loading="lazy" />
            }
            else
            {
                <div class="tbs-product-card__img-placeholder" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" viewBox="0 0 16 16"
                         aria-hidden="true">
                        <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z" />
                        <path
                        d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2h-12zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1h12z" />
                    </svg>
                </div>
            }

            @* Stock badge — top-left *@
            @if (Model.IsOutOfStock)
            {
                <span class="tbs-product-card__badge tbs-product-card__badge--oos">Out of Stock</span>
            }
            else if (Model.IsLowStock)
            {
                <span class="tbs-product-card__badge tbs-product-card__badge--low">Low Stock</span>
            }

        </a>

        @* Wishlist — top-right, outside the <a> so clicks don't trigger navigation *@
        <button type="button" class="tbs-product-card__wishlist @(Model.IsInWishlist ? "is-active" : "")"
                data-product-id="@Model.ProductId"
                aria-label="@(Model.IsInWishlist ? "Remove from wishlist" : "Add to wishlist")"
                aria-pressed="@(Model.IsInWishlist ? "true" : "false")">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 16 16" class="heart-outline" aria-hidden="true">
                <path d="M8 2.748l-.717-.737C5.6.281 2.514.878 1.4 3.053c-.523 1.023-.641 2.5.314 4.385.92 1.815 2.834 3.989 6.286 6.357 3.452-2.368 5.365-4.542 6.286-6.357.955-1.886.838-3.362.314-4.385C13.486.878 10.4.28 8.717 2.01L8 2.748z"/>
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 16 16" class="heart-filled" aria-hidden="true">
                <path d="M4 1c-1.9 0-3.5 1.4-3.5 3.1 0 2 2.5 4.5 7 8.1 4.5-3.6 7-6.1 7-8.1C15.5 2.4 13.9 1 12 1c-1.1 0-2.2.6-3 1.3C8.2 1.6 7.1 1 6 1z"/>
            </svg>
        </button>

        @* Dot indicators *@
        <div class="tbs-product-card__dots" aria-hidden="true">
            <span class="tbs-product-card__dot tbs-product-card__dot--active"></span>
            <span class="tbs-product-card__dot"></span>
            <span class="tbs-product-card__dot"></span>
            <span class="tbs-product-card__dot"></span>
        </div>

    </div>

    @* ── Card body ─────────────────────────────────────────── *@
    <div class="tbs-product-card__body">

        <div class="tbs-product-card__meta">
            <h3 class="tbs-product-card__name">
                <a asp-controller="Product" asp-action="Detail" asp-route-id="@Model.ProductId">@Model.Name</a>
            </h3>
            @if (Model.Brand != null)
            {
                <p class="tbs-product-card__subtitle">@Model.Brand</p>
            }
            @* Description always rendered — falls back to a non-breaking space so
               the line still occupies height and all cards stay visually consistent *@
            <p class="tbs-product-card__desc">
                @(!string.IsNullOrWhiteSpace(Model.ShortDescription)
                    ? Model.ShortDescription
                    : "\u00A0")
            </p>
        </div>

        <div class="tbs-product-card__footer">
            <span class="tbs-product-card__price">@Model.FormattedPrice</span>

            @if (!Model.IsOutOfStock)
            {
                <button type="button" class="tbs-product-card__cart-btn" data-product-id="@Model.ProductId"
                        aria-label="Add @Model.Name to cart">
                    Add to Cart
                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="currentColor" viewBox="0 0 16 16"
                         aria-hidden="true">
                        <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                    </svg>
                </button>
            }
            else
            {
                <button type="button" class="tbs-product-card__cart-btn tbs-product-card__cart-btn--disabled" disabled>
                    Out of Stock
                </button>
            }
        </div>

    </div>

</div>
