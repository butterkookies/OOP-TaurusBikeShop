@* WebApplication/Views/Customer/Partials/_ProductCard.cshtml *@
@model WebApplication.Models.ViewModels.ProductViewModel

<div class="cal-card overflow-hidden group hover:-translate-y-0.5 flex flex-col @(Model.IsOutOfStock ? "opacity-70" : "")" data-product-id="@Model.ProductId">

    @* ── Image zone ── *@
    <div class="relative">
        <a asp-controller="Product" asp-action="Detail" asp-route-id="@Model.ProductId"
           class="block aspect-square bg-light-gray dark:bg-neutral-800 overflow-hidden" tabindex="-1" aria-hidden="true">
            @if (Model.PrimaryImageUrl != null)
            {
                <img src="@Model.PrimaryImageUrl" alt="@Model.Name"
                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                     loading="lazy" />
            }
            else
            {
                <div class="w-full h-full flex items-center justify-center text-mid-gray">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" viewBox="0 0 16 16"><path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z"/><path d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2h-12zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1h12z"/></svg>
                </div>
            }
        </a>

        @* Stock badge *@
        @if (Model.IsOutOfStock)
        {
            <span class="absolute top-2.5 left-2.5 cal-badge cal-badge-error">Out of Stock</span>
        }
        else if (Model.IsLowStock)
        {
            <span class="absolute top-2.5 left-2.5 cal-badge cal-badge-warning">Low Stock</span>
        }

        @* Wishlist toggle *@
        <button type="button"
                class="wishlist-toggle absolute top-2.5 right-2.5 w-8 h-8 rounded-full bg-white/90 dark:bg-midnight/90 flex items-center justify-center text-mid-gray hover:text-error transition-colors shadow-sm @(Model.IsInWishlist ? "!text-error is-active" : "")"
                data-product-id="@Model.ProductId"
                aria-label="@(Model.IsInWishlist ? "Remove from wishlist" : "Add to wishlist")"
                aria-pressed="@(Model.IsInWishlist ? "true" : "false")">
            @if (Model.IsInWishlist)
            {
                <svg class="heart-filled" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                <svg class="heart-outline hidden" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            }
            else
            {
                <svg class="heart-filled hidden" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                <svg class="heart-outline" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            }
        </button>
    </div>

    @* ── Card body ── *@
    <div class="p-4 flex flex-col flex-1">
        <h3 class="text-sm font-medium text-charcoal dark:text-white line-clamp-2 mb-0.5">
            <a asp-controller="Product" asp-action="Detail" asp-route-id="@Model.ProductId"
               class="hover:underline">@Model.Name</a>
        </h3>
        @if (Model.Brand != null)
        {
            <p class="text-xs text-mid-gray">@Model.Brand</p>
        }
        @if (!string.IsNullOrWhiteSpace(Model.ShortDescription))
        {
            <p class="text-xs text-mid-gray mt-1 line-clamp-2">@Model.ShortDescription</p>
        }

        <div class="flex items-center justify-between mt-auto pt-3">
            <span class="font-display text-base font-semibold text-charcoal dark:text-white">@Model.FormattedPrice</span>

            @if (!Model.IsOutOfStock)
            {
                <button type="button"
                        class="btn-dark btn-sm catalog-add-to-cart"
                        data-product-id="@Model.ProductId"
                        aria-label="Add @Model.Name to cart">
                    Add to Cart
                </button>
            }
            else
            {
                <span class="text-xs text-mid-gray font-medium">Sold Out</span>
            }
        </div>
    </div>

</div>
