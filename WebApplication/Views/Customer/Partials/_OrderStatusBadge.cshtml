@* WebApplication/Views/Customer/Partials/_OrderStatusBadge.cshtml *@
@model string
@{
    string css = Model switch
    {
        "Pending"             => "cal-badge-warning",
        "PendingVerification" => "cal-badge-warning",
        "OnHold"              => "cal-badge-warning",
        "Processing"          => "cal-badge-info",
        "ReadyForPickup"      => "cal-badge-info",
        "PickedUp"            => "cal-badge-info",
        "Shipped"             => "cal-badge-info",
        "Delivered"           => "cal-badge-success",
        "Cancelled"           => "cal-badge-error",
        _                     => "cal-badge-muted"
    };
    string label = Model switch
    {
        "PendingVerification" => "Pending Verification",
        "ReadyForPickup"      => "Ready for Pickup",
        _                     => Model
    };
}
<span class="cal-badge @css" aria-label="Order status: @label">@label</span>
