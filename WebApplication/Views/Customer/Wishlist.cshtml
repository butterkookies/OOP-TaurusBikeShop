@* WebApplication/Views/Customer/Wishlist.cshtml *@
@model WebApplication.Models.ViewModels.WishlistViewModel
@{
    ViewData["Title"] = "My Wishlist";
}

@Html.AntiForgeryToken()

<div class="bg-light-gray dark:bg-midnight min-h-[calc(100vh-160px)]">
    <div class="max-w-[1200px] mx-auto px-6 py-12 md:py-16">

        <div class="mb-10" data-reveal>
            <h1 class="font-display text-3xl md:text-4xl font-semibold text-charcoal dark:text-white">My Wishlist</h1>
            @if (Model.Items != null && Model.Items.Any())
            {
                <p class="text-base text-mid-gray mt-2">@Model.Items.Count() item@(Model.Items.Count() != 1 ? "s" : "") saved</p>
            }
        </div>

        @if (Model.Items == null || !Model.Items.Any())
        {
            <div class="cal-card-static p-12 text-center max-w-md mx-auto" data-reveal="delay-1">
                <div class="text-mid-gray mb-4">
                    <svg class="mx-auto" xmlns="http://www.w3.org/2000/svg" width="36" height="36"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                    </svg>
                </div>
                <h2 class="font-display text-xl font-semibold text-charcoal dark:text-white mb-2">Your wishlist is empty</h2>
                <p class="text-sm text-mid-gray mb-6">Browse products and save items you love.</p>
                <a asp-controller="Product" asp-action="List" class="btn-dark">Browse Catalog</a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5" data-reveal="delay-1">
                @foreach (var item in Model.Items)
                {
                    <div class="cal-card overflow-hidden group hover:-translate-y-0.5 flex flex-col h-full">
                        <a asp-controller="Product" asp-action="Detail" asp-route-id="@item.ProductId">
                            <div class="aspect-square bg-light-gray dark:bg-neutral-800 overflow-hidden flex items-center justify-center">
                                @if (item.PrimaryImageUrl != null)
                                {
                                    <img src="@item.PrimaryImageUrl" alt="@item.Name"
                                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" class="text-mid-gray" viewBox="0 0 16 16"><path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z"/><path d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2h-12zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1h12z"/></svg>
                                }
                            </div>
                        </a>
                        <div class="p-4 flex flex-col flex-1">
                            <a asp-controller="Product" asp-action="Detail" asp-route-id="@item.ProductId"
                               class="text-sm font-medium text-charcoal dark:text-white line-clamp-2 hover:underline">
                                @item.Name
                            </a>
                            <p class="font-display text-lg font-semibold text-charcoal dark:text-white mt-2">@item.FormattedPrice</p>

                            <div class="flex gap-2 mt-auto pt-3">
                                <button type="button"
                                        class="btn-dark btn-sm flex-1 wishlist-add-to-cart"
                                        data-product-id="@item.ProductId">
                                    Add to Cart
                                </button>
                                <button type="button"
                                        class="wishlist-remove-btn w-9 h-9 flex items-center justify-center border border-border-ring dark:border-white/15 rounded-lg text-mid-gray hover:text-error hover:border-error/30 transition-colors"
                                        data-product-id="@item.ProductId"
                                        aria-label="Remove from wishlist">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/wishlist.js" asp-append-version="true"></script>
}
