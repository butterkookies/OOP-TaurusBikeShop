@{
    ViewData["Title"] = "Create Account";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Taurus Bike Shop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@300;400;500;600&family=Barlow+Condensed:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="register-page">

    <!-- Atmospheric Background -->
    <div class="bg-overlay"></div>
    <div class="bg-grid"></div>
    <div class="bg-red-glow"></div>

    <!-- Split Layout -->
    <div class="register-split">

        <!-- Left Panel — Brand Identity -->
        <div class="brand-panel">
            <div class="brand-panel__inner">

                <div class="brand-logo">
                    <span class="brand-logo__bull">&#9650;</span>
                </div>
                <h1 class="brand-name">TAURUS</h1>
                <p class="brand-tagline">Bike Shop</p>
                <div class="brand-divider"></div>
                <p class="brand-copy">Your journey starts here.<br>Join the Taurus community.</p>

                <!-- Step guide -->
                <div class="steps-guide">
                    <div class="step-item active" data-step="1">
                        <div class="step-circle">1</div>
                        <div class="step-info">
                            <span class="step-title">Account Info</span>
                            <span class="step-desc">Email & password</span>
                        </div>
                    </div>
                    <div class="step-connector"></div>
                    <div class="step-item" data-step="2">
                        <div class="step-circle">2</div>
                        <div class="step-info">
                            <span class="step-title">Verification</span>
                            <span class="step-desc">OTP via mobile</span>
                        </div>
                    </div>
                    <div class="step-connector"></div>
                    <div class="step-item" data-step="3">
                        <div class="step-circle">3</div>
                        <div class="step-info">
                            <span class="step-title">Delivery Address</span>
                            <span class="step-desc">Where to ship</span>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Decorative wheel -->
            <div class="deco-wheel">
                <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="100" cy="100" r="95" stroke="#E10600" stroke-width="1.5" stroke-dasharray="6 4"/>
                    <circle cx="100" cy="100" r="70" stroke="#ffffff10" stroke-width="1"/>
                    <circle cx="100" cy="100" r="12" fill="#E10600"/>
                    <line x1="100" y1="5"   x2="100" y2="88"  stroke="#ffffff20" stroke-width="1.5"/>
                    <line x1="100" y1="112" x2="100" y2="195" stroke="#ffffff20" stroke-width="1.5"/>
                    <line x1="5"   y1="100" x2="88"  y2="100" stroke="#ffffff20" stroke-width="1.5"/>
                    <line x1="112" y1="100" x2="195" y2="100" stroke="#ffffff20" stroke-width="1.5"/>
                    <line x1="32"  y1="32"  x2="91"  y2="91"  stroke="#ffffff15" stroke-width="1.5"/>
                    <line x1="109" y1="109" x2="168" y2="168" stroke="#ffffff15" stroke-width="1.5"/>
                    <line x1="168" y1="32"  x2="109" y2="91"  stroke="#ffffff15" stroke-width="1.5"/>
                    <line x1="91"  y1="109" x2="32"  y2="168" stroke="#ffffff15" stroke-width="1.5"/>
                </svg>
            </div>
        </div>

        <!-- Right Panel — Register Form -->
        <div class="form-panel">
            <div class="form-panel__inner">

                <div class="form-header">
                    <div class="form-header__eyebrow">New Rider</div>
                    <h2 class="form-header__title">Create Account</h2>
                    <p class="form-header__sub">Join thousands of Taurus riders today</p>
                </div>

                <form id="registerForm" method="post" action="/Customer/Register" class="register-form" novalidate>

                    <!-- ── SECTION 1: ACCOUNT INFO ── -->
                    <div class="form-section" id="section-account">
                        <div class="section-label">
                            <span class="section-label__num">01</span>
                            <span class="section-label__text">Account Information</span>
                        </div>

                        <div class="fields-grid">

                            <div class="field-group field-full">
                                <label for="email" class="field-label">Email Address</label>
                                <div class="field-wrap">
                                    <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                        <polyline points="22,6 12,13 2,6"/>
                                    </svg>
                                    <input type="email" class="field-input" id="email" name="email"
                                           placeholder="you@example.com" required autocomplete="email">
                                    <div class="field-line"></div>
                                </div>
                            </div>

                            <div class="field-group field-full">
                                <label for="password" class="field-label">Password</label>
                                <div class="field-wrap">
                                    <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                                    </svg>
                                    <input type="password" class="field-input" id="password" name="password"
                                           placeholder="Create a strong password" required autocomplete="new-password">
                                    <button type="button" class="toggle-password" id="togglePassword" aria-label="Toggle password">
                                        <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                            <circle cx="12" cy="12" r="3"/>
                                        </svg>
                                    </button>
                                    <div class="field-line"></div>
                                </div>
                                <div class="password-strength" id="passwordStrength">
                                    <div class="strength-bar"><span class="strength-fill" id="strengthFill"></span></div>
                                    <span class="strength-label" id="strengthLabel"></span>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- ── SECTION 2: VERIFICATION ── -->
                    <div class="form-section" id="section-verify">
                        <div class="section-label">
                            <span class="section-label__num">02</span>
                            <span class="section-label__text">Mobile Verification</span>
                        </div>

                        <div class="fields-grid">

                            <div class="field-group field-full">
                                <label for="contactNumber" class="field-label">Contact Number</label>
                                <div class="field-wrap otp-input-wrap">
                                    <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                                    </svg>
                                    <input type="tel" class="field-input" id="contactNumber" name="contactNumber"
                                           placeholder="09XXXXXXXXX" required autocomplete="tel">
                                    <button type="button" class="btn-send-otp" id="sendOtpBtn">Send OTP</button>
                                    <div class="field-line"></div>
                                </div>
                            </div>

                            <div class="field-group field-full" id="otpFieldGroup">
                                <label for="otpCode" class="field-label">OTP Verification Code</label>
                                <div class="otp-boxes" id="otpBoxes">
                                    <input type="text" class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]">
                                    <input type="text" class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]">
                                    <input type="text" class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]">
                                    <input type="text" class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]">
                                    <input type="text" class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]">
                                    <input type="text" class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]">
                                </div>
                                <!-- Hidden input to collect assembled OTP value -->
                                <input type="hidden" id="otpCode" name="otpCode">
                                <div class="otp-hint">
                                    <span id="otpTimer" class="otp-timer"></span>
                                    <button type="button" class="otp-resend" id="resendOtp" style="display:none">Resend code</button>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- ── SECTION DIVIDER ── -->
                    <div class="section-rule"></div>

                    <!-- ── SECTION 3: DELIVERY ADDRESS ── -->
                    <div class="form-section" id="section-address">
                        <div class="section-label">
                            <span class="section-label__num">03</span>
                            <span class="section-label__text">Delivery Address</span>
                        </div>

                        <div class="fields-grid">

                            <div class="field-group field-full">
                                <label for="streetAddress" class="field-label">Street Address</label>
                                <div class="field-wrap">
                                    <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                                        <polyline points="9 22 9 12 15 12 15 22"/>
                                    </svg>
                                    <input type="text" class="field-input" id="streetAddress" name="streetAddress"
                                           placeholder="House No. / Street / Barangay" required>
                                    <div class="field-line"></div>
                                </div>
                            </div>

                            <div class="field-group field-half">
                                <label for="city" class="field-label">City</label>
                                <div class="field-wrap">
                                    <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                        <circle cx="12" cy="10" r="3"/>
                                        <path d="M12 2a8 8 0 0 0-8 8c0 5.25 8 13 8 13s8-7.75 8-13a8 8 0 0 0-8-8z"/>
                                    </svg>
                                    <input type="text" class="field-input" id="city" name="city"
                                           placeholder="City / Municipality" required>
                                    <div class="field-line"></div>
                                </div>
                            </div>

                            <div class="field-group field-half">
                                <label for="province" class="field-label">Province</label>
                                <div class="field-wrap">
                                    <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                        <polygon points="3 11 22 2 13 21 11 13 3 11"/>
                                    </svg>
                                    <input type="text" class="field-input" id="province" name="province"
                                           placeholder="Province / Region" required>
                                    <div class="field-line"></div>
                                </div>
                            </div>

                            <div class="field-group field-half">
                                <label for="postalCode" class="field-label">Postal Code</label>
                                <div class="field-wrap">
                                    <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                        <path d="M4 4h16v16H4z"/><path d="M9 9h6M9 12h6M9 15h4"/>
                                    </svg>
                                    <input type="text" class="field-input" id="postalCode" name="postalCode"
                                           placeholder="0000" required>
                                    <div class="field-line"></div>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- ── SUBMIT ── -->
                    <button type="submit" class="btn-register" id="registerBtn">
                        <span class="btn-register__text">Create My Account</span>
                        <span class="btn-register__arrow">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <line x1="5" y1="12" x2="19" y2="12"/>
                                <polyline points="12 5 19 12 12 19"/>
                            </svg>
                        </span>
                        <span class="btn-register__loader"></span>
                    </button>

                    <div class="form-footer">
                        <span class="form-footer__text">Already have an account?</span>
                        <a href="/Customer/Login" class="form-footer__link">Sign in &rarr;</a>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

<style>
/* ============================================================
   TAURUS BIKE SHOP — REGISTER PAGE
   Dark / Red Premium Aesthetic  |  matches Login.cshtml
   ============================================================ */

:root {
    --bg-base:        #0B0B0B;
    --bg-surface:     #111111;
    --bg-card:        #161616;
    --bg-input:       #1A1A1A;
    --red:            #E10600;
    --red-hover:      #FF1A17;
    --red-dim:        #E1060022;
    --red-faint:      #E1060010;
    --white:          #FFFFFF;
    --text-primary:   #F0F0F0;
    --text-secondary: #888888;
    --text-muted:     #444444;
    --border:         #2A2A2A;
    --success:        #22C55E;

    --font-display:   'Bebas Neue', sans-serif;
    --font-cond:      'Barlow Condensed', sans-serif;
    --font-body:      'Barlow', sans-serif;

    --ease-out:       cubic-bezier(0.16, 1, 0.3, 1);
    --ease-spring:    cubic-bezier(0.34, 1.56, 0.64, 1);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
    height: 100%;
    background: var(--bg-base);
    color: var(--text-primary);
    font-family: var(--font-body);
    -webkit-font-smoothing: antialiased;
}

/* ── BACKGROUND ── */
.register-page {
    position: relative;
    min-height: 100vh;
    overflow-x: hidden;
}

.bg-overlay {
    position: fixed; inset: 0;
    background: radial-gradient(ellipse 80% 60% at 20% 50%, #1a0202 0%, transparent 70%);
    pointer-events: none; z-index: 0;
}

.bg-grid {
    position: fixed; inset: 0;
    background-image:
        linear-gradient(#ffffff04 1px, transparent 1px),
        linear-gradient(90deg, #ffffff04 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none; z-index: 0;
}

.bg-red-glow {
    position: fixed;
    top: 50%; left: 30%;
    width: 600px; height: 600px;
    background: radial-gradient(circle, #E1060018 0%, transparent 65%);
    transform: translate(-50%, -50%);
    pointer-events: none; z-index: 0;
    animation: glowPulse 6s ease-in-out infinite;
}

@@keyframes glowPulse {
    0%, 100% { opacity: 0.6; transform: translate(-50%, -50%) scale(1); }
    50%       { opacity: 1;   transform: translate(-50%, -50%) scale(1.08); }
}

/* ── SPLIT LAYOUT ── */
.register-split {
    position: relative; z-index: 1;
    display: grid;
    grid-template-columns: 380px 1fr;
    min-height: 100vh;
}

/* ── BRAND PANEL (LEFT) ── */
.brand-panel {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 40px;
    border-right: 1px solid #E1060030;
    overflow: hidden;
}

.brand-panel::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, #0f0000 0%, #0B0B0B 60%, #130000 100%);
}

.brand-panel__inner {
    position: relative; z-index: 1;
    text-align: center;
    width: 100%;
}

.brand-logo {
    display: flex; align-items: center; justify-content: center;
    width: 56px; height: 56px;
    margin: 0 auto 20px;
    border: 1.5px solid var(--red);
    background: var(--red-dim);
    clip-path: polygon(50% 0%, 100% 100%, 0% 100%);
    animation: fadeSlideUp 0.8s var(--ease-out) both;
}

.brand-logo__bull { font-size: 18px; color: var(--red); margin-top: 12px; }

.brand-name {
    font-family: var(--font-display);
    font-size: clamp(44px, 5vw, 68px);
    color: var(--white);
    letter-spacing: 0.06em;
    line-height: 1;
    animation: fadeSlideUp 0.8s 0.1s var(--ease-out) both;
}

.brand-tagline {
    font-family: var(--font-cond);
    font-size: 12px; font-weight: 600;
    letter-spacing: 0.35em;
    color: var(--red);
    text-transform: uppercase;
    margin-top: 5px;
    animation: fadeSlideUp 0.8s 0.15s var(--ease-out) both;
}

.brand-divider {
    width: 40px; height: 2px;
    background: var(--red);
    margin: 24px auto;
    animation: expandWidth 1s 0.4s var(--ease-out) both;
}

@@keyframes expandWidth {
    from { width: 0; opacity: 0; }
    to   { width: 40px; opacity: 1; }
}

.brand-copy {
    font-size: 15px; font-weight: 300;
    line-height: 1.7; color: var(--text-secondary);
    animation: fadeSlideUp 0.8s 0.25s var(--ease-out) both;
}

/* Step guide */
.steps-guide {
    margin-top: 40px;
    display: flex;
    flex-direction: column;
    gap: 0;
    text-align: left;
    animation: fadeSlideUp 0.8s 0.35s var(--ease-out) both;
}

.step-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 0;
    opacity: 0.4;
    transition: opacity 0.3s;
}

.step-item.active { opacity: 1; }
.step-item.done   { opacity: 0.7; }

.step-circle {
    width: 32px; height: 32px;
    border-radius: 50%;
    border: 1.5px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-cond);
    font-size: 13px; font-weight: 700;
    color: var(--text-muted);
    flex-shrink: 0;
    transition: border-color 0.3s, background 0.3s, color 0.3s;
}

.step-item.active .step-circle {
    border-color: var(--red);
    background: var(--red);
    color: var(--white);
}

.step-item.done .step-circle {
    border-color: var(--success);
    background: var(--success);
    color: var(--white);
}

.step-title {
    display: block;
    font-family: var(--font-cond);
    font-size: 13px; font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-primary);
}

.step-desc {
    display: block;
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 1px;
}

.step-connector {
    width: 1.5px; height: 20px;
    background: var(--border);
    margin-left: 15px;
}

/* Decorative wheel */
.deco-wheel {
    position: absolute;
    bottom: -80px; right: -80px;
    width: 280px; height: 280px;
    opacity: 0.3;
    animation: spinSlow 60s linear infinite;
}

@@keyframes spinSlow {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
}

/* ── FORM PANEL (RIGHT) ── */
.form-panel {
    display: flex;
    justify-content: center;
    padding: 60px 48px;
    overflow-y: auto;
}

.form-panel__inner {
    width: 100%;
    max-width: 540px;
    animation: fadeSlideUp 0.9s 0.2s var(--ease-out) both;
}

/* Form Header */
.form-header { margin-bottom: 36px; }

.form-header__eyebrow {
    font-family: var(--font-cond);
    font-size: 12px; font-weight: 600;
    letter-spacing: 0.35em;
    color: var(--red);
    text-transform: uppercase;
    margin-bottom: 8px;
}

.form-header__title {
    font-family: var(--font-display);
    font-size: 52px;
    color: var(--white);
    letter-spacing: 0.04em;
    line-height: 1;
}

.form-header__sub {
    font-size: 14px; font-weight: 300;
    color: var(--text-secondary);
    margin-top: 8px;
}

/* ── FORM SECTIONS ── */
.register-form { display: flex; flex-direction: column; gap: 28px; }

.form-section { display: flex; flex-direction: column; gap: 18px; }

.section-label {
    display: flex;
    align-items: center;
    gap: 12px;
}

.section-label__num {
    font-family: var(--font-display);
    font-size: 36px;
    color: var(--red);
    opacity: 0.25;
    line-height: 1;
    letter-spacing: 0.04em;
}

.section-label__text {
    font-family: var(--font-cond);
    font-size: 12px; font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--text-secondary);
}

.section-rule {
    height: 1px;
    background: linear-gradient(90deg, var(--red) 0%, transparent 100%);
    opacity: 0.2;
    margin: 4px 0;
}

/* ── FIELDS GRID ── */
.fields-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
}

.field-full  { grid-column: 1 / -1; }
.field-half  { grid-column: span 1; }

.field-group { display: flex; flex-direction: column; gap: 8px; }

.field-label {
    font-family: var(--font-cond);
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-secondary);
    transition: color 0.2s;
}

.field-group:focus-within .field-label { color: var(--red); }

.field-wrap { position: relative; }

.field-icon {
    position: absolute; left: 14px; top: 50%;
    transform: translateY(-50%);
    width: 15px; height: 15px;
    color: var(--text-muted);
    pointer-events: none;
    transition: color 0.2s;
}

.field-group:focus-within .field-icon { color: var(--red); }

.field-input {
    width: 100%; height: 50px;
    padding: 0 14px 0 42px;
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 14px; font-weight: 400;
    outline: none;
    transition: border-color 0.25s, background 0.25s, box-shadow 0.25s;
}

.field-input::placeholder { color: var(--text-muted); font-weight: 300; }

.field-input:focus {
    border-color: var(--red);
    background: #1E0A0A;
    box-shadow: 0 0 0 3px #E1060015, inset 0 1px 0 #E1060010;
}

.field-input:-webkit-autofill,
.field-input:-webkit-autofill:focus {
    -webkit-box-shadow: 0 0 0 1000px #1E0A0A inset !important;
    -webkit-text-fill-color: var(--text-primary) !important;
    border-color: var(--red) !important;
}

.field-line {
    position: absolute; bottom: 0; left: 0;
    width: 0; height: 2px;
    background: var(--red);
    border-radius: 0 0 4px 4px;
    transition: width 0.3s var(--ease-out);
}

.field-group:focus-within .field-line { width: 100%; }

/* Password toggle */
.toggle-password {
    position: absolute; right: 14px; top: 50%;
    transform: translateY(-50%);
    background: none; border: none; cursor: pointer;
    padding: 4px; color: var(--text-muted);
    display: flex; align-items: center;
    transition: color 0.2s;
}
.toggle-password:hover { color: var(--red); }
.eye-icon { width: 15px; height: 15px; }

/* Password strength */
.password-strength {
    display: flex; align-items: center; gap: 10px;
    margin-top: 6px;
    min-height: 14px;
}

.strength-bar {
    flex: 1; height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
}

.strength-fill {
    display: block; height: 100%; width: 0%;
    border-radius: 2px;
    transition: width 0.4s var(--ease-out), background 0.4s;
}

.strength-label {
    font-family: var(--font-cond);
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    min-width: 50px; text-align: right;
}

/* ── OTP SECTION ── */
.otp-input-wrap .field-input { padding-right: 110px; }

.btn-send-otp {
    position: absolute; right: 8px; top: 50%;
    transform: translateY(-50%);
    height: 34px; padding: 0 14px;
    background: var(--red);
    border: none; border-radius: 3px;
    font-family: var(--font-cond);
    font-size: 12px; font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--white);
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
}

.btn-send-otp:hover { background: var(--red-hover); }
.btn-send-otp:active { transform: translateY(-50%) scale(0.97); }
.btn-send-otp:disabled { background: var(--text-muted); cursor: not-allowed; }

/* OTP boxes */
.otp-boxes {
    display: flex; gap: 10px;
}

.otp-box {
    flex: 1; height: 56px;
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--white);
    font-family: var(--font-display);
    font-size: 28px;
    text-align: center;
    outline: none;
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    caret-color: var(--red);
}

.otp-box:focus {
    border-color: var(--red);
    background: #1E0A0A;
    box-shadow: 0 0 0 3px #E1060015;
}

.otp-box.filled {
    border-color: #E1060060;
    background: #1A0A0A;
}

.otp-hint {
    display: flex; align-items: center;
    justify-content: flex-end;
    gap: 10px;
    margin-top: 8px;
}

.otp-timer {
    font-family: var(--font-cond);
    font-size: 12px; font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.1em;
}

.otp-resend {
    background: none; border: none;
    font-family: var(--font-cond);
    font-size: 12px; font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--red);
    cursor: pointer;
    transition: color 0.2s;
}
.otp-resend:hover { color: var(--red-hover); }

/* ── REGISTER BUTTON ── */
.btn-register {
    position: relative;
    display: flex; align-items: center; justify-content: center;
    gap: 12px;
    width: 100%; height: 58px;
    margin-top: 8px;
    background: var(--red);
    border: none; border-radius: 4px;
    cursor: pointer; overflow: hidden;
    font-family: var(--font-cond);
    font-size: 16px; font-weight: 700;
    letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--white);
    transition: background 0.25s, transform 0.15s, box-shadow 0.25s;
}

.btn-register::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, #FF2A27 0%, #C00000 100%);
    opacity: 0; transition: opacity 0.25s;
}

.btn-register:hover {
    background: var(--red-hover);
    box-shadow: 0 8px 32px #E1060050, 0 2px 8px #E1060030;
    transform: translateY(-1px);
}
.btn-register:hover::before { opacity: 1; }
.btn-register:active { transform: translateY(0); box-shadow: 0 4px 16px #E1060040; }

.btn-register__text { position: relative; z-index: 1; }

.btn-register__arrow {
    position: relative; z-index: 1;
    display: flex; align-items: center;
    transition: transform 0.25s var(--ease-spring);
}
.btn-register__arrow svg { width: 18px; height: 18px; }
.btn-register:hover .btn-register__arrow { transform: translateX(4px); }

.btn-register__loader {
    display: none; position: absolute; right: 20px;
    width: 18px; height: 18px;
    border: 2px solid #ffffff40; border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
}
.btn-register.loading .btn-register__text,
.btn-register.loading .btn-register__arrow { opacity: 0; }
.btn-register.loading .btn-register__loader { display: block; }
.btn-register.loading { pointer-events: none; background: #9a0400; }

@@keyframes spin { to { transform: rotate(360deg); } }

/* ── FORM FOOTER ── */
.form-footer {
    text-align: center;
    font-size: 14px;
    color: var(--text-secondary);
    padding-top: 8px;
}

.form-footer__link {
    color: var(--red); font-weight: 600;
    text-decoration: none; margin-left: 6px;
    transition: color 0.2s;
}
.form-footer__link:hover { color: var(--red-hover); }

/* ── ANIMATIONS ── */
@@keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* ── RESPONSIVE ── */
@@media (max-width: 1024px) {
    .register-split { grid-template-columns: 300px 1fr; }
}

@@media (max-width: 820px) {
    .register-split { grid-template-columns: 1fr; }
    .brand-panel { display: none; }
    .form-panel { padding: 48px 24px; min-height: 100vh; }
    .form-panel__inner { max-width: 100%; }
}

@@media (max-width: 540px) {
    .fields-grid { grid-template-columns: 1fr; }
    .field-half  { grid-column: 1 / -1; }
    .form-header__title { font-size: 40px; }
    .form-panel { padding: 40px 20px; }
    .otp-boxes { gap: 6px; }
    .otp-box { height: 48px; font-size: 22px; }
}
</style>

<script>
(function () {

    /* ── Password toggle ── */
    const toggleBtn   = document.getElementById('togglePassword');
    const passwordInput = document.getElementById('password');
    const eyeIcon       = toggleBtn?.querySelector('.eye-icon');

    if (toggleBtn && passwordInput) {
        toggleBtn.addEventListener('click', function () {
            const show = passwordInput.type === 'password';
            passwordInput.type = show ? 'text' : 'password';
            eyeIcon.innerHTML = show
                ? `<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>`
                : `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`;
        });
    }

    /* ── Password strength ── */
    const strengthFill  = document.getElementById('strengthFill');
    const strengthLabel = document.getElementById('strengthLabel');

    function getStrength(pw) {
        let score = 0;
        if (pw.length >= 8)  score++;
        if (pw.length >= 12) score++;
        if (/[A-Z]/.test(pw)) score++;
        if (/[0-9]/.test(pw)) score++;
        if (/[^A-Za-z0-9]/.test(pw)) score++;
        return score;
    }

    if (passwordInput && strengthFill && strengthLabel) {
        passwordInput.addEventListener('input', function () {
            const score = getStrength(this.value);
            const levels = [
                { w: '0%',   color: 'transparent', label: '' },
                { w: '25%',  color: '#E10600',      label: 'Weak' },
                { w: '50%',  color: '#F97316',      label: 'Fair' },
                { w: '75%',  color: '#EAB308',      label: 'Good' },
                { w: '100%', color: '#22C55E',      label: 'Strong' },
            ];
            const lvl = levels[Math.min(score, 4)];
            strengthFill.style.width      = lvl.w;
            strengthFill.style.background = lvl.color;
            strengthLabel.textContent     = lvl.label;
            strengthLabel.style.color     = lvl.color;
        });
    }

    /* ── Send OTP button + countdown ── */
    const sendOtpBtn = document.getElementById('sendOtpBtn');
    const otpTimer   = document.getElementById('otpTimer');
    const resendOtp  = document.getElementById('resendOtp');
    let timerInterval;

    function startCountdown(seconds) {
        clearInterval(timerInterval);
        sendOtpBtn.disabled = true;
        resendOtp.style.display = 'none';
        let remaining = seconds;
        otpTimer.textContent = `Resend in ${remaining}s`;
        timerInterval = setInterval(function () {
            remaining--;
            if (remaining <= 0) {
                clearInterval(timerInterval);
                otpTimer.textContent = '';
                resendOtp.style.display = 'inline';
                sendOtpBtn.disabled = false;
            } else {
                otpTimer.textContent = `Resend in ${remaining}s`;
            }
        }, 1000);
    }

    if (sendOtpBtn) {
        sendOtpBtn.addEventListener('click', function () {
            const phone = document.getElementById('contactNumber').value;
            if (!phone) { document.getElementById('contactNumber').focus(); return; }
            startCountdown(60);
        });
    }

    if (resendOtp) {
        resendOtp.addEventListener('click', function () { startCountdown(60); });
    }

    /* ── OTP box auto-advance ── */
    const otpBoxes   = document.querySelectorAll('.otp-box');
    const otpHidden  = document.getElementById('otpCode');

    otpBoxes.forEach(function (box, i) {
        box.addEventListener('input', function () {
            this.value = this.value.replace(/[^0-9]/g, '').slice(-1);
            this.classList.toggle('filled', this.value !== '');
            if (this.value && i < otpBoxes.length - 1) {
                otpBoxes[i + 1].focus();
            }
            if (otpHidden) {
                otpHidden.value = Array.from(otpBoxes).map(b => b.value).join('');
            }
        });

        box.addEventListener('keydown', function (e) {
            if (e.key === 'Backspace' && !this.value && i > 0) {
                otpBoxes[i - 1].focus();
            }
        });

        box.addEventListener('paste', function (e) {
            e.preventDefault();
            const text = (e.clipboardData || window.clipboardData).getData('text').replace(/\D/g, '').slice(0, 6);
            text.split('').forEach(function (ch, idx) {
                if (otpBoxes[idx]) {
                    otpBoxes[idx].value = ch;
                    otpBoxes[idx].classList.add('filled');
                }
            });
            if (otpHidden) otpHidden.value = text;
            const next = otpBoxes[Math.min(text.length, otpBoxes.length - 1)];
            next?.focus();
        });
    });

    /* ── Side-panel step highlighter ── */
    const sections  = ['section-account', 'section-verify', 'section-address'];
    const stepItems = document.querySelectorAll('.step-item');

    function updateStep() {
        const scrollY = window.scrollY + window.innerHeight / 3;
        let active = 0;
        sections.forEach(function (id, idx) {
            const el = document.getElementById(id);
            if (el && el.getBoundingClientRect().top + window.scrollY <= scrollY) {
                active = idx;
            }
        });
        stepItems.forEach(function (item, idx) {
            item.classList.toggle('active', idx === active);
            item.classList.toggle('done',   idx < active);
        });
    }

    window.addEventListener('scroll', updateStep, { passive: true });

    /* ── Submit loading state ── */
    const registerForm = document.getElementById('registerForm');
    const registerBtn  = document.getElementById('registerBtn');

    if (registerForm && registerBtn) {
        registerForm.addEventListener('submit', function () {
            registerBtn.classList.add('loading');
        });
    }

})();
</script>

</body>
</html>