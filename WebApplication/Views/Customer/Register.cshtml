@{
    ViewData["Title"] = "Create Account";
}

<div class="register-page container">

    <div class="row justify-content-center">

        <div class="col-lg-6 col-md-8">

            <div class="register-card">

                <div class="text-center mb-4">
                    <h2 class="brand-title">Create Your Account</h2>
                    <p class="text-muted">Join Taurus Bike Shop and start browsing premium bikes.</p>
                </div>

                <form id="registerForm">

                    <!-- EMAIL -->
                    <div class="form-group mb-3">
                        <label>Email Address</label>
                        <input type="email" class="form-control" placeholder="example@email.com" required />
                    </div>

                    <!-- PASSWORD -->
                    <div class="form-group mb-3">
                        <label>Password</label>
                        <input type="password" class="form-control" placeholder="Enter password" required />
                    </div>

                    <!-- CONTACT NUMBER -->
                    <div class="form-group mb-3">
                        <label>Contact Number</label>
                        <input type="tel" class="form-control" placeholder="09XXXXXXXXX" required />
                    </div>

                    <!-- SEND OTP -->
                    <div class="otp-section">

                        <div class="d-grid mb-3">
                            <button type="button" class="btn btn-taurus">
                                Send OTP Verification
                            </button>
                        </div>

                        <div class="form-group mb-3">
                            <label>Enter OTP</label>
                            <input type="text" class="form-control" placeholder="Enter OTP code" />
                        </div>

                    </div>

                    <hr class="section-divider">

                    <!-- ADDRESS SECTION -->
                    <h5 class="section-title">Delivery Address</h5>

                    <div class="form-group mb-3">
                        <label>Street Address</label>
                        <input type="text" class="form-control" placeholder="House No / Street / Barangay" required />
                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label>City</label>
                            <input type="text" class="form-control" required />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Province</label>
                            <input type="text" class="form-control" required />
                        </div>

                    </div>

                    <div class="form-group mb-4">
                        <label>Postal Code</label>
                        <input type="text" class="form-control" required />
                    </div>

                    <!-- REGISTER BUTTON -->
                    <div class="d-grid">
                        <button type="submit" class="btn btn-taurus btn-lg">
                            Create Account
                        </button>
                    </div>

                    <div class="text-center mt-3">
                        <span class="text-muted">Already have an account?</span>
                        <a href="/Customer/Login" class="login-link">Login</a>
                    </div>

                </form>

            </div>

        </div>

    </div>

</div>