@* WebApplication/Views/Customer/Register.cshtml *@
@model WebApplication.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool showOTPModal = ViewBag.ShowOTPModal == true;
    string otpEmail   = ViewBag.OTPEmail ?? Model.Email ?? string.Empty;
}

<div class="min-h-[calc(100vh-160px)] flex items-center justify-center py-16 px-6 bg-light-gray dark:bg-midnight">
    <div class="w-full max-w-2xl">

        <div class="cal-card-static p-8 md:p-10">

            @* Header *@
            <div class="text-center mb-8">
                <a asp-controller="Home" asp-action="Index" class="inline-block mb-6">
                    <img src="~/FULL-COLOR.png" alt="Taurus Bike Shop" class="h-10 w-auto mx-auto" />
                </a>
                <h1 class="font-display text-2xl font-semibold text-charcoal dark:text-white">Create Account</h1>
                <p class="text-sm text-mid-gray mt-1">Join Taurus Bike Shop</p>
            </div>

            @* Validation summary *@
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="mb-6 p-3 bg-error/10 border border-error/20 rounded-lg text-sm text-error" role="alert">
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <form asp-action="Register" asp-controller="Customer" method="post" novalidate>
                @Html.AntiForgeryToken()

                @* Personal Info *@
                <fieldset class="mb-8">
                    <legend class="font-display text-base font-semibold text-charcoal dark:text-white mb-4" style="letter-spacing:0.2px">Personal Information</legend>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="FirstName" class="cal-label">First Name</label>
                            <input asp-for="FirstName" class="cal-input" autocomplete="given-name" placeholder="Juan" />
                            <span asp-validation-for="FirstName" class="cal-field-error"></span>
                        </div>
                        <div>
                            <label asp-for="LastName" class="cal-label">Last Name</label>
                            <input asp-for="LastName" class="cal-input" autocomplete="family-name" placeholder="Dela Cruz" />
                            <span asp-validation-for="LastName" class="cal-field-error"></span>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
                        <div>
                            <label asp-for="Email" class="cal-label">Email Address</label>
                            <input asp-for="Email" class="cal-input" type="email" autocomplete="email" placeholder="you@example.com" />
                            <span asp-validation-for="Email" class="cal-field-error"></span>
                        </div>
                        <div>
                            <label asp-for="PhoneNumber" class="cal-label">Phone Number</label>
                            <input asp-for="PhoneNumber" class="cal-input" type="tel" autocomplete="tel" placeholder="09XXXXXXXXX" />
                            <span asp-validation-for="PhoneNumber" class="cal-field-error"></span>
                        </div>
                    </div>
                </fieldset>

                @* Address *@
                <fieldset class="mb-8">
                    <legend class="font-display text-base font-semibold text-charcoal dark:text-white mb-4" style="letter-spacing:0.2px">Default Shipping Address</legend>
                    <div class="mb-4">
                        <label asp-for="Street" class="cal-label">Street Address</label>
                        <input asp-for="Street" class="cal-input" autocomplete="street-address" placeholder="House no., Street, Barangay" />
                        <span asp-validation-for="Street" class="cal-field-error"></span>
                    </div>
                    <div class="grid grid-cols-2 sm:grid-cols-[1fr_100px_1fr] gap-4">
                        <div class="col-span-2 sm:col-span-1">
                            <label asp-for="City" class="cal-label">City / Municipality</label>
                            <input asp-for="City" class="cal-input" autocomplete="address-level2" placeholder="Manila" />
                            <span asp-validation-for="City" class="cal-field-error"></span>
                        </div>
                        <div>
                            <label asp-for="PostalCode" class="cal-label">Postal Code</label>
                            <input asp-for="PostalCode" class="cal-input" autocomplete="postal-code" placeholder="1000" maxlength="4" />
                            <span asp-validation-for="PostalCode" class="cal-field-error"></span>
                        </div>
                        <div>
                            <label asp-for="Province" class="cal-label">Province <span class="cal-label-opt">(optional)</span></label>
                            <input asp-for="Province" class="cal-input" autocomplete="address-level1" placeholder="Metro Manila" />
                        </div>
                    </div>
                </fieldset>

                @* Password *@
                <fieldset class="mb-8">
                    <legend class="font-display text-base font-semibold text-charcoal dark:text-white mb-4" style="letter-spacing:0.2px">Password</legend>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="Password" class="cal-label">Password</label>
                            <input asp-for="Password" class="cal-input" type="password" autocomplete="new-password" placeholder="Minimum 8 characters" />
                            <span asp-validation-for="Password" class="cal-field-error"></span>
                        </div>
                        <div>
                            <label asp-for="ConfirmPassword" class="cal-label">Confirm Password</label>
                            <input asp-for="ConfirmPassword" class="cal-input" type="password" autocomplete="new-password" placeholder="Repeat your password" />
                            <span asp-validation-for="ConfirmPassword" class="cal-field-error"></span>
                        </div>
                    </div>
                </fieldset>

                <button type="submit" class="btn-dark btn-full">
                    Create Account &amp; Verify Email
                </button>
            </form>

            <p class="text-center text-sm text-mid-gray mt-6">
                Already have an account?
                <a asp-action="Login" asp-controller="Customer"
                   class="font-medium text-charcoal hover:underline dark:text-white">Sign in</a>
            </p>

        </div>
    </div>
</div>

@* OTP Modal — shown after successful POST *@
@if (showOTPModal)
{
    @await Html.PartialAsync("~/Views/Customer/Partials/_OTPModal.cshtml", otpEmail)
}

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    @if (showOTPModal)
    {
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                openModal('otpModal');

                const codeInput = document.getElementById('otp-code-input');
                if (codeInput) codeInput.focus();

                const countdownEl = document.getElementById('otp-countdown');
                const resendBtn   = document.getElementById('otp-resend-btn');
                if (!countdownEl) return;

                let seconds = 10 * 60;
                const interval = setInterval(() => {
                    seconds--;
                    const m = Math.floor(seconds / 60).toString().padStart(2, '0');
                    const s = (seconds % 60).toString().padStart(2, '0');
                    countdownEl.textContent = `${m}:${s}`;
                    if (seconds <= 0) {
                        clearInterval(interval);
                        countdownEl.textContent = '00:00';
                        countdownEl.style.color = '#ef4444';
                        if (resendBtn) resendBtn.disabled = false;
                    }
                }, 1000);

                setTimeout(() => { if (resendBtn) resendBtn.disabled = false; }, 60000);

                resendBtn?.addEventListener('click', async () => {
                    const email = document.querySelector('input[name="email"]')?.value;
                    if (!email) return;
                    resendBtn.disabled = true;
                    resendBtn.textContent = 'Sending\u2026';
                    try {
                        const response = await fetchWithCSRF('/Customer/ResendOTP', {
                            method: 'POST',
                            body: JSON.stringify({ email })
                        });
                        const data = await parseJsonResponse(response);
                        if (data.success) seconds = 10 * 60;
                        else resendBtn.disabled = false;
                    } catch { resendBtn.disabled = false; }
                    finally { resendBtn.textContent = 'Resend Code'; }
                });
            });
        </script>
    }
}
