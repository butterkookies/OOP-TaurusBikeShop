@* WebApplication/Views/Customer/Register.cshtml *@
@model WebApplication.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool showOTPModal = ViewBag.ShowOTPModal == true;
    string otpEmail   = ViewBag.OTPEmail ?? Model.Email ?? string.Empty;
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/register.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/otp-modal.css" asp-append-version="true" />
}

<div class="tbs-auth-page tbs-auth-page--register">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-10 col-lg-8 col-xl-7">

                <div class="tbs-auth-card tbs-auth-card--wide">

                    <div class="tbs-auth-card__header">
                        <div class="tbs-auth-card__logo" aria-hidden="true">&#9651;</div>
                        <h1 class="tbs-auth-card__title">Create Account</h1>
                        <p class="tbs-auth-card__subtitle">Join Taurus Bike Shop</p>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="tbs-auth-card__error" role="alert">
                            <asp-validation-summary asp-validation-group="" />
                        </div>
                    }

                    <form asp-action="Register" asp-controller="Customer" method="post"
                          class="tbs-auth-form tbs-register-form" novalidate>
                        @Html.AntiForgeryToken()

                        @* Personal Info *@
                        <fieldset class="tbs-register-form__section">
                            <legend class="tbs-register-form__legend">Personal Information</legend>
                            <div class="row g-3">
                                <div class="col-6">
                                    <div class="tbs-form-group">
                                        <label asp-for="FirstName" class="tbs-label">First Name</label>
                                        <input asp-for="FirstName" class="tbs-input" autocomplete="given-name" placeholder="Juan" />
                                        <span asp-validation-for="FirstName" class="tbs-field-error"></span>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="tbs-form-group">
                                        <label asp-for="LastName" class="tbs-label">Last Name</label>
                                        <input asp-for="LastName" class="tbs-input" autocomplete="family-name" placeholder="Dela Cruz" />
                                        <span asp-validation-for="LastName" class="tbs-field-error"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="row g-3">
                                <div class="col-12 col-sm-6">
                                    <div class="tbs-form-group">
                                        <label asp-for="Email" class="tbs-label">Email Address</label>
                                        <input asp-for="Email" class="tbs-input" type="email" autocomplete="email" placeholder="you@example.com" />
                                        <span asp-validation-for="Email" class="tbs-field-error"></span>
                                    </div>
                                </div>
                                <div class="col-12 col-sm-6">
                                    <div class="tbs-form-group">
                                        <label asp-for="PhoneNumber" class="tbs-label">Phone Number</label>
                                        <input asp-for="PhoneNumber" class="tbs-input" type="tel" autocomplete="tel" placeholder="09XXXXXXXXX" />
                                        <span asp-validation-for="PhoneNumber" class="tbs-field-error"></span>
                                    </div>
                                </div>
                            </div>
                        </fieldset>

                        @* Address *@
                        <fieldset class="tbs-register-form__section">
                            <legend class="tbs-register-form__legend">Default Shipping Address</legend>
                            <div class="tbs-form-group">
                                <label asp-for="Street" class="tbs-label">Street Address</label>
                                <input asp-for="Street" class="tbs-input" autocomplete="street-address" placeholder="House no., Street, Barangay" />
                                <span asp-validation-for="Street" class="tbs-field-error"></span>
                            </div>
                            <div class="row g-3">
                                <div class="col-12 col-sm-5">
                                    <div class="tbs-form-group">
                                        <label asp-for="City" class="tbs-label">City / Municipality</label>
                                        <input asp-for="City" class="tbs-input" autocomplete="address-level2" placeholder="Manila" />
                                        <span asp-validation-for="City" class="tbs-field-error"></span>
                                    </div>
                                </div>
                                <div class="col-6 col-sm-3">
                                    <div class="tbs-form-group">
                                        <label asp-for="PostalCode" class="tbs-label">Postal Code</label>
                                        <input asp-for="PostalCode" class="tbs-input" autocomplete="postal-code" placeholder="1000" maxlength="4" />
                                        <span asp-validation-for="PostalCode" class="tbs-field-error"></span>
                                    </div>
                                </div>
                                <div class="col-6 col-sm-4">
                                    <div class="tbs-form-group">
                                        <label asp-for="Province" class="tbs-label">Province <span class="tbs-label__optional">(optional)</span></label>
                                        <input asp-for="Province" class="tbs-input" autocomplete="address-level1" placeholder="Metro Manila" />
                                    </div>
                                </div>
                            </div>
                        </fieldset>

                        @* Password *@
                        <fieldset class="tbs-register-form__section">
                            <legend class="tbs-register-form__legend">Password</legend>
                            <div class="row g-3">
                                <div class="col-12 col-sm-6">
                                    <div class="tbs-form-group">
                                        <label asp-for="Password" class="tbs-label">Password</label>
                                        <input asp-for="Password" class="tbs-input" type="password" autocomplete="new-password" placeholder="Minimum 8 characters" />
                                        <span asp-validation-for="Password" class="tbs-field-error"></span>
                                    </div>
                                </div>
                                <div class="col-12 col-sm-6">
                                    <div class="tbs-form-group">
                                        <label asp-for="ConfirmPassword" class="tbs-label">Confirm Password</label>
                                        <input asp-for="ConfirmPassword" class="tbs-input" type="password" autocomplete="new-password" placeholder="Repeat your password" />
                                        <span asp-validation-for="ConfirmPassword" class="tbs-field-error"></span>
                                    </div>
                                </div>
                            </div>
                        </fieldset>

                        <button type="submit" class="btn tbs-btn-accent tbs-btn-full">
                            Create Account &amp; Verify Email
                        </button>

                    </form>

                    <div class="tbs-auth-card__footer">
                        Already have an account?
                        <a asp-action="Login" asp-controller="Customer">Sign in</a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@* OTP Modal — shown after successful POST *@
@if (showOTPModal)
{
    @await Html.PartialAsync("~/Views/Customer/Partials/_OTPModal.cshtml", otpEmail)
}

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    @if (showOTPModal)
    {
        <script>
            // Auto-open the OTP modal when the page loads after a successful registration POST
            document.addEventListener('DOMContentLoaded', () => {
                const otpModal = document.getElementById('otpModal');
                if (otpModal) {
                    const modal = new bootstrap.Modal(otpModal, { backdrop: 'static', keyboard: false });
                    modal.show();
                }
            });
        </script>
    }
}
