@* WebApplication/Views/Customer/Profile.cshtml *@
@model WebApplication.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Profile";
    bool reopenAddressModal = TempData["ReopenAddressModal"] is true;
    string? addressFormJson = TempData["AddressForm"] as string;
}

@Html.AntiForgeryToken()

<div class="bg-light-gray dark:bg-midnight min-h-[calc(100vh-160px)]">
    <div class="max-w-[800px] mx-auto px-6 py-12 md:py-16">

        <h1 class="font-display text-3xl font-semibold text-charcoal dark:text-white mb-10" data-reveal>Profile Settings</h1>

        @* ── Account Info ── *@
        <div class="cal-card-static p-6 mb-6" data-reveal="delay-1">
            <h2 class="font-display text-lg font-semibold text-charcoal dark:text-white mb-5" style="letter-spacing:0.2px">Account Information</h2>

            <form asp-action="Profile" asp-controller="Customer" method="post" novalidate>
                @Html.AntiForgeryToken()

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                    <div>
                        <label asp-for="FirstName" class="cal-label">First Name</label>
                        <input asp-for="FirstName" class="cal-input" autocomplete="given-name"
                               aria-invalid="@(ViewData.ModelState["FirstName"]?.Errors.Count > 0 ? "true" : "false")"
                               aria-describedby="FirstName-error" />
                        <span asp-validation-for="FirstName" id="FirstName-error" role="alert" class="cal-field-error"></span>
                    </div>
                    <div>
                        <label asp-for="LastName" class="cal-label">Last Name</label>
                        <input asp-for="LastName" class="cal-input" autocomplete="family-name"
                               aria-invalid="@(ViewData.ModelState["LastName"]?.Errors.Count > 0 ? "true" : "false")"
                               aria-describedby="LastName-error" />
                        <span asp-validation-for="LastName" id="LastName-error" role="alert" class="cal-field-error"></span>
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                    <div>
                        <label asp-for="Email" class="cal-label">Email</label>
                        <input asp-for="Email" class="cal-input cal-input-readonly" readonly aria-readonly="true" autocomplete="email" />
                    </div>
                    <div>
                        <label asp-for="PhoneNumber" class="cal-label">Phone Number</label>
                        <input asp-for="PhoneNumber" class="cal-input" type="tel" autocomplete="tel"
                               aria-invalid="@(ViewData.ModelState["PhoneNumber"]?.Errors.Count > 0 ? "true" : "false")"
                               aria-describedby="PhoneNumber-error" />
                        <span asp-validation-for="PhoneNumber" id="PhoneNumber-error" role="alert" class="cal-field-error"></span>
                    </div>
                </div>

                <button type="submit" class="btn-dark btn-sm mt-2">Save Changes</button>
            </form>
        </div>

        @* ── Change Password (collapsed by default — isolated from address UI) ── *@
        <div class="cal-card-static p-6 mb-6" data-reveal="delay-2">
            <div class="flex items-center justify-between">
                <h2 class="font-display text-lg font-semibold text-charcoal dark:text-white" style="letter-spacing:0.2px">Change Password</h2>
                <button type="button" id="toggle-password-form" class="btn-ghost btn-sm"
                        onclick="document.getElementById('password-form-section').toggleAttribute('hidden'); this.textContent = document.getElementById('password-form-section').hidden ? 'Change' : 'Cancel';">
                    Change
                </button>
            </div>

            <div id="password-form-section" hidden>
                <form asp-action="ChangePassword" asp-controller="Customer" method="post" novalidate class="mt-5">
                    @Html.AntiForgeryToken()

                    <div class="space-y-4 max-w-sm">
                        <div>
                            <label asp-for="ChangePassword.CurrentPassword" class="cal-label">Current Password</label>
                            <input asp-for="ChangePassword.CurrentPassword" class="cal-input" type="password" autocomplete="current-password"
                                   aria-invalid="@(ViewData.ModelState["ChangePassword.CurrentPassword"]?.Errors.Count > 0 ? "true" : "false")"
                                   aria-describedby="CurrentPassword-error" />
                            <span asp-validation-for="ChangePassword.CurrentPassword" id="CurrentPassword-error" role="alert" class="cal-field-error"></span>
                        </div>
                        <div>
                            <label asp-for="ChangePassword.NewPassword" class="cal-label">New Password</label>
                            <input asp-for="ChangePassword.NewPassword" class="cal-input" type="password" autocomplete="new-password"
                                   aria-invalid="@(ViewData.ModelState["ChangePassword.NewPassword"]?.Errors.Count > 0 ? "true" : "false")"
                                   aria-describedby="NewPassword-error" />
                            <span asp-validation-for="ChangePassword.NewPassword" id="NewPassword-error" role="alert" class="cal-field-error"></span>
                        </div>
                        <div>
                            <label asp-for="ChangePassword.ConfirmNewPassword" class="cal-label">Confirm New Password</label>
                            <input asp-for="ChangePassword.ConfirmNewPassword" class="cal-input" type="password" autocomplete="new-password"
                                   aria-invalid="@(ViewData.ModelState["ChangePassword.ConfirmNewPassword"]?.Errors.Count > 0 ? "true" : "false")"
                                   aria-describedby="ConfirmNewPassword-error" />
                            <span asp-validation-for="ChangePassword.ConfirmNewPassword" id="ConfirmNewPassword-error" role="alert" class="cal-field-error"></span>
                        </div>
                    </div>
                    <button type="submit" class="btn-dark btn-sm mt-4">Update Password</button>
                </form>
            </div>
        </div>

        @* ── Shipping Addresses ── *@
        <div class="cal-card-static p-6" data-reveal="delay-3">
            <div class="flex items-center justify-between mb-5">
                <h2 class="font-display text-lg font-semibold text-charcoal dark:text-white" style="letter-spacing:0.2px">Shipping Addresses</h2>
                <button type="button" class="btn-dark btn-sm" onclick="openModal('add-address-modal')">
                    + Add Address
                </button>
            </div>

            @if (Model.SavedAddresses != null && Model.SavedAddresses.Any())
            {
                <div class="space-y-3">
                    @foreach (var addr in Model.SavedAddresses)
                    {
                        <div class="flex items-start gap-4 p-4 border border-border-ring dark:border-white/10 rounded-xl">
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-medium text-charcoal dark:text-white">
                                    @addr.Label
                                    @if (addr.IsDefault)
                                    {
                                        <span class="cal-badge cal-badge-dark ml-2">Default</span>
                                    }
                                </p>
                                <p class="text-xs text-mid-gray mt-1">
                                    @addr.Street, @addr.City@(!string.IsNullOrEmpty(addr.Province) ? $", {addr.Province}" : "") — @addr.PostalCode
                                </p>
                            </div>
                            <div class="flex gap-2 shrink-0">
                                @if (!addr.IsDefault)
                                {
                                    <form asp-action="SetDefaultAddress" asp-controller="Customer" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="addressId" value="@addr.AddressId" />
                                        <button type="submit" class="text-xs text-mid-gray hover:text-charcoal transition-colors dark:hover:text-white">Set Default</button>
                                    </form>
                                }
                                <form asp-action="DeleteAddress" asp-controller="Customer" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="addressId" value="@addr.AddressId" />
                                    <button type="submit" class="text-xs text-error hover:text-red-700 transition-colors">Delete</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-sm text-mid-gray text-center py-6">No shipping addresses saved yet.</p>
            }
        </div>

    </div>
</div>

@* ── Add Address Modal ── *@
<div id="add-address-modal" class="cal-modal-backdrop fixed inset-0 z-50 bg-black/40 flex items-center justify-center p-4" hidden>
    <div class="cal-card-static rounded-2xl w-full max-w-lg p-6" @* stop click propagation *@ onclick="event.stopPropagation()">
        <div class="flex items-center justify-between mb-5">
            <h2 class="font-display text-lg font-semibold text-charcoal dark:text-white">Add New Address</h2>
            <button type="button" onclick="closeModal('add-address-modal')"
                    class="w-8 h-8 flex items-center justify-center rounded-lg text-mid-gray hover:text-charcoal transition-colors dark:hover:text-white"
                    aria-label="Close">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>

        <form asp-action="AddAddress" asp-controller="Customer" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div class="space-y-4">
                <div>
                    <label class="cal-label" for="NewAddress_Label">Label</label>
                    <select name="NewAddress.Label" id="NewAddress_Label" class="cal-input"
                            aria-invalid="@(ViewData.ModelState["NewAddress.Label"]?.Errors.Count > 0 ? "true" : "false")"
                            aria-describedby="NewAddress_Label-error">
                        <option value="Home">Home</option>
                        <option value="Work">Work</option>
                        <option value="Other">Other</option>
                    </select>
                    <span asp-validation-for="NewAddress.Label" id="NewAddress_Label-error" role="alert" class="cal-field-error"></span>
                </div>
                <div>
                    <label class="cal-label" for="NewAddress_Street">Street Address</label>
                    <input type="text" name="NewAddress.Street" id="NewAddress_Street" class="cal-input" required placeholder="e.g. 123 Rizal Ave"
                           autocomplete="street-address"
                           aria-invalid="@(ViewData.ModelState["NewAddress.Street"]?.Errors.Count > 0 ? "true" : "false")"
                           aria-describedby="NewAddress_Street-error" />
                    <span asp-validation-for="NewAddress.Street" id="NewAddress_Street-error" role="alert" class="cal-field-error"></span>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="cal-label" for="NewAddress_City">City</label>
                        <input type="text" name="NewAddress.City" id="NewAddress_City" class="cal-input" required placeholder="e.g. Quezon City"
                               autocomplete="address-level2"
                               aria-invalid="@(ViewData.ModelState["NewAddress.City"]?.Errors.Count > 0 ? "true" : "false")"
                               aria-describedby="NewAddress_City-error" />
                        <span asp-validation-for="NewAddress.City" id="NewAddress_City-error" role="alert" class="cal-field-error"></span>
                    </div>
                    <div>
                        <label class="cal-label" for="NewAddress_Province">Province</label>
                        <input type="text" name="NewAddress.Province" id="NewAddress_Province" class="cal-input" placeholder="e.g. Metro Manila"
                               autocomplete="address-level1"
                               aria-invalid="@(ViewData.ModelState["NewAddress.Province"]?.Errors.Count > 0 ? "true" : "false")" />
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="cal-label" for="NewAddress_PostalCode">Postal Code</label>
                        <input type="text" name="NewAddress.PostalCode" id="NewAddress_PostalCode" class="cal-input" required
                               placeholder="e.g. 1100" maxlength="4" pattern="\d{4}" inputmode="numeric"
                               autocomplete="postal-code"
                               aria-invalid="@(ViewData.ModelState["NewAddress.PostalCode"]?.Errors.Count > 0 ? "true" : "false")"
                               aria-describedby="NewAddress_PostalCode-hint NewAddress_PostalCode-error"
                               oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 4)" />
                        <span id="NewAddress_PostalCode-hint" class="sr-only">4-digit Philippine postal code</span>
                        <span asp-validation-for="NewAddress.PostalCode" id="NewAddress_PostalCode-error" role="alert" class="cal-field-error"></span>
                    </div>
                    <div>
                        <label class="cal-label" for="NewAddress_Country">Country</label>
                        <input type="text" name="NewAddress.Country" id="NewAddress_Country" class="cal-input" value="Philippines" readonly aria-readonly="true" autocomplete="country-name" />
                    </div>
                </div>
            </div>

            <div class="flex gap-3 mt-6">
                <button type="submit" class="btn-dark btn-sm">Save Address</button>
                <button type="button" class="btn-ghost btn-sm" onclick="closeModal('add-address-modal')">Cancel</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/js/customer.js" asp-append-version="true"></script>
    @if (reopenAddressModal)
    {
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                openModal('add-address-modal');
                @if (addressFormJson != null)
                {
                    <text>
                    const data = @Html.Raw(addressFormJson);
                    if (data.Label)      document.getElementById('NewAddress_Label').value = data.Label;
                    if (data.Street)     document.getElementById('NewAddress_Street').value = data.Street;
                    if (data.City)       document.getElementById('NewAddress_City').value = data.City;
                    if (data.Province)   document.getElementById('NewAddress_Province').value = data.Province;
                    if (data.PostalCode) document.getElementById('NewAddress_PostalCode').value = data.PostalCode;
                    </text>
                }
            });
        </script>
    }
}
