@* WebApplication/Views/Customer/Profile.cshtml *@
@model WebApplication.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Profile";
}

@Html.AntiForgeryToken()

<div class="bg-light-gray dark:bg-midnight min-h-[calc(100vh-160px)]">
    <div class="max-w-[800px] mx-auto px-6 py-12 md:py-16">

        <h1 class="font-display text-3xl font-semibold text-charcoal dark:text-white mb-10" data-reveal>Profile Settings</h1>

        @* ── Account Info ── *@
        <div class="cal-card-static p-6 mb-6" data-reveal="delay-1">
            <h2 class="font-display text-lg font-semibold text-charcoal dark:text-white mb-5" style="letter-spacing:0.2px">Account Information</h2>

            <form asp-action="UpdateProfile" asp-controller="Customer" method="post" novalidate>
                @Html.AntiForgeryToken()

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                    <div>
                        <label asp-for="FirstName" class="cal-label">First Name</label>
                        <input asp-for="FirstName" class="cal-input" autocomplete="given-name" />
                        <span asp-validation-for="FirstName" class="cal-field-error"></span>
                    </div>
                    <div>
                        <label asp-for="LastName" class="cal-label">Last Name</label>
                        <input asp-for="LastName" class="cal-input" autocomplete="family-name" />
                        <span asp-validation-for="LastName" class="cal-field-error"></span>
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                    <div>
                        <label asp-for="Email" class="cal-label">Email</label>
                        <input asp-for="Email" class="cal-input cal-input-readonly" readonly />
                    </div>
                    <div>
                        <label asp-for="PhoneNumber" class="cal-label">Phone Number</label>
                        <input asp-for="PhoneNumber" class="cal-input" type="tel" autocomplete="tel" />
                        <span asp-validation-for="PhoneNumber" class="cal-field-error"></span>
                    </div>
                </div>

                <button type="submit" class="btn-dark btn-sm mt-2">Save Changes</button>
            </form>
        </div>

        @* ── Change Password ── *@
        <div class="cal-card-static p-6 mb-6" data-reveal="delay-2">
            <h2 class="font-display text-lg font-semibold text-charcoal dark:text-white mb-5" style="letter-spacing:0.2px">Change Password</h2>

            <form asp-action="ChangePassword" asp-controller="Customer" method="post" novalidate>
                @Html.AntiForgeryToken()

                <div class="space-y-4 max-w-sm">
                    <div>
                        <label asp-for="ChangePassword.CurrentPassword" class="cal-label">Current Password</label>
                        <input asp-for="ChangePassword.CurrentPassword" class="cal-input" type="password" autocomplete="current-password" />
                        <span asp-validation-for="ChangePassword.CurrentPassword" class="cal-field-error"></span>
                    </div>
                    <div>
                        <label asp-for="ChangePassword.NewPassword" class="cal-label">New Password</label>
                        <input asp-for="ChangePassword.NewPassword" class="cal-input" type="password" autocomplete="new-password" />
                        <span asp-validation-for="ChangePassword.NewPassword" class="cal-field-error"></span>
                    </div>
                    <div>
                        <label asp-for="ChangePassword.ConfirmNewPassword" class="cal-label">Confirm New Password</label>
                        <input asp-for="ChangePassword.ConfirmNewPassword" class="cal-input" type="password" autocomplete="new-password" />
                        <span asp-validation-for="ChangePassword.ConfirmNewPassword" class="cal-field-error"></span>
                    </div>
                </div>
                <button type="submit" class="btn-dark btn-sm mt-4">Update Password</button>
            </form>
        </div>

        @* ── Shipping Addresses ── *@
        <div class="cal-card-static p-6" data-reveal="delay-3">
            <div class="flex items-center justify-between mb-5">
                <h2 class="font-display text-lg font-semibold text-charcoal dark:text-white" style="letter-spacing:0.2px">Shipping Addresses</h2>
                <button type="button" class="btn-dark btn-sm" onclick="openModal('add-address-modal')">
                    + Add Address
                </button>
            </div>

            @if (Model.SavedAddresses != null && Model.SavedAddresses.Any())
            {
                <div class="space-y-3">
                    @foreach (var addr in Model.SavedAddresses)
                    {
                        <div class="flex items-start gap-4 p-4 border border-border-ring dark:border-white/10 rounded-xl">
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-medium text-charcoal dark:text-white">
                                    @addr.Label
                                    @if (addr.IsDefault)
                                    {
                                        <span class="cal-badge cal-badge-dark ml-2">Default</span>
                                    }
                                </p>
                                <p class="text-xs text-mid-gray mt-1">
                                    @addr.Street, @addr.City@(!string.IsNullOrEmpty(addr.Province) ? $", {addr.Province}" : "") — @addr.PostalCode
                                </p>
                            </div>
                            <div class="flex gap-2 shrink-0">
                                @if (!addr.IsDefault)
                                {
                                    <form asp-action="SetDefaultAddress" asp-controller="Customer" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="addressId" value="@addr.AddressId" />
                                        <button type="submit" class="text-xs text-mid-gray hover:text-charcoal transition-colors dark:hover:text-white">Set Default</button>
                                    </form>
                                }
                                <form asp-action="DeleteAddress" asp-controller="Customer" method="post" class="inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="addressId" value="@addr.AddressId" />
                                    <button type="submit" class="text-xs text-error hover:text-red-700 transition-colors">Delete</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-sm text-mid-gray text-center py-6">No shipping addresses saved yet.</p>
            }
        </div>

    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/js/customer.js" asp-append-version="true"></script>
}
