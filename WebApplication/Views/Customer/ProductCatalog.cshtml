@* ── External stylesheet — no embedded <style> block needed ── *@
<link rel="stylesheet" href="~/css/product-catalog.css" asp-append-version="true" />

@* ══════════════════════════════════════════════════════
   HERO BANNER
══════════════════════════════════════════════════════ *@
<div class="catalog-page">

    <div class="catalog-hero">
        <div class="catalog-hero__glow"></div>
        <div class="container">
            <p class="catalog-hero__eyebrow">Taurus Bike Shop</p>
            <h1 class="catalog-hero__title">PARTS &amp; <span>BIKES</span></h1>
            <p class="catalog-hero__sub">@products.Length premium products — frames, forks, drivetrain, tires &amp; more.</p>
        </div>
    </div>

    <div class="container">

        @* ══════════════════════════════════════════════════════
           TOOLBAR — live search + part-type dropdown + sort
        ══════════════════════════════════════════════════════ *@
        <div class="catalog-toolbar">

            <div class="toolbar-search">
                <svg class="toolbar-search__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <input type="text" class="toolbar-search__input" id="catalogSearch"
                       placeholder="Search products, brands..." autocomplete="off">
            </div>

            <select class="toolbar-part-select" id="partTypeSelect">
                <option value="all">All Part Types</option>
                <option value="Complete Bike">Complete Bike</option>
                <option value="Frame">Frame</option>
                <option value="Fork">Fork</option>
                <option value="Hubs">Hubs</option>
                <option value="Upgrade Kit">Upgrade Kit</option>
                <option value="Stem">Stem</option>
                <option value="Handlebar">Handlebar</option>
                <option value="Saddle">Saddle</option>
                <option value="Handle Grip">Handle Grip</option>
                <option value="Pedals">Pedals</option>
                <option value="Rims / Wheelset">Rims / Wheelset</option>
                <option value="Tires / Tubes">Tires / Tubes</option>
                <option value="Chain">Chain</option>
            </select>

            <select class="toolbar-sort" id="catalogSort">
                <option value="default">Sort: Default</option>
                <option value="price-asc">Price: Low to High</option>
                <option value="price-desc">Price: High to Low</option>
                <option value="name-asc">Name: A to Z</option>
            </select>

            <div class="toolbar-count">
                Showing <span id="countNum">0</span> products
            </div>
        </div>

        @* ══════════════════════════════════════════════════════
           CATEGORY FILTER TABS
           data-cat must match the Category field on each product.
        ══════════════════════════════════════════════════════ *@
        <div class="catalog-filter-tabs">
            <button class="filter-tab active" data-cat="all">
                All Types <span class="filter-tab__count" id="cnt-all">0</span>
            </button>
            <button class="filter-tab" data-cat="mountain">
                Mountain <span class="filter-tab__count" id="cnt-mountain">0</span>
            </button>
            <button class="filter-tab" data-cat="road">
                Road <span class="filter-tab__count" id="cnt-road">0</span>
            </button>
            <button class="filter-tab" data-cat="fixie">
                Fixie <span class="filter-tab__count" id="cnt-fixie">0</span>
            </button>
            <button class="filter-tab" data-cat="kids">
                Kids <span class="filter-tab__count" id="cnt-kids">0</span>
            </button>
            <button class="filter-tab" data-cat="others">
                Others <span class="filter-tab__count" id="cnt-others">0</span>
            </button>
        </div>

        @* ══════════════════════════════════════════════════════
           PRODUCT GRID
        ══════════════════════════════════════════════════════ *@
        <div class="catalog-grid" id="catalogGrid">

            @foreach (var p in products)
            {
                var badgeColor = p.PartType switch {
                    "Complete Bike"    => "var(--c-unit)",
                    "Frame"            => "var(--c-frame)",
                    "Fork"             => "var(--c-fork)",
                    "Hubs"             => "var(--c-hubs)",
                    "Upgrade Kit"      => "var(--c-upkit)",
                    "Stem"             => "var(--c-stem)",
                    "Handlebar"        => "var(--c-bar)",
                    "Saddle"           => "var(--c-saddle)",
                    "Handle Grip"      => "var(--c-grip)",
                    "Pedals"           => "var(--c-pedals)",
                    "Rims / Wheelset"  => "var(--c-rims)",
                    "Tires / Tubes"    => "var(--c-tires)",
                    "Chain"            => "var(--c-chain)",
                    _                  => "var(--c-unit)"
                };

                var iconSvg = p.PartType switch {
                    "Complete Bike"    => @"<circle cx='12' cy='12' r='9'/><circle cx='12' cy='12' r='3'/><line x1='12' y1='3' x2='12' y2='9'/><line x1='12' y1='15' x2='12' y2='21'/><line x1='3' y1='12' x2='9' y2='12'/><line x1='15' y1='12' x2='21' y2='12'/>",
                    "Frame"            => @"<rect x='3' y='9' width='18' height='10' rx='2'/><line x1='8' y1='9' x2='8' y2='19'/><line x1='16' y1='9' x2='16' y2='19'/>",
                    "Fork"             => @"<line x1='12' y1='2' x2='12' y2='22'/><path d='M5 22l7-14 7 14'/>",
                    "Upgrade Kit"      => @"<circle cx='12' cy='12' r='3'/><path d='M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83'/>",
                    "Chain"            => @"<path d='M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71'/><path d='M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71'/>",
                    "Pedals"           => @"<rect x='2' y='10' width='20' height='4' rx='2'/><line x1='7' y1='10' x2='7' y2='14'/><line x1='12' y1='10' x2='12' y2='14'/><line x1='17' y1='10' x2='17' y2='14'/>",
                    "Saddle"           => @"<path d='M4 15c0-4 3-7 8-7s8 3 8 7'/><line x1='12' y1='8' x2='12' y2='20'/>",
                    "Tires / Tubes"    => @"<circle cx='12' cy='12' r='10'/><circle cx='12' cy='12' r='3'/>",
                    _                  => @"<circle cx='12' cy='12' r='10'/><line x1='12' y1='8' x2='12' y2='12'/><line x1='12' y1='16' x2='12.01' y2='16'/>"
                };

                <div class="product-card"
                     data-category="@p.Category"
                     data-parttype="@p.PartType"
                     data-price="@p.Price"
                     data-name="@p.Name.ToLower()"
                     data-brand="@p.Brand.ToLower()">

                    <span class="card-badge" style="background:@badgeColor">@p.PartType</span>

                    <button class="card-wish" aria-label="Add to wishlist">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                        </svg>
                    </button>

                    <div class="card-img-wrap">
                        <div class="card-img-placeholder">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                                @Html.Raw(iconSvg)
                            </svg>
                            <span>@p.Brand</span>
                        </div>
                        <div class="card-overlay">
                            <button class="btn-quick">Quick View</button>
                        </div>
                    </div>

                    <div class="card-body">
                        <span class="card-part-type" style="color:@badgeColor">@p.PartType</span>
                        <span class="card-brand">@p.Brand</span>
                        <h3 class="card-name">@p.Name</h3>
                        <p class="card-desc">@p.Desc</p>
                        <div class="card-price">&#8369;@p.Price.ToString("N0")</div>
                        <div class="card-actions">
                            <button class="btn-cart">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                                </svg>
                                Add to Cart
                            </button>
                            <button class="btn-details" title="View Details">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                </div>
            }

            <div class="catalog-empty" id="catalogEmpty">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <p class="catalog-empty__title">No Products Found</p>
                <p class="catalog-empty__sub">Try adjusting your search or filter.</p>
            </div>

        </div>
    </div>
</div>

@* ── JS loaded last via Scripts section so DOM is ready ── *@
@section Scripts {
    <script src="~/js/product-catalog.js" asp-append-version="true"></script>
}
