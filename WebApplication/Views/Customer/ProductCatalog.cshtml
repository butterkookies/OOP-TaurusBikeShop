@* WebApplication/Views/Customer/ProductCatalog.cshtml *@
@model IEnumerable<WebApplication.Models.ViewModels.ProductViewModel>
@using WebApplication.Models.Entities
@{
    ViewData["Title"] = "Product Catalog";
    int    currentPage = ViewBag.CurrentPage ?? 1;
    int    totalPages  = ViewBag.TotalPages  ?? 1;
    int    totalCount  = ViewBag.TotalCount  ?? 0;
    int?   catId       = ViewBag.CategoryId;
    int?   brandId     = ViewBag.BrandId;
    decimal? minPrice  = ViewBag.MinPrice;
    decimal? maxPrice  = ViewBag.MaxPrice;
    string? search     = ViewBag.Search;
    IEnumerable<Brand>    brands     = ViewBag.Brands     ?? Enumerable.Empty<Brand>();
    IEnumerable<Category> categories = ViewBag.Categories ?? Enumerable.Empty<Category>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/product-catalog.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/product-card.css"    asp-append-version="true" />
}

@* Hidden CSRF token for AJAX calls on this page *@
@Html.AntiForgeryToken()

<div class="tbs-catalog-page">
    <div class="container">

        @* Page header *@
        <div class="tbs-catalog__header">
            <h1 class="tbs-catalog__title">Product Catalog</h1>
            <p class="tbs-catalog__count">
                @totalCount product@(totalCount != 1 ? "s" : "") found
            </p>
        </div>

        <div class="tbs-catalog__layout">

            @* ======================== FILTER SIDEBAR ======================== *@
            <aside class="tbs-catalog__sidebar" id="filter-sidebar" aria-label="Product filters">

                @* Search *@
                <div class="tbs-filter-group">
                    <label class="tbs-filter-group__label" for="search-input">Search</label>
                    <input type="text"
                           id="search-input"
                           class="tbs-input"
                           placeholder="Search products…"
                           value="@search" />
                </div>

                @* Categories *@
                <div class="tbs-filter-group">
                    <div class="tbs-filter-group__label">Category</div>
                    <ul class="tbs-filter-list" id="category-list">
                        <li>
                            <label class="tbs-filter-check @(catId == null ? "tbs-filter-check--active" : "")">
                                <input type="radio" name="categoryId" value=""
                                       @(catId == null ? "checked" : "") class="tbs-filter-radio" />
                                All Categories
                            </label>
                        </li>
                        @foreach (Category cat in categories)
                        {
                            <li>
                                <label class="tbs-filter-check @(catId == cat.CategoryId ? "tbs-filter-check--active" : "")">
                                    <input type="radio" name="categoryId" value="@cat.CategoryId"
                                           @(catId == cat.CategoryId ? "checked" : "") class="tbs-filter-radio" />
                                    @cat.Name
                                </label>
                            </li>
                        }
                    </ul>
                </div>

                @* Brands *@
                @if (brands.Any())
                {
                    <div class="tbs-filter-group">
                        <div class="tbs-filter-group__label">Brand</div>
                        <ul class="tbs-filter-list" id="brand-list">
                            <li>
                                <label class="tbs-filter-check @(brandId == null ? "tbs-filter-check--active" : "")">
                                    <input type="radio" name="brandId" value=""
                                           @(brandId == null ? "checked" : "") class="tbs-filter-radio" />
                                    All Brands
                                </label>
                            </li>
                            @foreach (Brand brand in brands)
                            {
                                <li>
                                    <label class="tbs-filter-check @(brandId == brand.BrandId ? "tbs-filter-check--active" : "")">
                                        <input type="radio" name="brandId" value="@brand.BrandId"
                                               @(brandId == brand.BrandId ? "checked" : "") class="tbs-filter-radio" />
                                        @brand.BrandName
                                    </label>
                                </li>
                            }
                        </ul>
                    </div>
                }

                @* Price range *@
                <div class="tbs-filter-group">
                    <div class="tbs-filter-group__label">Price Range (₱)</div>
                    <div class="tbs-price-range">
                        <input type="number" id="min-price" class="tbs-input tbs-price-range__input"
                               placeholder="Min" value="@minPrice" min="0" step="100" />
                        <span class="tbs-price-range__sep">—</span>
                        <input type="number" id="max-price" class="tbs-input tbs-price-range__input"
                               placeholder="Max" value="@maxPrice" min="0" step="100" />
                    </div>
                </div>

                @* Apply / Clear *@
                <button type="button" class="btn tbs-btn-accent tbs-btn-full mt-2" id="apply-filters-btn">
                    Apply Filters
                </button>
                <a asp-action="List" asp-controller="Product"
                   class="btn tbs-btn-outline tbs-btn-full mt-2">
                    Clear All
                </a>

            </aside>

            @* ======================== PRODUCT GRID ======================== *@
            <div class="tbs-catalog__main">

                @* Sort bar *@
                <div class="tbs-catalog__sort-bar">
                    <span class="tbs-catalog__showing">
                        Showing @((currentPage - 1) * 12 + 1)–@(Math.Min(currentPage * 12, totalCount))
                        of @totalCount
                    </span>
                </div>

                @* Grid *@
                @if (!Model.Any())
                {
                    <div class="tbs-catalog__empty">
                        <div class="tbs-catalog__empty-icon" aria-hidden="true">🔍</div>
                        <p class="tbs-catalog__empty-text">No products found matching your filters.</p>
                        <a asp-action="List" asp-controller="Product" class="btn tbs-btn-accent">
                            Clear Filters
                        </a>
                    </div>
                }
                else
                {
                    <div class="row g-3" id="product-grid">
                        @foreach (WebApplication.Models.ViewModels.ProductViewModel product in Model)
                        {
                            <div class="col-6 col-lg-4">
                                @await Html.PartialAsync("_ProductCard", product)
                            </div>
                        }
                    </div>

                    @* Pagination *@
                    @if (totalPages > 1)
                    {
                        <nav class="tbs-pagination" aria-label="Product pages">
                            @if (currentPage > 1)
                            {
                                <a class="tbs-pagination__btn"
                                   asp-action="List" asp-controller="Product"
                                   asp-route-page="@(currentPage - 1)"
                                   asp-route-categoryId="@catId"
                                   asp-route-brandId="@brandId"
                                   asp-route-search="@search"
                                   aria-label="Previous page">
                                    &lsaquo;
                                </a>
                            }

                            @for (int p = Math.Max(1, currentPage - 2);
                                  p <= Math.Min(totalPages, currentPage + 2); p++)
                            {
                                <a class="tbs-pagination__btn @(p == currentPage ? "tbs-pagination__btn--active" : "")"
                                   asp-action="List" asp-controller="Product"
                                   asp-route-page="@p"
                                   asp-route-categoryId="@catId"
                                   asp-route-brandId="@brandId"
                                   asp-route-search="@search"
                                   aria-label="Page @p"
                                   @(p == currentPage ? "aria-current=page" : "")>
                                    @p
                                </a>
                            }

                            @if (currentPage < totalPages)
                            {
                                <a class="tbs-pagination__btn"
                                   asp-action="List" asp-controller="Product"
                                   asp-route-page="@(currentPage + 1)"
                                   asp-route-categoryId="@catId"
                                   asp-route-brandId="@brandId"
                                   asp-route-search="@search"
                                   aria-label="Next page">
                                    &rsaquo;
                                </a>
                            }
                        </nav>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/product-catalog.js" asp-append-version="true"></script>
}
