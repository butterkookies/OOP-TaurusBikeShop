@{
    ViewData["Title"] = "Product Catalog";
}

<link rel="stylesheet" href="~/css/product-catalog.css" />

<div class="register-page">
    <div class="container">
        <!-- Brand / Page Title -->
        <h2 class="brand-title section-title text-center">Taurus Bike Catalog</h2>
        <hr class="section-divider">

        <div class="row justify-content-center">
            <!-- Product Card 1 -->
            <div class="col-sm-6 col-md-4 col-lg-3 mb-4">
                <div class="register-card text-center">
                    <img src="~/images/bike1.jpg" class="img-fluid mb-3" alt="Mountain Bike X1">
                        <h5 class="section-title">Mountain Bike X1</h5>
                        <p>High performance mountain bike for all terrains.</p>
                        <button class="btn btn-taurus w-100">View Details</button>
                    </div>
                </div>

                <!-- Product Card 2 -->
                <div class="col-sm-6 col-md-4 col-lg-3 mb-4">
                    <div class="register-card text-center">
                        <img src="~/images/bike2.jpg" class="img-fluid mb-3" alt="Roadster R5">
                            <h5 class="section-title">Roadster R5</h5>
                            <p>Lightweight and fast road bike for daily commuting.</p>
                            <button class="btn btn-taurus w-100">View Details</button>
                        </div>
                    </div>

                    <!-- Product Card 3 -->
                    <div class="col-sm-6 col-md-4 col-lg-3 mb-4">
                        <div class="register-card text-center">
                            <img src="~/images/bike3.jpg" class="img-fluid mb-3" alt="Urban Cruiser C2">
                                <h5 class="section-title">Urban Cruiser C2</h5>
                                <p>Comfortable bike for city rides and casual trips.</p>
                                <button class="btn btn-taurus w-100">View Details</button>
                            </div>
                        </div>

                        <!-- Add more product cards as needed -->
                    </div>
                </div>
            </div>