@* WebApplication/Views/Customer/ProductCatalog.cshtml *@
@model IEnumerable<WebApplication.Models.ViewModels.ProductViewModel>
@using WebApplication.Models.Entities
@{
    ViewData["Title"] = "Product Catalog";
    int    currentPage = ViewBag.CurrentPage ?? 1;
    int    totalPages  = ViewBag.TotalPages  ?? 1;
    int    totalCount  = ViewBag.TotalCount  ?? 0;
    int?   catId       = ViewBag.CategoryId;
    int?   brandId     = ViewBag.BrandId;
    decimal? minPrice  = ViewBag.MinPrice;
    decimal? maxPrice  = ViewBag.MaxPrice;
    string? search     = ViewBag.Search;
    IEnumerable<Brand>    brands     = ViewBag.Brands     ?? Enumerable.Empty<Brand>();
    IEnumerable<Category> categories = ViewBag.Categories ?? Enumerable.Empty<Category>();
}

@* Hidden CSRF token for AJAX calls *@
@Html.AntiForgeryToken()

<div class="bg-light-gray dark:bg-midnight min-h-[calc(100vh-160px)]">
    <div class="max-w-[1200px] mx-auto px-6 py-12 md:py-16">

        @* ── Page header ── *@
        <div class="mb-8" data-reveal>
            <h1 class="font-display text-3xl md:text-4xl font-semibold text-charcoal dark:text-white">Product Catalog</h1>
            <p class="text-base text-mid-gray mt-2">
                @totalCount product@(totalCount != 1 ? "s" : "") available
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-[260px_1fr] gap-8">

            @* ══════════ FILTER SIDEBAR ══════════ *@
            <aside class="cal-card-static p-5 h-fit sticky top-24" id="filter-sidebar" aria-label="Product filters">

                <p class="font-display text-base font-semibold text-charcoal dark:text-white mb-5" style="letter-spacing:0.2px">Filters</p>

                @* Search *@
                <div class="mb-5">
                    <label class="cal-label" for="search-input">Search</label>
                    <div class="relative">
                        <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-mid-gray" xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                             fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                            <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.099zm-5.242 1.656a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11z"/>
                        </svg>
                        <input type="text" id="search-input" class="cal-input pl-9"
                               placeholder="Search products…" value="@search" />
                    </div>
                </div>

                @* Categories *@
                <div class="mb-5">
                    <p class="cal-label">Category</p>
                    <ul class="space-y-1.5 mt-2" id="category-list">
                        <li>
                            <label class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm cursor-pointer transition-colors @(catId == null ? "bg-charcoal text-white dark:bg-white dark:text-midnight font-medium" : "text-charcoal hover:bg-charcoal/[0.04] dark:text-neutral-300 dark:hover:bg-white/5")">
                                <input type="radio" name="categoryId" value="" @(catId == null ? "checked" : "") class="hidden" />
                                All Categories
                            </label>
                        </li>
                        @foreach (Category cat in categories)
                        {
                            <li>
                                <label class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm cursor-pointer transition-colors @(catId == cat.CategoryId ? "bg-charcoal text-white dark:bg-white dark:text-midnight font-medium" : "text-charcoal hover:bg-charcoal/[0.04] dark:text-neutral-300 dark:hover:bg-white/5")">
                                    <input type="radio" name="categoryId" value="@cat.CategoryId"
                                           @(catId == cat.CategoryId ? "checked" : "") class="hidden" />
                                    @cat.Name
                                </label>
                            </li>
                        }
                    </ul>
                </div>

                @* Brands *@
                @if (brands.Any())
                {
                    <div class="mb-5">
                        <p class="cal-label">Brand</p>
                        <ul class="space-y-1.5 mt-2" id="brand-list">
                            <li>
                                <label class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm cursor-pointer transition-colors @(brandId == null ? "bg-charcoal text-white dark:bg-white dark:text-midnight font-medium" : "text-charcoal hover:bg-charcoal/[0.04] dark:text-neutral-300 dark:hover:bg-white/5")">
                                    <input type="radio" name="brandId" value="" @(brandId == null ? "checked" : "") class="hidden" />
                                    All Brands
                                </label>
                            </li>
                            @foreach (Brand brand in brands)
                            {
                                <li>
                                    <label class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm cursor-pointer transition-colors @(brandId == brand.BrandId ? "bg-charcoal text-white dark:bg-white dark:text-midnight font-medium" : "text-charcoal hover:bg-charcoal/[0.04] dark:text-neutral-300 dark:hover:bg-white/5")">
                                        <input type="radio" name="brandId" value="@brand.BrandId"
                                               @(brandId == brand.BrandId ? "checked" : "") class="hidden" />
                                        @brand.BrandName
                                    </label>
                                </li>
                            }
                        </ul>
                    </div>
                }

                @* Price range *@
                <div class="mb-6">
                    <p class="cal-label">Price Range (₱)</p>
                    <div class="flex gap-2 mt-2 items-center">
                        <input type="number" id="min-price" class="cal-input text-center"
                               placeholder="Min" value="@minPrice" min="0" step="100" />
                        <span class="text-mid-gray">—</span>
                        <input type="number" id="max-price" class="cal-input text-center"
                               placeholder="Max" value="@maxPrice" min="0" step="100" />
                    </div>
                </div>

                @* Actions *@
                <div class="flex flex-col gap-2">
                    <button type="button" class="btn-dark btn-full" id="apply-filters-btn">Apply Filters</button>
                    <a asp-action="List" asp-controller="Product" class="btn-ghost btn-full text-center">Clear All</a>
                </div>
            </aside>

            @* ══════════ PRODUCT GRID ══════════ *@
            <div>
                @* Sort / results bar *@
                <div class="flex items-center justify-between mb-5" data-reveal>
                    <span class="text-sm text-mid-gray">
                        @if (Model.Any())
                        {
                            <text>Showing @((currentPage - 1) * 12 + 1)–@(Math.Min(currentPage * 12, totalCount)) of @totalCount</text>
                        }
                        else
                        {
                            <text>No results</text>
                        }
                    </span>
                </div>

                @* Empty state *@
                @if (!Model.Any())
                {
                    <div class="cal-card-static p-12 text-center" data-reveal="delay-1">
                        <div class="text-mid-gray mb-4">
                            <svg class="mx-auto" xmlns="http://www.w3.org/2000/svg" width="40" height="40"
                                 fill="currentColor" viewBox="0 0 16 16">
                                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.099zm-5.242 1.656a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11z"/>
                            </svg>
                        </div>
                        <h3 class="font-display text-lg font-semibold text-charcoal dark:text-white mb-2">No products found</h3>
                        <p class="text-sm text-mid-gray mb-4">Try adjusting your filters or search term.</p>
                        <a asp-action="List" asp-controller="Product" class="btn-dark btn-sm">Clear Filters</a>
                    </div>
                }
                else
                {
                    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5" id="product-grid" data-reveal="delay-1">
                        @foreach (WebApplication.Models.ViewModels.ProductViewModel product in Model)
                        {
                            @await Html.PartialAsync("~/Views/Customer/Partials/_ProductCard.cshtml", product)
                        }
                    </div>

                    @* Pagination *@
                    @if (totalPages > 1)
                    {
                        <nav class="flex items-center justify-center gap-1 mt-10" aria-label="Product pages" data-reveal="delay-2">
                            @if (currentPage > 1)
                            {
                                <a class="cal-page-btn"
                                   asp-action="List" asp-controller="Product"
                                   asp-route-page="@(currentPage - 1)"
                                   asp-route-categoryId="@catId"
                                   asp-route-brandId="@brandId"
                                   asp-route-search="@search"
                                   aria-label="Previous page">&#8249;</a>
                            }

                            @for (int p = Math.Max(1, currentPage - 2);
                                  p <= Math.Min(totalPages, currentPage + 2); p++)
                            {
                                <a class="cal-page-btn @(p == currentPage ? "cal-page-btn--active" : "")"
                                   asp-action="List" asp-controller="Product"
                                   asp-route-page="@p"
                                   asp-route-categoryId="@catId"
                                   asp-route-brandId="@brandId"
                                   asp-route-search="@search"
                                   aria-label="Page @p"
                                   aria-current="@(p == currentPage ? "page" : null)">@p</a>
                            }

                            @if (currentPage < totalPages)
                            {
                                <a class="cal-page-btn"
                                   asp-action="List" asp-controller="Product"
                                   asp-route-page="@(currentPage + 1)"
                                   asp-route-categoryId="@catId"
                                   asp-route-brandId="@brandId"
                                   asp-route-search="@search"
                                   aria-label="Next page">&#8250;</a>
                            }
                        </nav>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/product-catalog.js" asp-append-version="true"></script>
}
