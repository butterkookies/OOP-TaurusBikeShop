@* WebApplication/Views/Customer/SupportDetail.cshtml *@
@model WebApplication.Models.ViewModels.SupportTicketViewModel
@{
    ViewData["Title"] = $"Ticket #{Model.TicketId}";
}

@Html.AntiForgeryToken()

<div class="bg-light-gray dark:bg-midnight min-h-[calc(100vh-160px)]">
    <div class="max-w-[800px] mx-auto px-6 py-12 md:py-16">

        <ol class="cal-breadcrumb">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li><a asp-controller="Support" asp-action="Index">Support</a></li>
            <li>Ticket #@Model.TicketId</li>
        </ol>

        @* Header *@
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8" data-reveal>
            <div>
                <h1 class="font-display text-2xl md:text-3xl font-semibold text-charcoal dark:text-white">@Model.Subject</h1>
                <p class="text-sm text-mid-gray mt-1">
                    Ticket #@Model.TicketId &middot; @Model.Category &middot; Opened @Model.FormattedCreatedAt
                </p>
            </div>
            @await Html.PartialAsync("~/Views/Customer/Partials/_TicketStatusBadge.cshtml", Model.Status)
        </div>

        @* Order reference *@
        @if (Model.OrderId.HasValue)
        {
            <div class="mb-6 p-3 bg-light-gray dark:bg-white/5 rounded-lg text-sm text-charcoal dark:text-white inline-flex items-center gap-2" data-reveal="delay-1">
                📦 Regarding
                <a asp-controller="Order" asp-action="Detail" asp-route-orderId="@Model.OrderId"
                   class="font-medium underline underline-offset-2 hover:text-charcoal/70 dark:hover:text-white/70">
                    Order @(Model.OrderNumber ?? $"#{Model.OrderId}")
                </a>
            </div>
        }

        @* Reply thread *@
        <div class="space-y-4 mb-8" id="ticket-thread" data-reveal="delay-1">
            @foreach (WebApplication.Models.ViewModels.SupportReplyViewModel reply in Model.Replies)
            {
                <div class="cal-card-static p-5 @(reply.IsStaff ? "border-l-4 border-charcoal dark:border-white" : "")">
                    <div class="flex items-center gap-2 mb-2">
                        <strong class="text-sm text-charcoal dark:text-white">@reply.AuthorName</strong>
                        @if (reply.IsStaff)
                        {
                            <span class="cal-badge cal-badge-dark">Support Team</span>
                        }
                        <span class="text-xs text-mid-gray ml-auto">@reply.FormattedCreatedAt</span>
                    </div>
                    <p class="text-sm text-charcoal/80 dark:text-neutral-300 leading-relaxed whitespace-pre-line">@reply.Message</p>
                </div>
            }
        </div>

        @* Reply form *@
        @if (Model.CanReply)
        {
            <div class="cal-card-static p-6" data-reveal="delay-2">
                <h2 class="font-display text-lg font-semibold text-charcoal dark:text-white mb-4" style="letter-spacing:0.2px">Add a Reply</h2>
                <form asp-action="Reply" asp-controller="Support" method="post" id="reply-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ticketId" value="@Model.TicketId" />

                    <div class="mb-4">
                        <label class="cal-label" for="reply-message">Your Message</label>
                        <textarea id="reply-message" name="message" class="cal-input cal-textarea" rows="4"
                                  placeholder="Type your reply…" required maxlength="2000"></textarea>
                        <div class="flex justify-end mt-1">
                            <span class="text-xs text-mid-gray"><span id="reply-char-count">0</span> / 2000</span>
                        </div>
                    </div>

                    <button type="submit" class="btn-dark" id="reply-submit-btn">Send Reply</button>
                </form>
            </div>
        }
        else
        {
            <div class="cal-card-static p-5 text-sm text-mid-gray text-center" data-reveal="delay-2">
                This ticket is <strong class="text-charcoal dark:text-white">@Model.Status.ToLower()</strong>
                and cannot receive new replies.
                <a asp-controller="Support" asp-action="Create" class="font-medium underline underline-offset-2 hover:text-charcoal dark:hover:text-white">Open a new ticket</a>
                if you need further assistance.
            </div>
        }

    </div>
</div>

@section Scripts {
    <script src="~/js/support.js" asp-append-version="true"></script>
}
