@* WebApplication/Views/Customer/SupportDetail.cshtml *@
@model WebApplication.Models.ViewModels.SupportTicketDetailViewModel
@{
    ViewData["Title"] = $"Ticket #{Model.TicketId}";
}

<div class="container py-5">

    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Customer/Support">My Tickets</a></li>
            <li class="breadcrumb-item active" aria-current="page">Ticket #@Model.TicketId</li>
        </ol>
    </nav>

    <!-- ── Ticket header ── -->
    <div class="card border-0 shadow-sm mb-4 p-4">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-3">
            <div>
                <h1 class="h4 mb-1">@Model.Subject</h1>
                <p class="text-muted mb-0 small">
                    Ticket #@Model.TicketId
                    &middot; @Model.Category
                    @if (!string.IsNullOrEmpty(Model.OrderNumber))
                    {
                        <span>&middot; Order @Model.OrderNumber</span>
                    }
                    &middot; Opened <time datetime="@Model.CreatedAt.ToString("yyyy-MM-dd")">
                        @Model.CreatedAt.ToString("MMMM dd, yyyy")
                    </time>
                </p>
            </div>
            @{
                string badgeClass = Model.Status switch
                {
                    "Open"             => "bg-danger",
                    "InProgress"       => "bg-warning text-dark",
                    "AwaitingResponse" => "bg-info text-dark",
                    "Resolved"         => "bg-success",
                    "Closed"           => "bg-secondary",
                    _                  => "bg-secondary"
                };
            }
            <span class="badge @badgeClass fs-6">@Model.Status</span>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p class="mb-0">@Model.Description</p>
        }

        @if (!string.IsNullOrEmpty(Model.AttachmentUrl))
        {
            <div class="mt-3">
                <a href="@Model.AttachmentUrl" target="_blank" rel="noopener noreferrer"
                   class="btn btn-sm btn-outline-secondary">
                    View Attachment
                </a>
            </div>
        }

        @if (Model.ResolvedAt.HasValue)
        {
            <div class="mt-3 text-success small fw-semibold">
                Resolved on @Model.ResolvedAt.Value.ToString("MMMM dd, yyyy")
            </div>
        }
    </div>

    <!-- ── Reply thread ── -->
    <h2 class="h5 mb-3">Conversation</h2>

    @if (!Model.Replies.Any())
    {
        <p class="text-muted">No replies yet. Our support team will respond shortly.</p>
    }
    else
    {
        <div class="d-flex flex-column gap-3 mb-4">
            @foreach (var reply in Model.Replies)
            {
                string bubbleClass = reply.IsAdminReply
                    ? "border-start border-danger border-3 bg-light"
                    : "border-start border-secondary border-3";

                <article class="card border-0 shadow-sm p-3 @bubbleClass">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span class="fw-semibold @(reply.IsAdminReply ? "text-danger" : "")">
                            @reply.AuthorName
                        </span>
                        <time class="text-muted small"
                              datetime="@reply.CreatedAt.ToString("yyyy-MM-ddTHH:mm:ssZ")">
                            @reply.CreatedAt.ToString("MMM dd, yyyy HH:mm") UTC
                        </time>
                    </div>
                    <p class="mb-0">@reply.Message</p>
                    @if (!string.IsNullOrEmpty(reply.AttachmentUrl))
                    {
                        <div class="mt-2">
                            <a href="@reply.AttachmentUrl" target="_blank" rel="noopener noreferrer"
                               class="btn btn-sm btn-outline-secondary">
                                View Attachment
                            </a>
                        </div>
                    }
                </article>
            }
        </div>
    }

    <div class="mt-4">
        <a href="/Customer/Support" class="btn btn-outline-secondary">&larr; Back to Tickets</a>
    </div>

</div>
