@using WebApplication.Models.Entities
@model SupportTicket
@{
    ViewData["Title"] = $"Ticket #{Model.TicketId} - Taurus Bike Shop";
    Layout = "_Layout";

    var badgeClass = Model.Status switch {
        "Open"       => "bg-primary",
        "InProgress" => "bg-warning text-dark",
        "Resolved"   => "bg-success",
        "Closed"     => "bg-secondary",
        _            => "bg-secondary"
    };
}

<div class="container py-4" style="max-width:780px;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Support Ticket <span class="text-muted">#@Model.TicketId</span></h2>
        <a href="/Support/Index" class="btn btn-outline-secondary btn-sm">← Back to Support</a>
    </div>

    <!-- ── Ticket Details ─────────────────────────────────── -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <span class="fw-semibold">@Model.Subject</span>
            <span class="badge @badgeClass">@Model.Status</span>
        </div>
        <div class="card-body">
            <dl class="row mb-3">
                <dt class="col-sm-3 text-muted">Submitted</dt>
                <dd class="col-sm-9">@Model.CreatedAt.ToString("MMMM d, yyyy 'at' h:mm tt")</dd>

                @if (Model.UpdatedAt.HasValue)
                {
                    <dt class="col-sm-3 text-muted">Last Updated</dt>
                    <dd class="col-sm-9">@Model.UpdatedAt.Value.ToString("MMMM d, yyyy 'at' h:mm tt")</dd>
                }

                @if (Model.Order != null)
                {
                    <dt class="col-sm-3 text-muted">Related Order</dt>
                    <dd class="col-sm-9">@Model.Order.OrderNumber</dd>
                }
            </dl>

            <hr />

            <h6 class="fw-semibold mb-2">Your Message</h6>
            <p class="text-secondary" style="white-space:pre-wrap;">@Model.Message</p>
        </div>
    </div>

    <!-- ── Admin Response ─────────────────────────────────── -->
    @if (!string.IsNullOrWhiteSpace(Model.AdminResponse))
    {
        <div class="card border-success shadow-sm mb-4">
            <div class="card-header bg-success text-white fw-semibold">
                Response from Taurus Support
            </div>
            <div class="card-body">
                <p class="mb-0" style="white-space:pre-wrap;">@Model.AdminResponse</p>
            </div>
        </div>
    }
    else if (Model.Status == "Open" || Model.Status == "InProgress")
    {
        <div class="alert alert-info">
            Your ticket is <strong>@Model.Status</strong>. Our support team will respond shortly.
        </div>
    }
    else
    {
        <div class="alert alert-secondary">
            This ticket is <strong>@Model.Status</strong>. No admin response recorded.
        </div>
    }

    <a href="/Support/Index" class="btn btn-outline-secondary">← Back to Support</a>
</div>
