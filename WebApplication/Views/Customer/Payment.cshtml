@* WebApplication/Views/Customer/Payment.cshtml *@
@model WebApplication.BusinessLogic.Interfaces.PaymentDetailDto
@{
    ViewData["Title"] = "Upload Payment";
}

<div class="bg-light-gray dark:bg-midnight min-h-[calc(100vh-160px)]">
    <div class="max-w-[600px] mx-auto px-6 py-12 md:py-16">

        <ol class="cal-breadcrumb">
            <li><a asp-controller="Order" asp-action="History">Orders</a></li>
            <li><a asp-controller="Order" asp-action="Detail" asp-route-orderId="@Model.OrderId">@Model.OrderNumber</a></li>
            <li>Upload Payment</li>
        </ol>

        <h1 class="font-display text-2xl md:text-3xl font-semibold text-charcoal dark:text-white mb-2" data-reveal>Upload Payment Proof</h1>
        <p class="text-sm text-mid-gray mb-8" data-reveal>
            Order <strong class="text-charcoal dark:text-white">@Model.OrderNumber</strong> &middot;
            Total: <strong class="text-charcoal dark:text-white">₱@Model.GrandTotal.ToString("N2")</strong>
        </p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="mb-6 p-3 bg-error/10 border border-error/20 rounded-lg text-sm text-error" role="alert">
                <div asp-validation-summary="All"></div>
            </div>
        }

        @if (Model.PaymentMethod == "GCash")
        {
            <form asp-action="SubmitGCash" asp-controller="Payment" method="post" enctype="multipart/form-data" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="orderId" value="@Model.OrderId" />

                <div class="cal-card-static p-6 mb-6" data-reveal="delay-1">
                    <div class="mb-5 p-4 bg-light-gray dark:bg-white/5 rounded-xl">
                        <p class="text-sm font-medium text-charcoal dark:text-white mb-1">Payment via GCash</p>
                        <p class="text-xs text-mid-gray mb-4">
                            Send <strong class="text-charcoal dark:text-white">exactly ₱@Model.GrandTotal.ToString("N2")</strong> to the store GCash account below, then upload your screenshot.
                        </p>

                        @if (!string.IsNullOrEmpty(Model.StoreAccountNumber))
                        {
                            <div class="grid @(string.IsNullOrEmpty(Model.StoreAccountQrImageUrl) ? "grid-cols-1" : "md:grid-cols-[1fr_auto]") gap-4 items-center">
                                <div>
                                    <p class="text-xs uppercase tracking-wide text-mid-gray mb-1">Send to</p>
                                    <p class="text-sm font-semibold text-charcoal dark:text-white">@Model.StoreAccountName</p>
                                    <div class="flex items-center gap-2 mt-1">
                                        <span class="text-base font-mono font-semibold text-charcoal dark:text-white select-all" id="store-account-number">@Model.StoreAccountNumber</span>
                                        <button type="button"
                                                class="btn-ghost btn-sm"
                                                data-copy-target="store-account-number"
                                                aria-label="Copy GCash number">Copy</button>
                                    </div>
                                    @if (!string.IsNullOrEmpty(Model.StoreAccountInstructions))
                                    {
                                        <p class="text-xs text-mid-gray mt-2">@Model.StoreAccountInstructions</p>
                                    }
                                    <p class="text-xs text-mid-gray mt-2">
                                        Use <strong class="text-charcoal dark:text-white">@Model.OrderNumber</strong> as the message / note.
                                    </p>
                                </div>
                                @if (!string.IsNullOrEmpty(Model.StoreAccountQrImageUrl))
                                {
                                    <img src="@Model.StoreAccountQrImageUrl" alt="GCash QR code" class="w-32 h-32 rounded-lg border border-white/10 object-contain bg-white p-1" />
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-xs text-error">GCash account details are not yet configured by the store. Please contact support before sending payment.</p>
                        }
                    </div>

                    <div class="mb-5">
                        <label class="cal-label">GCash Number</label>
                        <input type="text" name="gcashNumber" class="cal-input" placeholder="09xxxxxxxxx" />
                    </div>

                    <div class="mb-5">
                        <label class="cal-label">Reference Number</label>
                        <input type="text" name="referenceNumber" class="cal-input" placeholder="GCash reference number" />
                    </div>

                    <div>
                        <label class="cal-label">Payment Screenshot</label>
                        <div class="cal-file-drop" id="file-drop-zone">
                            <input type="file" name="screenshotFile" accept="image/*"
                                   class="cal-file-drop__input" id="payment-file-input" required />
                            <div class="text-mid-gray">
                                <svg class="mx-auto mb-2" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                                <p class="text-sm font-medium text-charcoal dark:text-white">Drop file or click to upload</p>
                                <p class="text-xs mt-1">PNG, JPG, up to 10 MB</p>
                            </div>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn-dark btn-lg btn-full" data-reveal="delay-2">
                    Submit GCash Payment
                </button>
            </form>
        }
        else
        {
            <form asp-action="SubmitBankTransfer" asp-controller="Payment" method="post" enctype="multipart/form-data" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="orderId" value="@Model.OrderId" />

                <div class="cal-card-static p-6 mb-6" data-reveal="delay-1">
                    <div class="mb-5 p-4 bg-light-gray dark:bg-white/5 rounded-xl">
                        <p class="text-sm font-medium text-charcoal dark:text-white mb-1">Payment via Bank Transfer</p>
                        <p class="text-xs text-mid-gray mb-4">
                            Transfer <strong class="text-charcoal dark:text-white">exactly ₱@Model.GrandTotal.ToString("N2")</strong> to the store bank account below, then upload your deposit slip.
                        </p>

                        @if (!string.IsNullOrEmpty(Model.StoreAccountNumber))
                        {
                            <div>
                                <p class="text-xs uppercase tracking-wide text-mid-gray mb-1">Transfer to</p>
                                @if (!string.IsNullOrEmpty(Model.StoreAccountBankName))
                                {
                                    <p class="text-sm font-medium text-charcoal dark:text-white">@Model.StoreAccountBankName</p>
                                }
                                <p class="text-sm font-semibold text-charcoal dark:text-white">@Model.StoreAccountName</p>
                                <div class="flex items-center gap-2 mt-1">
                                    <span class="text-base font-mono font-semibold text-charcoal dark:text-white select-all" id="store-account-number">@Model.StoreAccountNumber</span>
                                    <button type="button"
                                            class="btn-ghost btn-sm"
                                            data-copy-target="store-account-number"
                                            aria-label="Copy bank account number">Copy</button>
                                </div>
                                @if (!string.IsNullOrEmpty(Model.StoreAccountInstructions))
                                {
                                    <p class="text-xs text-mid-gray mt-2">@Model.StoreAccountInstructions</p>
                                }
                                <p class="text-xs text-mid-gray mt-2">
                                    Use <strong class="text-charcoal dark:text-white">@Model.OrderNumber</strong> as the deposit note.
                                </p>
                            </div>
                        }
                        else
                        {
                            <p class="text-xs text-error">Bank account details are not yet configured by the store. Please contact support before sending payment.</p>
                        }
                    </div>

                    <div class="mb-5">
                        <label class="cal-label">Depositor Name</label>
                        <input type="text" name="depositorName" class="cal-input" placeholder="Full name on account" required />
                    </div>

                    <div class="mb-5">
                        <label class="cal-label">BPI Reference Number <span class="cal-label-opt">(optional)</span></label>
                        <input type="text" name="bpiReferenceNumber" class="cal-input" placeholder="BPI transaction reference" />
                    </div>

                    <div>
                        <label class="cal-label">Deposit Slip / Screenshot</label>
                        <div class="cal-file-drop" id="file-drop-zone">
                            <input type="file" name="depositSlipFile" accept="image/*,.pdf"
                                   class="cal-file-drop__input" id="payment-file-input" required />
                            <div class="text-mid-gray">
                                <svg class="mx-auto mb-2" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                                <p class="text-sm font-medium text-charcoal dark:text-white">Drop file or click to upload</p>
                                <p class="text-xs mt-1">PNG, JPG, PDF — up to 10 MB</p>
                            </div>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn-dark btn-lg btn-full" data-reveal="delay-2">
                    Submit Bank Transfer Proof
                </button>
            </form>
        }

        <p class="text-xs text-mid-gray text-center mt-3">
            Payment will be reviewed within 24 hours.
        </p>

    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        (function () {
            const zone  = document.getElementById('file-drop-zone');
            const input = document.getElementById('payment-file-input');
            if (!zone || !input) return;

            // Update drop zone UI to show the selected file's name
            function showFileInfo(file) {
                if (!file) return;
                const inner = zone.querySelector('div.text-mid-gray');
                if (!inner) return;
                inner.innerHTML =
                    '<svg class="mx-auto mb-2 text-success" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>' +
                    '<p class="text-sm font-medium text-charcoal dark:text-white" style="word-break:break-all">' + file.name + '</p>' +
                    '<p class="text-xs mt-1 text-success">File attached — ready to submit</p>';
                zone.style.borderColor = '#22c55e'; // success green
            }

            // Drag highlight
            ['dragenter', 'dragover'].forEach(e =>
                zone.addEventListener(e, ev => { ev.preventDefault(); zone.style.borderColor = '#242424'; }));

            // Drop: wire file to input, then show info
            zone.addEventListener('drop', ev => {
                ev.preventDefault();
                zone.style.borderColor = '';
                input.files = ev.dataTransfer.files;
                showFileInfo(input.files[0]);
            });

            zone.addEventListener('dragleave', ev => {
                ev.preventDefault();
                if (!input.files?.length) zone.style.borderColor = '';
            });

            // Regular file-picker selection
            input.addEventListener('change', () => showFileInfo(input.files[0]));
        })();

        // Copy-to-clipboard for the store account number.
        (function () {
            document.querySelectorAll('[data-copy-target]').forEach(btn => {
                btn.addEventListener('click', async () => {
                    const targetId = btn.getAttribute('data-copy-target');
                    const target = document.getElementById(targetId);
                    if (!target) return;
                    const value = target.innerText.trim();
                    try {
                        await navigator.clipboard.writeText(value);
                    } catch {
                        const r = document.createRange();
                        r.selectNodeContents(target);
                        const s = window.getSelection();
                        s.removeAllRanges(); s.addRange(r);
                        document.execCommand('copy'); s.removeAllRanges();
                    }
                    const original = btn.innerText;
                    btn.innerText = 'Copied';
                    btn.disabled = true;
                    setTimeout(() => { btn.innerText = original; btn.disabled = false; }, 1500);
                });
            });
        })();
    </script>
}
