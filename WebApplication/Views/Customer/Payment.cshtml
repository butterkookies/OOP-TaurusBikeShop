@* WebApplication/Views/Customer/Payment.cshtml *@
@model WebApplication.BusinessLogic.Interfaces.PaymentDetailDto
@{
    ViewData["Title"] = "Upload Payment";
}

<div class="bg-light-gray dark:bg-midnight min-h-[calc(100vh-160px)]">
    <div class="max-w-[600px] mx-auto px-6 py-12 md:py-16">

        <ol class="cal-breadcrumb">
            <li><a asp-controller="Order" asp-action="History">Orders</a></li>
            <li><a asp-controller="Order" asp-action="Detail" asp-route-orderId="@Model.OrderId">@Model.OrderNumber</a></li>
            <li>Upload Payment</li>
        </ol>

        <h1 class="font-display text-2xl md:text-3xl font-semibold text-charcoal dark:text-white mb-2" data-reveal>Upload Payment Proof</h1>
        <p class="text-sm text-mid-gray mb-8" data-reveal>
            Order <strong class="text-charcoal dark:text-white">@Model.OrderNumber</strong> &middot;
            Total: <strong class="text-charcoal dark:text-white">₱@Model.GrandTotal.ToString("N2")</strong>
        </p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="mb-6 p-3 bg-error/10 border border-error/20 rounded-lg text-sm text-error" role="alert">
                <div asp-validation-summary="All"></div>
            </div>
        }

        @if (Model.PaymentMethod == "GCash")
        {
            <form asp-action="SubmitGCash" asp-controller="Payment" method="post" enctype="multipart/form-data" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="orderId" value="@Model.OrderId" />

                <div class="cal-card-static p-6 mb-6" data-reveal="delay-1">
                    <div class="mb-5 p-4 bg-light-gray dark:bg-white/5 rounded-xl">
                        <p class="text-sm font-medium text-charcoal dark:text-white mb-1">Payment via GCash</p>
                        <p class="text-xs text-mid-gray mb-4">
                            Send <strong class="text-charcoal dark:text-white">exactly ₱@Model.GrandTotal.ToString("N2")</strong> to the store GCash account below, then upload your screenshot.
                        </p>

                        @if (!string.IsNullOrEmpty(Model.StoreAccountNumber))
                        {
                            <div class="grid @(string.IsNullOrEmpty(Model.StoreAccountQrImageUrl) ? "grid-cols-1" : "md:grid-cols-[1fr_auto]") gap-4 items-center">
                                <div>
                                    <p class="text-xs uppercase tracking-wide text-mid-gray mb-1">Send to</p>
                                    <p class="text-sm font-semibold text-charcoal dark:text-white">@Model.StoreAccountName</p>
                                    <div class="flex items-center gap-2 mt-1">
                                        <span class="text-base font-mono font-semibold text-charcoal dark:text-white select-all" id="store-account-number">@Model.StoreAccountNumber</span>
                                        <button type="button"
                                                class="btn-ghost btn-sm"
                                                data-copy-target="store-account-number"
                                                aria-label="Copy GCash number">Copy</button>
                                    </div>
                                    @if (!string.IsNullOrEmpty(Model.StoreAccountInstructions))
                                    {
                                        <p class="text-xs text-mid-gray mt-2">@Model.StoreAccountInstructions</p>
                                    }
                                    <p class="text-xs text-mid-gray mt-2">
                                        Use <strong class="text-charcoal dark:text-white">@Model.OrderNumber</strong> as the message / note.
                                    </p>
                                </div>
                                @if (!string.IsNullOrEmpty(Model.StoreAccountQrImageUrl))
                                {
                                    <img src="@Model.StoreAccountQrImageUrl" alt="GCash QR code" class="w-32 h-32 rounded-lg border border-white/10 object-contain bg-white p-1" />
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-xs text-error">GCash account details are not yet configured by the store. Please contact support before sending payment.</p>
                        }
                    </div>

                    <div class="mb-5">
                        <label class="cal-label">GCash Number <span class="text-xs text-mid-gray font-normal">(11 digits)</span></label>
                        <input type="text" name="gcashNumber" class="cal-input" placeholder="09xxxxxxxxx"
                               maxlength="11" inputmode="numeric" pattern="[0-9]{11}" />
                    </div>

                    <div class="mb-5">
                        <label class="cal-label">Reference Number <span class="text-xs text-mid-gray font-normal">(13 digits)</span></label>
                        <input type="text" name="referenceNumber" class="cal-input" placeholder="GCash reference number"
                               maxlength="13" inputmode="numeric" pattern="[0-9]{1,13}" />
                    </div>

                    <div>
                        <label class="cal-label">Payment Screenshot</label>
                        <div class="cal-file-drop" id="file-drop-zone">
                            <input type="file" name="screenshotFile" accept="image/*"
                                   class="cal-file-drop__input" id="payment-file-input"
                                   style="display:none" data-required="true" />
                            <!-- Default prompt (visible when no file attached) -->
                            <div class="cal-file-drop__prompt text-mid-gray">
                                <svg class="mx-auto mb-2" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                                <p class="text-sm font-medium text-charcoal dark:text-white">Drop file here or click to browse</p>
                                <p class="text-xs mt-1">PNG, JPG — up to 10 MB</p>
                            </div>
                            <!-- File info (hidden until file is attached) -->
                            <div class="cal-file-drop__info" style="display:none"></div>
                        </div>
                    </div>
                </div>

                <button type="button" class="btn-dark btn-lg btn-full payment-submit-btn" data-reveal="delay-2">
                    Submit GCash Payment
                </button>
            </form>
        }
        else
        {
            <form asp-action="SubmitBankTransfer" asp-controller="Payment" method="post" enctype="multipart/form-data" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="orderId" value="@Model.OrderId" />

                <div class="cal-card-static p-6 mb-6" data-reveal="delay-1">
                    <div class="mb-5 p-4 bg-light-gray dark:bg-white/5 rounded-xl">
                        <p class="text-sm font-medium text-charcoal dark:text-white mb-1">Payment via Bank Transfer</p>
                        <p class="text-xs text-mid-gray mb-4">
                            Transfer <strong class="text-charcoal dark:text-white">exactly ₱@Model.GrandTotal.ToString("N2")</strong> to the store bank account below, then upload your deposit slip.
                        </p>

                        @if (!string.IsNullOrEmpty(Model.StoreAccountNumber))
                        {
                            <div>
                                <p class="text-xs uppercase tracking-wide text-mid-gray mb-1">Transfer to</p>
                                @if (!string.IsNullOrEmpty(Model.StoreAccountBankName))
                                {
                                    <p class="text-sm font-medium text-charcoal dark:text-white">@Model.StoreAccountBankName</p>
                                }
                                <p class="text-sm font-semibold text-charcoal dark:text-white">@Model.StoreAccountName</p>
                                <div class="flex items-center gap-2 mt-1">
                                    <span class="text-base font-mono font-semibold text-charcoal dark:text-white select-all" id="store-account-number">@Model.StoreAccountNumber</span>
                                    <button type="button"
                                            class="btn-ghost btn-sm"
                                            data-copy-target="store-account-number"
                                            aria-label="Copy bank account number">Copy</button>
                                </div>
                                @if (!string.IsNullOrEmpty(Model.StoreAccountInstructions))
                                {
                                    <p class="text-xs text-mid-gray mt-2">@Model.StoreAccountInstructions</p>
                                }
                                <p class="text-xs text-mid-gray mt-2">
                                    Use <strong class="text-charcoal dark:text-white">@Model.OrderNumber</strong> as the deposit note.
                                </p>
                            </div>
                        }
                        else
                        {
                            <p class="text-xs text-error">Bank account details are not yet configured by the store. Please contact support before sending payment.</p>
                        }
                    </div>

                    <div class="mb-5">
                        <label class="cal-label">Depositor Name</label>
                        <input type="text" name="depositorName" class="cal-input" placeholder="Full name on account" required />
                    </div>

                    <div class="mb-5">
                        <label class="cal-label">BPI Reference Number <span class="cal-label-opt">(optional · 10 digits)</span></label>
                        <input type="text" name="bpiReferenceNumber" class="cal-input" placeholder="BPI transaction reference"
                               maxlength="10" inputmode="numeric" pattern="[0-9]{0,10}" />
                    </div>

                    <div>
                        <label class="cal-label">Deposit Slip / Screenshot</label>
                        <div class="cal-file-drop" id="file-drop-zone">
                            <input type="file" name="depositSlipFile" accept="image/*,.pdf"
                                   class="cal-file-drop__input" id="payment-file-input"
                                   style="display:none" data-required="true" />
                            <!-- Default prompt (visible when no file attached) -->
                            <div class="cal-file-drop__prompt text-mid-gray">
                                <svg class="mx-auto mb-2" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                                <p class="text-sm font-medium text-charcoal dark:text-white">Drop file here or click to browse</p>
                                <p class="text-xs mt-1">PNG, JPG, PDF — up to 10 MB</p>
                            </div>
                            <!-- File info (hidden until file is attached) -->
                            <div class="cal-file-drop__info" style="display:none"></div>
                        </div>
                    </div>
                </div>

                <button type="button" class="btn-dark btn-lg btn-full payment-submit-btn" data-reveal="delay-2">
                    Submit Bank Transfer Proof
                </button>
            </form>
        }

        <p class="text-xs text-mid-gray text-center mt-3">
            Payment will be reviewed within 24 hours.
        </p>

    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        (function () {
            'use strict';

            // ── File drop zone ───────────────────────────────────────────
            const zone      = document.getElementById('file-drop-zone');
            let   fileInput = document.getElementById('payment-file-input');
            if (!zone || !fileInput) return;

            const promptEl = zone.querySelector('.cal-file-drop__prompt');
            const infoEl   = zone.querySelector('.cal-file-drop__info');

            // Track drag-enter depth so nested elements don't flicker
            let dragCounter = 0;

            /* ── helpers ─────────────────────────────────────────────── */
            function escapeHtml(str) {
                return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            }

            function formatSize(bytes) {
                if (bytes < 1024) return bytes + ' B';
                if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
                return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
            }

            function getFileExtension(name) {
                var dot = name.lastIndexOf('.');
                return dot !== -1 ? name.substring(dot).toLowerCase() : '';
            }

            function getInput() {
                return zone.querySelector('.cal-file-drop__input');
            }

            /* ── reset to empty state ────────────────────────────────── */
            function resetDropZone() {
                // Clone the input to fully clear the file selection
                var old = getInput();
                if (old) {
                    var fresh = old.cloneNode(false);
                    fresh.value = '';
                    fresh.style.display = 'none';
                    fresh.addEventListener('change', function () { showFileInfo(fresh.files[0]); });
                    old.parentNode.replaceChild(fresh, old);
                    fileInput = fresh;
                }
                // Show prompt, hide info
                if (promptEl) promptEl.style.display = '';
                if (infoEl)   { infoEl.style.display = 'none'; infoEl.innerHTML = ''; }
                // Remove the X button (it lives directly on the zone)
                var existingBtn = zone.querySelector('.cal-file-drop__remove');
                if (existingBtn) existingBtn.remove();
                // Clear visual states
                zone.classList.remove('has-file', 'is-dragover');
            }

            /* ── show file info + optional preview ───────────────────── */
            function showFileInfo(file) {
                if (!file || !infoEl) return;

                var safeName = escapeHtml(file.name);
                var ext      = getFileExtension(file.name);
                var size     = formatSize(file.size);
                var isImage  = file.type.startsWith('image/');

                // Build preview HTML
                var html = '';

                if (isImage) {
                    html += '<div class="cal-file-drop__preview" id="file-preview-container">' +
                                '<img id="file-preview-img" alt="Preview" />' +
                            '</div>';
                } else {
                    html += '<svg class="mx-auto mb-2 text-success" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">' +
                                '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>' +
                                '<polyline points="14 2 14 8 20 8"/>' +
                            '</svg>';
                }

                html += '<p class="text-sm font-medium text-charcoal dark:text-white" style="word-break:break-all">' + safeName + '</p>';
                html += '<p class="text-xs mt-0.5 text-mid-gray">' + size;
                if (ext) html += ' &middot; <span class="uppercase font-medium">' + escapeHtml(ext.replace('.', '')) + '</span>';
                html += '</p>';
                html += '<p class="text-xs mt-1.5 text-success font-medium">&#10003; File attached &mdash; ready to submit</p>';

                // Hide prompt, show info
                if (promptEl) promptEl.style.display = 'none';
                infoEl.innerHTML = html;
                infoEl.style.display = '';

                zone.classList.add('has-file');
                zone.classList.remove('is-dragover', 'is-invalid');

                // Remove any old X, then create a fresh one
                var oldBtn = zone.querySelector('.cal-file-drop__remove');
                if (oldBtn) oldBtn.remove();

                var removeBtn = document.createElement('button');
                removeBtn.type = 'button';
                removeBtn.className = 'cal-file-drop__remove';
                removeBtn.setAttribute('aria-label', 'Remove attached file');
                // Inline styles to guarantee positioning (Tailwind v4 layer specificity)
                removeBtn.style.cssText = 'position:absolute;top:8px;right:8px;z-index:10;' +
                    'display:flex;align-items:center;justify-content:center;' +
                    'width:28px;height:28px;padding:0;border-radius:50%;cursor:pointer;' +
                    'color:#ef4444;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);' +
                    'transition:background 0.15s ease,transform 0.15s ease';
                removeBtn.innerHTML =
                    '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">' +
                        '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>' +
                    '</svg>';
                zone.appendChild(removeBtn);

                // X button click → remove file, do NOT open file explorer
                removeBtn.addEventListener('click', function (ev) {
                    ev.preventDefault();
                    ev.stopPropagation();
                    ev.stopImmediatePropagation();
                    resetDropZone();
                });
                removeBtn.addEventListener('mousedown', function (ev) {
                    ev.preventDefault();
                    ev.stopPropagation();
                });

                // Load image preview
                if (isImage) {
                    var reader = new FileReader();
                    reader.onload = function (e) {
                        var img = document.getElementById('file-preview-img');
                        if (img) img.src = e.target.result;
                    };
                    reader.readAsDataURL(file);
                }
            }

            /* ── click on zone → open file dialog (only when empty) ──── */
            zone.addEventListener('click', function (ev) {
                // If the click came from the remove button, do nothing
                if (ev.target.closest('.cal-file-drop__remove')) return;
                // Only open file explorer when no file is attached
                if (!zone.classList.contains('has-file')) {
                    getInput().click();
                }
            });

            /* ── drag & drop ─────────────────────────────────────────── */
            zone.addEventListener('dragenter', function (ev) {
                ev.preventDefault();
                dragCounter++;
                if (!zone.classList.contains('has-file')) {
                    zone.classList.add('is-dragover');
                }
            });

            zone.addEventListener('dragover', function (ev) {
                ev.preventDefault();
            });

            zone.addEventListener('dragleave', function (ev) {
                ev.preventDefault();
                dragCounter--;
                if (dragCounter <= 0) {
                    dragCounter = 0;
                    zone.classList.remove('is-dragover');
                }
            });

            zone.addEventListener('drop', function (ev) {
                ev.preventDefault();
                dragCounter = 0;
                zone.classList.remove('is-dragover');
                var inp = getInput();
                if (inp && ev.dataTransfer.files.length) {
                    inp.files = ev.dataTransfer.files;
                    showFileInfo(inp.files[0]);
                }
            });

            /* ── file input change ────────────────────────────────────── */
            fileInput.addEventListener('change', function () { showFileInfo(fileInput.files[0]); });

            // ── Digits-only enforcement on number fields ─────────────────
            document.querySelectorAll('input[inputmode="numeric"]').forEach(function (inp) {
                inp.addEventListener('input', function () {
                    inp.value = inp.value.replace(/[^0-9]/g, '');
                });
            });

            // ── Submit handler ───────────────────────────────────────────
            document.querySelectorAll('.payment-submit-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var form = btn.closest('form');
                    if (!form) return;

                    // Validate the hidden file input manually — reportValidity()
                    // silently fails on display:none required controls.
                    var fileField = form.querySelector('input[type="file"][data-required="true"]');
                    if (fileField && fileField.files.length === 0) {
                        var dropZone = form.querySelector('.cal-file-drop');
                        if (dropZone) {
                            dropZone.classList.add('is-invalid');
                            dropZone.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        }
                        return;
                    }

                    // Let the browser validate the remaining visible fields.
                    var otherInvalid = false;
                    form.querySelectorAll('input, textarea, select').forEach(function (el) {
                        if (el === fileField) return;
                        if (!el.checkValidity()) otherInvalid = true;
                    });
                    if (otherInvalid && !form.reportValidity()) return;

                    btn.disabled = true;
                    btn.textContent = 'Submitting\u2026';
                    form.submit();
                });
            });
        })();

        // ── Copy-to-clipboard ────────────────────────────────────────
        (function () {
            document.querySelectorAll('[data-copy-target]').forEach(function (btn) {
                btn.addEventListener('click', async function () {
                    var targetId = btn.getAttribute('data-copy-target');
                    var target = document.getElementById(targetId);
                    if (!target) return;
                    var value = target.innerText.trim();
                    try {
                        await navigator.clipboard.writeText(value);
                    } catch (_) {
                        var r = document.createRange();
                        r.selectNodeContents(target);
                        var s = window.getSelection();
                        s.removeAllRanges(); s.addRange(r);
                        document.execCommand('copy'); s.removeAllRanges();
                    }
                    var original = btn.innerText;
                    btn.innerText = 'Copied';
                    btn.disabled = true;
                    setTimeout(function () { btn.innerText = original; btn.disabled = false; }, 1500);
                });
            });
        })();
    </script>
}
