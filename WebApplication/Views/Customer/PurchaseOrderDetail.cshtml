@* WebApplication/Views/Customer/PurchaseOrderDetail.cshtml *@
@* Admin/Manager role only *@
@model WebApplication.Models.Entities.PurchaseOrder
@using WebApplication.Models.Entities
@{
    ViewData["Title"] = $"Purchase Order #{Model.PurchaseOrderId}";
    string badgeCss = Model.Status switch
    {
        PurchaseOrderStatuses.Pending   => "cal-badge-warning",
        PurchaseOrderStatuses.Received  => "cal-badge-success",
        PurchaseOrderStatuses.Cancelled => "cal-badge-error",
        _                               => "cal-badge-muted"
    };
}

<div class="bg-light-gray dark:bg-midnight min-h-[calc(100vh-160px)]">
    <div class="max-w-[1000px] mx-auto px-6 py-12 md:py-16">

        <ol class="cal-breadcrumb">
            <li><a asp-controller="Supplier" asp-action="Index">Suppliers</a></li>
            <li>
                <a asp-controller="Supplier" asp-action="PurchaseOrders" asp-route-supplierId="@Model.SupplierId">
                    @(Model.Supplier?.Name ?? "Purchase Orders")
                </a>
            </li>
            <li>PO #@Model.PurchaseOrderId</li>
        </ol>

        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8" data-reveal>
            <div>
                <h1 class="font-display text-2xl md:text-3xl font-semibold text-charcoal dark:text-white">PO #@Model.PurchaseOrderId</h1>
                <p class="text-sm text-mid-gray mt-1">
                    Ordered @Model.OrderDate.ToString("MMMM d, yyyy")
                    @if (Model.CreatedBy != null)
                    {
                        var createdBy = Model.CreatedBy;
                        <text> · Created by @createdBy.FirstName @createdBy.LastName</text>
                    }
                </p>
            </div>
            <span class="cal-badge @badgeCss">@Model.Status</span>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-6">

            @* ── Line Items ── *@
            <div class="cal-card-static overflow-hidden" data-reveal="delay-1">
                <div class="px-6 py-4 border-b border-border-ring dark:border-white/10">
                    <h2 class="font-display text-base font-semibold text-charcoal dark:text-white" style="letter-spacing:0.2px">Line Items</h2>
                </div>
                <div class="divide-y divide-border-ring dark:divide-white/10">
                    @foreach (PurchaseOrderItem item in Model.Items)
                    {
                        <div class="flex items-center justify-between px-6 py-4">
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-medium text-charcoal dark:text-white truncate">@(item.Product?.Name ?? "Product")</p>
                                @if (!string.IsNullOrWhiteSpace(item.Variant?.VariantName) && item.Variant.VariantName != "Default")
                                {
                                    <p class="text-xs text-mid-gray">@item.Variant.VariantName</p>
                                }
                                <p class="text-xs text-mid-gray mt-0.5">Qty: @item.Quantity · ₱@item.UnitPrice.ToString("N2") / unit</p>
                            </div>
                            <p class="text-sm font-semibold text-charcoal dark:text-white whitespace-nowrap">₱@((item.Quantity * item.UnitPrice).ToString("N2"))</p>
                        </div>
                    }
                </div>
                <div class="flex justify-between px-6 py-4 border-t border-border-ring dark:border-white/10 bg-light-gray/50 dark:bg-white/[0.02]">
                    <span class="text-sm font-semibold text-charcoal dark:text-white">Total</span>
                    <span class="font-display text-lg font-semibold text-charcoal dark:text-white">₱@Model.Items.Sum(i => i.Quantity * i.UnitPrice).ToString("N2")</span>
                </div>
            </div>

            @* ── Sidebar ── *@
            <aside class="space-y-5">
                <div class="cal-card-static p-5" data-reveal="delay-2">
                    <h2 class="font-display text-base font-semibold text-charcoal dark:text-white mb-3" style="letter-spacing:0.2px">Supplier</h2>
                    @if (Model.Supplier != null)
                    {
                        <dl class="space-y-2 text-sm">
                            <div class="flex justify-between">
                                <dt class="text-mid-gray">Name</dt>
                                <dd class="text-charcoal dark:text-white font-medium">@Model.Supplier.Name</dd>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(Model.Supplier.ContactPerson))
                            {
                                <div class="flex justify-between">
                                    <dt class="text-mid-gray">Contact</dt>
                                    <dd class="text-charcoal dark:text-white">@Model.Supplier.ContactPerson</dd>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(Model.Supplier.Email))
                            {
                                <div class="flex justify-between">
                                    <dt class="text-mid-gray">Email</dt>
                                    <dd><a href="mailto:@Model.Supplier.Email" class="text-charcoal dark:text-white hover:underline">@Model.Supplier.Email</a></dd>
                                </div>
                            }
                        </dl>
                    }
                </div>

                <div class="cal-card-static p-5" data-reveal="delay-2">
                    <h2 class="font-display text-base font-semibold text-charcoal dark:text-white mb-3" style="letter-spacing:0.2px">Timeline</h2>
                    <dl class="space-y-2 text-sm">
                        <div class="flex justify-between">
                            <dt class="text-mid-gray">Ordered</dt>
                            <dd class="text-charcoal dark:text-white">@Model.OrderDate.ToString("MMM d, yyyy")</dd>
                        </div>
                        @if (Model.ExpectedDeliveryDate.HasValue)
                        {
                            <div class="flex justify-between">
                                <dt class="text-mid-gray">Expected</dt>
                                <dd class="text-charcoal dark:text-white">@Model.ExpectedDeliveryDate.Value.ToString("MMM d, yyyy")</dd>
                            </div>
                        }
                        @if (Model.Status == PurchaseOrderStatuses.Received)
                        {
                            <div class="flex justify-between">
                                <dt class="text-mid-gray">Received</dt>
                                <dd class="text-charcoal dark:text-white">@Model.CreatedAt.ToString("MMM d, yyyy")</dd>
                            </div>
                        }
                    </dl>
                </div>
            </aside>

        </div>
    </div>
</div>
