@* WebApplication/Views/Customer/SupportList.cshtml *@
@model IReadOnlyList<WebApplication.Models.ViewModels.SupportTicketViewModel>
@{
    ViewData["Title"] = "Support Tickets";
}

<div class="bg-light-gray dark:bg-midnight min-h-[calc(100vh-160px)]">
    <div class="max-w-[900px] mx-auto px-6 py-12 md:py-16">

        <div class="flex items-center justify-between mb-10" data-reveal>
            <div>
                <h1 class="font-display text-3xl md:text-4xl font-semibold text-charcoal dark:text-white">Support Tickets</h1>
                @if (Model.Any())
                {
                    <p class="text-base text-mid-gray mt-2">@Model.Count ticket@(Model.Count != 1 ? "s" : "")</p>
                }
            </div>
            <a asp-controller="Support" asp-action="Create" class="btn-dark">+ New Ticket</a>
        </div>

        @if (!Model.Any())
        {
            <div class="cal-card-static p-12 text-center" data-reveal="delay-1">
                <div class="text-mid-gray mb-4 text-3xl">💬</div>
                <h2 class="font-display text-xl font-semibold text-charcoal dark:text-white mb-2">No support tickets</h2>
                <p class="text-sm text-mid-gray mb-6">Have a question or issue? Our team is happy to help.</p>
                <a asp-controller="Support" asp-action="Create" class="btn-dark">Open a Ticket</a>
            </div>
        }
        else
        {
            <div class="cal-card-static divide-y divide-border-ring dark:divide-white/10 overflow-hidden" data-reveal="delay-1">
                @foreach (WebApplication.Models.ViewModels.SupportTicketViewModel ticket in Model)
                {
                    @await Html.PartialAsync("~/Views/Customer/Partials/_SupportTicketCard.cshtml", ticket)
                }
            </div>
        }

    </div>
</div>
