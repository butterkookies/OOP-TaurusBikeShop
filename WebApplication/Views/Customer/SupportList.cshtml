@* WebApplication/Views/Customer/SupportList.cshtml *@
@model WebApplication.Models.ViewModels.SupportListViewModel
@{
    ViewData["Title"] = "My Support Tickets";
}

<div class="container py-5">

    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
        <h1 class="h3 mb-0">My Support Tickets</h1>
        <a href="/Customer/Support/Create" class="btn btn-danger">+ New Ticket</a>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Tickets.Any())
    {
        <div class="text-center py-5 text-muted">
            <p class="fs-5 mb-1">You have no support tickets.</p>
            <p>Need help? <a href="/Customer/Support/Create">Create a new ticket</a>.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Ticket #</th>
                            <th scope="col">Category</th>
                            <th scope="col">Subject</th>
                            <th scope="col">Order</th>
                            <th scope="col">Status</th>
                            <th scope="col">Created</th>
                            <th scope="col">Last Updated</th>
                            <th scope="col"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ticket in Model.Tickets)
                        {
                            <tr>
                                <td class="fw-semibold">#@ticket.TicketId</td>
                                <td>@ticket.Category</td>
                                <td>@ticket.Subject</td>
                                <td class="text-muted small">
                                    @(string.IsNullOrEmpty(ticket.OrderNumber) ? "—" : ticket.OrderNumber)
                                </td>
                                <td>
                                    @{
                                        string badgeClass = ticket.Status switch
                                        {
                                            "Open"             => "bg-danger",
                                            "InProgress"       => "bg-warning text-dark",
                                            "AwaitingResponse" => "bg-info text-dark",
                                            "Resolved"         => "bg-success",
                                            "Closed"           => "bg-secondary",
                                            _                  => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass">@ticket.Status</span>
                                </td>
                                <td class="text-muted small">@ticket.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td class="text-muted small">
                                    @(ticket.UpdatedAt.HasValue
                                        ? ticket.UpdatedAt.Value.ToString("MMM dd, yyyy")
                                        : "—")
                                </td>
                                <td>
                                    <a href="/Customer/Support/@ticket.TicketId"
                                       class="btn btn-sm btn-outline-secondary">
                                        View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>
