@using WebApplication.Models.Entities
@{
    ViewData["Title"] = "Product Details - Taurus Bike Shop";
    Layout = "_Layout";

    var    reviews      = ViewBag.Reviews as IEnumerable<Review> ?? Enumerable.Empty<Review>();
    bool   canReview    = ViewBag.CanReview == true;
    double avgRating    = ViewBag.AverageRating is double d ? d : 0.0;
    int    reviewCount  = reviews.Count();
}

@section Styles {
    <link rel="stylesheet" href="~/css/product-details.css" />
    <style>
        /* ── Reviews Section ── */
        .reviews-section {
            max-width: 860px;
            margin: 48px auto 0;
            padding: 0 16px 64px;
        }

        .reviews-section h2 {
            font-size: 18px;
            font-weight: 700;
            color: #f0f0f0;
            margin-bottom: 4px;
        }

        .avg-rating-row {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 28px;
        }

        .avg-score {
            font-size: 36px;
            font-weight: 800;
            color: #f0f0f0;
            line-height: 1;
        }

        .stars-display {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .stars {
            color: #f5a623;
            font-size: 18px;
            letter-spacing: 2px;
        }

        .review-count {
            font-size: 12px;
            color: #666;
        }

        /* Review cards */
        .review-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
            margin-bottom: 32px;
        }

        .review-card {
            background: #141414;
            border: 1px solid #2a2a2a;
            border-radius: 8px;
            padding: 20px 24px;
        }

        .review-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .reviewer-name {
            font-size: 14px;
            font-weight: 600;
            color: #f0f0f0;
        }

        .review-meta {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .review-date {
            font-size: 12px;
            color: #555;
        }

        .verified-badge {
            font-size: 11px;
            background: #002a12;
            color: #4caf7d;
            border: 1px solid #004020;
            border-radius: 10px;
            padding: 2px 8px;
        }

        .review-stars {
            color: #f5a623;
            font-size: 14px;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }

        .review-comment {
            font-size: 14px;
            color: #bbb;
            line-height: 1.6;
            margin: 0;
        }

        .no-reviews {
            text-align: center;
            padding: 32px;
            color: #555;
            font-size: 14px;
            background: #0e0e0e;
            border: 1px dashed #2a2a2a;
            border-radius: 8px;
            margin-bottom: 32px;
        }

        /* Write-a-review form */
        .write-review-toggle {
            background: none;
            border: 1px solid #E10600;
            color: #E10600;
            padding: 10px 22px;
            border-radius: 4px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s, color 0.2s;
            margin-bottom: 24px;
        }

        .write-review-toggle:hover {
            background: #E10600;
            color: #fff;
        }

        .review-form-wrapper {
            display: none;
            background: #141414;
            border: 1px solid #2a2a2a;
            border-radius: 8px;
            padding: 24px;
            margin-bottom: 24px;
        }

        .review-form-wrapper h3 {
            font-size: 15px;
            font-weight: 600;
            color: #f0f0f0;
            margin-bottom: 20px;
        }

        /* Star picker */
        .star-picker {
            display: flex;
            gap: 6px;
            margin-bottom: 20px;
        }

        .star-picker .star-btn {
            background: none;
            border: none;
            font-size: 28px;
            color: #333;
            cursor: pointer;
            transition: color 0.15s, transform 0.1s;
            padding: 0;
            line-height: 1;
        }

        .star-picker .star-btn.selected,
        .star-picker .star-btn:hover {
            color: #f5a623;
            transform: scale(1.15);
        }

        .review-form-wrapper textarea {
            width: 100%;
            background: #0e0e0e;
            border: 1px solid #2a2a2a;
            border-radius: 4px;
            color: #f0f0f0;
            font-size: 14px;
            padding: 12px;
            resize: vertical;
            min-height: 100px;
            box-sizing: border-box;
            outline: none;
            transition: border-color 0.2s;
        }

        .review-form-wrapper textarea:focus {
            border-color: #E10600;
        }

        .review-form-actions {
            display: flex;
            gap: 12px;
            margin-top: 16px;
            align-items: center;
        }

        .btn-submit-review {
            background: #E10600;
            color: #fff;
            border: none;
            padding: 10px 24px;
            border-radius: 4px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
        }

        .btn-submit-review:hover { background: #b80500; }
        .btn-submit-review:disabled { background: #555; cursor: not-allowed; }

        .btn-cancel-review {
            background: none;
            border: 1px solid #333;
            color: #888;
            padding: 10px 18px;
            border-radius: 4px;
            font-size: 14px;
            cursor: pointer;
            transition: border-color 0.2s, color 0.2s;
        }

        .btn-cancel-review:hover { border-color: #666; color: #ccc; }

        .review-feedback {
            font-size: 13px;
            padding: 8px 14px;
            border-radius: 4px;
            display: none;
        }

        .review-feedback.success {
            background: #002a12;
            color: #4caf7d;
            border: 1px solid #004020;
        }

        .review-feedback.error {
            background: #2a0000;
            color: #ff5252;
            border: 1px solid #4a0000;
        }
    </style>
}

<div class="product-page">
    <div class="product-gallery">
        <img id="main-image" src="~/images/bike1.jpg" alt="Taurus MTB Bike" />
        <div class="thumbnail-row">
            <img src="~/images/bike1.jpg" alt="Taurus MTB Bike" class="thumb active" />
            <img src="~/images/bike2.jpg" alt="Taurus MTB Bike Side" class="thumb" />
            <img src="~/images/bike3.jpg" alt="Taurus MTB Bike Closeup" class="thumb" />
        </div>
    </div>

    <div class="product-info">
        <h1>Taurus MTB Bike</h1>
        <p class="price">$1,200.00</p>
        <p class="description">
            Experience the thrill of the trail with the Taurus MTB Bike, built for speed, durability, and style. Perfect for both beginners and seasoned riders.
        </p>

        <div class="quantity-selector">
            <label for="quantity">Quantity:</label>
            <input type="number" id="quantity" min="1" value="1" />
        </div>

        <div class="product-actions">
            <button id="add-to-cart">Add to Cart &#128722;</button>
            <button id="buy-now">Buy Now &#128179;</button>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════ -->
<!-- Reviews Section                             -->
<!-- ═══════════════════════════════════════════ -->
<div class="reviews-section" id="reviews-section" data-product-id="@(ViewBag.ProductId ?? 0)">

    <h2>Customer Reviews</h2>

    <!-- Average Rating -->
    <div class="avg-rating-row">
        @if (reviewCount > 0)
        {
            <span class="avg-score">@avgRating.ToString("0.0")</span>
            <div class="stars-display">
                <span class="stars" id="avg-stars-display">@RenderStars(avgRating)</span>
                <span class="review-count" id="review-count-label">@reviewCount review@(reviewCount != 1 ? "s" : "")</span>
            </div>
        }
        else
        {
            <span class="avg-score" style="color:#444;">—</span>
            <div class="stars-display">
                <span class="stars" style="color:#333;">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
                <span class="review-count" id="review-count-label">No reviews yet</span>
            </div>
        }
    </div>

    <!-- Write a Review button (only if user can review) -->
    @if (canReview)
    {
        <button class="write-review-toggle" id="toggle-review-form">Write a Review</button>

        <div class="review-form-wrapper" id="review-form-wrapper">
            <h3>Share Your Experience</h3>

            <div class="star-picker" id="star-picker" role="group" aria-label="Select rating">
                <button type="button" class="star-btn" data-value="1" aria-label="1 star">&#9733;</button>
                <button type="button" class="star-btn" data-value="2" aria-label="2 stars">&#9733;</button>
                <button type="button" class="star-btn" data-value="3" aria-label="3 stars">&#9733;</button>
                <button type="button" class="star-btn" data-value="4" aria-label="4 stars">&#9733;</button>
                <button type="button" class="star-btn" data-value="5" aria-label="5 stars">&#9733;</button>
            </div>
            <input type="hidden" id="selected-rating" value="0" />

            <textarea id="review-comment" placeholder="Tell us what you think about this product..."></textarea>

            <!-- Hidden fields populated by JS -->
            <input type="hidden" id="review-product-id" value="0" />
            <input type="hidden" id="review-order-id"   value="0" />

            <div class="review-form-actions">
                <button class="btn-submit-review" id="submit-review-btn">Submit Review</button>
                <button class="btn-cancel-review" id="cancel-review-btn">Cancel</button>
                <span class="review-feedback" id="review-feedback"></span>
            </div>
        </div>
    }

    <!-- Review List -->
    <div class="review-list" id="review-list">
        @if (reviewCount == 0)
        {
            <div class="no-reviews" id="no-reviews-placeholder">
                Be the first to review this product!
            </div>
        }
        else
        {
            foreach (var review in reviews)
            {
                <div class="review-card">
                    <div class="review-card-header">
                        <span class="reviewer-name">@(review.User?.FullName ?? "Anonymous")</span>
                        <div class="review-meta">
                            @if (review.IsVerifiedPurchase)
                            {
                                <span class="verified-badge">Verified Purchase</span>
                            }
                            <span class="review-date">@review.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                    </div>
                    <div class="review-stars">@Html.Raw(RenderStars(review.Rating))</div>
                    @if (!string.IsNullOrWhiteSpace(review.Comment))
                    {
                        <p class="review-comment">@review.Comment</p>
                    }
                </div>
            }
        }
    </div>

</div>

@section Scripts {
    <script>
        const mainImage = document.getElementById('main-image');
        const thumbs = document.querySelectorAll('.thumb');

        thumbs.forEach(thumb => {
            thumb.addEventListener('click', () => {
                mainImage.src = thumb.src;
                thumbs.forEach(t => t.classList.remove('active'));
                thumb.classList.add('active');
            });
        });

        document.getElementById('add-to-cart').addEventListener('click', () => {
            const qty = parseInt(document.getElementById('quantity').value);
            alert(`Added ${qty} Taurus MTB Bike(s) to your cart!`);
        });

        document.getElementById('buy-now').addEventListener('click', () => {
            const qty = parseInt(document.getElementById('quantity').value);
            alert(`Proceeding to buy ${qty} Taurus MTB Bike(s)...`);
            window.location.href = '/Customer/Checkout';
        });
    </script>
    <script src="~/js/reviews.js"></script>
}

@functions {
    string RenderStars(double rating)
    {
        int full  = (int)Math.Round(rating);
        int empty = 5 - full;
        return string.Concat(Enumerable.Repeat("&#9733;", full))
             + string.Concat(Enumerable.Repeat("&#9734;", empty));
    }
}
