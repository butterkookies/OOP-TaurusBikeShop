@* WebApplication/Views/Customer/ProductDetails.cshtml *@
@model WebApplication.Models.ViewModels.ProductDetailViewModel
@{
    ViewData["Title"] = Model.Name;
}

@Html.AntiForgeryToken()

<div class="bg-white dark:bg-midnight min-h-[calc(100vh-160px)]">
    <div class="max-w-[1200px] mx-auto px-6 py-10 md:py-14">

        @* Breadcrumb *@
        <ol class="cal-breadcrumb">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li><a asp-controller="Product" asp-action="List">Catalog</a></li>
            <li><a asp-controller="Product" asp-action="List" asp-route-categoryId="@ViewBag.CategoryId">@Model.Category</a></li>
            <li>@Model.Name</li>
        </ol>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-16">

            @* ==================== IMAGE GALLERY ==================== *@
            <div>
                @* Main image *@
                <div class="aspect-square bg-light-gray dark:bg-neutral-900 rounded-2xl overflow-hidden flex items-center justify-center">
                    @if (Model.PrimaryImageUrl != null)
                    {
                        <img src="@Model.PrimaryImageUrl" alt="@Model.Name"
                             class="w-full h-full object-contain" id="main-product-img" loading="eager" />
                    }
                    else
                    {
                        <div class="text-mid-gray text-4xl" aria-label="No image available">△</div>
                    }
                </div>

                @* Thumbnail row *@
                @if (Model.Images.Count > 1)
                {
                    <div class="flex gap-2 mt-3 overflow-x-auto">
                        @foreach (WebApplication.Models.Entities.ProductImage img in Model.Images)
                        {
                            <button type="button"
                                    class="w-16 h-16 rounded-lg overflow-hidden border-2 shrink-0 transition-colors @(img.IsPrimary ? "border-charcoal dark:border-white" : "border-transparent hover:border-charcoal/30 dark:hover:border-white/30")"
                                    data-src="@img.ImageUrl" aria-label="View image"
                                    onclick="document.getElementById('main-product-img').src=this.dataset.src;this.parentElement.querySelectorAll('button').forEach(b=>b.classList.remove('border-charcoal','dark:border-white'));this.classList.add('border-charcoal','dark:border-white')">
                                <img src="@img.ImageUrl" alt="" loading="lazy" class="w-full h-full object-cover" />
                            </button>
                        }
                    </div>
                }
            </div>

            @* ==================== PRODUCT INFO ==================== *@
            <div>
                @if (Model.Brand != null)
                {
                    <p class="text-sm font-medium text-mid-gray uppercase tracking-wider mb-1">@Model.Brand</p>
                }

                <h1 class="font-display text-3xl md:text-4xl font-semibold text-charcoal dark:text-white leading-tight">@Model.Name</h1>

                @* Rating summary *@
                @if (Model.ReviewCount > 0)
                {
                    <div class="flex items-center gap-2 mt-3">
                        <div class="flex gap-0.5" aria-label="@Model.AverageRating out of 5">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span class="text-sm @(i <= (int)Model.AverageRating ? "cal-star--filled" : (i - 0.5m <= Model.AverageRating ? "cal-star--half" : "cal-star"))">★</span>
                            }
                        </div>
                        <span class="text-sm text-mid-gray">(@Model.ReviewCount review@(Model.ReviewCount != 1 ? "s" : ""))</span>
                    </div>
                }

                @* Price *@
                <div class="font-display text-3xl font-semibold text-charcoal dark:text-white mt-5" id="displayed-price">
                    @Model.FormattedPrice
                </div>

                @* Short description *@
                @if (!string.IsNullOrWhiteSpace(Model.ShortDescription))
                {
                    <p class="text-base text-mid-gray leading-relaxed mt-4">@Model.ShortDescription</p>
                }

                @* Variant selector *@
                @if (Model.Variants.Count > 1 ||
                     (Model.Variants.Count == 1 && Model.Variants[0].VariantName != "Default"))
                {
                    <div class="mt-6">
                        <p class="cal-label mb-2">Select Option</p>
                        <div class="flex flex-wrap gap-2" id="variant-selector">
                            @foreach (WebApplication.Models.Entities.ProductVariant v in Model.Variants)
                            {
                                <button type="button"
                                        class="cal-variant-btn @(v.ProductVariantId == Model.SelectedVariantId ? "cal-variant-btn--selected" : "") @(v.StockQuantity == 0 ? "cal-variant-btn--oos" : "")"
                                        data-variant-id="@v.ProductVariantId"
                                        data-additional-price="@v.AdditionalPrice"
                                        data-stock="@v.StockQuantity"
                                        @(v.StockQuantity == 0 ? "disabled" : "")
                                        aria-pressed="@(v.ProductVariantId == Model.SelectedVariantId ? "true" : "false")">
                                    @v.VariantName
                                    @if (v.StockQuantity == 0)
                                    {
                                        <span class="text-xs ml-1 opacity-60">(Out of Stock)</span>
                                    }
                                </button>
                            }
                        </div>
                    </div>
                }

                @* Stock status *@
                <div class="mt-4" id="stock-status">
                    @if (Model.IsOutOfStock)
                    {
                        <span class="cal-stock-oos">Out of Stock</span>
                    }
                    else if (Model.TotalStock <= 5)
                    {
                        <span class="cal-stock-low">Only @Model.TotalStock left</span>
                    }
                    else
                    {
                        <span class="cal-stock-in">In Stock</span>
                    }
                </div>

                @* Add to cart / Buy Now / Wishlist *@
                <div class="flex items-center gap-3 mt-6">
                    @if (!Model.IsOutOfStock)
                    {
                        <div class="cal-qty">
                            <button type="button" class="cal-qty-btn" id="qty-minus" aria-label="Decrease quantity">−</button>
                            <input type="number" id="qty-input" class="cal-qty-val"
                                   value="1" min="1" max="@Model.TotalStock" data-max-stock="@Model.TotalStock" aria-label="Quantity" />
                            <button type="button" class="cal-qty-btn" id="qty-plus" aria-label="Increase quantity">+</button>
                        </div>

                        <button type="button" class="btn-dark btn-lg flex-1"
                                id="add-to-cart-btn"
                                data-product-id="@Model.ProductId"
                                data-variant-id="@Model.SelectedVariantId">
                            Add to Cart
                        </button>

                        <button type="button"
                                class="btn-lg flex-1 flex items-center justify-center font-semibold rounded-lg border-2 border-charcoal dark:border-white text-charcoal dark:text-white hover:bg-charcoal hover:text-white dark:hover:bg-white dark:hover:text-midnight transition-colors"
                                id="buy-now-btn"
                                data-product-id="@Model.ProductId"
                                data-variant-id="@Model.SelectedVariantId">
                            Buy Now
                        </button>
                    }

                    <button type="button"
                            class="cal-heart @(Model.IsInWishlist ? "cal-heart--active" : "")"
                            data-product-id="@Model.ProductId"
                            aria-label="@(Model.IsInWishlist ? "Remove from wishlist" : "Add to wishlist")"
                            aria-pressed="@(Model.IsInWishlist ? "true" : "false")">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="heart-outline"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="heart-filled"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                    </button>
                </div>

                @* ── Buy Now Modal ── *@
                @if (!Model.IsOutOfStock)
                {
                    <div id="buy-now-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm hidden">
                        <div class="bg-white dark:bg-neutral-900 rounded-2xl shadow-xl max-w-md w-full mx-4 p-8">
                            <h3 class="font-display text-xl font-semibold text-charcoal dark:text-white mb-2">Ready to buy?</h3>
                            <p class="text-sm text-mid-gray mb-6">
                                <strong class="text-charcoal dark:text-white">@Model.Name</strong> will be added to your cart.
                            </p>
                            <div class="flex flex-col gap-3">
                                <button type="button" id="buy-now-checkout" class="btn-dark btn-lg w-full">
                                    Proceed to Checkout
                                </button>
                                <a asp-controller="Product" asp-action="List"
                                   class="btn-lg w-full text-center font-semibold rounded-lg border border-border-ring dark:border-white/15 text-charcoal dark:text-white hover:bg-light-gray dark:hover:bg-white/5 transition-colors">
                                    Continue Browsing
                                </a>
                            </div>
                            <button type="button" id="buy-now-close"
                                    class="absolute top-4 right-4 text-mid-gray hover:text-charcoal dark:hover:text-white transition-colors"
                                    aria-label="Close">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                            </button>
                        </div>
                    </div>
                }

            </div>
        </div>

        @* ==================== SPECS TABLE ==================== *@
        @{
            bool hasSpecs = Model.Material != null || Model.Color != null ||
                Model.WheelSize != null || Model.SpeedCompatibility != null ||
                Model.BoostCompatible != null || Model.TubelessReady != null ||
                Model.AxleStandard != null || Model.SuspensionTravel != null ||
                Model.BrakeType != null || !string.IsNullOrWhiteSpace(Model.AdditionalSpecs);
        }
        @if (hasSpecs || !string.IsNullOrWhiteSpace(Model.Description))
        {
            <div class="mt-16">
                <div class="cal-tabs" id="detail-tabs">
                    <button class="cal-tab cal-tab--active" data-tab="description">Description</button>
                    @if (hasSpecs)
                    {
                        <button class="cal-tab" data-tab="specs">Specifications</button>
                    }
                </div>

                <div class="cal-tab-panel cal-tab-panel--active" id="tab-description">
                    <div class="prose prose-sm max-w-none text-mid-gray dark:text-neutral-400 leading-relaxed">
                        <p>@(Model.Description ?? Model.ShortDescription ?? "No description available.")</p>
                    </div>
                </div>

                @if (hasSpecs)
                {
                    <div class="cal-tab-panel" id="tab-specs">
                        <table class="cal-specs w-full">
                            @if (Model.Material != null)           { <tr><th>Material</th><td>@Model.Material</td></tr> }
                            @if (Model.Color != null)              { <tr><th>Color</th><td>@Model.Color</td></tr> }
                            @if (Model.WheelSize != null)          { <tr><th>Wheel Size</th><td>@Model.WheelSize</td></tr> }
                            @if (Model.SpeedCompatibility != null) { <tr><th>Speed Compatibility</th><td>@Model.SpeedCompatibility</td></tr> }
                            @if (Model.BrakeType != null)          { <tr><th>Brake Type</th><td>@Model.BrakeType</td></tr> }
                            @if (Model.AxleStandard != null)       { <tr><th>Axle Standard</th><td>@Model.AxleStandard</td></tr> }
                            @if (Model.SuspensionTravel != null)   { <tr><th>Suspension Travel</th><td>@Model.SuspensionTravel</td></tr> }
                            @if (Model.BoostCompatible != null)    { <tr><th>Boost Compatible</th><td>@(Model.BoostCompatible.Value ? "Yes" : "No")</td></tr> }
                            @if (Model.TubelessReady != null)      { <tr><th>Tubeless Ready</th><td>@(Model.TubelessReady.Value ? "Yes" : "No")</td></tr> }
                            @if (!string.IsNullOrWhiteSpace(Model.AdditionalSpecs)) { <tr><th>Additional Specs</th><td>@Model.AdditionalSpecs</td></tr> }
                        </table>
                    </div>
                }
            </div>
        }

        @* ==================== REVIEWS ==================== *@
        <div class="mt-16" id="reviews-section">
            <div class="flex items-center justify-between mb-6">
                <h2 class="font-display text-2xl font-semibold text-charcoal dark:text-white">Customer Reviews</h2>
                @if (Model.ReviewCount > 0)
                {
                    <div class="flex items-baseline gap-1">
                        <span class="font-display text-2xl font-semibold text-charcoal dark:text-white">@Model.AverageRating.ToString("0.0")</span>
                        <span class="text-sm text-mid-gray">/5</span>
                        <span class="text-sm text-mid-gray ml-1">(@Model.ReviewCount)</span>
                    </div>
                }
            </div>

            @* Submit review form *@
            @if (Model.CanReview)
            {
                <div class="mb-8">
                    @await Html.PartialAsync("~/Views/Customer/Partials/_ReviewForm.cshtml",
                        new WebApplication.Models.ViewModels.ReviewViewModel
                        {
                            ProductId = Model.ProductId,
                            OrderId   = Model.ReviewOrderId
                        })
                </div>
            }

            @* Review list *@
            <div id="review-list">
                @if (!Model.Reviews.Any())
                {
                    <p class="text-sm text-mid-gray py-8 text-center">No reviews yet. Be the first to review this product.</p>
                }
                else
                {
                    <div class="space-y-4">
                        @foreach (WebApplication.Models.ViewModels.ProductReviewViewModel review in Model.Reviews)
                        {
                            <div class="cal-card-static p-5">
                                <div class="flex items-center gap-2 mb-2">
                                    <strong class="text-sm text-charcoal dark:text-white">@review.ReviewerName</strong>
                                    @if (review.IsVerifiedPurchase)
                                    {
                                        <span class="cal-badge cal-badge-success">✓ Verified Purchase</span>
                                    }
                                </div>
                                <div class="flex gap-0.5 mb-2" aria-label="@review.Rating out of 5">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <span class="text-sm @(i <= review.Rating ? "cal-star--filled" : "cal-star")">★</span>
                                    }
                                </div>
                                <p class="text-sm text-charcoal dark:text-neutral-200 leading-relaxed">@review.Comment</p>
                                <div class="mt-3 text-xs text-mid-gray">
                                    <span>@review.CreatedAt</span>
                                </div>
                            </div>
                        }
                    </div>

                    @if (Model.ReviewCount > Model.Reviews.Count)
                    {
                        <button type="button" class="btn-ghost mt-4"
                                id="load-more-reviews"
                                data-product-id="@Model.ProductId"
                                data-page="2">
                            Load More Reviews
                        </button>
                    }
                }
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/js/product-catalog.js" asp-append-version="true"></script>
    <script src="~/js/review.js"          asp-append-version="true"></script>
}
