@* WebApplication/Views/Customer/Review.cshtml *@
@model WebApplication.Models.ViewModels.ReviewViewModel
@{
    ViewData["Title"] = "Write a Review";
}

@Html.AntiForgeryToken()

<div class="bg-light-gray dark:bg-midnight min-h-[calc(100vh-160px)]">
    <div class="max-w-[1000px] mx-auto px-6 py-12 md:py-16">

        <ol class="cal-breadcrumb">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li><a asp-controller="Order" asp-action="History">Orders</a></li>
            <li>Write a Review</li>
        </ol>

        <div class="grid grid-cols-1 lg:grid-cols-[360px_1fr] gap-10">

            @* ── LEFT: Product context card ── *@
            <div>
                <div class="cal-card-static p-6 sticky top-24" data-reveal>
                    <a asp-controller="Home" asp-action="Index" class="inline-block mb-5">
                        <img src="~/FULL-COLOR.png" alt="Taurus Bike Shop" class="h-8 w-auto" />
                    </a>

                    <hr class="cal-divider !my-4" />

                    <p class="text-sm text-mid-gray mb-5">Your feedback shapes the ride for everyone.</p>

                    <div class="p-4 bg-light-gray dark:bg-white/5 rounded-xl">
                        <span class="cal-badge cal-badge-success mb-3">✓ Verified Purchase</span>
                        <p class="text-xs text-mid-gray uppercase tracking-wider mb-1">
                            @(Model?.ProductCategory ?? "Category")
                        </p>
                        <h2 class="font-display text-lg font-semibold text-charcoal dark:text-white leading-tight">
                            @(Model?.ProductName ?? "Product Name")
                        </h2>
                        <div class="flex items-center gap-2 mt-2 text-sm text-mid-gray">
                            <span>@(Model?.BrandName ?? "Brand")</span>
                            @if (!string.IsNullOrEmpty(Model?.SKU))
                            {
                                <span>· @Model.SKU</span>
                            }
                        </div>

                        @* Star display that syncs with form selection *@
                        <div class="flex gap-0.5 mt-3" id="cardStars" aria-hidden="true">
                            @for (int i = 0; i < 5; i++)
                            {
                                <span class="text-lg cal-star">★</span>
                            }
                        </div>
                    </div>

                    <div class="mt-5 space-y-2">
                        <a asp-controller="Product" asp-action="List"
                           class="flex items-center gap-2 text-sm text-mid-gray hover:text-charcoal transition-colors dark:hover:text-white">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                            Back to Catalog
                        </a>
                        <a asp-controller="Order" asp-action="History"
                           class="flex items-center gap-2 text-sm text-mid-gray hover:text-charcoal transition-colors dark:hover:text-white">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                            My Orders
                        </a>
                    </div>
                </div>
            </div>

            @* ── RIGHT: Review form + Existing reviews ── *@
            <div>
                <div class="mb-6" data-reveal>
                    <p class="text-sm font-medium tracking-widest uppercase text-mid-gray mb-2">Share Your Experience</p>
                    <h1 class="font-display text-3xl font-semibold text-charcoal dark:text-white">Write a Review</h1>
                    <p class="text-sm text-mid-gray mt-2">Help other riders make the right choice</p>
                </div>

                @* ── FORM ── *@
                <div class="cal-card-static p-6 mb-8" data-reveal="delay-1">
                    <form id="reviewForm" method="post" asp-controller="Review" asp-action="Submit" novalidate>
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="ProductId" value="@(Model?.ProductId ?? 0)" />
                        <input type="hidden" name="OrderId"   value="@(Model?.OrderId   ?? 0)" />

                        @* Star rating *@
                        <div class="mb-6">
                            <p class="cal-label mb-3">Your Rating</p>
                            <div class="cal-star-picker" id="starSelector" role="radiogroup" aria-label="Rate this product from 1 to 5 stars">
                                @for (int i = 5; i >= 1; i--)
                                {
                                    <input type="radio" id="star@(i)" name="Rating" value="@i" class="cal-star-picker__input" required />
                                    <label for="star@(i)" class="cal-star-picker__label" aria-label="@i star@(i != 1 ? "s" : "")">★</label>
                                }
                            </div>
                            <p class="text-sm text-mid-gray mt-2" id="ratingLabel" aria-live="polite">Select a rating</p>
                        </div>

                        <hr class="cal-divider" />

                        @* Comment *@
                        <div class="mb-6">
                            <label for="comment" class="cal-label">Tell us about your experience</label>
                            <textarea class="cal-input cal-textarea" id="comment" name="Comment" rows="5"
                                      maxlength="1000"
                                      placeholder="Describe the quality, fit, performance, and anything else riders should know…"
                                      required></textarea>
                            <div class="flex justify-end mt-1">
                                <span class="text-xs text-mid-gray"><span id="charCount">0</span> / 1000</span>
                            </div>
                        </div>

                        <button type="submit" class="btn-dark btn-lg" id="submitBtn">
                            Submit Review
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </button>

                        <p class="text-xs text-mid-gray mt-3">
                            Changed your mind?
                            <a asp-controller="Order" asp-action="History" class="font-medium underline underline-offset-2 hover:text-charcoal dark:hover:text-white">Back to Orders →</a>
                        </p>
                    </form>
                </div>

                @* ── EXISTING REVIEWS ── *@
                @if (Model?.ExistingReviews != null && Model.ExistingReviews.Any())
                {
                    <div data-reveal="delay-2">
                        <div class="flex items-center justify-between mb-5">
                            <h2 class="font-display text-xl font-semibold text-charcoal dark:text-white">What Others Are Saying</h2>
                            <span class="cal-badge cal-badge-muted">@Model.ExistingReviews.Count() review@(Model.ExistingReviews.Count() == 1 ? "" : "s")</span>
                        </div>

                        <div class="space-y-4">
                            @foreach (var review in Model.ExistingReviews.OrderByDescending(r => r.CreatedAt))
                            {
                                <div class="cal-card-static p-5">
                                    <div class="flex items-center gap-3 mb-2">
                                        <div class="w-8 h-8 rounded-full bg-charcoal/[0.06] dark:bg-white/10 flex items-center justify-center text-sm font-semibold text-charcoal dark:text-white">
                                            @(string.IsNullOrEmpty(review.UserName) ? "?" : review.UserName.Substring(0, 1).ToUpper())
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-sm font-medium text-charcoal dark:text-white">@(review.UserName ?? "Anonymous Rider")</p>
                                            <time class="text-xs text-mid-gray" datetime="@review.CreatedAt.ToString("yyyy-MM-dd")">
                                                @review.CreatedAt.ToString("MMM dd, yyyy")
                                            </time>
                                        </div>
                                        <div class="flex gap-0.5" aria-label="@review.Rating out of 5 stars">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <span class="text-sm @(i <= review.Rating ? "cal-star--filled" : "cal-star")">★</span>
                                            }
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(review.Comment))
                                    {
                                        <p class="text-sm text-charcoal/80 dark:text-neutral-300 leading-relaxed">@review.Comment</p>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    /* Star rating: update label + sync product-card stars */
    var radios      = document.querySelectorAll('#starSelector input[type="radio"]');
    var ratingLabel = document.getElementById('ratingLabel');
    var cardStars   = document.querySelectorAll('#cardStars span');

    var ratingText = {
        1: 'Poor — needs improvement',
        2: 'Fair — below expectations',
        3: 'Good — meets expectations',
        4: 'Great — exceeded expectations',
        5: 'Outstanding — absolutely loved it!'
    };

    function updateCardStars(rating) {
        cardStars.forEach(function (star, i) {
            star.classList.toggle('cal-star--filled', i < rating);
            star.classList.toggle('cal-star', i >= rating);
        });
    }

    radios.forEach(function (radio) {
        radio.addEventListener('change', function () {
            var val = parseInt(this.value, 10);
            if (ratingLabel) ratingLabel.textContent = ratingText[val] || '';
            updateCardStars(val);
        });
    });

    /* Textarea character counter */
    var textarea  = document.getElementById('comment');
    var charCount = document.getElementById('charCount');
    if (textarea && charCount) {
        textarea.addEventListener('input', function () {
            charCount.textContent = this.value.length;
        });
    }

    /* Submit: validation */
    var reviewForm = document.getElementById('reviewForm');
    var submitBtn  = document.getElementById('submitBtn');
    if (reviewForm && submitBtn) {
        reviewForm.addEventListener('submit', function (e) {
            var selected = document.querySelector('#starSelector input[type="radio"]:checked');
            if (!selected) {
                e.preventDefault();
                if (ratingLabel) ratingLabel.textContent = 'Please select a star rating to continue.';
                document.getElementById('starSelector').scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        });
    }
})();
</script>
}
