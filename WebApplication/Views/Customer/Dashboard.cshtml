@* WebApplication/Views/Customer/Dashboard.cshtml *@
@{
    ViewData["Title"] = "My Dashboard";
    string customerName = ViewBag.CustomerName ?? "Customer";
}

@section Styles {
    <link rel="stylesheet" href="~/css/customer.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
}

<div class="tbs-customer-page">
    <div class="container">

        @* Page header *@
        <div class="tbs-page-header">
            <div>
                <h1 class="tbs-page-header__title">Welcome back, @customerName.Split(' ')[0]</h1>
                <p class="tbs-page-header__subtitle">Here's what's happening with your account</p>
            </div>
        </div>

        @* Quick stat cards *@
        <div class="row g-3 tbs-dashboard__stats">
            <div class="col-6 col-md-3">
                <a asp-controller="Order" asp-action="History" class="tbs-stat-card">
                    <div class="tbs-stat-card__icon" aria-hidden="true">📦</div>
                    <div class="tbs-stat-card__body">
                        <div class="tbs-stat-card__label">My Orders</div>
                        <div class="tbs-stat-card__hint">View history</div>
                    </div>
                    <div class="tbs-stat-card__arrow" aria-hidden="true">›</div>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Wishlist" asp-action="ViewWishlist" class="tbs-stat-card">
                    <div class="tbs-stat-card__icon" aria-hidden="true">❤️</div>
                    <div class="tbs-stat-card__body">
                        <div class="tbs-stat-card__label">Wishlist</div>
                        <div class="tbs-stat-card__hint">Saved items</div>
                    </div>
                    <div class="tbs-stat-card__arrow" aria-hidden="true">›</div>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Customer" asp-action="Profile" class="tbs-stat-card">
                    <div class="tbs-stat-card__icon" aria-hidden="true">👤</div>
                    <div class="tbs-stat-card__body">
                        <div class="tbs-stat-card__label">Profile</div>
                        <div class="tbs-stat-card__hint">Settings &amp; addresses</div>
                    </div>
                    <div class="tbs-stat-card__arrow" aria-hidden="true">›</div>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Support" asp-action="Create" class="tbs-stat-card">
                    <div class="tbs-stat-card__icon" aria-hidden="true">💬</div>
                    <div class="tbs-stat-card__body">
                        <div class="tbs-stat-card__label">Support</div>
                        <div class="tbs-stat-card__hint">Get help</div>
                    </div>
                    <div class="tbs-stat-card__arrow" aria-hidden="true">›</div>
                </a>
            </div>
        </div>

        @* Recent orders placeholder — fully wired in Step 21 *@
        <div class="tbs-dashboard__section">
            <div class="tbs-section-header">
                <h2 class="tbs-section-title">Recent Orders</h2>
                <a asp-controller="Order" asp-action="History" class="tbs-section-link">
                    View all &rarr;
                </a>
            </div>
            <div class="tbs-card tbs-dashboard__empty-orders" id="recent-orders-panel">
                <p class="tbs-dashboard__empty-text">
                    You have no recent orders.
                    <a asp-controller="Product" asp-action="List">Start shopping →</a>
                </p>
            </div>
        </div>

        @* Quick shop CTA *@
        <div class="tbs-dashboard__cta">
            <a asp-controller="Product" asp-action="List" class="btn tbs-btn-accent">
                Browse Catalog
            </a>
            <a asp-controller="Cart" asp-action="ViewCart" class="btn tbs-btn-outline">
                View Cart
            </a>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/js/customer.js" asp-append-version="true"></script>
}
