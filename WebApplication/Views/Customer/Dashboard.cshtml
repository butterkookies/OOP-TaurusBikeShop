@* WebApplication/Views/Customer/Dashboard.cshtml *@
@model WebApplication.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "My Dashboard";
}

<div class="bg-light-gray dark:bg-midnight min-h-[calc(100vh-160px)]">
    <div class="max-w-[1200px] mx-auto px-6 py-12 md:py-16">

        @* ── Page header ── *@
        <div class="mb-10" data-reveal>
            <p class="text-sm font-medium tracking-widest uppercase text-mid-gray mb-2">Account Overview</p>
            <h1 class="font-display text-3xl md:text-4xl font-semibold text-charcoal dark:text-white">Welcome back, @Model.FirstName</h1>
            <p class="text-base text-mid-gray mt-2">Here's what's happening with your account.</p>
        </div>

        @* ── Stat cards ── *@
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-10" data-reveal="delay-1">

            <a asp-controller="Order" asp-action="History" class="cal-card p-5 flex items-center gap-4 group hover:-translate-y-0.5">
                <div class="w-10 h-10 rounded-lg bg-charcoal/[0.06] dark:bg-white/10 flex items-center justify-center text-charcoal dark:text-white shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="font-display text-2xl font-semibold text-charcoal dark:text-white">@Model.TotalOrders</p>
                    <p class="text-xs text-mid-gray">Total Orders</p>
                    @if (Model.ActiveOrders > 0)
                    { <p class="text-xs text-success font-medium mt-0.5">@Model.ActiveOrders active</p> }
                </div>
                <svg class="shrink-0 text-mid-gray group-hover:text-charcoal transition-colors dark:group-hover:text-white" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>

            <a asp-controller="Wishlist" asp-action="ViewWishlist" class="cal-card p-5 flex items-center gap-4 group hover:-translate-y-0.5">
                <div class="w-10 h-10 rounded-lg bg-charcoal/[0.06] dark:bg-white/10 flex items-center justify-center text-charcoal dark:text-white shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="font-display text-2xl font-semibold text-charcoal dark:text-white">@Model.WishlistCount</p>
                    <p class="text-xs text-mid-gray">Wishlist</p>
                </div>
                <svg class="shrink-0 text-mid-gray group-hover:text-charcoal transition-colors dark:group-hover:text-white" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>

            <a asp-controller="Review" asp-action="MyReviews" class="cal-card p-5 flex items-center gap-4 group hover:-translate-y-0.5 @(Model.HasPendingReviews ? "ring-2 ring-warning/30" : "")">
                <div class="w-10 h-10 rounded-lg bg-charcoal/[0.06] dark:bg-white/10 flex items-center justify-center text-charcoal dark:text-white shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="font-display text-2xl font-semibold text-charcoal dark:text-white">@Model.PendingReviewCount</p>
                    <p class="text-xs text-mid-gray">Pending Reviews</p>
                    <p class="text-xs @(Model.HasPendingReviews ? "text-warning font-medium" : "text-mid-gray") mt-0.5">
                        @(Model.HasPendingReviews ? "Ready to review" : "All caught up")
                    </p>
                </div>
                <svg class="shrink-0 text-mid-gray group-hover:text-charcoal transition-colors dark:group-hover:text-white" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>

            <a asp-controller="Support" asp-action="Index" class="cal-card p-5 flex items-center gap-4 group hover:-translate-y-0.5 @(Model.HasOpenTickets ? "ring-2 ring-warning/30" : "")">
                <div class="w-10 h-10 rounded-lg bg-charcoal/[0.06] dark:bg-white/10 flex items-center justify-center text-charcoal dark:text-white shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="font-display text-2xl font-semibold text-charcoal dark:text-white">@Model.OpenTicketCount</p>
                    <p class="text-xs text-mid-gray">Open Tickets</p>
                    <p class="text-xs @(Model.HasOpenTickets ? "text-warning font-medium" : "text-mid-gray") mt-0.5">
                        @(Model.HasOpenTickets ? "Awaiting response" : "No open issues")
                    </p>
                </div>
                <svg class="shrink-0 text-mid-gray group-hover:text-charcoal transition-colors dark:group-hover:text-white" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>

        </div>

        @* ── Pending reviews prompt ── *@
        @if (Model.HasPendingReviews)
        {
            <div class="cal-card-static p-5 flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-10 border-l-4 border-warning" data-reveal="delay-2">
                <div class="flex-1">
                    <p class="text-sm font-medium text-charcoal dark:text-white">
                        You have <strong>@Model.PendingReviewCount</strong>
                        product@(Model.PendingReviewCount != 1 ? "s" : "") awaiting review
                    </p>
                    <div class="flex flex-wrap gap-2 mt-2">
                        @foreach (WebApplication.Models.ViewModels.ReviewViewModel item in Model.PendingReviews)
                        {
                            <a asp-controller="Product" asp-action="Detail" asp-route-id="@item.ProductId" asp-fragment="reviews-section"
                               class="inline-flex items-center px-3 py-1 bg-light-gray dark:bg-white/10 rounded-full text-xs font-medium text-charcoal dark:text-white hover:bg-charcoal/10 transition-colors">
                                @item.ProductName
                            </a>
                        }
                        @if (Model.PendingReviewCount > 3)
                        {
                            <a asp-controller="Review" asp-action="MyReviews"
                               class="inline-flex items-center px-3 py-1 bg-charcoal text-white rounded-full text-xs font-medium">
                                +@(Model.PendingReviewCount - 3) more
                            </a>
                        }
                    </div>
                </div>
                <a asp-controller="Review" asp-action="MyReviews" class="btn-dark btn-sm shrink-0">
                    Write Reviews
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
            </div>
        }

        @* ── Recent orders ── *@
        <div class="mb-10" data-reveal="delay-2">
            <div class="flex items-center justify-between mb-5">
                <h2 class="font-display text-xl font-semibold text-charcoal dark:text-white">Recent Orders</h2>
                <a asp-controller="Order" asp-action="History"
                   class="text-sm font-medium text-mid-gray hover:text-charcoal transition-colors dark:hover:text-white">
                    View all
                    <svg class="inline ml-1" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
            </div>

            @if (Model.HasNoOrders)
            {
                <div class="cal-card-static p-10 text-center">
                    <div class="text-mid-gray mb-3">
                        <svg class="mx-auto" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                    </div>
                    <p class="text-sm text-mid-gray mb-4">You haven't placed any orders yet.</p>
                    <a asp-controller="Product" asp-action="List" class="btn-dark btn-sm">Browse Catalog</a>
                </div>
            }
            else
            {
                <div class="cal-card-static divide-y divide-border-ring dark:divide-white/10 overflow-hidden">
                    @foreach (WebApplication.Models.ViewModels.OrderViewModel order in Model.RecentOrders)
                    {
                        <a asp-controller="Order" asp-action="Detail" asp-route-orderId="@order.OrderId"
                           class="flex items-center px-5 py-4 hover:bg-surface-hover transition-colors gap-4 group dark:hover:bg-white/[0.03]">

                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-medium text-charcoal dark:text-white truncate">@order.OrderNumber</p>
                                <p class="text-xs text-mid-gray mt-0.5">@order.OrderDate.ToString("MMM d, yyyy") &middot; @order.ItemCount item@(order.ItemCount != 1 ? "s" : "")</p>
                            </div>

                            <div class="hidden sm:block">
                                @await Html.PartialAsync("~/Views/Customer/Partials/_OrderStatusBadge.cshtml", order.OrderStatus)
                            </div>

                            <p class="text-sm font-semibold text-charcoal dark:text-white whitespace-nowrap">@order.FormattedGrandTotal</p>

                            <svg class="shrink-0 text-mid-gray group-hover:text-charcoal transition-colors dark:group-hover:text-white" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                        </a>
                    }
                </div>
            }
        </div>

        @* ── Quick actions ── *@
        <div data-reveal="delay-3">
            <h2 class="font-display text-xl font-semibold text-charcoal dark:text-white mb-5">Quick Actions</h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

                <a asp-controller="Product" asp-action="List"
                   class="cal-card p-5 flex items-center gap-4 group hover:-translate-y-0.5">
                    <div class="w-10 h-10 rounded-lg bg-charcoal/[0.06] dark:bg-white/10 flex items-center justify-center text-charcoal dark:text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium text-charcoal dark:text-white">Browse Catalog</p>
                        <p class="text-xs text-mid-gray mt-0.5">Explore all products</p>
                    </div>
                    <svg class="shrink-0 text-mid-gray group-hover:text-charcoal transition-colors dark:group-hover:text-white" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </a>

                <a asp-controller="Cart" asp-action="ViewCart"
                   class="cal-card p-5 flex items-center gap-4 group hover:-translate-y-0.5">
                    <div class="w-10 h-10 rounded-lg bg-charcoal/[0.06] dark:bg-white/10 flex items-center justify-center text-charcoal dark:text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium text-charcoal dark:text-white">View Cart</p>
                        <p class="text-xs text-mid-gray mt-0.5">Review items before checkout</p>
                    </div>
                    <svg class="shrink-0 text-mid-gray group-hover:text-charcoal transition-colors dark:group-hover:text-white" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </a>

                <a asp-controller="Support" asp-action="Create"
                   class="cal-card p-5 flex items-center gap-4 group hover:-translate-y-0.5">
                    <div class="w-10 h-10 rounded-lg bg-charcoal/[0.06] dark:bg-white/10 flex items-center justify-center text-charcoal dark:text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium text-charcoal dark:text-white">Get Support</p>
                        <p class="text-xs text-mid-gray mt-0.5">Open a support ticket</p>
                    </div>
                    <svg class="shrink-0 text-mid-gray group-hover:text-charcoal transition-colors dark:group-hover:text-white" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </a>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/js/customer.js" asp-append-version="true"></script>
}
