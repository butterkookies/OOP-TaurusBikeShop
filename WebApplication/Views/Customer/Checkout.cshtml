@* WebApplication/Views/Checkout/Checkout.cshtml *@
@model WebApplication.Models.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
}

@Html.AntiForgeryToken()

<div class="bg-light-gray dark:bg-midnight min-h-[calc(100vh-160px)]">
    <div class="max-w-[1200px] mx-auto px-6 py-12 md:py-16">

        <h1 class="font-display text-3xl md:text-4xl font-semibold text-charcoal dark:text-white mb-10" data-reveal>Checkout</h1>

        <form asp-action="PlaceOrder" asp-controller="Checkout" method="post" id="checkout-form" novalidate>
            @Html.AntiForgeryToken()

            <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-8">

                @* =================== LEFT: FORM =================== *@
                <div class="space-y-8" data-reveal="delay-1">

                    @* ── DELIVERY ADDRESS ── *@
                    <div class="cal-card-static p-6">
                        <h2 class="font-display text-lg font-semibold text-charcoal dark:text-white mb-5" style="letter-spacing:0.2px">Delivery Address</h2>

                        @if (Model.SavedAddresses.Any())
                        {
                            <div class="space-y-3" role="radiogroup" aria-label="Select delivery address"
                                 aria-invalid="@(ViewData.ModelState["SelectedAddressId"]?.Errors.Count > 0 ? "true" : "false")"
                                 aria-describedby="SelectedAddressId-error">
                                @foreach (WebApplication.Models.Entities.Address addr in Model.SavedAddresses)
                                {
                                    <label class="cal-option @(Model.SelectedAddressId == addr.AddressId ? "" : "")">
                                        <input type="radio" name="SelectedAddressId" value="@addr.AddressId"
                                               @(Model.SelectedAddressId == addr.AddressId ? "checked" : "") />
                                        <div class="flex-1 min-w-0">
                                            <span class="text-sm font-medium text-charcoal dark:text-white">@addr.Label</span>
                                            <address class="text-xs text-mid-gray mt-0.5 not-italic">
                                                @addr.Street, @addr.City@(!string.IsNullOrEmpty(addr.Province) ? $", {addr.Province}" : "") — @addr.PostalCode
                                            </address>
                                        </div>
                                        @if (addr.IsDefault)
                                        {
                                            <span class="cal-badge cal-badge-muted">Default</span>
                                        }
                                    </label>
                                }
                            </div>
                            <a asp-controller="Customer" asp-action="Profile"
                               class="inline-block mt-3 text-sm font-medium text-mid-gray hover:text-charcoal transition-colors dark:hover:text-white">
                                + Manage addresses
                            </a>
                        }
                        else
                        {
                            <div class="text-center py-6">
                                <p class="text-sm text-mid-gray mb-3">No saved addresses found.</p>
                                <a asp-controller="Customer" asp-action="Profile" class="btn-dark btn-sm">Add Address</a>
                            </div>
                        }
                        <span asp-validation-for="SelectedAddressId" id="SelectedAddressId-error" role="alert" class="cal-field-error"></span>
                    </div>

                    @* ── DELIVERY METHOD ── *@
                    <div class="cal-card-static p-6">
                        <h2 class="font-display text-lg font-semibold text-charcoal dark:text-white mb-5" style="letter-spacing:0.2px">Delivery Method</h2>
                        <div class="space-y-3" role="radiogroup" aria-label="Select delivery method"
                             aria-invalid="@(ViewData.ModelState["DeliveryMethod"]?.Errors.Count > 0 ? "true" : "false")"
                             aria-describedby="DeliveryMethod-error">

                            @* Home Delivery option *@
                            <label class="cal-option">
                                <input type="radio" name="DeliveryMethod" value="Delivery"
                                       @(Model.DeliveryMethod != "Pickup" ? "checked" : "") />
                                <div class="flex-1">
                                    <span class="text-sm font-medium text-charcoal dark:text-white">Home Delivery</span>
                                    <span class="block text-xs text-mid-gray mt-0.5">Courier assigned based on your address. Shipping fee paid to courier.</span>
                                </div>
                            </label>

                            @* In-Store Pickup option *@
                            <label class="cal-option">
                                <input type="radio" name="DeliveryMethod" value="Pickup"
                                       @(Model.DeliveryMethod == "Pickup" ? "checked" : "") />
                                <div class="flex-1">
                                    <span class="text-sm font-medium text-charcoal dark:text-white">In-Store Pickup</span>
                                    <span class="block text-xs text-mid-gray mt-0.5">Pick up at our Marilao, Bulacan store. No shipping fee.</span>
                                </div>
                                <span class="text-sm font-semibold text-success">Free</span>
                            </label>
                        </div>
                        <span asp-validation-for="DeliveryMethod" id="DeliveryMethod-error" role="alert" class="cal-field-error"></span>

                        @* ── COURIER INFO BANNER (shown when Home Delivery is selected) ── *@
                        <div id="courier-info"
                             class="mt-4 p-5 rounded-xl border border-charcoal/10 dark:border-white/10 bg-[#f9f9f9] dark:bg-[#1f1f1f]"
                             style="display:@(Model.DeliveryMethod == "Pickup" ? "none" : "block")">
                            <p class="text-sm font-semibold text-charcoal dark:text-white mb-2 flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-charcoal dark:text-white"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                                About delivery shipping fees
                            </p>
                            <p class="text-xs text-mid-gray leading-relaxed">
                                Your courier will be auto-assigned based on your address:
                                <strong class="text-charcoal dark:text-white font-medium">Lalamove</strong> for Metro Manila &amp; Bulacan,
                                <strong class="text-charcoal dark:text-white font-medium">LBC</strong> for nationwide delivery.
                            </p>
                            <div class="mt-3 p-3 bg-warning/10 border border-warning/20 rounded-lg flex gap-2 items-start">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-warning mt-0.5 shrink-0"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                                <p class="text-xs text-warning leading-relaxed m-0">
                                    <strong>Shipping fees are paid directly to the courier</strong> — they are <em>not</em> included in your online payment here.
                                    You will be notified of the exact shipping cost when your order is dispatched.
                                </p>
                            </div>
                        </div>

                        @* ── PICKUP DETAILS (shown only when Pickup is selected) ── *@
                        <div id="pickup-details"
                             class="mt-4 p-5 rounded-xl border border-charcoal/10 dark:border-white/10 bg-[#f9f9f9] dark:bg-[#1f1f1f]"
                             style="display:@(Model.DeliveryMethod == "Pickup" ? "block" : "none")">
                            <div class="flex items-start gap-4">
                                <div class="w-10 h-10 rounded-full bg-charcoal/5 dark:bg-white/10 flex items-center justify-center shrink-0">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-charcoal dark:text-white"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                                </div>
                                <div>
                                    <p class="text-sm font-semibold text-charcoal dark:text-white">Taurus Bike Shop</p>
                                    <p class="text-sm text-mid-gray mt-1">QW7V+8Q2, Sandico, Marilao, 3019 Bulacan</p>
                                    <a href="https://maps.app.goo.gl/TL5fHi2JttHoC9GcA"
                                       target="_blank" rel="noopener noreferrer"
                                       class="inline-flex items-center gap-1.5 mt-3 text-sm font-medium text-link-blue hover:text-charcoal dark:hover:text-white transition-colors">
                                        View on Google Maps
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                                    </a>
                                </div>
                            </div>
                            <div class="mt-4 pt-4 border-t border-charcoal/10 dark:border-white/10 flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-mid-gray"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                                <p class="text-xs text-mid-gray m-0">Please bring a valid ID when picking up your order.</p>
                            </div>
                        </div>
                    </div>

                    @* ── PAYMENT METHOD ── *@
                    <div class="cal-card-static p-6">
                        <h2 class="font-display text-lg font-semibold text-charcoal dark:text-white mb-5" style="letter-spacing:0.2px">Payment Method</h2>
                        <div class="space-y-3" role="radiogroup" aria-label="Select payment method"
                             aria-invalid="@(ViewData.ModelState["PaymentMethod"]?.Errors.Count > 0 ? "true" : "false")"
                             aria-describedby="PaymentMethod-error">
                            <label class="cal-option">
                                <input type="radio" name="PaymentMethod" value="GCash"
                                       @(Model.PaymentMethod == "GCash" ? "checked" : "") />
                                <div class="flex-1">
                                    <span class="text-sm font-medium text-charcoal dark:text-white">GCash</span>
                                    <span class="block text-xs text-mid-gray mt-0.5">You'll upload your proof of payment after placing your order.</span>
                                </div>
                            </label>
                            <label class="cal-option">
                                <input type="radio" name="PaymentMethod" value="BankTransfer"
                                       @(Model.PaymentMethod == "BankTransfer" ? "checked" : "") />
                                <div class="flex-1">
                                    <span class="text-sm font-medium text-charcoal dark:text-white">Bank Transfer (BPI)</span>
                                    <span class="block text-xs text-mid-gray mt-0.5">24-hour verification window after submitting proof.</span>
                                </div>
                            </label>
                        </div>
                        <span asp-validation-for="PaymentMethod" id="PaymentMethod-error" role="alert" class="cal-field-error"></span>
                    </div>

                    @* ── VOUCHER ── *@
                    <div class="cal-card-static p-6">
                        <h2 class="font-display text-lg font-semibold text-charcoal dark:text-white mb-5" style="letter-spacing:0.2px">Voucher / Promo Code</h2>

                        @if (!string.IsNullOrWhiteSpace(Model.VoucherCode))
                        {
                            <div class="flex items-center gap-2 p-3 bg-success/10 border border-success/20 rounded-lg text-sm text-success" id="voucher-applied-banner">
                                <span>✓</span>
                                <span id="voucher-applied-label">@Model.VoucherCode applied</span>
                                <button type="button" id="voucher-remove-btn"
                                        class="ml-auto text-success/60 hover:text-success transition-colors"
                                        aria-label="Remove voucher">✕</button>
                            </div>
                        }
                        else
                        {
                            <div id="voucher-applied-banner" style="display:none">
                                <div class="flex items-center gap-2 p-3 bg-success/10 border border-success/20 rounded-lg text-sm text-success">
                                    <span>✓</span>
                                    <span id="voucher-applied-label"></span>
                                    <button type="button" id="voucher-remove-btn"
                                            class="ml-auto text-success/60 hover:text-success transition-colors"
                                            aria-label="Remove voucher">✕</button>
                                </div>
                            </div>
                        }

                        <div id="voucher-inputs-wrapper" style="display:@(!string.IsNullOrWhiteSpace(Model.VoucherCode) ? "none" : "block")">
                            
                            <label for="voucher-code-input" class="block text-sm font-medium text-charcoal dark:text-white mb-2">
                                Enter or select a voucher
                            </label>

                            <div class="flex gap-3" id="voucher-input-row">
                                <input type="text" id="voucher-code-input" class="cal-input flex-1"
                                       placeholder="Enter or select voucher code..." autocomplete="off" aria-label="Voucher code"
                                       aria-invalid="false" aria-describedby="voucher-error"
                                       list="assigned-vouchers-list" />
                                
                                <datalist id="assigned-vouchers-list">
                                    @if (Model.AssignedVouchers.Any())
                                    {
                                        @foreach (var v in Model.AssignedVouchers)
                                        {
                                            <option value="@v.Code">@v.Code — @v.Description (@v.TimeLeft)</option>
                                        }
                                    }
                                </datalist>

                                <button type="button" id="voucher-apply-btn" class="btn-ghost">Apply</button>
                            </div>
                            
                            @if (!Model.AssignedVouchers.Any())
                            {
                                <p class="text-xs text-mid-gray mt-2">You currently have no assigned vouchers.</p>
                            }
                        </div>
                        <p class="cal-field-error" id="voucher-error" role="alert" style="display:none"></p>

                        <input type="hidden" name="VoucherCode" value="@Model.VoucherCode" />
                        <input type="hidden" name="DiscountAmount" value="@Model.DiscountAmount" />
                    </div>

                    @* Submit *@
                    <button type="submit" class="btn-dark btn-lg btn-full" id="place-order-btn">
                        Place Order
                    </button>

                    <p class="text-xs text-mid-gray text-center mt-3">
                        By placing your order you agree to our
                        <a asp-controller="Home" asp-action="Privacy" class="underline underline-offset-2 hover:text-charcoal dark:hover:text-white">Privacy Policy</a>.
                        No refunds. Payment confirmation required within 24 hours.
                    </p>

                </div>

                @* =================== RIGHT: ORDER SUMMARY =================== *@
                <aside data-reveal="delay-2">
                    @await Html.PartialAsync("~/Views/Customer/Partials/_OrderSummary.cshtml", Model)
                </aside>

            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/js/voucher.js"  asp-append-version="true"></script>
    <script src="~/js/checkout.js" asp-append-version="true"></script>
}
