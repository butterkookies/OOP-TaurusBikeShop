@* WebApplication/Views/Customer/OrderHistory.cshtml *@
@model IEnumerable<WebApplication.Models.ViewModels.OrderViewModel>
@{
    ViewData["Title"] = "My Orders";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages  = ViewBag.TotalPages  ?? 1;
    int totalCount  = ViewBag.TotalCount  ?? 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/order.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/order-history.css" asp-append-version="true" />
}

<div class="tbs-order-history-page">
    <div class="container">

        <div class="tbs-page-header">
            <div>
                <h1 class="tbs-page-header__title">My Orders</h1>
                <p class="tbs-page-header__subtitle">
                    @totalCount order@(totalCount != 1 ? "s" : "") total
                </p>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="tbs-order-history__empty">
                <div class="tbs-order-history__empty-icon" aria-hidden="true">📦</div>
                <h2>No orders yet</h2>
                <p>Your order history will appear here once you make a purchase.</p>
                <a asp-controller="Product" asp-action="List"
                   class="btn tbs-btn-accent">Start Shopping</a>
            </div>
        }
        else
        {
            <div class="tbs-order-history__list">
                @foreach (var order in Model)
                {
                    <a asp-controller="Order" asp-action="Detail"
                       asp-route-orderId="@order.OrderId"
                       class="tbs-order-row">

                        <div class="tbs-order-row__number">
                            <span class="tbs-order-row__label">Order</span>
                            <span class="tbs-order-row__value">@order.OrderNumber</span>
                        </div>

                        <div class="tbs-order-row__date">
                            <span class="tbs-order-row__label">Date</span>
                            <span class="tbs-order-row__value">
                                @order.OrderDate.ToString("MMM d, yyyy")
                            </span>
                        </div>

                        <div class="tbs-order-row__items">
                            <span class="tbs-order-row__label">Items</span>
                            <span class="tbs-order-row__value">
                                @order.ItemCount item@(order.ItemCount != 1 ? "s" : "")
                            </span>
                        </div>

                        <div class="tbs-order-row__status">
                            @await Html.PartialAsync(
                                "~/Views/Customer/Partials/_OrderStatusBadge.cshtml",
                                order.OrderStatus)
                        </div>

                        <div class="tbs-order-row__total">
                            <span class="tbs-order-row__label">Total</span>
                            <span class="tbs-order-row__value tbs-order-row__value--total">
                                @order.FormattedGrandTotal
                            </span>
                        </div>

                        <div class="tbs-order-row__arrow" aria-hidden="true">›</div>
                    </a>
                }
            </div>

            @if (totalPages > 1)
            {
                <nav class="tbs-pagination" aria-label="Order pages">
                    @if (currentPage > 1)
                    {
                        <a class="tbs-pagination__btn"
                           asp-action="History" asp-controller="Order"
                           asp-route-page="@(currentPage - 1)"
                           aria-label="Previous page">&lsaquo;</a>
                    }
                    @for (int p = Math.Max(1, currentPage - 2);
                          p <= Math.Min(totalPages, currentPage + 2); p++)
                    {
                        <a class="tbs-pagination__btn @(p == currentPage ? "tbs-pagination__btn--active" : "")"
                           asp-action="History" asp-controller="Order"
                           asp-route-page="@p"
                           aria-label="Page @p"
                           @(p == currentPage ? "aria-current=page" : "")>@p</a>
                    }
                    @if (currentPage < totalPages)
                    {
                        <a class="tbs-pagination__btn"
                           asp-action="History" asp-controller="Order"
                           asp-route-page="@(currentPage + 1)"
                           aria-label="Next page">&rsaquo;</a>
                    }
                </nav>
            }
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/order-history.js" asp-append-version="true"></script>
}
