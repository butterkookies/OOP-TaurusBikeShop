@* WebApplication/Views/Cart/Cart.cshtml *@
@model WebApplication.Models.ViewModels.CartViewModel
@{
    ViewData["Title"] = "Shopping Cart";
}

@section Styles {
    <link rel="stylesheet" href="~/css/cart.css"      asp-append-version="true" />
    <link rel="stylesheet" href="~/css/cart-item.css" asp-append-version="true" />
}

@Html.AntiForgeryToken()

<div class="tbs-cart-page">
    <div class="container">

        <div class="tbs-page-header">
            <h1 class="tbs-page-header__title">Shopping Cart</h1>
            @if (!Model.IsEmpty)
            {
                <span class="tbs-cart-page__count">
                    @Model.TotalQuantity item@(Model.TotalQuantity != 1 ? "s" : "")
                </span>
            }
        </div>

        @if (Model.IsEmpty)
        {
            <div class="tbs-cart-page__empty">
                <div class="tbs-cart-page__empty-icon" aria-hidden="true">🛒</div>
                <h2 class="tbs-cart-page__empty-title">Your cart is empty</h2>
                <p class="tbs-cart-page__empty-text">
                    Browse our catalog and add items to get started.
                </p>
                <a asp-controller="Product" asp-action="List"
                   class="btn tbs-btn-accent tbs-btn-lg">
                    Shop Now
                </a>
            </div>
        }
        else
        {
            <div class="tbs-cart-layout">

                @* ==================== ITEMS ==================== *@
                <div class="tbs-cart-layout__items">

                    <div class="tbs-cart-items" id="cart-items-list">
                        @foreach (WebApplication.Models.ViewModels.CartItemViewModel item in Model.Items)
                        {
                            @await Html.PartialAsync("~/Views/Customer/Partials/_CartItem.cshtml", item)
                        }
                    </div>

                    <div class="tbs-cart-actions">
                        <a asp-controller="Product" asp-action="List"
                           class="tbs-cart-actions__continue">
                            ← Continue Shopping
                        </a>
                    </div>
                </div>

                @* ==================== ORDER SUMMARY ==================== *@
                <aside class="tbs-cart-layout__summary">
                    <div class="tbs-order-summary">
                        <h2 class="tbs-order-summary__title">Order Summary</h2>

                        <div class="tbs-order-summary__row">
                            <span>Subtotal</span>
                            <span id="cart-subtotal">@Model.FormattedSubTotal</span>
                        </div>

                        @if (Model.DiscountAmount > 0)
                        {
                            <div class="tbs-order-summary__row tbs-order-summary__row--discount">
                                <span>Discount (@Model.AppliedVoucherCode)</span>
                                <span>−₱@Model.DiscountAmount.ToString("N2")</span>
                            </div>
                        }

                        <div class="tbs-order-summary__row tbs-order-summary__row--shipping">
                            <span>Shipping</span>
                            <span class="tbs-order-summary__shipping-note">
                                Calculated at checkout
                            </span>
                        </div>

                        <div class="tbs-order-summary__divider"></div>

                        <div class="tbs-order-summary__row tbs-order-summary__row--total">
                            <span>Estimated Total</span>
                            <span id="cart-total">@Model.FormattedSubTotal</span>
                        </div>

                        <a asp-controller="Checkout" asp-action="Index"
                           class="btn tbs-btn-accent tbs-btn-full tbs-order-summary__checkout-btn">
                            Proceed to Checkout
                        </a>

                        <div class="tbs-order-summary__payment-note">
                            <span>Accepted payments:</span>
                            <strong>GCash</strong> &bull; <strong>Bank Transfer</strong>
                        </div>
                    </div>
                </aside>

            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/cart.js" asp-append-version="true"></script>
}
