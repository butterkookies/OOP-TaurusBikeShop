@* WebApplication/Views/Cart/Cart.cshtml *@
@model WebApplication.Models.ViewModels.CartViewModel
@{
    ViewData["Title"] = "Shopping Cart";
}

@section Styles {
    <link rel="stylesheet" href="~/css/cart.css"      asp-append-version="true" />
    <link rel="stylesheet" href="~/css/cart-item.css" asp-append-version="true" />
    <style>
        body {
            background-color: #0D0D1A;
            background-image:
                linear-gradient(rgba(8, 6, 18, 0.68), rgba(8, 6, 18, 0.68)),
                url('/mobile wallpaper.png');
            background-size: cover;
            background-position: center top;
            background-attachment: fixed;
            background-repeat: no-repeat;
        }
    </style>
}

@Html.AntiForgeryToken()

<div class="tbs-cart-page">
    <div class="container">

        <div class="tbs-page-header cart-anim cart-anim-d0">
            <div>
                <p class="tbs-cart-eyebrow">Your Selection</p>
                <h1 class="tbs-page-header__title">Shopping Cart</h1>
                @if (!Model.IsEmpty)
                {
                    <p class="tbs-page-header__subtitle">
                        @Model.TotalQuantity item@(Model.TotalQuantity != 1 ? "s" : "") in your cart
                    </p>
                }
            </div>
        </div>

        @if (Model.IsEmpty)
        {
            <div class="tbs-cart-empty cart-anim cart-anim-d1">
                <div class="tbs-cart-empty__icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="9" cy="21" r="1"/>
                        <circle cx="20" cy="21" r="1"/>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72
                                 a2 2 0 0 0 2-1.61L23 6H6"/>
                    </svg>
                </div>
                <h2 class="tbs-cart-empty__title">Your cart is empty</h2>
                <p class="tbs-cart-empty__text">
                    Browse our catalog and add items to get started.
                </p>
                <a asp-controller="Product" asp-action="List"
                   class="tbs-btn-accent">
                    Shop Now
                </a>
            </div>
        }
        else
        {
            <div class="tbs-cart-layout">

                @* ── ITEMS ── *@
                <div class="tbs-cart-layout__items cart-anim cart-anim-d1">

                    <div class="tbs-cart-items-wrapper">
                        <div class="tbs-cart-items" id="cart-items-list">
                            @foreach (WebApplication.Models.ViewModels.CartItemViewModel item in Model.Items)
                            {
                                @await Html.PartialAsync("~/Views/Customer/Partials/_CartItem.cshtml", item)
                            }
                        </div>
                    </div>

                    <div class="tbs-cart-footer">
                        <a asp-controller="Product" asp-action="List"
                           class="tbs-cart-back">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                                 aria-hidden="true">
                                <polyline points="15 18 9 12 15 6"/>
                            </svg>
                            Continue Shopping
                        </a>
                    </div>
                </div>

                @* ── ORDER SUMMARY ── *@
                <aside class="tbs-cart-layout__summary cart-anim cart-anim-d2">
                    <div class="tbs-order-summary">
                        <h2 class="tbs-order-summary__title">Order Summary</h2>

                        <div class="tbs-order-summary__rows">

                            <div class="tbs-order-summary__row">
                                <span class="tbs-order-summary__row-label">Subtotal</span>
                                <span class="tbs-order-summary__row-value"
                                      id="cart-subtotal">@Model.FormattedSubTotal</span>
                            </div>

                            @if (Model.DiscountAmount > 0)
                            {
                                <div class="tbs-order-summary__row tbs-order-summary__row--discount">
                                    <span class="tbs-order-summary__row-label">
                                        Discount (@Model.AppliedVoucherCode)
                                    </span>
                                    <span class="tbs-order-summary__row-value tbs-order-summary__row-value--discount">
                                        −₱@Model.DiscountAmount.ToString("N2")
                                    </span>
                                </div>
                            }

                            <div class="tbs-order-summary__row">
                                <span class="tbs-order-summary__row-label">Shipping</span>
                                <span class="tbs-order-summary__row-value tbs-order-summary__shipping-note">
                                    At checkout
                                </span>
                            </div>

                        </div>

                        <div class="tbs-order-summary__divider"></div>

                        <div class="tbs-order-summary__total">
                            <span class="tbs-order-summary__total-label">Estimated Total</span>
                            <span class="tbs-order-summary__total-value"
                                  id="cart-total">@Model.FormattedSubTotal</span>
                        </div>

                        <a asp-controller="Checkout" asp-action="Index"
                           class="tbs-btn-accent tbs-btn-full">
                            Proceed to Checkout
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15"
                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                                 aria-hidden="true">
                                <polyline points="9 18 15 12 9 6"/>
                            </svg>
                        </a>

                        <div class="tbs-order-summary__payment-note">
                            <span>Accepted:</span>
                            <strong>GCash</strong>
                            <span class="tbs-order-summary__payment-sep">&bull;</span>
                            <strong>Bank Transfer</strong>
                        </div>

                    </div>
                </aside>

            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/cart.js" asp-append-version="true"></script>
}
