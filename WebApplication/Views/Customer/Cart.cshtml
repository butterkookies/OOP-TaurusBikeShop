@* WebApplication/Views/Cart/Cart.cshtml *@
@model WebApplication.Models.ViewModels.CartViewModel
@{
    ViewData["Title"] = "Shopping Cart";
}

@Html.AntiForgeryToken()

<div class="bg-light-gray dark:bg-midnight min-h-[calc(100vh-160px)]">
    <div class="max-w-[1200px] mx-auto px-6 py-12 md:py-16">

        @* ── Page Header ── *@
        <div class="mb-10" data-reveal>
            <p class="text-sm font-medium tracking-widest uppercase text-mid-gray mb-2">Your Selection</p>
            <h1 class="font-display text-3xl md:text-4xl font-semibold text-charcoal dark:text-white">Shopping Cart</h1>
            @if (!Model.IsEmpty)
            {
                <p class="text-base text-mid-gray mt-2">
                    @Model.TotalQuantity item@(Model.TotalQuantity != 1 ? "s" : "") in your cart
                </p>
            }
        </div>

        @if (Model.IsEmpty)
        {
            <div class="cal-card-static p-12 text-center max-w-md mx-auto" data-reveal="delay-1">
                <div class="text-mid-gray mb-4">
                    <svg class="mx-auto" xmlns="http://www.w3.org/2000/svg" width="36" height="36"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                    </svg>
                </div>
                <h2 class="font-display text-xl font-semibold text-charcoal dark:text-white mb-2">Your cart is empty</h2>
                <p class="text-sm text-mid-gray mb-6">Browse our catalog and add items to get started.</p>
                <a asp-controller="Product" asp-action="List" class="btn-dark">Shop Now</a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 lg:grid-cols-[1fr_360px] gap-8" data-reveal="delay-1">

                @* ── Cart Items ── *@
                <div>
                    <div class="cal-card-static overflow-hidden">
                        <div id="cart-items-list" class="divide-y divide-border-ring dark:divide-white/10">
                            @foreach (WebApplication.Models.ViewModels.CartItemViewModel item in Model.Items)
                            {
                                @await Html.PartialAsync("~/Views/Customer/Partials/_CartItem.cshtml", item)
                            }
                        </div>
                    </div>

                    <div class="mt-4">
                        <a asp-controller="Product" asp-action="List"
                           class="inline-flex items-center gap-2 text-sm font-medium text-mid-gray hover:text-charcoal transition-colors dark:hover:text-white">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="15 18 9 12 15 6"/>
                            </svg>
                            Continue Shopping
                        </a>
                    </div>
                </div>

                @* ── Order Summary sidebar ── *@
                <aside>
                    <div class="cal-card-static p-6 sticky top-24">
                        <h2 class="font-display text-lg font-semibold text-charcoal dark:text-white mb-5" style="letter-spacing:0.2px">Order Summary</h2>

                        <div class="space-y-3 text-sm">
                            <div class="flex justify-between">
                                <span class="text-mid-gray">Subtotal</span>
                                <span class="text-charcoal dark:text-white font-medium" id="cart-subtotal">@Model.FormattedSubTotal</span>
                            </div>
                            @if (Model.DiscountAmount > 0)
                            {
                                <div class="flex justify-between">
                                    <span class="text-mid-gray">Discount (@Model.AppliedVoucherCode)</span>
                                    <span class="text-success font-medium">−₱@Model.DiscountAmount.ToString("N2")</span>
                                </div>
                            }
                            <div class="flex justify-between">
                                <span class="text-mid-gray">Shipping</span>
                                <span class="text-mid-gray italic">At checkout</span>
                            </div>
                        </div>

                        <hr class="cal-divider" />

                        <div class="flex justify-between items-center mb-6">
                            <span class="text-sm font-medium text-charcoal dark:text-white">Estimated Total</span>
                            <span class="font-display text-xl font-semibold text-charcoal dark:text-white" id="cart-total">@Model.FormattedSubTotal</span>
                        </div>

                        <a asp-controller="Checkout" asp-action="Index" class="btn-dark btn-full">
                            Proceed to Checkout
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15"
                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="9 18 15 12 9 6"/>
                            </svg>
                        </a>

                        <p class="text-xs text-mid-gray text-center mt-4">
                            Accepted: <strong class="text-charcoal dark:text-white">GCash</strong> &bull;
                            <strong class="text-charcoal dark:text-white">Bank Transfer</strong>
                        </p>
                    </div>
                </aside>

            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/cart.js" asp-append-version="true"></script>
}
