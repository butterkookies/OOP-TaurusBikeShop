@* WebApplication/Views/Customer/PurchaseOrderList.cshtml *@
@* Admin/Manager role only *@
@model IReadOnlyList<WebApplication.Models.Entities.PurchaseOrder>
@using WebApplication.Models.Entities
@{
    ViewData["Title"] = ViewData["Title"] ?? "Purchase Orders";
    Supplier? supplier = ViewBag.Supplier as Supplier;
}

<div class="bg-light-gray dark:bg-midnight min-h-[calc(100vh-160px)]">
    <div class="max-w-[900px] mx-auto px-6 py-12 md:py-16">

        <ol class="cal-breadcrumb">
            <li><a asp-controller="Supplier" asp-action="Index">Suppliers</a></li>
            <li>@(supplier?.Name ?? "Purchase Orders")</li>
        </ol>

        <div class="mb-10" data-reveal>
            <h1 class="font-display text-3xl font-semibold text-charcoal dark:text-white">
                Purchase Orders
                @if (supplier != null)
                {
                    <span class="text-mid-gray font-normal">— @supplier.Name</span>
                }
            </h1>
            <p class="text-base text-mid-gray mt-2">@Model.Count order@(Model.Count != 1 ? "s" : "")</p>
        </div>

        @if (!Model.Any())
        {
            <div class="cal-card-static p-10 text-center" data-reveal="delay-1">
                <p class="text-sm text-mid-gray">No purchase orders found for this supplier.</p>
            </div>
        }
        else
        {
            <div class="cal-card-static divide-y divide-border-ring dark:divide-white/10 overflow-hidden" data-reveal="delay-1">
                @foreach (PurchaseOrder po in Model)
                {
                    var badgeCss = po.Status switch
                    {
                        PurchaseOrderStatuses.Pending   => "cal-badge-warning",
                        PurchaseOrderStatuses.Received  => "cal-badge-success",
                        PurchaseOrderStatuses.Cancelled => "cal-badge-error",
                        _                               => "cal-badge-muted"
                    };
                    <a asp-controller="Supplier" asp-action="PurchaseOrderDetail" asp-route-purchaseOrderId="@po.PurchaseOrderId"
                       class="flex items-center px-5 py-4 hover:bg-surface-hover transition-colors gap-4 group dark:hover:bg-white/[0.03]">

                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-medium text-charcoal dark:text-white">PO #@po.PurchaseOrderId</p>
                            <p class="text-xs text-mid-gray mt-0.5">
                                @po.OrderDate.ToString("MMM d, yyyy") &middot;
                                @po.Items.Count item@(po.Items.Count != 1 ? "s" : "")
                            </p>
                        </div>

                        <span class="cal-badge @badgeCss">@po.Status</span>

                        <svg class="shrink-0 text-mid-gray group-hover:text-charcoal transition-colors dark:group-hover:text-white" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                    </a>
                }
            </div>
        }

    </div>
</div>
