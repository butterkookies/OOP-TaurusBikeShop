@* WebApplication/Views/Customer/OrderDetail.cshtml *@
@model WebApplication.Models.ViewModels.OrderViewModel
@{
    ViewData["Title"] = $"Order {Model.OrderNumber}";
    var latestPayment = Model.Payments.OrderByDescending(p => p.CreatedAt).FirstOrDefault();
    string paymentMethodLabel = latestPayment?.PaymentMethod ?? "Pending";
    string paymentStatusLabel = latestPayment?.PaymentStatus ?? "Pending";
    bool canUploadPayment = latestPayment == null
        && Model.OrderStatus != "Cancelled"
        && Model.OrderStatus != "Delivered";
}

@Html.AntiForgeryToken()

<div class="bg-light-gray dark:bg-midnight min-h-[calc(100vh-160px)]">
    <div class="max-w-[900px] mx-auto px-6 py-12 md:py-16">

        @* ── Breadcrumb ── *@
        <ol class="cal-breadcrumb">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li><a asp-controller="Customer" asp-action="Dashboard">Dashboard</a></li>
            <li><a asp-controller="Order" asp-action="History">Orders</a></li>
            <li>@Model.OrderNumber</li>
        </ol>

        @* ── Header ── *@
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8" data-reveal>
            <div>
                <h1 class="font-display text-2xl md:text-3xl font-semibold text-charcoal dark:text-white">Order @Model.OrderNumber</h1>
                <p class="text-sm text-mid-gray mt-1">Placed @Model.OrderDate.ToString("MMMM d, yyyy") at @Model.OrderDate.ToString("h:mm tt")</p>
            </div>
            @await Html.PartialAsync("~/Views/Customer/Partials/_OrderStatusBadge.cshtml", Model.OrderStatus)
        </div>

        @* ── Cancellation Countdown Timer (Pending orders only) ── *@
        @if (Model.ShowCancellationTimer)
        {
            <div id="countdown-banner"
                 class="cal-card-static overflow-hidden mb-6 border border-amber-400/30 dark:border-amber-400/20"
                 data-reveal="delay-0"
                 data-deadline="@Model.CancellationDeadlineIso">

                <div class="px-6 py-5">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="shrink-0 w-9 h-9 rounded-full bg-amber-400/15 flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                 class="text-amber-500" id="countdown-icon">
                                <circle cx="12" cy="12" r="10"/>
                                <polyline points="12 6 12 12 16 14"/>
                            </svg>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-semibold text-charcoal dark:text-white">Payment deadline</p>
                            <p class="text-xs text-mid-gray mt-0.5">
                                Submit payment proof before the timer runs out to avoid cancellation.
                            </p>
                        </div>
                    </div>

                    @* Timer display *@
                    <div class="flex items-center gap-4">
                        <div id="countdown-display" class="flex items-baseline gap-1.5 font-mono tabular-nums">
                            <span class="inline-flex flex-col items-center">
                                <span id="cd-hours" class="text-2xl font-bold text-amber-600 dark:text-amber-400 transition-colors">--</span>
                                <span class="text-[10px] uppercase tracking-wider text-mid-gray font-sans">hrs</span>
                            </span>
                            <span class="text-xl font-bold text-mid-gray pb-4">:</span>
                            <span class="inline-flex flex-col items-center">
                                <span id="cd-minutes" class="text-2xl font-bold text-amber-600 dark:text-amber-400 transition-colors">--</span>
                                <span class="text-[10px] uppercase tracking-wider text-mid-gray font-sans">min</span>
                            </span>
                            <span class="text-xl font-bold text-mid-gray pb-4">:</span>
                            <span class="inline-flex flex-col items-center">
                                <span id="cd-seconds" class="text-2xl font-bold text-amber-600 dark:text-amber-400 transition-colors">--</span>
                                <span class="text-[10px] uppercase tracking-wider text-mid-gray font-sans">sec</span>
                            </span>
                        </div>
                        <div class="flex-1">
                            <div class="text-right text-xs text-mid-gray mb-1" id="cd-percent-label">-- remaining</div>
                            <div class="h-2 rounded-full bg-light-gray dark:bg-neutral-800 overflow-hidden">
                                <div id="cd-progress" class="h-full rounded-full bg-amber-400 transition-all duration-1000 ease-linear" style="width:100%"></div>
                            </div>
                        </div>
                    </div>
                </div>

                @* Expired state (hidden by default) *@
                <div id="countdown-expired" class="hidden px-6 py-5">
                    <div class="flex items-center gap-3">
                        <div class="shrink-0 w-9 h-9 rounded-full bg-red-400/15 flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                 class="text-red-500">
                                <circle cx="12" cy="12" r="10"/>
                                <line x1="15" y1="9" x2="9" y2="15"/>
                                <line x1="9" y1="9" x2="15" y2="15"/>
                            </svg>
                        </div>
                        <div>
                            <p class="text-sm font-semibold text-red-600 dark:text-red-400">Payment deadline expired</p>
                            <p class="text-xs text-mid-gray mt-0.5">This order will be automatically cancelled shortly.</p>
                        </div>
                    </div>
                </div>
            </div>

            <script>
            (function() {
                const banner   = document.getElementById('countdown-banner');
                const deadline = new Date(banner.dataset.deadline);
                const placed   = new Date(deadline.getTime() - 24 * 60 * 60 * 1000);
                const totalMs  = 24 * 60 * 60 * 1000;

                const cdH = document.getElementById('cd-hours');
                const cdM = document.getElementById('cd-minutes');
                const cdS = document.getElementById('cd-seconds');
                const prog = document.getElementById('cd-progress');
                const pctLabel = document.getElementById('cd-percent-label');

                const digits = [cdH, cdM, cdS];
                const icon = document.getElementById('countdown-icon');

                function pad(n) { return n.toString().padStart(2, '0'); }

                function tick() {
                    const now = new Date();
                    let remaining = deadline - now;

                    if (remaining <= 0) {
                        // Expired
                        banner.querySelector('.px-6.py-5').classList.add('hidden');
                        document.getElementById('countdown-expired').classList.remove('hidden');
                        banner.classList.remove('border-amber-400/30', 'dark:border-amber-400/20');
                        banner.classList.add('border-red-400/30', 'dark:border-red-400/20');
                        return;
                    }

                    const hours   = Math.floor(remaining / 3600000);
                    const minutes = Math.floor((remaining % 3600000) / 60000);
                    const seconds = Math.floor((remaining % 60000) / 1000);

                    cdH.textContent = pad(hours);
                    cdM.textContent = pad(minutes);
                    cdS.textContent = pad(seconds);

                    // Progress bar
                    const pct = Math.max(0, (remaining / totalMs) * 100);
                    prog.style.width = pct.toFixed(2) + '%';
                    pctLabel.textContent = Math.round(pct) + '% remaining';

                    // Color transitions: amber → red when < 4 hours
                    const urgent = remaining < 4 * 60 * 60 * 1000;
                    digits.forEach(el => {
                        el.classList.toggle('text-amber-600', !urgent);
                        el.classList.toggle('dark:text-amber-400', !urgent);
                        el.classList.toggle('text-red-600', urgent);
                        el.classList.toggle('dark:text-red-400', urgent);
                    });
                    prog.classList.toggle('bg-amber-400', !urgent);
                    prog.classList.toggle('bg-red-500', urgent);
                    if (icon) {
                        icon.classList.toggle('text-amber-500', !urgent);
                        icon.classList.toggle('text-red-500', urgent);
                    }

                    requestAnimationFrame(() => setTimeout(tick, 1000));
                }

                tick();
            })();
            </script>
        }

        <div class="space-y-6">

            @* ── Items ── *@
            <div class="cal-card-static overflow-hidden" data-reveal="delay-1">
                <div class="px-6 py-4 border-b border-border-ring dark:border-white/10">
                    <h2 class="font-display text-base font-semibold text-charcoal dark:text-white" style="letter-spacing:0.2px">Items Ordered</h2>
                </div>
                <div class="divide-y divide-border-ring dark:divide-white/10">
                    @foreach (var item in Model.Items)
                    {
                        <div class="flex items-center gap-4 px-6 py-4">
                            <div class="w-16 h-16 bg-light-gray dark:bg-neutral-800 rounded-lg overflow-hidden shrink-0">
                                @if (item.ImageUrl != null)
                                {
                                    <img src="@item.ImageUrl" alt="@item.ProductName" class="w-full h-full object-cover" loading="lazy" />
                                }
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-medium text-charcoal dark:text-white truncate">@item.ProductName</p>
                                @if (item.VariantName != null && item.VariantName != "Default")
                                {
                                    <p class="text-xs text-mid-gray">@item.VariantName</p>
                                }
                                <p class="text-xs text-mid-gray mt-0.5">Qty: @item.Quantity</p>
                            </div>
                            <p class="text-sm font-semibold text-charcoal dark:text-white whitespace-nowrap">@item.FormattedLineTotal</p>
                        </div>
                    }
                </div>
            </div>

            @* ── Order Summary ── *@
            <div class="cal-card-static p-6" data-reveal="delay-2">
                <h2 class="font-display text-base font-semibold text-charcoal dark:text-white mb-4" style="letter-spacing:0.2px">Order Summary</h2>
                <div class="space-y-2 text-sm">
                    <div class="flex justify-between">
                        <span class="text-mid-gray">Subtotal</span>
                        <span class="text-charcoal dark:text-white">@Model.FormattedSubTotal</span>
                    </div>
                    @if (Model.DiscountAmount > 0)
                    {
                        <div class="flex justify-between">
                            <span class="text-mid-gray">Discount</span>
                            <span class="text-success">−₱@Model.DiscountAmount.ToString("N2")</span>
                        </div>
                    }
                    <div class="flex justify-between">
                        <span class="text-mid-gray">Shipping</span>
                        <span class="text-mid-gray italic">
                            @(Model.DeliveryMethod == "Pickup" ? "Free" : "Paid to courier")
                        </span>
                    </div>
                    <hr class="cal-divider !my-3" />
                    <div class="flex justify-between font-semibold text-base">
                        <span class="text-charcoal dark:text-white">Total (excl. shipping)</span>
                        <span class="font-display text-charcoal dark:text-white">@Model.FormattedGrandTotal</span>
                    </div>
                    @if (Model.DeliveryMethod != "Pickup")
                    {
                        <p class="text-xs text-mid-gray mt-1 leading-relaxed">
                            Shipping fees are collected by the courier (Lalamove / LBC) and are not included in your online payment.
                        </p>
                    }
                </div>
            </div>

            @* ── Delivery / Payment Info ── *@
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div class="cal-card-static p-6" data-reveal="delay-2">
                    <h2 class="font-display text-base font-semibold text-charcoal dark:text-white mb-3" style="letter-spacing:0.2px">Delivery</h2>
                    <p class="text-sm text-charcoal dark:text-white font-medium">@Model.DeliveryMethod</p>
                    @if (Model.ShippingAddress != null)
                    {
                        <address class="text-xs text-mid-gray mt-2 not-italic leading-relaxed">
                            @Model.ShippingAddress.Street<br />
                            @Model.ShippingAddress.City@(!string.IsNullOrEmpty(Model.ShippingAddress.Province) ? $", {Model.ShippingAddress.Province}" : "")<br />
                            @Model.ShippingAddress.PostalCode
                        </address>
                    }
                </div>
                <div class="cal-card-static p-6" data-reveal="delay-2">
                    <h2 class="font-display text-base font-semibold text-charcoal dark:text-white mb-3" style="letter-spacing:0.2px">Payment</h2>
                    <p class="text-sm text-charcoal dark:text-white font-medium mb-1">@paymentMethodLabel</p>
                    @await Html.PartialAsync("~/Views/Customer/Partials/_PaymentStatusBadge.cshtml", paymentStatusLabel)
                </div>
            </div>

            @* ── Delivery Tracking (shown once admin ships the order) ── *@
            @{
                var activeDelivery = Model.Deliveries.FirstOrDefault();
            }
            @if (activeDelivery != null)
            {
                bool isLalamove = activeDelivery.Courier == "Lalamove";
                bool isLBC      = activeDelivery.Courier == "LBC";
                var  lm         = activeDelivery.LalamoveDelivery;
                var  lbc        = activeDelivery.LBCDelivery;

                <div class="cal-card-static overflow-hidden" data-reveal="delay-2"
                     style="border-color: rgba(99,179,237,0.25);">

                    <div class="px-6 py-4 border-b border-border-ring dark:border-white/10"
                         style="background: linear-gradient(135deg,rgba(16,30,54,0.6),rgba(12,22,40,0.4));">
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                 fill="none" stroke="#60A5FA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                                <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                            </svg>
                            <h2 class="font-display text-base font-semibold text-charcoal dark:text-white"
                                style="letter-spacing:0.2px">
                                Delivery Tracking
                                <span class="ml-2 text-xs font-normal px-2 py-0.5 rounded-full"
                                      style="background:rgba(99,179,237,0.15);color:#60A5FA">
                                    @activeDelivery.Courier
                                </span>
                            </h2>
                        </div>
                    </div>

                    <div class="p-6 space-y-4">

                        @* Shipping fee chip *@
                        <div class="flex items-center gap-2 text-sm">
                            <span class="text-mid-gray">Shipping Fee:</span>
                            <span class="font-semibold text-charcoal dark:text-white">
                                ₱@Model.ShippingFee.ToString("N2")
                            </span>
                        </div>

                        @if (isLalamove && lm != null)
                        {
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                                <div>
                                    <p class="text-xs uppercase tracking-wider text-mid-gray mb-1">Booking Ref</p>
                                    <p class="font-mono font-semibold text-charcoal dark:text-white">@lm.BookingRef</p>
                                </div>
                                @if (lm.DriverName != null)
                                {
                                    <div>
                                        <p class="text-xs uppercase tracking-wider text-mid-gray mb-1">Driver</p>
                                        <p class="font-medium text-charcoal dark:text-white">@lm.DriverName</p>
                                        @if (lm.DriverPhone != null)
                                        {
                                            <a href="tel:@lm.DriverPhone"
                                               class="text-xs text-blue-400 hover:underline mt-0.5 block">
                                                📞 @lm.DriverPhone
                                            </a>
                                        }
                                    </div>
                                }
                            </div>

                            <a href="https://www.lalamove.com/track/@lm.BookingRef"
                               target="_blank" rel="noopener noreferrer"
                               class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold transition-all"
                               style="background:#1A3A2A;color:#34D399;border:1px solid rgba(52,211,153,0.35);">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                                    <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                                </svg>
                                Track on Lalamove
                            </a>
                        }
                        else if (isLBC && lbc != null)
                        {
                            <div class="text-sm">
                                <p class="text-xs uppercase tracking-wider text-mid-gray mb-1">Tracking Number</p>
                                <div class="flex items-center gap-2">
                                    <p class="font-mono font-semibold text-charcoal dark:text-white" id="lbc-tracking-no">@lbc.TrackingNumber</p>
                                    <button onclick="navigator.clipboard.writeText('@lbc.TrackingNumber').then(()=>{this.textContent='✓ Copied';setTimeout(()=>{this.textContent='Copy'},1500)})"
                                            class="text-xs px-2 py-0.5 rounded transition-all"
                                            style="background:rgba(99,179,237,0.12);color:#60A5FA;border:1px solid rgba(99,179,237,0.25);">
                                        Copy
                                    </button>
                                </div>
                            </div>

                            <a href="https://www.lbcexpress.com/track/?tracking_no=@lbc.TrackingNumber"
                               target="_blank" rel="noopener noreferrer"
                               class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold transition-all"
                               style="background:#1A2A3A;color:#60A5FA;border:1px solid rgba(99,179,237,0.35);">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                                    <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                                </svg>
                                Track on LBC Express
                            </a>
                        }

                        @* Delivery status pill *@
                        <div class="text-xs text-mid-gray pt-1">
                            Courier status:
                            <span class="font-medium text-charcoal dark:text-white">
                                @activeDelivery.DeliveryStatus
                            </span>
                        </div>

                    </div>
                </div>
            }

            @* ── Action Buttons ── *@
            <div class="flex flex-wrap gap-3" data-reveal="delay-3">
                @if (canUploadPayment)
                {
                    <a asp-controller="Payment" asp-action="Submit" asp-route-orderId="@Model.OrderId" class="btn-dark">
                        Upload Payment Proof
                    </a>
                }
                @if (Model.IsDeliveryConfirmable)
                {
                    <form asp-action="ConfirmDelivery" asp-controller="Order" method="post" class="inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="orderId" value="@Model.OrderId" />
                        <button type="submit" class="btn-dark"
                                onclick="return confirm('Confirm that you have received this order?')">
                            Confirm Delivery
                        </button>
                    </form>
                }
                @if (Model.IsCancellable)
                {
                    <form asp-action="Cancel" asp-controller="Order" method="post" class="inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="orderId" value="@Model.OrderId" />
                        <button type="submit" class="btn-danger btn-sm"
                                onclick="return confirm('Are you sure you want to cancel this order?')">
                            Cancel Order
                        </button>
                    </form>
                }
                <a asp-controller="Order" asp-action="History" class="btn-ghost">
                    ← Back to Orders
                </a>
            </div>

        </div>
    </div>
</div>
