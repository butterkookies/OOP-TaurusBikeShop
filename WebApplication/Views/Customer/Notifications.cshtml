@* WebApplication/Views/Customer/Notifications.cshtml *@
@model WebApplication.Models.ViewModels.NotificationListViewModel
@{
    ViewData["Title"] = "Notifications";
}

<div class="bg-light-gray dark:bg-midnight min-h-[calc(100vh-160px)]">
    <div class="max-w-[800px] mx-auto px-6 py-12 md:py-16">

        @* ── Page header ── *@
        <div class="flex items-center justify-between mb-8" data-reveal>
            <div>
                <p class="text-sm font-medium tracking-widest uppercase text-mid-gray mb-2">Account</p>
                <h1 class="font-display text-3xl md:text-4xl font-semibold text-charcoal dark:text-white">Notifications</h1>
                @if (Model.UnreadCount > 0)
                {
                    <p class="text-sm text-mid-gray mt-1">
                        <span class="font-semibold text-charcoal dark:text-white">@Model.UnreadCount</span> unread
                    </p>
                }
            </div>

            @if (Model.UnreadCount > 0)
            {
                <form asp-action="MarkAllNotificationsRead" method="post">
                    <button type="submit" class="btn-outline btn-sm">
                        Mark all read
                    </button>
                </form>
            }
        </div>

        @* ── Notification list ── *@
        @if (!Model.Notifications.Any())
        {
            <div class="cal-card-static p-12 text-center" data-reveal="delay-1">
                <div class="text-mid-gray mb-3">
                    <svg class="mx-auto" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                </div>
                <p class="text-sm text-mid-gray mb-1">No notifications yet</p>
                <p class="text-xs text-mid-gray">You'll be notified here when there's activity on your orders, payments, or support tickets.</p>
            </div>
        }
        else
        {
            <div class="cal-card-static divide-y divide-border-ring dark:divide-white/10 overflow-hidden" data-reveal="delay-1">
                @foreach (WebApplication.Models.ViewModels.NotificationViewModel notif in Model.Notifications)
                {
                    <div class="flex items-start gap-4 px-5 py-4 @(!notif.IsRead ? "bg-blue-50/50 dark:bg-blue-500/[0.06]" : "") transition-colors">

                        @* Icon *@
                        <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0 @(!notif.IsRead ? "bg-charcoal text-white dark:bg-white dark:text-midnight" : "bg-charcoal/[0.06] text-mid-gray dark:bg-white/10 dark:text-neutral-400")">
                            @switch (notif.IconClass)
                            {
                                case "package":
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                                    break;
                                case "credit-card":
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                                    break;
                                case "truck":
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                                    break;
                                case "check-circle":
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                    break;
                                case "heart":
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                                    break;
                                case "message-square":
                                case "message-circle":
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                                    break;
                                case "check-square":
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                                    break;
                                case "alert-triangle":
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                                    break;
                                case "x-circle":
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                                    break;
                                case "user-plus":
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                                    break;
                                default:
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                                    break;
                            }
                        </div>

                        @* Content *@
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2 mb-0.5">
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold uppercase tracking-wide
                                    @(!notif.IsRead ? "bg-charcoal text-white dark:bg-white dark:text-midnight" : "bg-charcoal/[0.06] text-mid-gray dark:bg-white/10")">
                                    @notif.TypeLabel
                                </span>
                                <span class="text-xs text-mid-gray">@notif.TimeAgo</span>
                            </div>
                            <p class="text-sm font-medium text-charcoal dark:text-white truncate">
                                @(notif.Subject ?? notif.TypeLabel)
                            </p>
                            @if (!string.IsNullOrWhiteSpace(notif.Body))
                            {
                                <p class="text-xs text-mid-gray mt-0.5 line-clamp-2">
                                    @(notif.Body.Length > 120 ? notif.Body[..120] + "…" : notif.Body)
                                </p>
                            }

                            @* Links to related entities *@
                            <div class="flex items-center gap-3 mt-1.5">
                                @if (notif.OrderId.HasValue)
                                {
                                    <a asp-controller="Order" asp-action="Detail" asp-route-orderId="@notif.OrderId"
                                       class="text-xs font-medium text-charcoal/70 hover:text-charcoal dark:text-neutral-400 dark:hover:text-white transition-colors">
                                        View order →
                                    </a>
                                }
                                @if (notif.TicketId.HasValue)
                                {
                                    <a asp-controller="Support" asp-action="Detail" asp-route-ticketId="@notif.TicketId"
                                       class="text-xs font-medium text-charcoal/70 hover:text-charcoal dark:text-neutral-400 dark:hover:text-white transition-colors">
                                        View ticket →
                                    </a>
                                }
                            </div>
                        </div>

                        @* Mark as read button *@
                        @if (!notif.IsRead)
                        {
                            <form asp-action="MarkNotificationRead" method="post" class="shrink-0">
                                <input type="hidden" name="notificationId" value="@notif.NotificationId" />
                                <button type="submit" title="Mark as read"
                                        class="w-8 h-8 flex items-center justify-center rounded-lg text-mid-gray hover:text-charcoal hover:bg-light-gray transition-colors dark:hover:text-white dark:hover:bg-white/10">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                </button>
                            </form>
                        }
                        else
                        {
                            <div class="w-8 h-8 flex items-center justify-center shrink-0 text-mid-gray/30">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            </div>
                        }
                    </div>
                }
            </div>

            @* ── Pagination ── *@
            @if (Model.TotalPages > 1)
            {
                <div class="flex items-center justify-center gap-2 mt-8" data-reveal="delay-2">
                    @if (Model.HasPreviousPage)
                    {
                        <a asp-action="Notifications" asp-route-page="@(Model.CurrentPage - 1)"
                           class="px-4 py-2 text-sm font-medium rounded-lg bg-white text-charcoal hover:bg-light-gray transition-colors dark:bg-neutral-800 dark:text-neutral-300 dark:hover:bg-white/10">
                            ← Previous
                        </a>
                    }
                    <span class="text-sm text-mid-gray px-3">
                        Page @Model.CurrentPage of @Model.TotalPages
                    </span>
                    @if (Model.HasNextPage)
                    {
                        <a asp-action="Notifications" asp-route-page="@(Model.CurrentPage + 1)"
                           class="px-4 py-2 text-sm font-medium rounded-lg bg-white text-charcoal hover:bg-light-gray transition-colors dark:bg-neutral-800 dark:text-neutral-300 dark:hover:bg-white/10">
                            Next →
                        </a>
                    }
                </div>
            }
        }

    </div>
</div>

@section Scripts {
    <script src="~/js/customer.js" asp-append-version="true"></script>
}
