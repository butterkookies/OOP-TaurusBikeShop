@* WebApplication/Views/Customer/Login.cshtml *@
@model WebApplication.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-[calc(100vh-160px)] flex items-center justify-center py-16 px-6 bg-light-gray dark:bg-midnight">
    <div class="w-full max-w-md">

        <div class="cal-card-static p-8 md:p-10">

            @* Header *@
            <div class="text-center mb-8">
                <a asp-controller="Home" asp-action="Index" class="inline-block mb-6">
                    <img src="~/FULL-COLOR.png" alt="Taurus Bike Shop" class="h-10 w-auto mx-auto" />
                </a>
                <h1 class="font-display text-2xl font-semibold text-charcoal dark:text-white">Welcome Back</h1>
                <p class="text-sm text-mid-gray mt-1">Sign in to your Taurus account</p>
            </div>

            @* Validation summary *@
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="mb-6 p-3 bg-error/10 border border-error/20 rounded-lg text-sm text-error" role="alert">
                    <div asp-validation-summary="ModelOnly"></div>
                </div>
            }

            @* Form *@
            <form asp-action="Login" asp-controller="Customer" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />

                <div class="mb-5">
                    <label asp-for="Email" class="cal-label">Email Address</label>
                    <input asp-for="Email"
                           class="cal-input"
                           type="email"
                           autocomplete="email"
                           placeholder="you@example.com"
                           aria-invalid="@(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "true" : "false")"
                           aria-describedby="Email-error" />
                    <span asp-validation-for="Email" id="Email-error" role="alert" class="cal-field-error"></span>
                </div>

                <div class="mb-6">
                    <label asp-for="Password" class="cal-label">Password</label>
                    <div class="relative">
                        <input asp-for="Password"
                               class="cal-input pr-11"
                               type="password"
                               autocomplete="current-password"
                               placeholder="Enter your password"
                               id="password-input"
                               aria-invalid="@(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "true" : "false")"
                               aria-describedby="Password-error" />
                        <button type="button"
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-mid-gray hover:text-charcoal transition-colors dark:hover:text-white"
                                aria-label="Show password"
                                aria-pressed="false"
                                data-target="password-input"
                                onclick="(function(b){var i=document.getElementById(b.dataset.target);if(!i)return;var show=i.type==='password';i.type=show?'text':'password';b.setAttribute('aria-pressed',show?'true':'false');b.setAttribute('aria-label',show?'Hide password':'Show password');})(this)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        </button>
                    </div>
                    <span asp-validation-for="Password" id="Password-error" role="alert" class="cal-field-error"></span>
                </div>

                <button type="submit" class="btn-dark btn-full">
                    Sign In
                </button>
            </form>

            <p class="text-center text-sm text-mid-gray mt-6">
                Don't have an account?
                <a asp-action="Register" asp-controller="Customer"
                   class="font-medium text-charcoal hover:underline dark:text-white">Create one</a>
            </p>

        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
