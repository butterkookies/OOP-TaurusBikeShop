@* WebApplication/Views/Customer/Login.cshtml *@
@model WebApplication.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="tbs-auth-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-8 col-lg-5">

                <div class="tbs-auth-card">

                    @* Header *@
                    <div class="tbs-auth-card__header">
                        <img src="~/FULL-COLOR.png" alt="Taurus Bike Shop" class="tbs-auth-card__logo" />
                        <h1 class="tbs-auth-card__title">Welcome Back</h1>
                        <p class="tbs-auth-card__subtitle">Sign in to your Taurus account</p>
                    </div>

                    @* Validation summary *@
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="tbs-auth-card__error" role="alert">
                            <div asp-validation-summary="All"></div>
                        </div>
                    }

                    @* Form *@
                    <form asp-action="Login" asp-controller="Customer" method="post"
                          class="tbs-auth-form" novalidate>
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ReturnUrl" />

                        <div class="tbs-form-group">
                            <label asp-for="Email" class="tbs-label">Email Address</label>
                            <input asp-for="Email"
                                   class="tbs-input"
                                   type="email"
                                   autocomplete="email"
                                   placeholder="you@example.com" />
                            <span asp-validation-for="Email" class="tbs-field-error"></span>
                        </div>

                        <div class="tbs-form-group">
                            <label asp-for="Password" class="tbs-label">Password</label>
                            <div class="tbs-input-group">
                                <input asp-for="Password"
                                       class="tbs-input"
                                       type="password"
                                       autocomplete="current-password"
                                       placeholder="Enter your password"
                                       id="password-input" />
                                <button type="button"
                                        class="tbs-input-group__toggle"
                                        aria-label="Toggle password visibility"
                                        data-target="password-input">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                         fill="currentColor" viewBox="0 0 16 16" class="tbs-eye-icon">
                                        <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                                        <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                                    </svg>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="tbs-field-error"></span>
                        </div>

                        <button type="submit" class="btn tbs-btn-accent tbs-btn-full">
                            Sign In
                        </button>

                    </form>

                    <div class="tbs-auth-card__footer">
                        Don't have an account?
                        <a asp-action="Register" asp-controller="Customer">Create one</a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        // Password visibility toggle
        document.querySelectorAll('.tbs-input-group__toggle').forEach(btn => {
            btn.addEventListener('click', () => {
                const input = document.getElementById(btn.dataset.target);
                if (input) {
                    input.type = input.type === 'password' ? 'text' : 'password';
                    btn.setAttribute('aria-pressed', input.type === 'text');
                }
            });
        });
    </script>
}
