@* WebApplication/Views/Customer/Confirmation.cshtml *@
@model WebApplication.Models.ViewModels.OrderViewModel
@{
    ViewData["Title"] = $"Order Confirmed — {Model.OrderNumber}";
    bool isPendingPayment =
        Model.OrderStatus == WebApplication.Models.Entities.OrderStatuses.Pending ||
        Model.OrderStatus == WebApplication.Models.Entities.OrderStatuses.PendingVerification;
}

@section Styles {
    <link rel="stylesheet" href="~/css/order.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/confirmation.css" asp-append-version="true" />
}

<div class="tbs-confirmation-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-9">

                @* Success hero *@
                <div class="tbs-confirmation-hero">
                    <div class="tbs-confirmation-hero__icon" aria-hidden="true">✓</div>
                    <h1 class="tbs-confirmation-hero__title">Order Placed!</h1>
                    <p class="tbs-confirmation-hero__number" title="Click to copy"
                       id="order-number-copy">
                        @Model.OrderNumber
                    </p>
                    <p class="tbs-confirmation-hero__message">
                        Thank you for your order. We'll notify you once your
                        payment has been verified.
                    </p>
                </div>

                @* Payment CTA *@
                @if (isPendingPayment && !Model.Payments.Any())
                {
                    <div class="tbs-confirmation-cta">
                        <div class="tbs-confirmation-cta__body">
                            <h2 class="tbs-confirmation-cta__title">Complete Your Payment</h2>
                            <p class="tbs-confirmation-cta__text">
                                Your order is reserved. Please submit your
                                payment proof to confirm it.
                            </p>
                        </div>
                        <a asp-controller="Payment"
                           asp-action="Submit"
                           asp-route-orderId="@Model.OrderId"
                           class="btn tbs-btn-accent tbs-btn-lg">
                            Submit Payment →
                        </a>
                    </div>
                }
                else if (Model.Payments.Any())
                {
                    <div class="tbs-confirmation-cta tbs-confirmation-cta--info">
                        <div class="tbs-confirmation-cta__body">
                            <h2 class="tbs-confirmation-cta__title">Payment Submitted</h2>
                            <p class="tbs-confirmation-cta__text">
                                We've received your payment details and are verifying them.
                                You'll get an email update shortly.
                            </p>
                        </div>
                    </div>
                }

                @* Order card *@
                <div class="tbs-order-card">
                    <div class="tbs-order-card__header">
                        <div>
                            <span class="tbs-order-card__label">Order Number</span>
                            <span class="tbs-order-card__value">@Model.OrderNumber</span>
                        </div>
                        <div>
                            <span class="tbs-order-card__label">Date</span>
                            <span class="tbs-order-card__value">@Model.FormattedOrderDate</span>
                        </div>
                        <div>
                            <span class="tbs-order-card__label">Status</span>
                            @await Html.PartialAsync(
                                "~/Views/Customer/Partials/_OrderStatusBadge.cshtml",
                                Model.OrderStatus)
                        </div>
                        <div>
                            <span class="tbs-order-card__label">Total</span>
                            <span class="tbs-order-card__value tbs-order-card__value--total">
                                @Model.FormattedGrandTotal
                            </span>
                        </div>
                    </div>

                    <div class="tbs-order-card__items">
                        @foreach (var item in Model.Items)
                        {
                            <div class="tbs-order-item">
                                @if (item.ImageUrl != null)
                                {
                                    <img src="@item.ImageUrl"
                                         alt="@item.ProductName"
                                         class="tbs-order-item__img"
                                         loading="lazy" />
                                }
                                else
                                {
                                    <div class="tbs-order-item__img-placeholder"
                                         aria-hidden="true">&#9651;</div>
                                }
                                <div class="tbs-order-item__info">
                                    <span class="tbs-order-item__name">@item.ProductName</span>
                                    @if (!string.IsNullOrWhiteSpace(item.VariantName))
                                    {
                                        <span class="tbs-order-item__variant">@item.VariantName</span>
                                    }
                                    <span class="tbs-order-item__qty">Qty: @item.Quantity</span>
                                </div>
                                <span class="tbs-order-item__total">@item.FormattedLineTotal</span>
                            </div>
                        }
                    </div>

                    <div class="tbs-order-card__totals">
                        <div class="tbs-order-total-row">
                            <span>Subtotal</span><span>@Model.FormattedSubTotal</span>
                        </div>
                        @if (Model.DiscountAmount > 0)
                        {
                            <div class="tbs-order-total-row tbs-order-total-row--discount">
                                <span>Discount</span>
                                <span>−₱@Model.DiscountAmount.ToString("N2")</span>
                            </div>
                        }
                        <div class="tbs-order-total-row">
                            <span>Shipping (@Model.DeliveryMethod)</span>
                            <span>@Model.FormattedShippingFee</span>
                        </div>
                        <div class="tbs-order-total-row tbs-order-total-row--grand">
                            <span>Total</span><span>@Model.FormattedGrandTotal</span>
                        </div>
                    </div>
                </div>

                <div class="tbs-confirmation-actions">
                    <a asp-controller="Order" asp-action="Detail"
                       asp-route-orderId="@Model.OrderId"
                       class="btn tbs-btn-primary">
                        Track Order
                    </a>
                    <a asp-controller="Product" asp-action="List"
                       class="btn tbs-btn-outline">
                        Continue Shopping
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/order.js" asp-append-version="true"></script>
}
