@* WebApplication/Views/Customer/Confirmation.cshtml *@
@model WebApplication.Models.ViewModels.OrderViewModel
@{
    ViewData["Title"] = "Order Confirmed";
    bool hasPendingPayment = Model.Payments.Count == 0
        && Model.OrderStatus != "Cancelled";
}

<div class="bg-light-gray dark:bg-midnight min-h-[calc(100vh-160px)]">
    <div class="max-w-[600px] mx-auto px-6 py-16 md:py-24">

        <div class="cal-card-static p-8 md:p-10 text-center" data-reveal>

            @* Success icon *@
            <div class="w-16 h-16 rounded-full bg-success/10 flex items-center justify-center mx-auto mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                </svg>
            </div>

            <h1 class="font-display text-2xl md:text-3xl font-semibold text-charcoal dark:text-white mb-2">
                Order Confirmed!
            </h1>
            <p class="text-sm text-mid-gray mb-6 leading-relaxed">
                Your order <strong class="text-charcoal dark:text-white">@Model.OrderNumber</strong> has been placed successfully.
                @if (hasPendingPayment)
                {
                    <text>Please upload your payment proof to complete the order.</text>
                }
            </p>

            @* Order summary card *@
            <div class="bg-light-gray dark:bg-white/5 rounded-xl p-5 text-left mb-6">
                <div class="space-y-2 text-sm">
                    <div class="flex justify-between">
                        <span class="text-mid-gray">Order</span>
                        <span class="text-charcoal dark:text-white font-medium">@Model.OrderNumber</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-mid-gray">Items</span>
                        <span class="text-charcoal dark:text-white">@Model.ItemCount item@(Model.ItemCount != 1 ? "s" : "")</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-mid-gray">Delivery</span>
                        <span class="text-charcoal dark:text-white">@Model.DeliveryMethod</span>
                    </div>
                    <hr class="cal-divider !my-2" />
                    <div class="flex justify-between font-semibold">
                        <span class="text-charcoal dark:text-white">Total</span>
                        <span class="font-display text-charcoal dark:text-white">@Model.FormattedGrandTotal</span>
                    </div>
                </div>
            </div>

            @* Actions *@
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
                @if (hasPendingPayment)
                {
                    <a asp-controller="Payment" asp-action="Submit" asp-route-orderId="@Model.OrderId" class="btn-dark">
                        Upload Payment Proof
                    </a>
                }
                <a asp-controller="Order" asp-action="Detail" asp-route-orderId="@Model.OrderId" class="btn-ghost">
                    View Order Details
                </a>
            </div>

            <p class="text-xs text-mid-gray mt-6">
                A confirmation has been sent to your email. You can track your order from your
                <a asp-controller="Customer" asp-action="Dashboard" class="underline underline-offset-2 hover:text-charcoal dark:hover:text-white">dashboard</a>.
            </p>

        </div>
    </div>
</div>
