@* WebApplication/Views/Customer/SupportCreate.cshtml *@
@model WebApplication.Models.ViewModels.SupportCreateViewModel
@{
    ViewData["Title"] = "Create Support Ticket";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">

            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="/Customer/Support">My Tickets</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">New Ticket</li>
                </ol>
            </nav>

            <h1 class="h3 mb-1">New Support Ticket</h1>
            <p class="text-muted mb-4">Describe your issue and our support team will get back to you.</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <ul class="mb-0">
                        @foreach (var state in ViewData.ModelState.Values)
                        {
                            @foreach (var error in state.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                </div>
            }

            <form method="post"
                  action="/Customer/Support/Create"
                  enctype="multipart/form-data"
                  novalidate>

                @Html.AntiForgeryToken()

                @if (Model.OrderId.HasValue)
                {
                    <input type="hidden" name="OrderId" value="@Model.OrderId" />
                }

                <!-- Category -->
                <div class="mb-3">
                    <label for="category" class="form-label fw-semibold">
                        Category <span class="text-danger">*</span>
                    </label>
                    <select id="category" name="Category" class="form-select" required>
                        <option value="" disabled selected>Select a category…</option>
                        @foreach (var cat in Model.AvailableCategories)
                        {
                            <option value="@cat"
                                    selected="@(Model.Category == cat)">
                                @cat
                            </option>
                        }
                    </select>
                </div>

                <!-- Subject -->
                <div class="mb-3">
                    <label for="subject" class="form-label fw-semibold">
                        Subject <span class="text-danger">*</span>
                    </label>
                    <input type="text"
                           id="subject"
                           name="Subject"
                           class="form-control"
                           maxlength="200"
                           value="@Model.Subject"
                           placeholder="Brief summary of your issue"
                           required />
                </div>

                <!-- Related order (display only when pre-populated) -->
                @if (!string.IsNullOrEmpty(Model.OrderNumber))
                {
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Related Order</label>
                        <input type="text" class="form-control" value="@Model.OrderNumber" readonly />
                    </div>
                }

                <!-- Description -->
                <div class="mb-3">
                    <label for="description" class="form-label fw-semibold">Description</label>
                    <textarea id="description"
                              name="Description"
                              class="form-control"
                              rows="6"
                              maxlength="5000"
                              placeholder="Please describe the issue in detail…">@Model.Description</textarea>
                    <div class="form-text">Optional — up to 5 000 characters.</div>
                </div>

                <!-- Attachment -->
                <div class="mb-4">
                    <label for="attachment" class="form-label fw-semibold">Attachment</label>
                    <input type="file"
                           id="attachment"
                           name="attachment"
                           class="form-control"
                           accept="image/webp,image/jpeg,image/png,application/pdf" />
                    <div class="form-text">
                        Optional — image (WEBP, JPEG, PNG) or PDF, max 5 MB.
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Submit Ticket</button>
                    <a href="/Customer/Support" class="btn btn-outline-secondary">Cancel</a>
                </div>

            </form>

        </div>
    </div>
</div>
