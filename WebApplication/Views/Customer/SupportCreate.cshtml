@* WebApplication/Views/Customer/SupportCreate.cshtml *@
@model WebApplication.Models.ViewModels.SupportCreateViewModel
@using WebApplication.Models.Entities
@{
    ViewData["Title"] = "New Support Ticket";
}

<div class="bg-light-gray dark:bg-midnight min-h-[calc(100vh-160px)]">
    <div class="max-w-[700px] mx-auto px-6 py-12 md:py-16">

        <ol class="cal-breadcrumb">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li><a asp-controller="Support" asp-action="Index">Support</a></li>
            <li>New Ticket</li>
        </ol>

        <div class="mb-8" data-reveal>
            <h1 class="font-display text-2xl md:text-3xl font-semibold text-charcoal dark:text-white">New Support Ticket</h1>
            <p class="text-sm text-mid-gray mt-2">Describe your issue and our team will respond shortly.</p>
        </div>

        <div class="cal-card-static p-6" data-reveal="delay-1">
            <form asp-action="Create" asp-controller="Support" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="OrderId" />

                @if (Model.OrderId.HasValue)
                {
                    <div class="mb-5 p-3 bg-light-gray dark:bg-white/5 rounded-lg text-sm text-charcoal dark:text-white">
                        📦 Regarding Order #@Model.OrderId
                    </div>
                }

                <div class="mb-5">
                    <label asp-for="Category" class="cal-label">Category</label>
                    <select asp-for="Category" class="cal-input cal-select" required
                            aria-invalid="@(ViewData.ModelState["Category"]?.Errors.Count > 0 ? "true" : "false")"
                            aria-describedby="Category-error">
                        <option value="">— Select a category —</option>
                        <option value="@TicketCategories.DamagedItem">Damaged Item</option>
                        <option value="@TicketCategories.WrongItem">Wrong Item Received</option>
                        <option value="@TicketCategories.DeliveryIssue">Delivery Issue</option>
                        <option value="@TicketCategories.PaymentIssue">Payment Issue</option>
                        <option value="@TicketCategories.ProductInquiry">Product Inquiry</option>
                        <option value="@TicketCategories.ReturnRefund">Return / Refund</option>
                        <option value="@TicketCategories.General">General</option>
                    </select>
                    <span asp-validation-for="Category" id="Category-error" role="alert" class="cal-field-error"></span>
                </div>

                <div class="mb-5">
                    <label asp-for="Subject" class="cal-label">Subject</label>
                    <input asp-for="Subject" class="cal-input" placeholder="Brief summary of your issue" maxlength="200"
                           aria-invalid="@(ViewData.ModelState["Subject"]?.Errors.Count > 0 ? "true" : "false")"
                           aria-describedby="Subject-error" />
                    <span asp-validation-for="Subject" id="Subject-error" role="alert" class="cal-field-error"></span>
                </div>

                <div class="mb-6">
                    <label asp-for="Description" class="cal-label">Message</label>
                    <textarea asp-for="Description" class="cal-input cal-textarea" rows="6"
                              placeholder="Describe your issue in detail."
                              maxlength="5000"
                              aria-invalid="@(ViewData.ModelState["Description"]?.Errors.Count > 0 ? "true" : "false")"
                              aria-describedby="msg-char-count-label Description-error"></textarea>
                    <div class="flex justify-end mt-1">
                        <span class="text-xs text-mid-gray" id="msg-char-count-label" aria-live="polite"><span id="msg-char-count">0</span> / 5000</span>
                    </div>
                    <span asp-validation-for="Description" id="Description-error" role="alert" class="cal-field-error"></span>
                </div>

                <div class="flex gap-3">
                    <button type="submit" class="btn-dark">Submit Ticket</button>
                    <a asp-controller="Support" asp-action="Index" class="btn-ghost">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/js/support.js" asp-append-version="true"></script>
}
