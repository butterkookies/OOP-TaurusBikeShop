    PAYMENT             ||--o| BANK_TRANSFER_PAYMENT   : "detail (Bank)"
    USER                ||--o{ BANK_TRANSFER_PAYMENT   : "verified by"

    ORDER               ||--o{ DELIVERY                : "shipped via"
