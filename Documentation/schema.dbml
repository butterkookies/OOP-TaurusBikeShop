// --- Orders ---

Table "Order" {
  OrderId int [pk, increment, not null]
  UserId int
  OrderNumber nvarchar(50) [unique, not null]
  OrderDate datetime2 [not null, default: `sysdatetime()`]
  OrderStatus nvarchar(50) [not null, note: 'See enum OrderStatus']
  SubTotal decimal(10,2) [not null, note: 'CK: >= 0']
  DiscountAmount decimal(10,2) [not null, default: 0, note: 'CK: >= 0']
  ShippingFee decimal(10,2) [not null, default: 0, note: 'CK: >= 0']
  ShippingAddressId int
  ContactPhone nvarchar(20)
  DeliveryInstructions nvarchar(500)
  IsWalkIn bit [not null, default: 0]
  CreatedAt datetime2 [not null, default: `sysdatetime()`]
  UpdatedAt datetime2
  IsDeleted bit [not null, default: 0]
  FulfillmentType nvarchar(20) [not null, default: 'Delivery', note: 'Delivery | Pickup | WalkIn']
  GuestSessionId int
  CartId int
  POSSessionId int
  TotalAmount decimal(10,2) [not null, note: 'COMPUTED PERSISTED: (SubTotal - DiscountAmount) + ShippingFee']
  PaymentMethod nvarchar(50) [not null, note: 'GCash | BankTransfer | Cash']

  Note: 'CK: UserId IS NOT NULL OR GuestSessionId IS NOT NULL'

  indexes {
    OrderNumber [name: 'IX_Order_OrderNumber']
    OrderDate [name: 'IX_Order_OrderDate']
    OrderStatus [name: 'IX_Order_OrderStatus']
    FulfillmentType [name: 'IX_Order_FulfillmentType']
    IsWalkIn [name: 'IX_Order_IsWalkIn']
    IsDeleted [name: 'IX_Order_IsDeleted', note: 'WHERE IsDeleted=0']
    UserId [name: 'IX_Order_UserId']
    (UserId, OrderStatus) [name: 'IX_Order_UserId_Status', note: 'INCLUDE(OrderDate,TotalAmount,FulfillmentType) WHERE IsDeleted=0']
    ShippingAddressId [name: 'IX_Order_ShippingAddressId', note: 'WHERE ShippingAddressId IS NOT NULL']
    CartId [name: 'IX_Order_CartId', note: 'WHERE CartId IS NOT NULL']
    POSSessionId [name: 'IX_Order_POSSessionId', note: 'WHERE POSSessionId IS NOT NULL']
  }
}

