    OrderId [name: 'IX_Ticket_OrderId', note: 'WHERE OrderId IS NOT NULL']
    TicketStatus [name: 'IX_Ticket_Status']
    TicketCategory [name: 'IX_Ticket_Category']
    AssignedToUserId [name: 'IX_Ticket_AssignedTo', note: 'WHERE AssignedToUserId IS NOT NULL']
    CreatedAt [name: 'IX_Ticket_CreatedAt']
  }
}

Table SupportTicketReply {
  ReplyId bigint [pk, increment, not null]
  TicketId int [not null]
  UserId int [not null]
  IsAdminReply bit [not null, default: 0]
  Message nvarchar(max) [not null]
  AttachmentUrl nvarchar(1000)
  AttachmentBucket nvarchar(200)
  AttachmentPath nvarchar(1000)
  CreatedAt datetime2 [not null, default: `sysdatetime()`]

  indexes {
    TicketId [name: 'IX_Reply_TicketId']
    UserId [name: 'IX_Reply_UserId']
    CreatedAt [name: 'IX_Reply_CreatedAt']
  }
}

Table SupportTask {
  TaskId int [pk, increment, not null]
  TicketId int [not null]
  AssignedToUserId int
  TaskType nvarchar(50) [not null, note: 'ShipReplacement|ArrangeReturn|ContactSupplier|Other']
  TaskStatus nvarchar(20) [not null, default: 'Pending', note: 'Pending|InProgress|Done|Cancelled']
  DueDate datetime2
  Notes nvarchar(500)
  CreatedAt datetime2 [not null, default: `sysdatetime()`]
  CompletedAt datetime2

  indexes {
    TicketId [name: 'IX_SupportTask_TicketId']
    AssignedToUserId [name: 'IX_SupportTask_AssignedToUserId', note: 'WHERE AssignedToUserId IS NOT NULL']
    TaskStatus [name: 'IX_SupportTask_TaskStatus']
    DueDate [name: 'IX_SupportTask_DueDate', note: 'WHERE DueDate IS NOT NULL']
  }
}

// --- Refund ---

Table Refund {
  RefundId int [pk, increment, not null]
  OrderId int [not null]
  PaymentId int
  RefundAmount decimal(10,2) [not null, note: 'CK: > 0']
  RefundReason nvarchar(500) [not null]
  RefundStatus nvarchar(50) [not null, default: 'Pending', note: 'Pending|Approved|Rejected|Completed']
  RefundMethod nvarchar(50) [note: 'NULL or OriginalPayment|StoreCredit|Cash']
  RequestedByUserId int
  ApprovedByUserId int
  TicketId int
  Notes nvarchar(500)
  CreatedAt datetime2 [not null, default: `sysdatetime()`]
  ProcessedAt datetime2

  indexes {
    OrderId [name: 'IX_Refund_OrderId']
    RefundStatus [name: 'IX_Refund_Status', note: 'WHERE RefundStatus IN (Pending, Approved)']
    TicketId [name: 'IX_Refund_TicketId', note: 'WHERE TicketId IS NOT NULL']
  }
}

// --- Reviews & Wishlist ---

Table Review {
  ReviewId int [pk, increment, not null]
  UserId int [not null]
  ProductId int [not null]
  OrderId int [not null]
  Rating int [not null, note: 'CK: 1-5']
  Comment nvarchar(1000)
  IsVerifiedPurchase bit [not null, default: 0]
  CreatedAt datetime2 [not null, default: `sysdatetime()`]

  indexes {
    UserId [name: 'IX_Review_UserId']
    ProductId [name: 'IX_Review_ProductId']
    OrderId [name: 'IX_Review_OrderId']
    Rating [name: 'IX_Review_Rating']
  }
}

Table Wishlist {
  WishlistId int [pk, increment, not null]
  UserId int [not null]
  ProductId int [not null]
  AddedAt datetime2 [not null, default: `sysdatetime()`]

  indexes {
    (UserId, ProductId) [unique, name: 'UX_Wishlist_UserProduct']
    UserId [name: 'IX_Wishlist_UserId']
    ProductId [name: 'IX_Wishlist_ProductId']
  }
}

// --- Notifications ---

Table Notification {
  NotificationId int [pk, increment, not null]
  UserId int [not null]
  OrderId int
  TicketId int
  Channel nvarchar(20) [not null, note: 'SMS | Email | InApp']
  NotifType nvarchar(100) [not null, note: 'WelcomeEmail|OrderConfirmation|PaymentReceived|...']
  Recipient nvarchar(255) [not null]
  Subject nvarchar(255)
  Body nvarchar(max)
  Status nvarchar(20) [not null, default: 'Pending', note: 'Pending | Sent | Failed']
  RetryCount int [not null, default: 0]
  SentAt datetime2
  FailureReason nvarchar(500)
  CreatedAt datetime2 [not null, default: `sysdatetime()`]
  IsRead bit [not null, default: 0]
  ReadAt datetime2

  indexes {
    UserId [name: 'IX_Notif_UserId']
    (UserId, IsRead) [name: 'IX_Notif_UserId_Unread', note: 'INCLUDE(NotifType,Subject,CreatedAt) WHERE IsRead=0']
    OrderId [name: 'IX_Notif_OrderId', note: 'WHERE OrderId IS NOT NULL']
    TicketId [name: 'IX_Notif_TicketId', note: 'WHERE TicketId IS NOT NULL']
    Channel [name: 'IX_Notif_Channel']
    Status [name: 'IX_Notif_Status']
    (Status, CreatedAt) [name: 'IX_Notif_Pending', note: 'WHERE Status=Pending']
    CreatedAt [name: 'IX_Notif_CreatedAt']
  }
}

// --- POS ---

Table POS_Session {
  POSSessionId int [pk, increment, not null]
  UserId int [not null]
  TerminalName nvarchar(50) [not null]
  ShiftStart datetime2 [not null]
  ShiftEnd datetime2
  TotalSales decimal(10,2) [not null, default: 0]
  CreatedAt datetime2 [not null, default: `sysdatetime()`]

  indexes {
    UserId [name: 'IX_POS_Session_UserId']
    ShiftStart [name: 'IX_POS_Session_ShiftStart']
    ShiftEnd [name: 'IX_POS_Session_ShiftEnd']
  }
}

// --- System ---

Table SystemLog {
  SystemLogId bigint [pk, increment, not null]
  UserId int
  EventType nvarchar(100) [not null, note: 'Login|Logout|AccessDenied|UserCreated|...']
  EventDescription nvarchar(1000)
  CreatedAt datetime2 [not null, default: `sysdatetime()`]

  indexes {
    UserId [name: 'IX_SystemLog_UserId']
    EventType [name: 'IX_SystemLog_EventType']
    CreatedAt [name: 'IX_SystemLog_CreatedAt']
  }
}

Table __EFMigrationsHistory {
  MigrationId nvarchar(150) [pk, not null]
  ProductVersion nvarchar(32) [not null]
}

// =============================================================================
//  REFERENCES (Foreign Keys)
// =============================================================================

// --- User & Auth ---
Ref FK_User_DefaultAddress:       User.DefaultAddressId           > Address.AddressId
Ref FK_ActiveSession_User:        ActiveSession.UserId            > User.UserId
Ref FK_OTPVerification_User:      OTPVerification.UserId          > User.UserId
Ref FK_GuestSession_User:         GuestSession.ConvertedToUserId  > User.UserId

// --- RBAC ---
Ref FK_UserRole_User:             UserRole.UserId                 > User.UserId
Ref FK_UserRole_Role:             UserRole.RoleId                 > Role.RoleId

// --- Address ---
Ref FK_Address_User:              Address.UserId                  > User.UserId

// --- Catalog ---
Ref FK_Category_Parent:           Category.ParentCategoryId       > Category.CategoryId
Ref FK_Product_Category:          Product.CategoryId              > Category.CategoryId
Ref FK_Product_Brand:             Product.BrandId                 > Brand.BrandId
Ref FK_ProductVariant_Product:    ProductVariant.ProductId        > Product.ProductId
Ref FK_ProductImage_Product:      ProductImage.ProductId          > Product.ProductId
Ref FK_ProductImage_Uploader:     ProductImage.UploadedByUserId   > User.UserId
Ref FK_PriceHistory_Product:      PriceHistory.ProductId          > Product.ProductId
Ref FK_PriceHistory_User:         PriceHistory.ChangedByUserId    > User.UserId

// --- Cart ---
Ref FK_Cart_User:                 Cart.UserId                     > User.UserId
Ref FK_Cart_GuestSession:         Cart.GuestSessionId             > GuestSession.GuestSessionId
Ref FK_CartItem_Cart:             CartItem.CartId                 > Cart.CartId           [delete: cascade]
Ref FK_CartItem_Product:          CartItem.ProductId              > Product.ProductId
Ref FK_CartItem_Variant:          CartItem.ProductVariantId       > ProductVariant.ProductVariantId

// --- Orders ---
Ref FK_Order_User:                "Order".UserId                  > User.UserId
Ref FK_Order_ShipAddress:         "Order".ShippingAddressId       > Address.AddressId
Ref FK_Order_GuestSession:        "Order".GuestSessionId          > GuestSession.GuestSessionId
Ref FK_Order_Cart:                "Order".CartId                  > Cart.CartId
Ref FK_Order_POSSession:          "Order".POSSessionId            > POS_Session.POSSessionId
Ref FK_OrderItem_Order:           OrderItem.OrderId               > "Order".OrderId
Ref FK_OrderItem_Product:         OrderItem.ProductId             > Product.ProductId
Ref FK_OrderItem_Variant:         OrderItem.ProductVariantId      > ProductVariant.ProductVariantId
Ref FK_OrderStatusAudit_Order:    OrderStatusAudit.OrderId        > "Order".OrderId
Ref FK_PickupOrder_Order:         PickupOrder.OrderId             > "Order".OrderId       [delete: cascade]

// --- Payments ---
Ref FK_Payment_Order:             Payment.OrderId                 > "Order".OrderId
Ref FK_Payment_StorePaymentAcct:  Payment.StorePaymentAccountId   > StorePaymentAccount.StorePaymentAccountId
Ref FK_GCashPayment_Pmt:          GCashPayment.PaymentId          > Payment.PaymentId     [delete: cascade]
Ref FK_BankTransferPayment_Pmt:   BankTransferPayment.PaymentId   > Payment.PaymentId     [delete: cascade]
Ref FK_BankTransferPayment_Admin: BankTransferPayment.VerifiedByUserId > User.UserId

// --- Delivery ---
Ref FK_Delivery_Order:            Delivery.OrderId                > "Order".OrderId
Ref FK_LalamoveDelivery_Base:     LalamoveDelivery.DeliveryId     > Delivery.DeliveryId   [delete: cascade]
Ref FK_LBCDelivery_Base:          LBCDelivery.DeliveryId          > Delivery.DeliveryId   [delete: cascade]

// --- Vouchers ---
Ref FK_UserVoucher_User:          UserVoucher.UserId              > User.UserId
Ref FK_UserVoucher_Voucher:       UserVoucher.VoucherId           > Voucher.VoucherId
Ref FK_VoucherUsage_Voucher:      VoucherUsage.VoucherId          > Voucher.VoucherId
Ref FK_VoucherUsage_User:         VoucherUsage.UserId             > User.UserId
Ref FK_VoucherUsage_Order:        VoucherUsage.OrderId            > "Order".OrderId

// --- Inventory & Suppliers ---
Ref FK_InvLog_Product:            InventoryLog.ProductId          > Product.ProductId
Ref FK_InvLog_Variant:            InventoryLog.ProductVariantId   > ProductVariant.ProductVariantId
Ref FK_InvLog_Order:              InventoryLog.OrderId            > "Order".OrderId
Ref FK_InvLog_PurchaseOrder:      InventoryLog.PurchaseOrderId    > PurchaseOrder.PurchaseOrderId
Ref FK_InvLog_User:               InventoryLog.ChangedByUserId    > User.UserId
Ref FK_PurchaseOrder_Supplier:    PurchaseOrder.SupplierId        > Supplier.SupplierId
Ref FK_PurchaseOrder_User:        PurchaseOrder.CreatedByUserId   > User.UserId
Ref FK_POItem_PO:                 PurchaseOrderItem.PurchaseOrderId > PurchaseOrder.PurchaseOrderId [delete: cascade]
Ref FK_POItem_Product:            PurchaseOrderItem.ProductId     > Product.ProductId
Ref FK_POItem_Variant:            PurchaseOrderItem.ProductVariantId > ProductVariant.ProductVariantId

// --- Support ---
Ref FK_Ticket_User:               SupportTicket.UserId            > User.UserId
Ref FK_Ticket_Order:              SupportTicket.OrderId           > "Order".OrderId
Ref FK_Ticket_AssignedTo:         SupportTicket.AssignedToUserId  > User.UserId
Ref FK_Reply_Ticket:              SupportTicketReply.TicketId     > SupportTicket.TicketId [delete: cascade]
Ref FK_Reply_User:                SupportTicketReply.UserId       > User.UserId
Ref FK_SupportTask_Ticket:        SupportTask.TicketId            > SupportTicket.TicketId [delete: cascade]
Ref FK_SupportTask_AssignedTo:    SupportTask.AssignedToUserId    > User.UserId

// --- Refund ---
Ref FK_Refund_Order:              Refund.OrderId                  > "Order".OrderId
Ref FK_Refund_Payment:            Refund.PaymentId                > Payment.PaymentId
Ref FK_Refund_RequestedBy:        Refund.RequestedByUserId        > User.UserId
Ref FK_Refund_ApprovedBy:         Refund.ApprovedByUserId         > User.UserId
Ref FK_Refund_Ticket:             Refund.TicketId                 > SupportTicket.TicketId

// --- Reviews & Wishlist ---
Ref FK_Review_User:               Review.UserId                   > User.UserId
Ref FK_Review_Product:            Review.ProductId                > Product.ProductId
Ref FK_Review_Order:              Review.OrderId                  > "Order".OrderId
Ref FK_Wishlist_User:             Wishlist.UserId                 > User.UserId
Ref FK_Wishlist_Product:          Wishlist.ProductId              > Product.ProductId

// --- Notifications ---
Ref FK_Notif_User:                Notification.UserId             > User.UserId
Ref FK_Notif_Order:               Notification.OrderId            > "Order".OrderId
Ref FK_Notif_Ticket:              Notification.TicketId           > SupportTicket.TicketId

// --- POS ---
Ref FK_POS_Session_User:          POS_Session.UserId              > User.UserId

// --- System ---
Ref FK_SystemLog_User:            SystemLog.UserId                > User.UserId