Table User {
  UserId int [pk, increment, not null]
  Email nvarchar(255)
  PasswordHash nvarchar(255)
  FirstName nvarchar(100) [not null]
  LastName nvarchar(100) [not null]
  PhoneNumber nvarchar(20)
  DefaultAddressId int
  IsActive bit [not null, default: 1]
  IsWalkIn bit [not null, default: 0]
  CreatedAt datetime2 [not null, default: `sysdatetime()`]
  LastLoginAt datetime2
  FailedLoginAttempts int [not null, default: 0]
  LockoutUntil datetime2
  IsDeleted bit [not null, default: 0]

  Note: 'CK: IsWalkIn=1 OR (Email IS NOT NULL AND PasswordHash IS NOT NULL)'

  indexes {
    Email [unique, name: 'UX_User_Email', note: 'WHERE Email IS NOT NULL AND IsWalkIn=0']
    IsActive [name: 'IX_User_IsActive']
    IsDeleted [name: 'IX_User_IsDeleted', note: 'WHERE IsDeleted=0']
    IsWalkIn [name: 'IX_User_IsWalkIn']
    PhoneNumber [name: 'IX_User_PhoneNumber']
    DefaultAddressId [name: 'IX_User_DefaultAddressId', note: 'WHERE DefaultAddressId IS NOT NULL']
  }
}

Table Address {
  AddressId int [pk, increment, not null]
  UserId int [not null]
  Label nvarchar(50) [not null, default: 'Home', note: 'Home | Work | Other']
  Street nvarchar(500) [not null]
  City nvarchar(100) [not null]
  PostalCode nvarchar(20) [not null]
  Province nvarchar(100)
  Country nvarchar(100) [not null, default: 'Philippines']
  IsDefault bit [not null, default: 0]
  IsSnapshot bit [not null, default: 0]
  CreatedAt datetime2 [not null, default: `sysdatetime()`]

  indexes {
    UserId [name: 'IX_Address_UserId']
    (UserId, IsDefault) [name: 'IX_Address_IsDefault', note: 'WHERE IsDefault=1']
    IsSnapshot [name: 'IX_Address_IsSnapshot']
  }
}

Table Role {
  RoleId int [pk, increment, not null]
  RoleName nvarchar(50) [unique, not null, note: 'Admin | Manager | Cashier | Staff | Customer']
  Description nvarchar(255)
  CreatedAt datetime2 [not null, default: `sysdatetime()`]

  indexes {
    RoleName [name: 'IX_Role_RoleName']
  }
}

Table UserRole {
  UserRoleId int [pk, increment, not null]
  UserId int [not null]
  RoleId int [not null]
  AssignedAt datetime2 [not null, default: `sysdatetime()`]

  indexes {
    (UserId, RoleId) [unique, name: 'UX_UserRole_Pair']
